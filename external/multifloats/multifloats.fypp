#! multifloats.fypp — Mock multifloats module (generated with fypp)
#!
#! Mock implementation: casts operands to REAL(16)/COMPLEX(16), performs
#! operations at quad precision, then splits the result back into
#! double-double (hi, lo) limbs.
#!
#! The interface for float64x2 mirrors REAL(KIND=16) as closely as possible:
#! all mixed-type arithmetic, comparisons, and assignments with real(dp),
#! real(sp), integer, complex(dp), and complex(sp) are supported.

#! =====================================================================
#! Type system metadata
#! =====================================================================
#:set RTYPES = [('mf', 'type(float64x2)'), ('dp', 'real(dp)'), ('sp', 'real(sp)'), ('int', 'integer')]
#:set CTYPES = [('cx', 'type(complex128x2)'), ('cdp', 'complex(dp)'), ('csp', 'complex(sp)')]
#:set ATYPES = RTYPES + CTYPES

#! Conversion expressions: type-id → Python format string producing Fortran code
#:set CONV = {'mf': 'to_qp({})', 'cx': 'to_cqp({})', 'dp': 'real({}, qp)', 'sp': 'real({}, qp)', 'int': 'real({}, qp)', 'cdp': 'cmplx({}, kind=qp)', 'csp': 'cmplx({}, kind=qp)'}
#:set ISCPLX = {'mf': False, 'cx': True, 'dp': False, 'sp': False, 'int': False, 'cdp': True, 'csp': True}

#! Operator tables
#:set ARITH_OPS = [('+', 'add'), ('-', 'sub'), ('*', 'mul'), ('/', 'div')]
#:set EQ_OPS = [('==', 'eq'), ('/=', 'ne')]
#:set ORD_OPS = [('<', 'lt'), ('>', 'gt'), ('<=', 'le'), ('>=', 'ge')]

#! Unary math function tables
#:set UNARY_MF_MF = ['abs', 'sqrt', 'sin', 'cos', 'tan', 'exp', 'log', 'log10', 'atan', 'asin', 'acos']
#:set UNARY_CX_CX = ['sqrt', 'sin', 'cos', 'tan', 'exp', 'log', 'atan', 'asin', 'acos', 'conjg']
#:set UNARY_CX_MF = ['abs', 'aimag']
#:set ALL_UNARY = sorted(set(UNARY_MF_MF + UNARY_CX_CX + UNARY_CX_MF))

#! Binary real function tables
#:set BINARY_REAL = ['sign', 'mod', 'atan2']
#:set BINARY_MINMAX = ['min', 'max']

#! Array reduction function tables
#:set ARRAY_REDUCE_VAL = ['maxval', 'minval']
#:set ARRAY_REDUCE_LOC = ['maxloc', 'minloc']

module multifloats
    implicit none
    private

    integer, parameter :: qp = 16  ! Quad precision
    integer, parameter :: dp = 8   ! Double precision
    integer, parameter :: sp = 4   ! Single precision

    type, public :: float64x2
        real(dp) :: limbs(2)
    end type float64x2

    type, public :: complex128x2
        type(float64x2) :: re, im
    end type complex128x2

    ! ================================================================
    ! Constructors
    ! ================================================================

    interface float64x2
        module procedure mf_from_dp
        module procedure mf_from_sp
        module procedure mf_from_int
        module procedure mf_from_char
        module procedure mf_from_cx
        module procedure mf_from_cdp
        module procedure mf_from_csp
    end interface float64x2

    interface complex128x2
        module procedure cx_from_mf_2
        module procedure cx_from_dp_2
        module procedure cx_from_mf_1
        module procedure cx_from_dp_1
    end interface complex128x2

    ! ================================================================
    ! Arithmetic operators (+, -, *, /)
    ! ================================================================

#:for opsym, opname in ARITH_OPS
    interface operator(${opsym}$)
#:for n1, _ in ATYPES
#:for n2, _ in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
        module procedure ${n1}$_${opname}$_${n2}$
#:endif
#:endfor
#:endfor
#:if opsym == '-'
        module procedure mf_neg
        module procedure cx_neg
#:endif
    end interface
    public :: operator(${opsym}$)

#:endfor
    ! ================================================================
    ! Power operator (**)
    ! ================================================================

    interface operator(**)
#:for n1, _ in ATYPES
#:for n2, _ in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
        module procedure ${n1}$_pow_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: operator(**)

    ! ================================================================
    ! Equality comparison (==, /=) — all type pairs
    ! ================================================================

#:for opsym, opname in EQ_OPS
    interface operator(${opsym}$)
#:for n1, _ in ATYPES
#:for n2, _ in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
        module procedure ${n1}$_${opname}$_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: operator(${opsym}$)

#:endfor
    ! ================================================================
    ! Ordered comparison (<, >, <=, >=) — real types only
    ! ================================================================

#:for opsym, opname in ORD_OPS
    interface operator(${opsym}$)
#:for n1, _ in RTYPES
#:for n2, _ in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
        module procedure ${n1}$_${opname}$_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: operator(${opsym}$)

#:endfor
    ! ================================================================
    ! Unary math generics
    ! ================================================================

#:for func in ALL_UNARY
    interface ${func}$
#:if func in UNARY_MF_MF
        module procedure mf_${func}$
#:endif
#:if func in UNARY_CX_CX or func in UNARY_CX_MF
        module procedure cx_${func}$
#:endif
    end interface
    public :: ${func}$

#:endfor
    ! ================================================================
    ! Binary real functions (sign, mod, atan2, min, max)
    ! ================================================================

#:for func in BINARY_REAL
    interface ${func}$
#:for n1, _ in RTYPES
#:for n2, _ in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
        module procedure ${n1}$_${func}$_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: ${func}$

#:endfor
#:for func in BINARY_MINMAX
    interface ${func}$
#:for n1, _ in RTYPES
#:for n2, _ in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
        module procedure ${n1}$_${func}$_${n2}$
#:endif
#:endfor
#:endfor
        module procedure mf_${func}$3
    end interface
    public :: ${func}$

#:endfor
    ! ================================================================
    ! Array reductions (maxval, minval, maxloc, minloc)
    ! ================================================================

#:for func in ARRAY_REDUCE_VAL
    interface ${func}$
        module procedure mf_${func}$_1d
        module procedure mf_${func}$_1d_dim
        module procedure mf_${func}$_1d_mask
        module procedure mf_${func}$_1d_dim_mask
        module procedure mf_${func}$_2d
        module procedure mf_${func}$_2d_dim
        module procedure mf_${func}$_2d_mask
        module procedure mf_${func}$_2d_dim_mask
    end interface
    public :: ${func}$

#:endfor
#:for func in ARRAY_REDUCE_LOC
    interface ${func}$
        module procedure mf_${func}$_1d
        module procedure mf_${func}$_1d_dim
        module procedure mf_${func}$_1d_mask
        module procedure mf_${func}$_1d_dim_mask
        module procedure mf_${func}$_2d
        module procedure mf_${func}$_2d_dim
        module procedure mf_${func}$_2d_mask
        module procedure mf_${func}$_2d_dim_mask
    end interface
    public :: ${func}$

#:endfor
    ! ================================================================
    ! Complex-specific: cmplx, real, mf_real
    ! ================================================================

    interface cmplx
        module procedure mf_cmplx_2
        module procedure mf_cmplx_1
    end interface
    public :: cmplx

    interface real
        module procedure cx_real
        module procedure mf_real_mf
    end interface
    public :: real

    interface mf_real
        module procedure mf_real_mf
        module procedure cx_real_mf
    end interface
    public :: mf_real

    ! ================================================================
    ! Conversions: dble, int, nint, mf_to_double
    ! ================================================================

    interface dble
        module procedure mf_dble
    end interface
    public :: dble

    interface int
        module procedure mf_int
    end interface
    public :: int

    interface nint
        module procedure mf_nint
    end interface
    public :: nint

    public :: mf_to_double

    ! ================================================================
    ! Assignment (=)
    ! ================================================================

    interface assignment(=)
#:for n, _ in ATYPES
#:if n != 'mf'
        module procedure mf_assign_${n}$
#:endif
#:endfor
#:for n, _ in ATYPES
#:if n != 'cx'
        module procedure cx_assign_${n}$
#:endif
#:endfor
    end interface
    public :: assignment(=)

    ! ================================================================
    ! Defined I/O
    ! ================================================================

    interface write(formatted)
        module procedure write_mf_formatted
        module procedure write_cx_formatted
    end interface
    public :: write(formatted)

    interface read(formatted)
        module procedure read_mf_formatted
        module procedure read_cx_formatted
    end interface
    public :: read(formatted)

    ! ================================================================
    ! Named constants
    ! ================================================================

    type(float64x2), parameter, public :: MF_ZERO  = float64x2([0.0_dp, 0.0_dp])
    type(float64x2), parameter, public :: MF_ONE   = float64x2([1.0_dp, 0.0_dp])
    type(float64x2), parameter, public :: MF_TWO   = float64x2([2.0_dp, 0.0_dp])
    type(float64x2), parameter, public :: MF_HALF  = float64x2([0.5_dp, 0.0_dp])
    type(float64x2), parameter, public :: MF_EIGHT = float64x2([8.0_dp, 0.0_dp])

    type(float64x2), parameter, public :: MF_SAFMIN = float64x2([tiny(0.0_dp),  0.0_dp])
    type(float64x2), parameter, public :: MF_SAFMAX = float64x2([huge(0.0_dp),  0.0_dp])
    type(float64x2), parameter, public :: MF_TSML   = float64x2([1.0e-100_dp,   0.0_dp])
    type(float64x2), parameter, public :: MF_TBIG   = float64x2([1.0e+100_dp,   0.0_dp])
    type(float64x2), parameter, public :: MF_SSML   = float64x2([1.0e-50_dp,    0.0_dp])
    type(float64x2), parameter, public :: MF_SBIG   = float64x2([1.0e+50_dp,    0.0_dp])
    type(float64x2), parameter, public :: MF_RTMIN  = float64x2([1.0e-150_dp,   0.0_dp])
    type(float64x2), parameter, public :: MF_RTMAX  = float64x2([1.0e+150_dp,   0.0_dp])

contains

    ! ================================================================
    ! Internal conversion helpers
    ! ================================================================

    pure function to_qp(mf) result(res)
        type(float64x2), intent(in) :: mf
        real(qp) :: res
        res = real(mf%limbs(1), qp) + real(mf%limbs(2), qp)
    end function

    pure function from_qp(v) result(res)
        real(qp), intent(in) :: v
        type(float64x2) :: res
        res%limbs(1) = real(v, dp)
        res%limbs(2) = real(v - real(res%limbs(1), qp), dp)
    end function

    pure function to_cqp(cx) result(res)
        type(complex128x2), intent(in) :: cx
        complex(qp) :: res
        res = cmplx(to_qp(cx%re), to_qp(cx%im), kind=qp)
    end function

    pure function from_cqp(v) result(res)
        complex(qp), intent(in) :: v
        type(complex128x2) :: res
        res%re = from_qp(real(v, qp))
        res%im = from_qp(aimag(v))
    end function

    ! ================================================================
    ! Constructors
    ! ================================================================

    pure function mf_from_dp(v) result(res)
        real(dp), intent(in) :: v
        type(float64x2) :: res
        res = from_qp(real(v, qp))
    end function

    pure function mf_from_sp(v) result(res)
        real(sp), intent(in) :: v
        type(float64x2) :: res
        res = from_qp(real(v, qp))
    end function

    pure function mf_from_int(v) result(res)
        integer, intent(in) :: v
        type(float64x2) :: res
        res = from_qp(real(v, qp))
    end function

    function mf_from_char(v) result(res)
        character(len=*), intent(in) :: v
        type(float64x2) :: res
        real(qp) :: val_qp
        read(v, *) val_qp
        res = from_qp(val_qp)
    end function

    pure function mf_from_cx(cx) result(res)
        type(complex128x2), intent(in) :: cx
        type(float64x2) :: res
        res = cx%re
    end function

    pure function mf_from_cdp(x) result(res)
        complex(dp), intent(in) :: x
        type(float64x2) :: res
        res = from_qp(real(x, qp))
    end function

    pure function mf_from_csp(x) result(res)
        complex(sp), intent(in) :: x
        type(float64x2) :: res
        res = from_qp(real(x, qp))
    end function

    pure function cx_from_mf_2(r, i) result(res)
        type(float64x2), intent(in) :: r, i
        type(complex128x2) :: res
        res%re = r
        res%im = i
    end function

    pure function cx_from_dp_2(r, i) result(res)
        real(dp), intent(in) :: r, i
        type(complex128x2) :: res
        res%re = from_qp(real(r, qp))
        res%im = from_qp(real(i, qp))
    end function

    pure function cx_from_mf_1(r) result(res)
        type(float64x2), intent(in) :: r
        type(complex128x2) :: res
        res%re = r
        res%im = from_qp(0.0_qp)
    end function

    pure function cx_from_dp_1(r) result(res)
        real(dp), intent(in) :: r
        type(complex128x2) :: res
        res%re = from_qp(real(r, qp))
        res%im = from_qp(0.0_qp)
    end function

    ! ================================================================
    ! Assignment
    ! ================================================================

#:for n, d in ATYPES
#:if n != 'mf'
    pure subroutine mf_assign_${n}$(lhs, rhs)
        type(float64x2), intent(out) :: lhs
        ${d}$, intent(in) :: rhs
#:if ISCPLX[n]
        lhs = from_qp(real(${CONV[n].format('rhs')}$, qp))
#:else
        lhs = from_qp(${CONV[n].format('rhs')}$)
#:endif
    end subroutine

#:endif
#:endfor
#:for n, d in ATYPES
#:if n != 'cx'
    pure subroutine cx_assign_${n}$(lhs, rhs)
        type(complex128x2), intent(out) :: lhs
        ${d}$, intent(in) :: rhs
#:if ISCPLX[n]
        lhs = from_cqp(${CONV[n].format('rhs')}$)
#:else
        lhs = from_cqp(cmplx(${CONV[n].format('rhs')}$, 0.0_qp, qp))
#:endif
    end subroutine

#:endif
#:endfor
    ! ================================================================
    ! Conversions
    ! ================================================================

    pure function mf_dble(x) result(res)
        type(float64x2), intent(in) :: x
        real(dp) :: res
        res = real(to_qp(x), dp)
    end function

    pure function mf_int(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        res = int(to_qp(x))
    end function

    pure function mf_nint(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        res = nint(to_qp(x))
    end function

    pure function mf_to_double(x) result(res)
        type(float64x2), intent(in) :: x
        real(dp) :: res
        res = real(to_qp(x), dp)
    end function

    ! ================================================================
    ! Unary operators
    ! ================================================================

    pure function mf_neg(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        res = from_qp(-to_qp(x))
    end function

    pure function cx_neg(x) result(res)
        type(complex128x2), intent(in) :: x
        type(complex128x2) :: res
        res = from_cqp(-to_cqp(x))
    end function

    ! ================================================================
    ! Unary math: mf → mf
    ! ================================================================

#:for func in UNARY_MF_MF
    pure function mf_${func}$(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        res = from_qp(${func}$(to_qp(x)))
    end function

#:endfor
    ! ================================================================
    ! Unary math: cx → cx
    ! ================================================================

#:for func in UNARY_CX_CX
    pure function cx_${func}$(x) result(res)
        type(complex128x2), intent(in) :: x
        type(complex128x2) :: res
        res = from_cqp(${func}$(to_cqp(x)))
    end function

#:endfor
    ! ================================================================
    ! Unary math: cx → mf (abs, aimag)
    ! ================================================================

#:for func in UNARY_CX_MF
    pure function cx_${func}$(x) result(res)
        type(complex128x2), intent(in) :: x
        type(float64x2) :: res
        res = from_qp(${func}$(to_cqp(x)))
    end function

#:endfor
    ! ================================================================
    ! Complex-specific: cmplx, real, mf_real
    ! ================================================================

    pure function mf_cmplx_2(re, im) result(res)
        type(float64x2), intent(in) :: re, im
        type(complex128x2) :: res
        res%re = re
        res%im = im
    end function

    pure function mf_cmplx_1(re) result(res)
        type(float64x2), intent(in) :: re
        type(complex128x2) :: res
        res%re = re
        res%im = from_qp(0.0_qp)
    end function

    pure function cx_real(x) result(res)
        type(complex128x2), intent(in) :: x
        type(float64x2) :: res
        res = from_qp(real(to_cqp(x), qp))
    end function

    pure function mf_real_mf(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        res = x
    end function

    pure function cx_real_mf(x) result(res)
        type(complex128x2), intent(in) :: x
        type(float64x2) :: res
        res = x%re
    end function

    ! ================================================================
    ! Binary real functions (sign, mod, atan2, min, max)
    ! ================================================================

#:for func in BINARY_REAL + BINARY_MINMAX
#:for n1, d1 in RTYPES
#:for n2, d2 in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
    pure function ${n1}$_${func}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        type(float64x2) :: res
        res = from_qp(${func}$(${CONV[n1].format('a')}$, ${CONV[n2].format('b')}$))
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! min/max with 3 arguments
#:for func in BINARY_MINMAX
    pure function mf_${func}$3(a, b, c) result(res)
        type(float64x2), intent(in) :: a, b, c
        type(float64x2) :: res
        res = from_qp(${func}$(to_qp(a), to_qp(b), to_qp(c)))
    end function

#:endfor
    ! ================================================================
    ! Array reductions (maxval, minval, maxloc, minloc)
    ! ================================================================

#:for func in ARRAY_REDUCE_VAL
    ! ${func}$ — rank 1
    pure function mf_${func}$_1d(array) result(res)
        type(float64x2), intent(in) :: array(:)
        type(float64x2) :: res
        real(qp) :: tmp(size(array))
        integer :: i
        do i = 1, size(array)
            tmp(i) = to_qp(array(i))
        end do
        res = from_qp(${func}$(tmp))
    end function

    pure function mf_${func}$_1d_dim(array, dim) result(res)
        type(float64x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        type(float64x2) :: res
        real(qp) :: tmp(size(array))
        integer :: i
        do i = 1, size(array)
            tmp(i) = to_qp(array(i))
        end do
        res = from_qp(${func}$(tmp, dim=dim))
    end function

    pure function mf_${func}$_1d_mask(array, mask) result(res)
        type(float64x2), intent(in) :: array(:)
        logical, intent(in) :: mask(:)
        type(float64x2) :: res
        real(qp) :: tmp(size(array))
        integer :: i
        do i = 1, size(array)
            tmp(i) = to_qp(array(i))
        end do
        res = from_qp(${func}$(tmp, mask=mask))
    end function

    pure function mf_${func}$_1d_dim_mask(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        logical, intent(in) :: mask(:)
        type(float64x2) :: res
        real(qp) :: tmp(size(array))
        integer :: i
        do i = 1, size(array)
            tmp(i) = to_qp(array(i))
        end do
        res = from_qp(${func}$(tmp, dim=dim, mask=mask))
    end function

    ! ${func}$ — rank 2
    pure function mf_${func}$_2d(array) result(res)
        type(float64x2), intent(in) :: array(:,:)
        type(float64x2) :: res
        real(qp) :: tmp(size(array,1), size(array,2))
        integer :: i, j
        do j = 1, size(array, 2)
            do i = 1, size(array, 1)
                tmp(i,j) = to_qp(array(i,j))
            end do
        end do
        res = from_qp(${func}$(tmp))
    end function

    pure function mf_${func}$_2d_dim(array, dim) result(res)
        type(float64x2), intent(in) :: array(:,:)
        integer, intent(in) :: dim
        type(float64x2) :: res(merge(size(array,2), size(array,1), dim==1))
        real(qp) :: tmp(size(array,1), size(array,2))
        real(qp) :: tmp_res(merge(size(array,2), size(array,1), dim==1))
        integer :: i, j
        do j = 1, size(array, 2)
            do i = 1, size(array, 1)
                tmp(i,j) = to_qp(array(i,j))
            end do
        end do
        tmp_res = ${func}$(tmp, dim=dim)
        do i = 1, size(tmp_res)
            res(i) = from_qp(tmp_res(i))
        end do
    end function

    pure function mf_${func}$_2d_mask(array, mask) result(res)
        type(float64x2), intent(in) :: array(:,:)
        logical, intent(in) :: mask(:,:)
        type(float64x2) :: res
        real(qp) :: tmp(size(array,1), size(array,2))
        integer :: i, j
        do j = 1, size(array, 2)
            do i = 1, size(array, 1)
                tmp(i,j) = to_qp(array(i,j))
            end do
        end do
        res = from_qp(${func}$(tmp, mask=mask))
    end function

    pure function mf_${func}$_2d_dim_mask(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(:,:)
        integer, intent(in) :: dim
        logical, intent(in) :: mask(:,:)
        type(float64x2) :: res(merge(size(array,2), size(array,1), dim==1))
        real(qp) :: tmp(size(array,1), size(array,2))
        real(qp) :: tmp_res(merge(size(array,2), size(array,1), dim==1))
        integer :: i, j
        do j = 1, size(array, 2)
            do i = 1, size(array, 1)
                tmp(i,j) = to_qp(array(i,j))
            end do
        end do
        tmp_res = ${func}$(tmp, dim=dim, mask=mask)
        do i = 1, size(tmp_res)
            res(i) = from_qp(tmp_res(i))
        end do
    end function

#:endfor
#:for func in ARRAY_REDUCE_LOC
    ! ${func}$ — rank 1
    pure function mf_${func}$_1d(array) result(res)
        type(float64x2), intent(in) :: array(:)
        integer :: res(1)
        real(qp) :: tmp(size(array))
        integer :: i
        do i = 1, size(array)
            tmp(i) = to_qp(array(i))
        end do
        res = ${func}$(tmp)
    end function

    pure function mf_${func}$_1d_dim(array, dim) result(res)
        type(float64x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        integer :: res
        real(qp) :: tmp(size(array))
        integer :: i
        do i = 1, size(array)
            tmp(i) = to_qp(array(i))
        end do
        res = ${func}$(tmp, dim=dim)
    end function

    pure function mf_${func}$_1d_mask(array, mask) result(res)
        type(float64x2), intent(in) :: array(:)
        logical, intent(in) :: mask(:)
        integer :: res(1)
        real(qp) :: tmp(size(array))
        integer :: i
        do i = 1, size(array)
            tmp(i) = to_qp(array(i))
        end do
        res = ${func}$(tmp, mask=mask)
    end function

    pure function mf_${func}$_1d_dim_mask(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        logical, intent(in) :: mask(:)
        integer :: res
        real(qp) :: tmp(size(array))
        integer :: i
        do i = 1, size(array)
            tmp(i) = to_qp(array(i))
        end do
        res = ${func}$(tmp, dim=dim, mask=mask)
    end function

    ! ${func}$ — rank 2
    pure function mf_${func}$_2d(array) result(res)
        type(float64x2), intent(in) :: array(:,:)
        integer :: res(2)
        real(qp) :: tmp(size(array,1), size(array,2))
        integer :: i, j
        do j = 1, size(array, 2)
            do i = 1, size(array, 1)
                tmp(i,j) = to_qp(array(i,j))
            end do
        end do
        res = ${func}$(tmp)
    end function

    pure function mf_${func}$_2d_dim(array, dim) result(res)
        type(float64x2), intent(in) :: array(:,:)
        integer, intent(in) :: dim
        integer :: res(merge(size(array,2), size(array,1), dim==1))
        real(qp) :: tmp(size(array,1), size(array,2))
        integer :: i, j
        do j = 1, size(array, 2)
            do i = 1, size(array, 1)
                tmp(i,j) = to_qp(array(i,j))
            end do
        end do
        res = ${func}$(tmp, dim=dim)
    end function

    pure function mf_${func}$_2d_mask(array, mask) result(res)
        type(float64x2), intent(in) :: array(:,:)
        logical, intent(in) :: mask(:,:)
        integer :: res(2)
        real(qp) :: tmp(size(array,1), size(array,2))
        integer :: i, j
        do j = 1, size(array, 2)
            do i = 1, size(array, 1)
                tmp(i,j) = to_qp(array(i,j))
            end do
        end do
        res = ${func}$(tmp, mask=mask)
    end function

    pure function mf_${func}$_2d_dim_mask(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(:,:)
        integer, intent(in) :: dim
        logical, intent(in) :: mask(:,:)
        integer :: res(merge(size(array,2), size(array,1), dim==1))
        real(qp) :: tmp(size(array,1), size(array,2))
        integer :: i, j
        do j = 1, size(array, 2)
            do i = 1, size(array, 1)
                tmp(i,j) = to_qp(array(i,j))
            end do
        end do
        res = ${func}$(tmp, dim=dim, mask=mask)
    end function

#:endfor
    ! ================================================================
    ! Binary arithmetic (+, -, *, /)
    ! ================================================================

#:for opsym, opname in ARITH_OPS
#:for n1, d1 in ATYPES
#:for n2, d2 in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
#:set rc = ISCPLX[n1] or ISCPLX[n2]
    pure function ${n1}$_${opname}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        ${'type(complex128x2)' if rc else 'type(float64x2)'}$ :: res
        res = ${'from_cqp' if rc else 'from_qp'}$(${CONV[n1].format('a')}$ ${opsym}$ ${CONV[n2].format('b')}$)
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! ================================================================
    ! Power operator (**)  — preserves integer exponent semantics
    ! ================================================================

#:for n1, d1 in ATYPES
#:for n2, d2 in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
#:set rc = ISCPLX[n1] or ISCPLX[n2]
    pure function ${n1}$_pow_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        ${'type(complex128x2)' if rc else 'type(float64x2)'}$ :: res
#:if n2 == 'int'
        res = ${'from_cqp' if rc else 'from_qp'}$(${CONV[n1].format('a')}$ ** b)
#:else
        res = ${'from_cqp' if rc else 'from_qp'}$(${CONV[n1].format('a')}$ ** ${CONV[n2].format('b')}$)
#:endif
    end function

#:endif
#:endfor
#:endfor
    ! ================================================================
    ! Equality comparison (==, /=)
    ! ================================================================

#:for opsym, opname in EQ_OPS
#:for n1, d1 in ATYPES
#:for n2, d2 in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
    pure function ${n1}$_${opname}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        logical :: res
        res = ${CONV[n1].format('a')}$ ${opsym}$ ${CONV[n2].format('b')}$
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! ================================================================
    ! Ordered comparison (<, >, <=, >=)
    ! ================================================================

#:for opsym, opname in ORD_OPS
#:for n1, d1 in RTYPES
#:for n2, d2 in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
    pure function ${n1}$_${opname}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        logical :: res
        res = ${CONV[n1].format('a')}$ ${opsym}$ ${CONV[n2].format('b')}$
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! ================================================================
    ! Defined I/O
    ! ================================================================

    subroutine write_mf_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        class(float64x2), intent(in) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
        real(qp) :: val_qp
        val_qp = to_qp(dtv)
        if (iotype == 'LISTDIRECTED') then
            write(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            write(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_qp
        else
            write(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        end if
    end subroutine

    subroutine write_cx_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        class(complex128x2), intent(in) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
        complex(qp) :: val_cqp
        val_cqp = to_cqp(dtv)
        if (iotype == 'LISTDIRECTED') then
            write(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            write(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_cqp
        else
            write(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        end if
    end subroutine

    subroutine read_mf_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        class(float64x2), intent(inout) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
        real(qp) :: val_qp
        if (iotype == 'LISTDIRECTED') then
            read(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            read(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_qp
        else
            read(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        end if
        if (iostat == 0) then
            dtv%limbs(1) = real(val_qp, dp)
            dtv%limbs(2) = real(val_qp - real(dtv%limbs(1), qp), dp)
        end if
    end subroutine

    subroutine read_cx_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        class(complex128x2), intent(inout) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
        complex(qp) :: val_cqp
        if (iotype == 'LISTDIRECTED') then
            read(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            read(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_cqp
        else
            read(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        end if
        if (iostat == 0) then
            dtv%re%limbs(1) = real(real(val_cqp, qp), dp)
            dtv%re%limbs(2) = real(real(val_cqp, qp) - real(dtv%re%limbs(1), qp), dp)
            dtv%im%limbs(1) = real(aimag(val_cqp), dp)
            dtv%im%limbs(2) = real(aimag(val_cqp) - real(dtv%im%limbs(1), qp), dp)
        end if
    end subroutine

end module multifloats
