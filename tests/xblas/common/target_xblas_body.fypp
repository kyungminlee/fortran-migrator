#! Per-framework XBLAS test wrapper, parameterized by target.
#!
#! Each per-target shim sets:
#!   target          'kind10' | 'kind16' | 'multifloats'
#!   target_name     human-readable label string (for reports)
#!   target_eps      Fortran expression giving the target's epsilon as REAL(KIND=ep)
#!   target_real     Fortran type-spec for the target's real type
#!   target_complex  Fortran type-spec for the target's complex type
#!   prefix_real     migrated entry-point prefix for the D family ('e' / 'q' / 'm')
#!   prefix_complex  migrated entry-point prefix for the Z family ('y' / 'x' / 'w')
#!
#! XBLAS calling convention:
#!   The migrated archive ships C entry points (BLAS_<P>...) plus
#!   Fortran-callable bridges named ``blas_<P>..._`` (compiled with
#!   -DCONFIG_FC_UNDERSCORE). The bridge takes integer arguments by
#!   reference, hardcodes ``blas_colmajor``, and forwards a trailing
#!   ``int *prec`` enumerator. We always pass ``blas_prec_extra``.

#:set R = prefix_real
#:set C = prefix_complex

#:def IMPORT_R()
#:if target == 'multifloats'
            import :: real64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

#:def IMPORT_C()
#:if target == 'multifloats'
            import :: cmplx64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

module target_xblas
    use prec_kinds, only: ep
    use target_conv, only: q2t_r, t2q_r, q2t_c, t2q_c
#:if target == 'multifloats'
    use multifloats, only: real64x2, cmplx64x2
#:endif
    implicit none
    private

    public :: target_name, target_eps
    public :: blas_prec_extra
    public :: blas_conj, blas_no_conj, blas_conj_k
    public :: blas_no_trans, blas_trans_k, blas_conj_trans
    public :: blas_upper, blas_lower
    public :: blas_non_unit_diag, blas_unit_diag
    public :: blas_left_side, blas_right_side
    ! Level 1
    public :: target_blas_daxpby_x, target_blas_zaxpby_x
    public :: target_blas_ddot_x,   target_blas_zdot_x
    public :: target_blas_dsum_x,   target_blas_zsum_x
    public :: target_blas_dwaxpby_x, target_blas_zwaxpby_x
    ! Level 2
    public :: target_blas_dgemv_x,  target_blas_zgemv_x
    public :: target_blas_dgemv2_x, target_blas_zgemv2_x
    public :: target_blas_dgbmv_x,  target_blas_zgbmv_x
    public :: target_blas_dgbmv2_x, target_blas_zgbmv2_x
    public :: target_blas_dsymv_x,  target_blas_zsymv_x
    public :: target_blas_dsymv2_x, target_blas_zsymv2_x
    public :: target_blas_dsbmv_x,  target_blas_zsbmv_x
    public :: target_blas_dspmv_x,  target_blas_zspmv_x
    public :: target_blas_zhemv_x,  target_blas_zhemv2_x
    public :: target_blas_zhbmv_x,  target_blas_zhpmv_x
    public :: target_blas_dge_sum_mv_x, target_blas_zge_sum_mv_x
    public :: target_blas_dtrmv_x,  target_blas_ztrmv_x
    public :: target_blas_dtpmv_x,  target_blas_ztpmv_x
    public :: target_blas_dtbsv_x,  target_blas_ztbsv_x
    public :: target_blas_dtrsv_x,  target_blas_ztrsv_x
    ! Level 3
    public :: target_blas_dgemm_x,  target_blas_zgemm_x
    public :: target_blas_dsymm_x,  target_blas_zsymm_x
    public :: target_blas_zhemm_x

    character(len=*), parameter :: target_name = "${target_name}$"
    real(ep),         parameter :: target_eps  = ${target_eps}$

    ! XBLAS enum values (from external/xblas-1.0.248/src/blas_enum.h).
    integer, parameter :: blas_prec_extra   = 214
    integer, parameter :: blas_conj         = 191
    integer, parameter :: blas_no_conj      = 192
    integer, parameter :: blas_conj_k       = blas_conj
    integer, parameter :: blas_no_trans     = 111
    integer, parameter :: blas_trans_k      = 112
    integer, parameter :: blas_conj_trans   = 113
    integer, parameter :: blas_upper        = 121
    integer, parameter :: blas_lower        = 122
    integer, parameter :: blas_non_unit_diag = 131
    integer, parameter :: blas_unit_diag    = 132
    integer, parameter :: blas_left_side    = 141
    integer, parameter :: blas_right_side   = 142

    interface

        ! ── Level 1 ────────────────────────────────────────────────
        subroutine blas_${R}$axpby_x(n, alpha, x, incx, beta, y, incy, prec)
$:IMPORT_R()
            integer,         intent(in) :: n, incx, incy, prec
            ${target_real}$, intent(in) :: alpha, beta, x(*)
            ${target_real}$, intent(inout) :: y(*)
        end subroutine
        subroutine blas_${C}$axpby_x(n, alpha, x, incx, beta, y, incy, prec)
$:IMPORT_C()
            integer,            intent(in) :: n, incx, incy, prec
            ${target_complex}$, intent(in) :: alpha, beta, x(*)
            ${target_complex}$, intent(inout) :: y(*)
        end subroutine

        subroutine blas_${R}$dot_x(conj, n, alpha, x, incx, beta, y, incy, r, prec)
$:IMPORT_R()
            integer,         intent(in)    :: conj, n, incx, incy, prec
            ${target_real}$, intent(in)    :: alpha, beta, x(*), y(*)
            ${target_real}$, intent(inout) :: r
        end subroutine
        subroutine blas_${C}$dot_x(conj, n, alpha, x, incx, beta, y, incy, r, prec)
$:IMPORT_C()
            integer,            intent(in)    :: conj, n, incx, incy, prec
            ${target_complex}$, intent(in)    :: alpha, beta, x(*), y(*)
            ${target_complex}$, intent(inout) :: r
        end subroutine

        subroutine blas_${R}$sum_x(n, x, incx, s, prec)
$:IMPORT_R()
            integer,         intent(in)  :: n, incx, prec
            ${target_real}$, intent(in)  :: x(*)
            ${target_real}$, intent(out) :: s
        end subroutine
        subroutine blas_${C}$sum_x(n, x, incx, s, prec)
$:IMPORT_C()
            integer,            intent(in)  :: n, incx, prec
            ${target_complex}$, intent(in)  :: x(*)
            ${target_complex}$, intent(out) :: s
        end subroutine

        subroutine blas_${R}$waxpby_x(n, alpha, x, incx, beta, y, incy, w, incw, prec)
$:IMPORT_R()
            integer,         intent(in)  :: n, incx, incy, incw, prec
            ${target_real}$, intent(in)  :: alpha, beta, x(*), y(*)
            ${target_real}$, intent(out) :: w(*)
        end subroutine
        subroutine blas_${C}$waxpby_x(n, alpha, x, incx, beta, y, incy, w, incw, prec)
$:IMPORT_C()
            integer,            intent(in)  :: n, incx, incy, incw, prec
            ${target_complex}$, intent(in)  :: alpha, beta, x(*), y(*)
            ${target_complex}$, intent(out) :: w(*)
        end subroutine

        ! ── Level 2 — gemv ─────────────────────────────────────────
        subroutine blas_${R}$gemv_x(trans, m, n, alpha, a, lda, x, incx, &
                                   beta, y, incy, prec)
$:IMPORT_R()
            integer,         intent(in)    :: trans, m, n, lda, incx, incy, prec
            ${target_real}$, intent(in)    :: alpha, beta, a(lda,*), x(*)
            ${target_real}$, intent(inout) :: y(*)
        end subroutine
        subroutine blas_${C}$gemv_x(trans, m, n, alpha, a, lda, x, incx, &
                                   beta, y, incy, prec)
$:IMPORT_C()
            integer,            intent(in)    :: trans, m, n, lda, incx, incy, prec
