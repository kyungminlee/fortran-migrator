            ${target_complex}$, intent(inout) :: c(ldc,*)
        end subroutine

    end interface

contains

    ! ── Conversion macro shorthand ─────────────────────────────────
    ! Quad-domain wrappers convert ep → target via q2t_*, call the
    ! migrated bridge with prec=blas_prec_extra, then convert the
    ! result back to ep via t2q_*. q2t_* / t2q_* are elemental,
    ! so they map naturally over arrays and slices.

    ! ════════════════════════════════════════════════════════════════
    ! Level 1
    ! ════════════════════════════════════════════════════════════════

    subroutine target_blas_daxpby_x(n, alpha_q, x_q, incx, beta_q, y_q, incy)
        integer,  intent(in)    :: n, incx, incy
        real(ep), intent(in)    :: alpha_q, beta_q, x_q(*)
        real(ep), intent(inout) :: y_q(*)
        ${target_real}$ :: alpha_t, beta_t
        ${target_real}$, allocatable :: x_t(:), y_t(:)
        integer :: lx, ly
        lx = 1 + (n - 1) * abs(incx); ly = 1 + (n - 1) * abs(incy)
        allocate(x_t(lx), y_t(ly))
        alpha_t = q2t_r(alpha_q); beta_t = q2t_r(beta_q)
