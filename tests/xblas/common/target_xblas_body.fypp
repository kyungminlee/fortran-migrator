        x_q(1:lenx) = t2q_c(x_t)
    end subroutine

    ! ════════════════════════════════════════════════════════════════
    ! Level 3 — gemm / symm / hemm
    ! ════════════════════════════════════════════════════════════════

    subroutine target_blas_dgemm_x(transa, transb, m, n, k, alpha_q, &
                                   a_q, lda, b_q, ldb, beta_q, c_q, ldc)
        integer,  intent(in)    :: transa, transb, m, n, k, lda, ldb, ldc
        real(ep), intent(in)    :: alpha_q, beta_q, a_q(lda,*), b_q(ldb,*)
        real(ep), intent(inout) :: c_q(ldc,*)
        ${target_real}$ :: alpha_t, beta_t
        ${target_real}$, allocatable :: a_t(:,:), b_t(:,:), c_t(:,:)
        integer :: a_cols, b_cols
        if (transa == blas_no_trans) then; a_cols = k; else; a_cols = m; end if
        if (transb == blas_no_trans) then; b_cols = n; else; b_cols = k; end if
        allocate(a_t(lda, a_cols), b_t(ldb, b_cols), c_t(ldc, n))
        alpha_t = q2t_r(alpha_q); beta_t = q2t_r(beta_q)
        a_t = q2t_r(a_q(1:lda, 1:a_cols))
        b_t = q2t_r(b_q(1:ldb, 1:b_cols))
        c_t = q2t_r(c_q(1:ldc, 1:n))
        call blas_${R}$gemm_x(transa, transb, m, n, k, alpha_t, &
                             a_t, lda, b_t, ldb, beta_t, c_t, ldc, blas_prec_extra)
        c_q(1:ldc, 1:n) = t2q_r(c_t)
    end subroutine

    subroutine target_blas_zgemm_x(transa, transb, m, n, k, alpha_q, &
                                   a_q, lda, b_q, ldb, beta_q, c_q, ldc)
        integer,     intent(in)    :: transa, transb, m, n, k, lda, ldb, ldc
        complex(ep), intent(in)    :: alpha_q, beta_q, a_q(lda,*), b_q(ldb,*)
        complex(ep), intent(inout) :: c_q(ldc,*)
        ${target_complex}$ :: alpha_t, beta_t
        ${target_complex}$, allocatable :: a_t(:,:), b_t(:,:), c_t(:,:)
        integer :: a_cols, b_cols
        if (transa == blas_no_trans) then; a_cols = k; else; a_cols = m; end if
        if (transb == blas_no_trans) then; b_cols = n; else; b_cols = k; end if
        allocate(a_t(lda, a_cols), b_t(ldb, b_cols), c_t(ldc, n))
        alpha_t = q2t_c(alpha_q); beta_t = q2t_c(beta_q)
        a_t = q2t_c(a_q(1:lda, 1:a_cols))
        b_t = q2t_c(b_q(1:ldb, 1:b_cols))
        c_t = q2t_c(c_q(1:ldc, 1:n))
        call blas_${C}$gemm_x(transa, transb, m, n, k, alpha_t, &
                             a_t, lda, b_t, ldb, beta_t, c_t, ldc, blas_prec_extra)
        c_q(1:ldc, 1:n) = t2q_c(c_t)
    end subroutine

    subroutine target_blas_dsymm_x(side, uplo, m, n, alpha_q, a_q, lda, &
                                   b_q, ldb, beta_q, c_q, ldc)
        integer,  intent(in)    :: side, uplo, m, n, lda, ldb, ldc
        real(ep), intent(in)    :: alpha_q, beta_q, a_q(lda,*), b_q(ldb,*)
        real(ep), intent(inout) :: c_q(ldc,*)
        ${target_real}$ :: alpha_t, beta_t
        ${target_real}$, allocatable :: a_t(:,:), b_t(:,:), c_t(:,:)
        integer :: a_cols
        if (side == blas_left_side) then; a_cols = m; else; a_cols = n; end if
        allocate(a_t(lda, a_cols), b_t(ldb, n), c_t(ldc, n))
        alpha_t = q2t_r(alpha_q); beta_t = q2t_r(beta_q)
        a_t = q2t_r(a_q(1:lda, 1:a_cols))
        b_t = q2t_r(b_q(1:ldb, 1:n))
        c_t = q2t_r(c_q(1:ldc, 1:n))
        call blas_${R}$symm_x(side, uplo, m, n, alpha_t, a_t, lda, &
                             b_t, ldb, beta_t, c_t, ldc, blas_prec_extra)
        c_q(1:ldc, 1:n) = t2q_r(c_t)
    end subroutine

    subroutine target_blas_zsymm_x(side, uplo, m, n, alpha_q, a_q, lda, &
                                   b_q, ldb, beta_q, c_q, ldc)
        integer,     intent(in)    :: side, uplo, m, n, lda, ldb, ldc
        complex(ep), intent(in)    :: alpha_q, beta_q, a_q(lda,*), b_q(ldb,*)
