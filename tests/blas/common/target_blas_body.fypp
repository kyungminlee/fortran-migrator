        real(ep),  intent(inout) :: C(ldc,*)
        integer :: an
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), Ct(:,:)
        if (side == 'L' .or. side == 'l') then; an = m; else; an = n; end if
        allocate(At(lda, an), Bt(ldb, n), Ct(ldc, n))
        At = q2t_r(A(1:lda, 1:an))
        Bt = q2t_r(B(1:ldb, 1:n))
        Ct = q2t_r(C(1:ldc, 1:n))
        call ${R}$symm(side, uplo, m, n, q2t_r(alpha), At, lda, &
                       Bt, ldb, q2t_r(beta), Ct, ldc)
        C(1:ldc, 1:n) = t2q_r(Ct)
