    ! ── Level 2 — real ───────────────────────────────────────────────
    subroutine target_dgemv(trans, m, n, alpha, A, lda, x, incx, beta, y, incy)
        character, intent(in)    :: trans
        integer,   intent(in)    :: m, n, lda, incx, incy
        real(ep),  intent(in)    :: alpha, beta
        real(ep),  intent(in)    :: A(lda,*), x(*)
        real(ep),  intent(inout) :: y(*)
        integer :: nx, ny
        ${target_real}$, allocatable :: At(:,:), xt(:), yt(:)
        if (trans == 'N' .or. trans == 'n') then
            nx = (n - 1) * abs(incx) + 1
            ny = (m - 1) * abs(incy) + 1
        else
            nx = (m - 1) * abs(incx) + 1
            ny = (n - 1) * abs(incy) + 1
        end if
        allocate(At(lda, n), xt(nx), yt(ny))
        At = q2t_r(A(1:lda, 1:n))
        xt = q2t_r(x(1:nx)); yt = q2t_r(y(1:ny))
        call ${R}$gemv(trans, m, n, q2t_r(alpha), At, lda, xt, incx, &
                       q2t_r(beta), yt, incy)
        y(1:ny) = t2q_r(yt)
    end subroutine

