        allocate(At(na), Bt(nb), Ct(nc))
        At = q2t_c(A(1:na)); Bt = q2t_c(B(1:nb)); Ct = q2t_c(C(1:nc))
        call ${C}$symm(side, uplo, m, n, q2t_c(alpha), &
                        At, ia, ja, desca, Bt, ib, jb, descb, &
                        q2t_c(beta), Ct, ic, jc, descc)
        C(1:nc) = t2q_c(Ct)
    end subroutine

