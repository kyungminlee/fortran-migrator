#! Per-framework PBLAS test wrapper, parameterized by target.
#!
#! Each per-target shim sets:
#!   target          'kind10' | 'kind16' | 'multifloats'
#!   target_name     human-readable label string
#!   target_eps      Fortran expression giving the target's epsilon as REAL(KIND=ep)
#!   target_real     Fortran type-spec for the target's real type
#!   target_complex  Fortran type-spec for the target's complex type
#!   prefix_real     migrated entry-point prefix for the D family (e.g. 'pq')
#!   prefix_complex  migrated entry-point prefix for the Z family (e.g. 'px')

#:set R = prefix_real
#:set C = prefix_complex

#! Mixed-precision PBLAS routines have *both* the real and the complex
#! letter substituted independently. e.g. pdzasum -> pqxasum (kind16),
#! peyasum (kind10), ptvasum (multifloats); pzdscal -> pxqscal,
#! pyescal, pvtscal. The prefix is the leading 'p' followed by the
#! single-letter trailing slot of each underlying prefix in the order
#! the original name uses them. The per-target shim files only set
#! prefix_real / prefix_complex (always two characters: 'p' + slot
#! letter), so we can derive the mixed prefixes here.
#:set RC = 'p' + prefix_real[1:] + prefix_complex[1:]
#:set CR = 'p' + prefix_complex[1:] + prefix_real[1:]

#:def IMPORT_R()
#:if target == 'multifloats'
            import :: real64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

#:def IMPORT_C()
#:if target == 'multifloats'
            import :: cmplx64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

#:def IMPORT_RC()
#:if target == 'multifloats'
            import :: real64x2, cmplx64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

module target_pblas
    use prec_kinds, only: ep
    use target_conv, only: q2t_r, t2q_r, q2t_c, t2q_c
#:if target == 'multifloats'
    use multifloats, only: real64x2, cmplx64x2
#:endif
    implicit none
    private

    public :: target_name, target_eps
    public :: target_pddot, target_pdnrm2, target_pdasum
    public :: target_pdscal, target_pdaxpy, target_pdcopy
    public :: target_pdswap, target_pdamax
    public :: target_pdzasum, target_pdznrm2
    public :: target_pzdotc, target_pzdotu, target_pzaxpy
    public :: target_pzcopy, target_pzswap, target_pzscal, target_pzdscal
    public :: target_pzamax
    public :: target_pdgemv, target_pdger, target_pdsymv, target_pdtrsv
    public :: target_pdtrmv, target_pdsyr, target_pdsyr2
    public :: target_pzgemv, target_pzhemv
    public :: target_pzgerc, target_pzgeru, target_pzher, target_pzher2
    public :: target_pztrmv, target_pztrsv
    public :: target_pdgemm, target_pdsymm, target_pdsyrk, target_pdsyr2k
    public :: target_pdtrmm, target_pdtrsm
    public :: target_pzgemm, target_pzhemm, target_pzsymm
    public :: target_pzherk, target_pzher2k
    public :: target_pzsyrk, target_pzsyr2k
    public :: target_pztrmm, target_pztrsm
    public :: target_pdgeadd, target_pdtran, target_pdtradd
    public :: target_pzgeadd, target_pztranc, target_pztranu, target_pztradd

    character(len=*), parameter :: target_name = "${target_name}$"
    real(ep),         parameter :: target_eps  = ${target_eps}$

    interface
        ! ── Level 1 — real ───────────────────────────────────────────
        subroutine ${R}$dot(n, dot, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
$:IMPORT_R()
            integer, intent(in)  :: n, ix, jx, incx, iy, jy, incy
            integer, intent(in)  :: descx(9), descy(9)
            ${target_real}$, intent(in)  :: x(*), y(*)
            ${target_real}$, intent(out) :: dot
        end subroutine

        subroutine ${R}$nrm2(n, norm2, x, ix, jx, descx, incx)
$:IMPORT_R()
            integer, intent(in) :: n, ix, jx, incx
            integer, intent(in) :: descx(9)
            ${target_real}$, intent(in)  :: x(*)
            ${target_real}$, intent(out) :: norm2
        end subroutine

        subroutine ${R}$asum(n, asum, x, ix, jx, descx, incx)
$:IMPORT_R()
            integer, intent(in) :: n, ix, jx, incx
            integer, intent(in) :: descx(9)
            ${target_real}$, intent(in)  :: x(*)
            ${target_real}$, intent(out) :: asum
        end subroutine

        subroutine ${R}$scal(n, alpha, x, ix, jx, descx, incx)
$:IMPORT_R()
            integer, intent(in) :: n, ix, jx, incx
            integer, intent(in) :: descx(9)
            ${target_real}$, intent(in)    :: alpha
            ${target_real}$, intent(inout) :: x(*)
        end subroutine

        subroutine ${R}$axpy(n, alpha, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
$:IMPORT_R()
            integer, intent(in) :: n, ix, jx, incx, iy, jy, incy
            integer, intent(in) :: descx(9), descy(9)
            ${target_real}$, intent(in)    :: alpha, x(*)
            ${target_real}$, intent(inout) :: y(*)
        end subroutine

        subroutine ${R}$copy(n, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
$:IMPORT_R()
            integer, intent(in) :: n, ix, jx, incx, iy, jy, incy
            integer, intent(in) :: descx(9), descy(9)
            ${target_real}$, intent(in)  :: x(*)
            ${target_real}$, intent(out) :: y(*)
        end subroutine

        subroutine ${R}$swap(n, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
$:IMPORT_R()
            integer, intent(in) :: n, ix, jx, incx, iy, jy, incy
            integer, intent(in) :: descx(9), descy(9)
            ${target_real}$, intent(inout) :: x(*), y(*)
        end subroutine

        subroutine ${R}$amax(n, amax, indx, x, ix, jx, descx, incx)
$:IMPORT_R()
            integer, intent(in)  :: n, ix, jx, incx
            integer, intent(in)  :: descx(9)
            integer, intent(out) :: indx
            ${target_real}$, intent(in)  :: x(*)
            ${target_real}$, intent(out) :: amax
        end subroutine

        ! ── Level 1 — mixed real-from-complex (asum, nrm2) ───────────
        subroutine ${RC}$asum(n, asum, x, ix, jx, descx, incx)
$:IMPORT_RC()
            integer, intent(in) :: n, ix, jx, incx
            integer, intent(in) :: descx(9)
            ${target_complex}$, intent(in)  :: x(*)
            ${target_real}$,    intent(out) :: asum
        end subroutine

        subroutine ${RC}$nrm2(n, norm2, x, ix, jx, descx, incx)
$:IMPORT_RC()
            integer, intent(in) :: n, ix, jx, incx
            integer, intent(in) :: descx(9)
            ${target_complex}$, intent(in)  :: x(*)
            ${target_real}$,    intent(out) :: norm2
        end subroutine

        ! ── Level 1 — complex ────────────────────────────────────────
        subroutine ${C}$dotc(n, dot, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
$:IMPORT_C()
            integer, intent(in)  :: n, ix, jx, incx, iy, jy, incy
            integer, intent(in)  :: descx(9), descy(9)
            ${target_complex}$, intent(in)  :: x(*), y(*)
            ${target_complex}$, intent(out) :: dot
        end subroutine

        subroutine ${C}$axpy(n, alpha, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
$:IMPORT_C()
            integer, intent(in) :: n, ix, jx, incx, iy, jy, incy
            integer, intent(in) :: descx(9), descy(9)
            ${target_complex}$, intent(in)    :: alpha, x(*)
            ${target_complex}$, intent(inout) :: y(*)
        end subroutine

        subroutine ${C}$dotu(n, dot, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
$:IMPORT_C()
            integer, intent(in)  :: n, ix, jx, incx, iy, jy, incy
            integer, intent(in)  :: descx(9), descy(9)
            ${target_complex}$, intent(in)  :: x(*), y(*)
            ${target_complex}$, intent(out) :: dot
        end subroutine

        subroutine ${C}$copy(n, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
$:IMPORT_C()
            integer, intent(in) :: n, ix, jx, incx, iy, jy, incy
            integer, intent(in) :: descx(9), descy(9)
            ${target_complex}$, intent(in)  :: x(*)
            ${target_complex}$, intent(out) :: y(*)
        end subroutine

        subroutine ${C}$swap(n, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
$:IMPORT_C()
            integer, intent(in) :: n, ix, jx, incx, iy, jy, incy
            integer, intent(in) :: descx(9), descy(9)
            ${target_complex}$, intent(inout) :: x(*), y(*)
        end subroutine

        subroutine ${C}$scal(n, alpha, x, ix, jx, descx, incx)
$:IMPORT_C()
            integer, intent(in) :: n, ix, jx, incx
            integer, intent(in) :: descx(9)
            ${target_complex}$, intent(in)    :: alpha
            ${target_complex}$, intent(inout) :: x(*)
        end subroutine

        subroutine ${C}$amax(n, amax, indx, x, ix, jx, descx, incx)
$:IMPORT_C()
            integer, intent(in)  :: n, ix, jx, incx
            integer, intent(in)  :: descx(9)
            integer, intent(out) :: indx
            ${target_complex}$, intent(in)  :: x(*)
            ${target_complex}$, intent(out) :: amax
        end subroutine

        ! ── Level 1 — mixed complex-with-real-scalar (zdscal) ────────
        subroutine ${CR}$scal(n, alpha, x, ix, jx, descx, incx)
$:IMPORT_RC()
            integer, intent(in) :: n, ix, jx, incx
            integer, intent(in) :: descx(9)
            ${target_real}$,    intent(in)    :: alpha
            ${target_complex}$, intent(inout) :: x(*)
        end subroutine

        ! ── Level 2 — real ───────────────────────────────────────────
        subroutine ${R}$gemv(trans, m, n, alpha, A, ia, ja, desca, &
                             x, ix, jx, descx, incx, beta, y, iy, jy, descy, incy)
$:IMPORT_R()
            character, intent(in) :: trans
            integer,   intent(in) :: m, n, ia, ja, ix, jx, incx, iy, jy, incy
            integer,   intent(in) :: desca(9), descx(9), descy(9)
            ${target_real}$, intent(in)    :: alpha, beta, A(*), x(*)
            ${target_real}$, intent(inout) :: y(*)
        end subroutine

        subroutine ${R}$ger(m, n, alpha, x, ix, jx, descx, incx, &
                            y, iy, jy, descy, incy, A, ia, ja, desca)
$:IMPORT_R()
            integer, intent(in) :: m, n, ix, jx, incx, iy, jy, incy, ia, ja
            integer, intent(in) :: desca(9), descx(9), descy(9)
            ${target_real}$, intent(in)    :: alpha, x(*), y(*)
            ${target_real}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${R}$symv(uplo, n, alpha, A, ia, ja, desca, &
                             x, ix, jx, descx, incx, beta, y, iy, jy, descy, incy)
$:IMPORT_R()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, ia, ja, ix, jx, incx, iy, jy, incy
            integer,   intent(in) :: desca(9), descx(9), descy(9)
            ${target_real}$, intent(in)    :: alpha, beta, A(*), x(*)
            ${target_real}$, intent(inout) :: y(*)
        end subroutine

        subroutine ${R}$trsv(uplo, trans, diag, n, A, ia, ja, desca, &
                             x, ix, jx, descx, incx)
$:IMPORT_R()
            character, intent(in) :: uplo, trans, diag
            integer,   intent(in) :: n, ia, ja, ix, jx, incx
            integer,   intent(in) :: desca(9), descx(9)
            ${target_real}$, intent(in)    :: A(*)
            ${target_real}$, intent(inout) :: x(*)
        end subroutine

        subroutine ${R}$trmv(uplo, trans, diag, n, A, ia, ja, desca, &
                             x, ix, jx, descx, incx)
$:IMPORT_R()
            character, intent(in) :: uplo, trans, diag
            integer,   intent(in) :: n, ia, ja, ix, jx, incx
            integer,   intent(in) :: desca(9), descx(9)
            ${target_real}$, intent(in)    :: A(*)
            ${target_real}$, intent(inout) :: x(*)
        end subroutine

        subroutine ${R}$syr(uplo, n, alpha, x, ix, jx, descx, incx, &
                            A, ia, ja, desca)
$:IMPORT_R()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, ix, jx, incx, ia, ja
            integer,   intent(in) :: desca(9), descx(9)
            ${target_real}$, intent(in)    :: alpha, x(*)
            ${target_real}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${R}$syr2(uplo, n, alpha, x, ix, jx, descx, incx, &
                             y, iy, jy, descy, incy, A, ia, ja, desca)
$:IMPORT_R()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, ix, jx, incx, iy, jy, incy, ia, ja
            integer,   intent(in) :: desca(9), descx(9), descy(9)
            ${target_real}$, intent(in)    :: alpha, x(*), y(*)
            ${target_real}$, intent(inout) :: A(*)
        end subroutine

        ! ── Level 2 — complex ────────────────────────────────────────
        subroutine ${C}$gemv(trans, m, n, alpha, A, ia, ja, desca, &
                             x, ix, jx, descx, incx, beta, y, iy, jy, descy, incy)
$:IMPORT_C()
            character, intent(in) :: trans
            integer,   intent(in) :: m, n, ia, ja, ix, jx, incx, iy, jy, incy
            integer,   intent(in) :: desca(9), descx(9), descy(9)
            ${target_complex}$, intent(in)    :: alpha, beta, A(*), x(*)
            ${target_complex}$, intent(inout) :: y(*)
        end subroutine

        subroutine ${C}$hemv(uplo, n, alpha, A, ia, ja, desca, &
                             x, ix, jx, descx, incx, beta, y, iy, jy, descy, incy)
$:IMPORT_C()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, ia, ja, ix, jx, incx, iy, jy, incy
            integer,   intent(in) :: desca(9), descx(9), descy(9)
            ${target_complex}$, intent(in)    :: alpha, beta, A(*), x(*)
            ${target_complex}$, intent(inout) :: y(*)
        end subroutine

        subroutine ${C}$gerc(m, n, alpha, x, ix, jx, descx, incx, &
                             y, iy, jy, descy, incy, A, ia, ja, desca)
$:IMPORT_C()
            integer, intent(in) :: m, n, ix, jx, incx, iy, jy, incy, ia, ja
            integer, intent(in) :: desca(9), descx(9), descy(9)
            ${target_complex}$, intent(in)    :: alpha, x(*), y(*)
            ${target_complex}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${C}$geru(m, n, alpha, x, ix, jx, descx, incx, &
                             y, iy, jy, descy, incy, A, ia, ja, desca)
$:IMPORT_C()
            integer, intent(in) :: m, n, ix, jx, incx, iy, jy, incy, ia, ja
            integer, intent(in) :: desca(9), descx(9), descy(9)
            ${target_complex}$, intent(in)    :: alpha, x(*), y(*)
            ${target_complex}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${C}$her(uplo, n, alpha, x, ix, jx, descx, incx, &
                            A, ia, ja, desca)
$:IMPORT_RC()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, ix, jx, incx, ia, ja
            integer,   intent(in) :: desca(9), descx(9)
            ${target_real}$,    intent(in)    :: alpha
            ${target_complex}$, intent(in)    :: x(*)
            ${target_complex}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${C}$her2(uplo, n, alpha, x, ix, jx, descx, incx, &
                             y, iy, jy, descy, incy, A, ia, ja, desca)
$:IMPORT_C()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, ix, jx, incx, iy, jy, incy, ia, ja
            integer,   intent(in) :: desca(9), descx(9), descy(9)
            ${target_complex}$, intent(in)    :: alpha, x(*), y(*)
            ${target_complex}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${C}$trmv(uplo, trans, diag, n, A, ia, ja, desca, &
                             x, ix, jx, descx, incx)
$:IMPORT_C()
            character, intent(in) :: uplo, trans, diag
            integer,   intent(in) :: n, ia, ja, ix, jx, incx
            integer,   intent(in) :: desca(9), descx(9)
            ${target_complex}$, intent(in)    :: A(*)
            ${target_complex}$, intent(inout) :: x(*)
        end subroutine

        subroutine ${C}$trsv(uplo, trans, diag, n, A, ia, ja, desca, &
                             x, ix, jx, descx, incx)
$:IMPORT_C()
            character, intent(in) :: uplo, trans, diag
            integer,   intent(in) :: n, ia, ja, ix, jx, incx
            integer,   intent(in) :: desca(9), descx(9)
            ${target_complex}$, intent(in)    :: A(*)
            ${target_complex}$, intent(inout) :: x(*)
        end subroutine

        ! ── Level 3 — real ───────────────────────────────────────────
        subroutine ${R}$gemm(transa, transb, m, n, k, alpha, A, ia, ja, desca, &
                             B, ib, jb, descb, beta, C, ic, jc, descc)
$:IMPORT_R()
            character, intent(in) :: transa, transb
            integer,   intent(in) :: m, n, k, ia, ja, ib, jb, ic, jc
            integer,   intent(in) :: desca(9), descb(9), descc(9)
            ${target_real}$, intent(in)    :: alpha, beta, A(*), B(*)
            ${target_real}$, intent(inout) :: C(*)
        end subroutine

        subroutine ${R}$symm(side, uplo, m, n, alpha, A, ia, ja, desca, &
                             B, ib, jb, descb, beta, C, ic, jc, descc)
$:IMPORT_R()
            character, intent(in) :: side, uplo
            integer,   intent(in) :: m, n, ia, ja, ib, jb, ic, jc
            integer,   intent(in) :: desca(9), descb(9), descc(9)
            ${target_real}$, intent(in)    :: alpha, beta, A(*), B(*)
            ${target_real}$, intent(inout) :: C(*)
        end subroutine

        subroutine ${R}$syrk(uplo, trans, n, k, alpha, A, ia, ja, desca, &
                             beta, C, ic, jc, descc)
$:IMPORT_R()
            character, intent(in) :: uplo, trans
            integer,   intent(in) :: n, k, ia, ja, ic, jc
            integer,   intent(in) :: desca(9), descc(9)
            ${target_real}$, intent(in)    :: alpha, beta, A(*)
            ${target_real}$, intent(inout) :: C(*)
        end subroutine

        subroutine ${R}$trmm(side, uplo, trans, diag, m, n, alpha, &
                             A, ia, ja, desca, B, ib, jb, descb)
$:IMPORT_R()
            character, intent(in) :: side, uplo, trans, diag
            integer,   intent(in) :: m, n, ia, ja, ib, jb
            integer,   intent(in) :: desca(9), descb(9)
            ${target_real}$, intent(in)    :: alpha, A(*)
            ${target_real}$, intent(inout) :: B(*)
        end subroutine

        subroutine ${R}$trsm(side, uplo, trans, diag, m, n, alpha, &
                             A, ia, ja, desca, B, ib, jb, descb)
$:IMPORT_R()
            character, intent(in) :: side, uplo, trans, diag
            integer,   intent(in) :: m, n, ia, ja, ib, jb
            integer,   intent(in) :: desca(9), descb(9)
            ${target_real}$, intent(in)    :: alpha, A(*)
            ${target_real}$, intent(inout) :: B(*)
        end subroutine

        subroutine ${R}$syr2k(uplo, trans, n, k, alpha, A, ia, ja, desca, &
                              B, ib, jb, descb, beta, C, ic, jc, descc)
$:IMPORT_R()
            character, intent(in) :: uplo, trans
            integer,   intent(in) :: n, k, ia, ja, ib, jb, ic, jc
            integer,   intent(in) :: desca(9), descb(9), descc(9)
            ${target_real}$, intent(in)    :: alpha, beta, A(*), B(*)
            ${target_real}$, intent(inout) :: C(*)
        end subroutine

        ! ── Level 3 — complex ────────────────────────────────────────
        subroutine ${C}$gemm(transa, transb, m, n, k, alpha, A, ia, ja, desca, &
                             B, ib, jb, descb, beta, C, ic, jc, descc)
$:IMPORT_C()
            character, intent(in) :: transa, transb
            integer,   intent(in) :: m, n, k, ia, ja, ib, jb, ic, jc
            integer,   intent(in) :: desca(9), descb(9), descc(9)
            ${target_complex}$, intent(in)    :: alpha, beta, A(*), B(*)
            ${target_complex}$, intent(inout) :: C(*)
        end subroutine

        subroutine ${C}$herk(uplo, trans, n, k, alpha, A, ia, ja, desca, &
                             beta, C, ic, jc, descc)
$:IMPORT_RC()
            character, intent(in) :: uplo, trans
            integer,   intent(in) :: n, k, ia, ja, ic, jc
            integer,   intent(in) :: desca(9), descc(9)
            ${target_real}$,    intent(in)    :: alpha, beta
            ${target_complex}$, intent(in)    :: A(*)
            ${target_complex}$, intent(inout) :: C(*)
        end subroutine

        subroutine ${C}$hemm(side, uplo, m, n, alpha, A, ia, ja, desca, &
                             B, ib, jb, descb, beta, C, ic, jc, descc)
$:IMPORT_C()
            character, intent(in) :: side, uplo
            integer,   intent(in) :: m, n, ia, ja, ib, jb, ic, jc
            integer,   intent(in) :: desca(9), descb(9), descc(9)
            ${target_complex}$, intent(in)    :: alpha, beta, A(*), B(*)
            ${target_complex}$, intent(inout) :: C(*)
        end subroutine

        subroutine ${C}$symm(side, uplo, m, n, alpha, A, ia, ja, desca, &
                             B, ib, jb, descb, beta, C, ic, jc, descc)
$:IMPORT_C()
            character, intent(in) :: side, uplo
            integer,   intent(in) :: m, n, ia, ja, ib, jb, ic, jc
            integer,   intent(in) :: desca(9), descb(9), descc(9)
            ${target_complex}$, intent(in)    :: alpha, beta, A(*), B(*)
            ${target_complex}$, intent(inout) :: C(*)
        end subroutine

        subroutine ${C}$syrk(uplo, trans, n, k, alpha, A, ia, ja, desca, &
                             beta, C, ic, jc, descc)
$:IMPORT_C()
            character, intent(in) :: uplo, trans
            integer,   intent(in) :: n, k, ia, ja, ic, jc
            integer,   intent(in) :: desca(9), descc(9)
            ${target_complex}$, intent(in)    :: alpha, beta, A(*)
            ${target_complex}$, intent(inout) :: C(*)
        end subroutine

        subroutine ${C}$syr2k(uplo, trans, n, k, alpha, A, ia, ja, desca, &
                              B, ib, jb, descb, beta, C, ic, jc, descc)
$:IMPORT_C()
            character, intent(in) :: uplo, trans
            integer,   intent(in) :: n, k, ia, ja, ib, jb, ic, jc
            integer,   intent(in) :: desca(9), descb(9), descc(9)
            ${target_complex}$, intent(in)    :: alpha, beta, A(*), B(*)
            ${target_complex}$, intent(inout) :: C(*)
        end subroutine

        subroutine ${C}$her2k(uplo, trans, n, k, alpha, A, ia, ja, desca, &
                              B, ib, jb, descb, beta, C, ic, jc, descc)
$:IMPORT_RC()
            character, intent(in) :: uplo, trans
            integer,   intent(in) :: n, k, ia, ja, ib, jb, ic, jc
            integer,   intent(in) :: desca(9), descb(9), descc(9)
            ${target_complex}$, intent(in)    :: alpha
            ${target_real}$,    intent(in)    :: beta
            ${target_complex}$, intent(in)    :: A(*), B(*)
            ${target_complex}$, intent(inout) :: C(*)
        end subroutine

        subroutine ${C}$trmm(side, uplo, trans, diag, m, n, alpha, &
                             A, ia, ja, desca, B, ib, jb, descb)
$:IMPORT_C()
            character, intent(in) :: side, uplo, trans, diag
            integer,   intent(in) :: m, n, ia, ja, ib, jb
            integer,   intent(in) :: desca(9), descb(9)
