        na = desca(9) * desca(4); nb = descb(9) * descb(4); nc = descc(9) * descc(4)
        allocate(At(na), Bt(nb), Ct(nc))
        At = q2t_r(A(1:na)); Bt = q2t_r(B(1:nb)); Ct = q2t_r(C(1:nc))
