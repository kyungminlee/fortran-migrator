        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(xt(nx), yt(ny))
        xt = q2t_c(x(1:nx)); yt = q2t_c(y(1:ny))
        call ${C}$swap(n, xt, ix, jx, descx, incx, yt, iy, jy, descy, incy)
        x(1:nx) = t2q_c(xt); y(1:ny) = t2q_c(yt)
    end subroutine

    subroutine target_pzscal(n, alpha, x, ix, jx, descx, incx)
        integer,     intent(in)    :: n, ix, jx, incx
        integer,     intent(in)    :: descx(9)
        complex(ep), intent(in)    :: alpha
        complex(ep), intent(inout) :: x(*)
        integer :: nx
        ${target_complex}$, allocatable :: xt(:)
        nx = descx(9) * descx(4)
        allocate(xt(nx))
        xt = q2t_c(x(1:nx))
        call ${C}$scal(n, q2t_c(alpha), xt, ix, jx, descx, incx)
