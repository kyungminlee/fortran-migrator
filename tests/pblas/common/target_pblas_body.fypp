    ! ── Level 1 — mixed complex-with-real-scalar ─────────────────────
    subroutine target_pzdscal(n, alpha, x, ix, jx, descx, incx)
        integer,     intent(in)    :: n, ix, jx, incx
        integer,     intent(in)    :: descx(9)
        real(ep),    intent(in)    :: alpha
        complex(ep), intent(inout) :: x(*)
        integer :: nx
        ${target_complex}$, allocatable :: xt(:)
        nx = descx(9) * descx(4)
        allocate(xt(nx))
        xt = q2t_c(x(1:nx))
        call ${CR}$scal(n, q2t_r(alpha), xt, ix, jx, descx, incx)
        x(1:nx) = t2q_c(xt)
    end subroutine

    ! ── Level 2 — real ───────────────────────────────────────────────
    subroutine target_pdgemv(trans, m, n, alpha, A, ia, ja, desca, &
                             x, ix, jx, descx, incx, beta, y, iy, jy, descy, incy)
        character, intent(in)    :: trans
        integer,   intent(in)    :: m, n, ia, ja, ix, jx, incx, iy, jy, incy
        integer,   intent(in)    :: desca(9), descx(9), descy(9)
        real(ep),  intent(in)    :: alpha, beta, A(*), x(*)
        real(ep),  intent(inout) :: y(*)
        integer :: na, nx, ny
        ${target_real}$, allocatable :: At(:), xt(:), yt(:)
        na = desca(9) * desca(4)
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(At(na), xt(nx), yt(ny))
        At = q2t_r(A(1:na))
        xt = q2t_r(x(1:nx)); yt = q2t_r(y(1:ny))
        call ${R}$gemv(trans, m, n, q2t_r(alpha), At, ia, ja, desca, &
                        xt, ix, jx, descx, incx, q2t_r(beta), &
                        yt, iy, jy, descy, incy)
        y(1:ny) = t2q_r(yt)
    end subroutine

    subroutine target_pdger(m, n, alpha, x, ix, jx, descx, incx, &
                            y, iy, jy, descy, incy, A, ia, ja, desca)
        integer,  intent(in)    :: m, n, ix, jx, incx, iy, jy, incy, ia, ja
        integer,  intent(in)    :: desca(9), descx(9), descy(9)
        real(ep), intent(in)    :: alpha, x(*), y(*)
        real(ep), intent(inout) :: A(*)
        integer :: na, nx, ny
        ${target_real}$, allocatable :: At(:), xt(:), yt(:)
        na = desca(9) * desca(4)
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(At(na), xt(nx), yt(ny))
        At = q2t_r(A(1:na))
        xt = q2t_r(x(1:nx)); yt = q2t_r(y(1:ny))
        call ${R}$ger(m, n, q2t_r(alpha), xt, ix, jx, descx, incx, &
                       yt, iy, jy, descy, incy, At, ia, ja, desca)
        A(1:na) = t2q_r(At)
    end subroutine

    subroutine target_pdsymv(uplo, n, alpha, A, ia, ja, desca, &
                             x, ix, jx, descx, incx, beta, y, iy, jy, descy, incy)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, ia, ja, ix, jx, incx, iy, jy, incy
        integer,   intent(in)    :: desca(9), descx(9), descy(9)
        real(ep),  intent(in)    :: alpha, beta, A(*), x(*)
        real(ep),  intent(inout) :: y(*)
        integer :: na, nx, ny
        ${target_real}$, allocatable :: At(:), xt(:), yt(:)
        na = desca(9) * desca(4)
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(At(na), xt(nx), yt(ny))
        At = q2t_r(A(1:na))
        xt = q2t_r(x(1:nx)); yt = q2t_r(y(1:ny))
        call ${R}$symv(uplo, n, q2t_r(alpha), At, ia, ja, desca, &
                        xt, ix, jx, descx, incx, q2t_r(beta), &
                        yt, iy, jy, descy, incy)
        y(1:ny) = t2q_r(yt)
    end subroutine

    subroutine target_pdtrsv(uplo, trans, diag, n, A, ia, ja, desca, &
                             x, ix, jx, descx, incx)
