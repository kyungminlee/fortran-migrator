        allocate(xt(nx))
        xt = q2t_c(x(1:nx))
        call ${RC}$asum(n, asum_t, xt, ix, jx, descx, incx)
        asum = t2q_r(asum_t)
    end subroutine

    subroutine target_pdznrm2(n, norm2, x, ix, jx, descx, incx)
        integer,     intent(in)  :: n, ix, jx, incx
