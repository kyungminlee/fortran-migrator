            ${target_complex}$, intent(inout) :: C(*)
        end subroutine
    end interface

contains

    ! ── Level 1 — real ───────────────────────────────────────────────
    subroutine target_pddot(n, dot, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
        integer,  intent(in)  :: n, ix, jx, incx, iy, jy, incy
        integer,  intent(in)  :: descx(9), descy(9)
        real(ep), intent(in)  :: x(*), y(*)
        real(ep), intent(out) :: dot
        integer :: nx, ny
        ${target_real}$, allocatable :: xt(:), yt(:)
        ${target_real}$ :: dot_t
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(xt(nx), yt(ny))
        xt = q2t_r(x(1:nx)); yt = q2t_r(y(1:ny))
        call ${R}$dot(n, dot_t, xt, ix, jx, descx, incx, yt, iy, jy, descy, incy)
        dot = t2q_r(dot_t)
    end subroutine

    subroutine target_pdnrm2(n, norm2, x, ix, jx, descx, incx)
        integer,  intent(in)  :: n, ix, jx, incx
        integer,  intent(in)  :: descx(9)
        real(ep), intent(in)  :: x(*)
        real(ep), intent(out) :: norm2
        integer :: nx
        ${target_real}$, allocatable :: xt(:)
        ${target_real}$ :: norm_t
        nx = descx(9) * descx(4)
        allocate(xt(nx))
        xt = q2t_r(x(1:nx))
        call ${R}$nrm2(n, norm_t, xt, ix, jx, descx, incx)
        norm2 = t2q_r(norm_t)
    end subroutine

    subroutine target_pdasum(n, asum, x, ix, jx, descx, incx)
        integer,  intent(in)  :: n, ix, jx, incx
        integer,  intent(in)  :: descx(9)
        real(ep), intent(in)  :: x(*)
        real(ep), intent(out) :: asum
        integer :: nx
        ${target_real}$, allocatable :: xt(:)
        ${target_real}$ :: asum_t
        nx = descx(9) * descx(4)
        allocate(xt(nx))
        xt = q2t_r(x(1:nx))
        call ${R}$asum(n, asum_t, xt, ix, jx, descx, incx)
        asum = t2q_r(asum_t)
    end subroutine

    subroutine target_pdscal(n, alpha, x, ix, jx, descx, incx)
        integer,  intent(in)    :: n, ix, jx, incx
        integer,  intent(in)    :: descx(9)
        real(ep), intent(in)    :: alpha
        real(ep), intent(inout) :: x(*)
        integer :: nx
        ${target_real}$, allocatable :: xt(:)
        nx = descx(9) * descx(4)
        allocate(xt(nx))
        xt = q2t_r(x(1:nx))
        call ${R}$scal(n, q2t_r(alpha), xt, ix, jx, descx, incx)
        x(1:nx) = t2q_r(xt)
    end subroutine

    subroutine target_pdaxpy(n, alpha, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
        integer,  intent(in)    :: n, ix, jx, incx, iy, jy, incy
        integer,  intent(in)    :: descx(9), descy(9)
        real(ep), intent(in)    :: alpha, x(*)
        real(ep), intent(inout) :: y(*)
        integer :: nx, ny
        ${target_real}$, allocatable :: xt(:), yt(:)
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(xt(nx), yt(ny))
        xt = q2t_r(x(1:nx)); yt = q2t_r(y(1:ny))
        call ${R}$axpy(n, q2t_r(alpha), xt, ix, jx, descx, incx, &
                        yt, iy, jy, descy, incy)
        y(1:ny) = t2q_r(yt)
    end subroutine

    subroutine target_pdcopy(n, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
        integer,  intent(in)  :: n, ix, jx, incx, iy, jy, incy
        integer,  intent(in)  :: descx(9), descy(9)
        real(ep), intent(in)  :: x(*)
        real(ep), intent(out) :: y(*)
        integer :: nx, ny
        ${target_real}$, allocatable :: xt(:), yt(:)
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(xt(nx), yt(ny))
        xt = q2t_r(x(1:nx))
        call ${R}$copy(n, xt, ix, jx, descx, incx, yt, iy, jy, descy, incy)
        y(1:ny) = t2q_r(yt)
    end subroutine

    subroutine target_pdswap(n, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
        integer,  intent(in)    :: n, ix, jx, incx, iy, jy, incy
        integer,  intent(in)    :: descx(9), descy(9)
        real(ep), intent(inout) :: x(*), y(*)
        integer :: nx, ny
        ${target_real}$, allocatable :: xt(:), yt(:)
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(xt(nx), yt(ny))
        xt = q2t_r(x(1:nx)); yt = q2t_r(y(1:ny))
        call ${R}$swap(n, xt, ix, jx, descx, incx, yt, iy, jy, descy, incy)
        x(1:nx) = t2q_r(xt); y(1:ny) = t2q_r(yt)
    end subroutine

    subroutine target_pdamax(n, amax, indx, x, ix, jx, descx, incx)
        integer,  intent(in)  :: n, ix, jx, incx
        integer,  intent(in)  :: descx(9)
        integer,  intent(out) :: indx
        real(ep), intent(in)  :: x(*)
        real(ep), intent(out) :: amax
        integer :: nx
        ${target_real}$, allocatable :: xt(:)
        ${target_real}$ :: amax_t
        nx = descx(9) * descx(4)
        allocate(xt(nx))
        xt = q2t_r(x(1:nx))
        call ${R}$amax(n, amax_t, indx, xt, ix, jx, descx, incx)
        amax = t2q_r(amax_t)
    end subroutine

    ! ── Level 1 — mixed real-from-complex ────────────────────────────
    subroutine target_pdzasum(n, asum, x, ix, jx, descx, incx)
        integer,     intent(in)  :: n, ix, jx, incx
        integer,     intent(in)  :: descx(9)
        complex(ep), intent(in)  :: x(*)
        real(ep),    intent(out) :: asum
