#! Per-framework PBLAS test wrapper, parameterized by target.
#!
#! Each per-target shim sets:
#!   target          'kind10' | 'kind16' | 'multifloats'
#!   target_name     human-readable label string
#!   target_eps      Fortran expression giving the target's epsilon as REAL(KIND=ep)
#!   target_real     Fortran type-spec for the target's real type
#!   target_complex  Fortran type-spec for the target's complex type
#!   prefix_real     migrated entry-point prefix for the D family (e.g. 'pq')
#!   prefix_complex  migrated entry-point prefix for the Z family (e.g. 'px')

#:set R = prefix_real
#:set C = prefix_complex

#:def IMPORT_R()
#:if target == 'multifloats'
            import :: real64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

#:def IMPORT_C()
#:if target == 'multifloats'
            import :: cmplx64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

#:def IMPORT_RC()
#:if target == 'multifloats'
            import :: real64x2, cmplx64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

module target_pblas
    use prec_kinds, only: ep
    use target_conv, only: q2t_r, t2q_r, q2t_c, t2q_c
#:if target == 'multifloats'
    use multifloats, only: real64x2, cmplx64x2
#:endif
    implicit none
    private

    public :: target_name, target_eps
    public :: target_pddot, target_pdnrm2, target_pdasum
    public :: target_pdscal, target_pdaxpy, target_pdcopy
    public :: target_pzdotc, target_pzaxpy
    public :: target_pdgemv, target_pdger, target_pdsymv, target_pdtrsv
    public :: target_pzgemv
    public :: target_pdgemm, target_pdsymm, target_pdsyrk
    public :: target_pdtrmm, target_pdtrsm
    public :: target_pzgemm, target_pzherk

    character(len=*), parameter :: target_name = "${target_name}$"
    real(ep),         parameter :: target_eps  = ${target_eps}$

    interface
        ! ── Level 1 — real ───────────────────────────────────────────
        subroutine ${R}$dot(n, dot, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
$:IMPORT_R()
            integer, intent(in)  :: n, ix, jx, incx, iy, jy, incy
            integer, intent(in)  :: descx(9), descy(9)
            ${target_real}$, intent(in)  :: x(*), y(*)
            ${target_real}$, intent(out) :: dot
        end subroutine

        subroutine ${R}$nrm2(n, norm2, x, ix, jx, descx, incx)
$:IMPORT_R()
            integer, intent(in) :: n, ix, jx, incx
            integer, intent(in) :: descx(9)
            ${target_real}$, intent(in)  :: x(*)
            ${target_real}$, intent(out) :: norm2
        end subroutine

        subroutine ${R}$asum(n, asum, x, ix, jx, descx, incx)
$:IMPORT_R()
            integer, intent(in) :: n, ix, jx, incx
            integer, intent(in) :: descx(9)
            ${target_real}$, intent(in)  :: x(*)
            ${target_real}$, intent(out) :: asum
        end subroutine

        subroutine ${R}$scal(n, alpha, x, ix, jx, descx, incx)
$:IMPORT_R()
            integer, intent(in) :: n, ix, jx, incx
            integer, intent(in) :: descx(9)
            ${target_real}$, intent(in)    :: alpha
            ${target_real}$, intent(inout) :: x(*)
        end subroutine

        subroutine ${R}$axpy(n, alpha, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
$:IMPORT_R()
            integer, intent(in) :: n, ix, jx, incx, iy, jy, incy
            integer, intent(in) :: descx(9), descy(9)
            ${target_real}$, intent(in)    :: alpha, x(*)
            ${target_real}$, intent(inout) :: y(*)
        end subroutine

        subroutine ${R}$copy(n, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
$:IMPORT_R()
            integer, intent(in) :: n, ix, jx, incx, iy, jy, incy
            integer, intent(in) :: descx(9), descy(9)
            ${target_real}$, intent(in)  :: x(*)
            ${target_real}$, intent(out) :: y(*)
        end subroutine

        ! ── Level 1 — complex ────────────────────────────────────────
        subroutine ${C}$dotc(n, dot, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
$:IMPORT_C()
            integer, intent(in)  :: n, ix, jx, incx, iy, jy, incy
            integer, intent(in)  :: descx(9), descy(9)
            ${target_complex}$, intent(in)  :: x(*), y(*)
            ${target_complex}$, intent(out) :: dot
        end subroutine

        subroutine ${C}$axpy(n, alpha, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
$:IMPORT_C()
            integer, intent(in) :: n, ix, jx, incx, iy, jy, incy
            integer, intent(in) :: descx(9), descy(9)
            ${target_complex}$, intent(in)    :: alpha, x(*)
            ${target_complex}$, intent(inout) :: y(*)
        end subroutine

        ! ── Level 2 — real ───────────────────────────────────────────
        subroutine ${R}$gemv(trans, m, n, alpha, A, ia, ja, desca, &
                             x, ix, jx, descx, incx, beta, y, iy, jy, descy, incy)
$:IMPORT_R()
            character, intent(in) :: trans
            integer,   intent(in) :: m, n, ia, ja, ix, jx, incx, iy, jy, incy
            integer,   intent(in) :: desca(9), descx(9), descy(9)
            ${target_real}$, intent(in)    :: alpha, beta, A(*), x(*)
            ${target_real}$, intent(inout) :: y(*)
        end subroutine

        subroutine ${R}$ger(m, n, alpha, x, ix, jx, descx, incx, &
                            y, iy, jy, descy, incy, A, ia, ja, desca)
$:IMPORT_R()
            integer, intent(in) :: m, n, ix, jx, incx, iy, jy, incy, ia, ja
            integer, intent(in) :: desca(9), descx(9), descy(9)
            ${target_real}$, intent(in)    :: alpha, x(*), y(*)
            ${target_real}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${R}$symv(uplo, n, alpha, A, ia, ja, desca, &
                             x, ix, jx, descx, incx, beta, y, iy, jy, descy, incy)
$:IMPORT_R()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, ia, ja, ix, jx, incx, iy, jy, incy
            integer,   intent(in) :: desca(9), descx(9), descy(9)
            ${target_real}$, intent(in)    :: alpha, beta, A(*), x(*)
            ${target_real}$, intent(inout) :: y(*)
        end subroutine

        subroutine ${R}$trsv(uplo, trans, diag, n, A, ia, ja, desca, &
                             x, ix, jx, descx, incx)
$:IMPORT_R()
            character, intent(in) :: uplo, trans, diag
            integer,   intent(in) :: n, ia, ja, ix, jx, incx
            integer,   intent(in) :: desca(9), descx(9)
            ${target_real}$, intent(in)    :: A(*)
            ${target_real}$, intent(inout) :: x(*)
        end subroutine

        ! ── Level 2 — complex ────────────────────────────────────────
        subroutine ${C}$gemv(trans, m, n, alpha, A, ia, ja, desca, &
                             x, ix, jx, descx, incx, beta, y, iy, jy, descy, incy)
$:IMPORT_C()
            character, intent(in) :: trans
            integer,   intent(in) :: m, n, ia, ja, ix, jx, incx, iy, jy, incy
            integer,   intent(in) :: desca(9), descx(9), descy(9)
            ${target_complex}$, intent(in)    :: alpha, beta, A(*), x(*)
            ${target_complex}$, intent(inout) :: y(*)
        end subroutine

        ! ── Level 3 — real ───────────────────────────────────────────
        subroutine ${R}$gemm(transa, transb, m, n, k, alpha, A, ia, ja, desca, &
                             B, ib, jb, descb, beta, C, ic, jc, descc)
$:IMPORT_R()
            character, intent(in) :: transa, transb
            integer,   intent(in) :: m, n, k, ia, ja, ib, jb, ic, jc
            integer,   intent(in) :: desca(9), descb(9), descc(9)
            ${target_real}$, intent(in)    :: alpha, beta, A(*), B(*)
            ${target_real}$, intent(inout) :: C(*)
        end subroutine

        subroutine ${R}$symm(side, uplo, m, n, alpha, A, ia, ja, desca, &
                             B, ib, jb, descb, beta, C, ic, jc, descc)
$:IMPORT_R()
            character, intent(in) :: side, uplo
            integer,   intent(in) :: m, n, ia, ja, ib, jb, ic, jc
            integer,   intent(in) :: desca(9), descb(9), descc(9)
            ${target_real}$, intent(in)    :: alpha, beta, A(*), B(*)
            ${target_real}$, intent(inout) :: C(*)
        end subroutine

        subroutine ${R}$syrk(uplo, trans, n, k, alpha, A, ia, ja, desca, &
                             beta, C, ic, jc, descc)
$:IMPORT_R()
            character, intent(in) :: uplo, trans
            integer,   intent(in) :: n, k, ia, ja, ic, jc
            integer,   intent(in) :: desca(9), descc(9)
            ${target_real}$, intent(in)    :: alpha, beta, A(*)
            ${target_real}$, intent(inout) :: C(*)
        end subroutine

        subroutine ${R}$trmm(side, uplo, trans, diag, m, n, alpha, &
                             A, ia, ja, desca, B, ib, jb, descb)
$:IMPORT_R()
            character, intent(in) :: side, uplo, trans, diag
            integer,   intent(in) :: m, n, ia, ja, ib, jb
            integer,   intent(in) :: desca(9), descb(9)
            ${target_real}$, intent(in)    :: alpha, A(*)
            ${target_real}$, intent(inout) :: B(*)
        end subroutine

        subroutine ${R}$trsm(side, uplo, trans, diag, m, n, alpha, &
                             A, ia, ja, desca, B, ib, jb, descb)
$:IMPORT_R()
            character, intent(in) :: side, uplo, trans, diag
            integer,   intent(in) :: m, n, ia, ja, ib, jb
            integer,   intent(in) :: desca(9), descb(9)
            ${target_real}$, intent(in)    :: alpha, A(*)
            ${target_real}$, intent(inout) :: B(*)
        end subroutine

        ! ── Level 3 — complex ────────────────────────────────────────
        subroutine ${C}$gemm(transa, transb, m, n, k, alpha, A, ia, ja, desca, &
                             B, ib, jb, descb, beta, C, ic, jc, descc)
$:IMPORT_C()
            character, intent(in) :: transa, transb
            integer,   intent(in) :: m, n, k, ia, ja, ib, jb, ic, jc
            integer,   intent(in) :: desca(9), descb(9), descc(9)
            ${target_complex}$, intent(in)    :: alpha, beta, A(*), B(*)
            ${target_complex}$, intent(inout) :: C(*)
        end subroutine

        subroutine ${C}$herk(uplo, trans, n, k, alpha, A, ia, ja, desca, &
                             beta, C, ic, jc, descc)
$:IMPORT_RC()
            character, intent(in) :: uplo, trans
            integer,   intent(in) :: n, k, ia, ja, ic, jc
            integer,   intent(in) :: desca(9), descc(9)
            ${target_real}$,    intent(in)    :: alpha, beta
            ${target_complex}$, intent(in)    :: A(*)
            ${target_complex}$, intent(inout) :: C(*)
        end subroutine
    end interface

contains

    ! ── Level 1 — real ───────────────────────────────────────────────
    subroutine target_pddot(n, dot, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
        integer,  intent(in)  :: n, ix, jx, incx, iy, jy, incy
        integer,  intent(in)  :: descx(9), descy(9)
        real(ep), intent(in)  :: x(*), y(*)
        real(ep), intent(out) :: dot
        integer :: nx, ny
        ${target_real}$, allocatable :: xt(:), yt(:)
        ${target_real}$ :: dot_t
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(xt(nx), yt(ny))
        xt = q2t_r(x(1:nx)); yt = q2t_r(y(1:ny))
        call ${R}$dot(n, dot_t, xt, ix, jx, descx, incx, yt, iy, jy, descy, incy)
        dot = t2q_r(dot_t)
    end subroutine

    subroutine target_pdnrm2(n, norm2, x, ix, jx, descx, incx)
        integer,  intent(in)  :: n, ix, jx, incx
        integer,  intent(in)  :: descx(9)
        real(ep), intent(in)  :: x(*)
        real(ep), intent(out) :: norm2
        integer :: nx
        ${target_real}$, allocatable :: xt(:)
        ${target_real}$ :: norm_t
        nx = descx(9) * descx(4)
        allocate(xt(nx))
        xt = q2t_r(x(1:nx))
        call ${R}$nrm2(n, norm_t, xt, ix, jx, descx, incx)
        norm2 = t2q_r(norm_t)
    end subroutine

    subroutine target_pdasum(n, asum, x, ix, jx, descx, incx)
        integer,  intent(in)  :: n, ix, jx, incx
        integer,  intent(in)  :: descx(9)
        real(ep), intent(in)  :: x(*)
        real(ep), intent(out) :: asum
        integer :: nx
        ${target_real}$, allocatable :: xt(:)
        ${target_real}$ :: asum_t
        nx = descx(9) * descx(4)
        allocate(xt(nx))
        xt = q2t_r(x(1:nx))
        call ${R}$asum(n, asum_t, xt, ix, jx, descx, incx)
        asum = t2q_r(asum_t)
    end subroutine

    subroutine target_pdscal(n, alpha, x, ix, jx, descx, incx)
        integer,  intent(in)    :: n, ix, jx, incx
        integer,  intent(in)    :: descx(9)
        real(ep), intent(in)    :: alpha
        real(ep), intent(inout) :: x(*)
        integer :: nx
        ${target_real}$, allocatable :: xt(:)
        nx = descx(9) * descx(4)
        allocate(xt(nx))
        xt = q2t_r(x(1:nx))
        call ${R}$scal(n, q2t_r(alpha), xt, ix, jx, descx, incx)
        x(1:nx) = t2q_r(xt)
    end subroutine

    subroutine target_pdaxpy(n, alpha, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
        integer,  intent(in)    :: n, ix, jx, incx, iy, jy, incy
        integer,  intent(in)    :: descx(9), descy(9)
        real(ep), intent(in)    :: alpha, x(*)
        real(ep), intent(inout) :: y(*)
        integer :: nx, ny
        ${target_real}$, allocatable :: xt(:), yt(:)
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(xt(nx), yt(ny))
        xt = q2t_r(x(1:nx)); yt = q2t_r(y(1:ny))
        call ${R}$axpy(n, q2t_r(alpha), xt, ix, jx, descx, incx, &
                        yt, iy, jy, descy, incy)
        y(1:ny) = t2q_r(yt)
    end subroutine

    subroutine target_pdcopy(n, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
        integer,  intent(in)  :: n, ix, jx, incx, iy, jy, incy
        integer,  intent(in)  :: descx(9), descy(9)
        real(ep), intent(in)  :: x(*)
        real(ep), intent(out) :: y(*)
        integer :: nx, ny
        ${target_real}$, allocatable :: xt(:), yt(:)
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(xt(nx), yt(ny))
        xt = q2t_r(x(1:nx))
        call ${R}$copy(n, xt, ix, jx, descx, incx, yt, iy, jy, descy, incy)
        y(1:ny) = t2q_r(yt)
    end subroutine

    ! ── Level 1 — complex ────────────────────────────────────────────
    subroutine target_pzdotc(n, dot, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
        integer,     intent(in)  :: n, ix, jx, incx, iy, jy, incy
        integer,     intent(in)  :: descx(9), descy(9)
        complex(ep), intent(in)  :: x(*), y(*)
        complex(ep), intent(out) :: dot
        integer :: nx, ny
        ${target_complex}$, allocatable :: xt(:), yt(:)
        ${target_complex}$ :: dot_t
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(xt(nx), yt(ny))
        xt = q2t_c(x(1:nx)); yt = q2t_c(y(1:ny))
        call ${C}$dotc(n, dot_t, xt, ix, jx, descx, incx, yt, iy, jy, descy, incy)
        dot = t2q_c(dot_t)
    end subroutine

    subroutine target_pzaxpy(n, alpha, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
        integer,     intent(in)    :: n, ix, jx, incx, iy, jy, incy
        integer,     intent(in)    :: descx(9), descy(9)
        complex(ep), intent(in)    :: alpha, x(*)
        complex(ep), intent(inout) :: y(*)
        integer :: nx, ny
        ${target_complex}$, allocatable :: xt(:), yt(:)
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(xt(nx), yt(ny))
        xt = q2t_c(x(1:nx)); yt = q2t_c(y(1:ny))
        call ${C}$axpy(n, q2t_c(alpha), xt, ix, jx, descx, incx, &
                        yt, iy, jy, descy, incy)
        y(1:ny) = t2q_c(yt)
    end subroutine

    ! ── Level 2 — real ───────────────────────────────────────────────
    subroutine target_pdgemv(trans, m, n, alpha, A, ia, ja, desca, &
                             x, ix, jx, descx, incx, beta, y, iy, jy, descy, incy)
        character, intent(in)    :: trans
        integer,   intent(in)    :: m, n, ia, ja, ix, jx, incx, iy, jy, incy
        integer,   intent(in)    :: desca(9), descx(9), descy(9)
        real(ep),  intent(in)    :: alpha, beta, A(*), x(*)
        real(ep),  intent(inout) :: y(*)
        integer :: na, nx, ny
        ${target_real}$, allocatable :: At(:), xt(:), yt(:)
        na = desca(9) * desca(4)
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(At(na), xt(nx), yt(ny))
        At = q2t_r(A(1:na))
        xt = q2t_r(x(1:nx)); yt = q2t_r(y(1:ny))
        call ${R}$gemv(trans, m, n, q2t_r(alpha), At, ia, ja, desca, &
                        xt, ix, jx, descx, incx, q2t_r(beta), &
                        yt, iy, jy, descy, incy)
        y(1:ny) = t2q_r(yt)
    end subroutine

    subroutine target_pdger(m, n, alpha, x, ix, jx, descx, incx, &
                            y, iy, jy, descy, incy, A, ia, ja, desca)
        integer,  intent(in)    :: m, n, ix, jx, incx, iy, jy, incy, ia, ja
        integer,  intent(in)    :: desca(9), descx(9), descy(9)
        real(ep), intent(in)    :: alpha, x(*), y(*)
        real(ep), intent(inout) :: A(*)
        integer :: na, nx, ny
        ${target_real}$, allocatable :: At(:), xt(:), yt(:)
        na = desca(9) * desca(4)
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(At(na), xt(nx), yt(ny))
        At = q2t_r(A(1:na))
        xt = q2t_r(x(1:nx)); yt = q2t_r(y(1:ny))
        call ${R}$ger(m, n, q2t_r(alpha), xt, ix, jx, descx, incx, &
                       yt, iy, jy, descy, incy, At, ia, ja, desca)
        A(1:na) = t2q_r(At)
    end subroutine

    subroutine target_pdsymv(uplo, n, alpha, A, ia, ja, desca, &
                             x, ix, jx, descx, incx, beta, y, iy, jy, descy, incy)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, ia, ja, ix, jx, incx, iy, jy, incy
        integer,   intent(in)    :: desca(9), descx(9), descy(9)
        real(ep),  intent(in)    :: alpha, beta, A(*), x(*)
        real(ep),  intent(inout) :: y(*)
        integer :: na, nx, ny
        ${target_real}$, allocatable :: At(:), xt(:), yt(:)
        na = desca(9) * desca(4)
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(At(na), xt(nx), yt(ny))
        At = q2t_r(A(1:na))
        xt = q2t_r(x(1:nx)); yt = q2t_r(y(1:ny))
        call ${R}$symv(uplo, n, q2t_r(alpha), At, ia, ja, desca, &
                        xt, ix, jx, descx, incx, q2t_r(beta), &
                        yt, iy, jy, descy, incy)
        y(1:ny) = t2q_r(yt)
    end subroutine

    subroutine target_pdtrsv(uplo, trans, diag, n, A, ia, ja, desca, &
                             x, ix, jx, descx, incx)
        character, intent(in)    :: uplo, trans, diag
        integer,   intent(in)    :: n, ia, ja, ix, jx, incx
        integer,   intent(in)    :: desca(9), descx(9)
        real(ep),  intent(in)    :: A(*)
        real(ep),  intent(inout) :: x(*)
        integer :: na, nx
        ${target_real}$, allocatable :: At(:), xt(:)
        na = desca(9) * desca(4); nx = descx(9) * descx(4)
        allocate(At(na), xt(nx))
        At = q2t_r(A(1:na)); xt = q2t_r(x(1:nx))
        call ${R}$trsv(uplo, trans, diag, n, At, ia, ja, desca, &
                        xt, ix, jx, descx, incx)
        x(1:nx) = t2q_r(xt)
    end subroutine

    ! ── Level 2 — complex ────────────────────────────────────────────
    subroutine target_pzgemv(trans, m, n, alpha, A, ia, ja, desca, &
                             x, ix, jx, descx, incx, beta, y, iy, jy, descy, incy)
        character,   intent(in)    :: trans
        integer,     intent(in)    :: m, n, ia, ja, ix, jx, incx, iy, jy, incy
        integer,     intent(in)    :: desca(9), descx(9), descy(9)
        complex(ep), intent(in)    :: alpha, beta, A(*), x(*)
        complex(ep), intent(inout) :: y(*)
        integer :: na, nx, ny
        ${target_complex}$, allocatable :: At(:), xt(:), yt(:)
        na = desca(9) * desca(4)
        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(At(na), xt(nx), yt(ny))
        At = q2t_c(A(1:na))
        xt = q2t_c(x(1:nx)); yt = q2t_c(y(1:ny))
        call ${C}$gemv(trans, m, n, q2t_c(alpha), At, ia, ja, desca, &
                        xt, ix, jx, descx, incx, q2t_c(beta), &
                        yt, iy, jy, descy, incy)
        y(1:ny) = t2q_c(yt)
    end subroutine

    ! ── Level 3 — real ───────────────────────────────────────────────
    subroutine target_pdgemm(transa, transb, m, n, k, alpha, A, ia, ja, desca, &
                             B, ib, jb, descb, beta, C, ic, jc, descc)
        character, intent(in)    :: transa, transb
        integer,   intent(in)    :: m, n, k, ia, ja, ib, jb, ic, jc
        integer,   intent(in)    :: desca(9), descb(9), descc(9)
        real(ep),  intent(in)    :: alpha, beta, A(*), B(*)
        real(ep),  intent(inout) :: C(*)
        integer :: na, nb, nc
        ${target_real}$, allocatable :: At(:), Bt(:), Ct(:)
        na = desca(9) * desca(4); nb = descb(9) * descb(4); nc = descc(9) * descc(4)
        allocate(At(na), Bt(nb), Ct(nc))
        At = q2t_r(A(1:na)); Bt = q2t_r(B(1:nb)); Ct = q2t_r(C(1:nc))
        call ${R}$gemm(transa, transb, m, n, k, q2t_r(alpha), &
                        At, ia, ja, desca, Bt, ib, jb, descb, &
                        q2t_r(beta), Ct, ic, jc, descc)
        C(1:nc) = t2q_r(Ct)
    end subroutine

