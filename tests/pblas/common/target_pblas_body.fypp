            ${target_complex}$, intent(inout) :: B(*)
        end subroutine

        subroutine ${C}$trsm(side, uplo, trans, diag, m, n, alpha, &
                             A, ia, ja, desca, B, ib, jb, descb)
$:IMPORT_C()
            character, intent(in) :: side, uplo, trans, diag
            integer,   intent(in) :: m, n, ia, ja, ib, jb
            integer,   intent(in) :: desca(9), descb(9)
            ${target_complex}$, intent(in)    :: alpha, A(*)
            ${target_complex}$, intent(inout) :: B(*)
        end subroutine

        ! Auxiliary additions: pdgeadd / pdtran / pdtradd (real),
        ! pzgeadd / pztranc / pztranu / pztradd (complex).
        subroutine ${R}$geadd(trans, m, n, alpha, A, ia, ja, desca, &
                              beta, C, ic, jc, descc)
$:IMPORT_R()
            character, intent(in)    :: trans
            integer,   intent(in)    :: m, n, ia, ja, ic, jc
            integer,   intent(in)    :: desca(9), descc(9)
            ${target_real}$, intent(in)    :: alpha, beta, A(*)
