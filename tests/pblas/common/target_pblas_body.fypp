        subroutine ${C}$tradd(uplo, trans, m, n, alpha, A, ia, ja, desca, &
                              beta, C, ic, jc, descc)
$:IMPORT_C()
            character, intent(in)    :: uplo, trans
            integer,   intent(in)    :: m, n, ia, ja, ic, jc
            integer,   intent(in)    :: desca(9), descc(9)
