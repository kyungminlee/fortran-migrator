    end subroutine

    ! ── Level 1 — complex ────────────────────────────────────────────
    subroutine target_pzdotc(n, dot, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
        integer,     intent(in)  :: n, ix, jx, incx, iy, jy, incy
        integer,     intent(in)  :: descx(9), descy(9)
        complex(ep), intent(in)  :: x(*), y(*)
        complex(ep), intent(out) :: dot
