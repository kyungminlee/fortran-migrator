        nx = descx(9) * descx(4); ny = descy(9) * descy(4)
        allocate(xt(nx), yt(ny))
        xt = q2t_c(x(1:nx))
        call ${C}$copy(n, xt, ix, jx, descx, incx, yt, iy, jy, descy, incy)
        y(1:ny) = t2q_c(yt)
    end subroutine

    subroutine target_pzswap(n, x, ix, jx, descx, incx, y, iy, jy, descy, incy)
        integer,     intent(in)    :: n, ix, jx, incx, iy, jy, incy
        integer,     intent(in)    :: descx(9), descy(9)
        complex(ep), intent(inout) :: x(*), y(*)
        integer :: nx, ny
