        subroutine ${R}$gecon(norm, n, A, ia, ja, desca, anorm, rcond, &
                              work, lwork, iwork, liwork, info)
$:IMPORT_R()
            character, intent(in)  :: norm
            integer,   intent(in)  :: n, ia, ja, lwork, liwork
            integer,   intent(in)  :: desca(9)
            ${target_real}$, intent(in)  :: A(*), anorm
            ${target_real}$, intent(out) :: rcond
            ${target_real}$, intent(out) :: work(*)
            integer,   intent(out) :: iwork(*), info
        end subroutine

        subroutine ${R}$geequ(m, n, A, ia, ja, desca, R, C, &
                              rowcnd, colcnd, amax, info)
$:IMPORT_R()
            integer,   intent(in)  :: m, n, ia, ja
            integer,   intent(in)  :: desca(9)
            ${target_real}$, intent(in)  :: A(*)
            ${target_real}$, intent(out) :: R(*), C(*), rowcnd, colcnd, amax
            integer,   intent(out) :: info
        end subroutine

        subroutine ${R}$pocon(uplo, n, A, ia, ja, desca, anorm, rcond, &
                              work, lwork, iwork, liwork, info)
$:IMPORT_R()
            character, intent(in)  :: uplo
            integer,   intent(in)  :: n, ia, ja, lwork, liwork
