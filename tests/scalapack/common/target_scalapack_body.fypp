    subroutine target_pzgetri(n, A, ia, ja, desca, ipiv, work, lwork, &
                              iwork, liwork, info)
        integer,     intent(in)    :: n, ia, ja, lwork, liwork
        integer,     intent(in)    :: desca(9), ipiv(*)
        integer,     intent(out)   :: info
        integer,     intent(out)   :: iwork(*)
        complex(ep), intent(inout) :: A(*)
        complex(ep), intent(out)   :: work(*)
        integer :: na, lwt
        ${target_complex}$, allocatable :: At(:), work_t(:)
        na = nloc(desca)
        if (lwork == -1) then
            allocate(At(max(1,na)), work_t(1))
            call ${C}$getri(n, At, ia, ja, desca, ipiv, work_t, -1, &
                             iwork, liwork, info)
            work(1) = t2q_c(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), work_t(lwt))
            At = q2t_c(A(1:na))
            call ${C}$getri(n, At, ia, ja, desca, ipiv, work_t, lwt, &
                             iwork, liwork, info)
            A(1:na) = t2q_c(At)
        end if
    end subroutine

    subroutine target_pzgebrd(m, n, A, ia, ja, desca, d, e, tauq, taup, &
                              work, lwork, info)
        integer,     intent(in)    :: m, n, ia, ja, lwork
        integer,     intent(in)    :: desca(9)
        integer,     intent(out)   :: info
        complex(ep), intent(inout) :: A(*)
        real(ep),    intent(out)   :: d(*), e(*)
        complex(ep), intent(out)   :: tauq(*), taup(*), work(*)
        integer :: na, nd, ne, ntauq, ntaup, lwt
        ${target_complex}$, allocatable :: At(:), tq(:), tp(:), work_t(:)
        ${target_real}$,    allocatable :: dt(:), et(:)
        na = nloc(desca)
        if (m >= n) then
            nd = max(1, loccols(desca))
            ne = max(1, locrows(desca))
        else
            nd = max(1, locrows(desca))
            ne = max(1, loccols(desca))
        end if
        ntauq = max(1, loccols(desca))
        ntaup = max(1, locrows(desca))
        if (lwork == -1) then
            allocate(At(max(1,na)), dt(nd), et(ne), tq(ntauq), tp(ntaup), work_t(1))
            call ${C}$gebrd(m, n, At, ia, ja, desca, dt, et, tq, tp, &
                             work_t, -1, info)
            work(1) = t2q_c(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), dt(nd), et(ne), tq(ntauq), tp(ntaup), work_t(lwt))
            At = q2t_c(A(1:na))
            call ${C}$gebrd(m, n, At, ia, ja, desca, dt, et, tq, tp, &
                             work_t, lwt, info)
            A(1:na) = t2q_c(At)
            d(1:nd) = t2q_r(dt); e(1:ne) = t2q_r(et)
            tauq(1:ntauq) = t2q_c(tq); taup(1:ntaup) = t2q_c(tp)
        end if
    end subroutine

    subroutine target_pzheev(jobz, uplo, n, A, ia, ja, desca, w, &
                             Z, iz, jz, descz, work, lwork, rwork, lrwork, info)
        character,   intent(in)    :: jobz, uplo
        integer,     intent(in)    :: n, ia, ja, iz, jz, lwork, lrwork
        integer,     intent(in)    :: desca(9), descz(9)
        integer,     intent(out)   :: info
        complex(ep), intent(inout) :: A(*)
        real(ep),    intent(out)   :: w(*), rwork(*)
        complex(ep), intent(out)   :: Z(*), work(*)
        integer :: na, nz, lwt, lrwt
        ${target_complex}$, allocatable :: At(:), Zt(:), work_t(:)
        ${target_real}$,    allocatable :: wt(:), rwork_t(:)
        na = nloc(desca); nz = nloc(descz)
        if (lwork == -1) then
            allocate(At(1), Zt(1), wt(1), work_t(1), rwork_t(1))
            call ${C}$heev(jobz, uplo, n, At, ia, ja, desca, wt, &
                            Zt, iz, jz, descz, work_t, -1, rwork_t, -1, info)
            work(1) = t2q_c(work_t(1))
            rwork(1) = t2q_r(rwork_t(1))
        else
            lwt = max(1, lwork); lrwt = max(1, lrwork)
            allocate(At(na), Zt(nz), wt(n), work_t(lwt), rwork_t(lrwt))
            At = q2t_c(A(1:na))
            call ${C}$heev(jobz, uplo, n, At, ia, ja, desca, wt, &
                            Zt, iz, jz, descz, work_t, lwt, rwork_t, lrwt, info)
            w(1:n) = t2q_r(wt)
            Z(1:nz) = t2q_c(Zt)
        end if
    end subroutine

    subroutine target_pzheevd(jobz, uplo, n, A, ia, ja, desca, w, &
                              Z, iz, jz, descz, work, lwork, rwork, lrwork, &
                              iwork, liwork, info)
        character,   intent(in)    :: jobz, uplo
        integer,     intent(in)    :: n, ia, ja, iz, jz, lwork, lrwork, liwork
        integer,     intent(in)    :: desca(9), descz(9)
        integer,     intent(out)   :: iwork(*), info
        complex(ep), intent(inout) :: A(*)
        real(ep),    intent(out)   :: w(*), rwork(*)
        complex(ep), intent(out)   :: Z(*), work(*)
        integer :: na, nz, lwt, lrwt
        ${target_complex}$, allocatable :: At(:), Zt(:), work_t(:)
        ${target_real}$,    allocatable :: wt(:), rwork_t(:)
        na = nloc(desca); nz = nloc(descz)
        if (lwork == -1) then
            allocate(At(1), Zt(1), wt(1), work_t(1), rwork_t(1))
            call ${C}$heevd(jobz, uplo, n, At, ia, ja, desca, wt, &
                             Zt, iz, jz, descz, work_t, -1, rwork_t, -1, &
                             iwork, -1, info)
            work(1)  = t2q_c(work_t(1))
            rwork(1) = t2q_r(rwork_t(1))
        else
            lwt  = max(1, lwork)
            lrwt = max(1, lrwork)
            allocate(At(na), Zt(nz), wt(n), work_t(lwt), rwork_t(lrwt))
            At = q2t_c(A(1:na))
            call ${C}$heevd(jobz, uplo, n, At, ia, ja, desca, wt, &
                             Zt, iz, jz, descz, work_t, lwt, rwork_t, lrwt, &
                             iwork, liwork, info)
            w(1:n) = t2q_r(wt)
            Z(1:nz) = t2q_c(Zt)
        end if
    end subroutine

