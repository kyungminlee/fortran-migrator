        if (lwork == -1) then
            allocate(At(max(1,na)), Ct(max(1,nc)), tau_t(ntau), work_t(1))
            call ${R}$ormql(side, trans, m, n, k, At, ia, ja, desca, tau_t, &
                             Ct, ic, jc, descc, work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), Ct(nc), tau_t(ntau), work_t(lwt))
            At = q2t_r(A(1:na)); Ct = q2t_r(C(1:nc))
            tau_t(1:ntau) = q2t_r(tau(1:ntau))
            call ${R}$ormql(side, trans, m, n, k, At, ia, ja, desca, tau_t, &
                             Ct, ic, jc, descc, work_t, lwt, info)
            C(1:nc) = t2q_r(Ct)
        end if
