        allocate(At(na))
        At = q2t_r(A(1:na))
        call ${R}$trtri(uplo, diag, n, At, ia, ja, desca, info)
        A(1:na) = t2q_r(At)
    end subroutine

    subroutine target_pdgetri(n, A, ia, ja, desca, ipiv, work, lwork, &
                              iwork, liwork, info)
        integer,  intent(in)    :: n, ia, ja, lwork, liwork
        integer,  intent(in)    :: desca(9), ipiv(*)
        integer,  intent(out)   :: info
        integer,  intent(out)   :: iwork(*)
        real(ep), intent(inout) :: A(*)
        real(ep), intent(out)   :: work(*)
        integer :: na, lwt
        ${target_real}$, allocatable :: At(:), work_t(:)
        na = nloc(desca)
        if (lwork == -1) then
            allocate(At(max(1,na)), work_t(1))
            call ${R}$getri(n, At, ia, ja, desca, ipiv, work_t, -1, &
                             iwork, liwork, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), work_t(lwt))
            At = q2t_r(A(1:na))
            call ${R}$getri(n, At, ia, ja, desca, ipiv, work_t, lwt, &
                             iwork, liwork, info)
            A(1:na) = t2q_r(At)
        end if
    end subroutine

    subroutine target_pdgebrd(m, n, A, ia, ja, desca, d, e, tauq, taup, &
                              work, lwork, info)
        integer,  intent(in)    :: m, n, ia, ja, lwork
        integer,  intent(in)    :: desca(9)
        integer,  intent(out)   :: info
        real(ep), intent(inout) :: A(*)
        real(ep), intent(out)   :: d(*), e(*), tauq(*), taup(*), work(*)
        integer :: na, nd, ne, ntauq, ntaup, lwt
        ${target_real}$, allocatable :: At(:), dt(:), et(:), tq(:), tp(:), work_t(:)
        na = nloc(desca)
        if (m >= n) then
            nd = max(1, loccols(desca))
            ne = max(1, locrows(desca))
            ntauq = max(1, loccols(desca))
            ntaup = max(1, locrows(desca))
        else
            nd = max(1, locrows(desca))
            ne = max(1, loccols(desca))
            ntauq = max(1, loccols(desca))
            ntaup = max(1, locrows(desca))
        end if
        if (lwork == -1) then
            allocate(At(max(1,na)), dt(nd), et(ne), tq(ntauq), tp(ntaup), work_t(1))
            call ${R}$gebrd(m, n, At, ia, ja, desca, dt, et, tq, tp, &
                             work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), dt(nd), et(ne), tq(ntauq), tp(ntaup), work_t(lwt))
            At = q2t_r(A(1:na))
            call ${R}$gebrd(m, n, At, ia, ja, desca, dt, et, tq, tp, &
                             work_t, lwt, info)
            A(1:na) = t2q_r(At)
            d(1:nd) = t2q_r(dt); e(1:ne) = t2q_r(et)
            tauq(1:ntauq) = t2q_r(tq); taup(1:ntaup) = t2q_r(tp)
        end if
    end subroutine

    subroutine target_pdsyev(jobz, uplo, n, A, ia, ja, desca, w, &
                             Z, iz, jz, descz, work, lwork, info)
        character, intent(in)    :: jobz, uplo
        integer,   intent(in)    :: n, ia, ja, iz, jz, lwork
        integer,   intent(in)    :: desca(9), descz(9)
        integer,   intent(out)   :: info
        real(ep),  intent(inout) :: A(*)
        real(ep),  intent(out)   :: w(*), Z(*), work(*)
        integer :: na, nz, lwt
        ${target_real}$, allocatable :: At(:), Zt(:), wt(:), work_t(:)
        na = nloc(desca); nz = nloc(descz)
        if (lwork == -1) then
            allocate(At(1), Zt(1), wt(1), work_t(1))
            call ${R}$syev(jobz, uplo, n, At, ia, ja, desca, wt, &
                            Zt, iz, jz, descz, work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), Zt(nz), wt(n), work_t(lwt))
            At = q2t_r(A(1:na))
            call ${R}$syev(jobz, uplo, n, At, ia, ja, desca, wt, &
                            Zt, iz, jz, descz, work_t, lwt, info)
            w(1:n) = t2q_r(wt)
            Z(1:nz) = t2q_r(Zt)
        end if
    end subroutine

    subroutine target_pdsyevd(jobz, uplo, n, A, ia, ja, desca, w, &
                              Z, iz, jz, descz, work, lwork, &
                              iwork, liwork, info)
        character, intent(in)    :: jobz, uplo
        integer,   intent(in)    :: n, ia, ja, iz, jz, lwork, liwork
        integer,   intent(in)    :: desca(9), descz(9)
        integer,   intent(out)   :: iwork(*), info
        real(ep),  intent(inout) :: A(*)
        real(ep),  intent(out)   :: w(*), Z(*), work(*)
        integer :: na, nz, lwt
        ${target_real}$, allocatable :: At(:), Zt(:), wt(:), work_t(:)
        na = nloc(desca); nz = nloc(descz)
        if (lwork == -1) then
            allocate(At(1), Zt(1), wt(1), work_t(1))
            call ${R}$syevd(jobz, uplo, n, At, ia, ja, desca, wt, &
                             Zt, iz, jz, descz, work_t, -1, &
                             iwork, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), Zt(nz), wt(n), work_t(lwt))
            At = q2t_r(A(1:na))
            call ${R}$syevd(jobz, uplo, n, At, ia, ja, desca, wt, &
                             Zt, iz, jz, descz, work_t, lwt, &
                             iwork, liwork, info)
            w(1:n) = t2q_r(wt)
            Z(1:nz) = t2q_r(Zt)
        end if
    end subroutine

    subroutine target_pdgesvd(jobu, jobvt, m, n, A, ia, ja, desca, s, &
                              U, iu, ju, descu, VT, ivt, jvt, descvt, &
                              work, lwork, info)
        character, intent(in)    :: jobu, jobvt
        integer,   intent(in)    :: m, n, ia, ja, iu, ju, ivt, jvt, lwork
        integer,   intent(in)    :: desca(9), descu(9), descvt(9)
        integer,   intent(out)   :: info
        real(ep),  intent(inout) :: A(*)
        real(ep),  intent(out)   :: s(*), U(*), VT(*), work(*)
        integer :: na, nu, nvt, ns, lwt
        ${target_real}$, allocatable :: At(:), Ut(:), VTt(:), st(:), work_t(:)
        na = nloc(desca); nu = nloc(descu); nvt = nloc(descvt)
        ns = min(m, n)
        if (lwork == -1) then
            allocate(At(1), Ut(1), VTt(1), st(1), work_t(1))
            call ${R}$gesvd(jobu, jobvt, m, n, At, ia, ja, desca, st, &
                             Ut, iu, ju, descu, VTt, ivt, jvt, descvt, &
                             work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), Ut(nu), VTt(nvt), st(ns), work_t(lwt))
            At = q2t_r(A(1:na))
            call ${R}$gesvd(jobu, jobvt, m, n, At, ia, ja, desca, st, &
                             Ut, iu, ju, descu, VTt, ivt, jvt, descvt, &
                             work_t, lwt, info)
            s(1:ns) = t2q_r(st)
            U(1:nu) = t2q_r(Ut)
            VT(1:nvt) = t2q_r(VTt)
        end if
    end subroutine

    subroutine target_pzgesvd(jobu, jobvt, m, n, A, ia, ja, desca, s, &
                              U, iu, ju, descu, VT, ivt, jvt, descvt, &
                              work, lwork, rwork, info)
        ! Complex SVD: S is real, U/VT/A are complex; RWORK is real
        ! workspace for singular-value/rotation arrays.
        character,   intent(in)    :: jobu, jobvt
        integer,     intent(in)    :: m, n, ia, ja, iu, ju, ivt, jvt, lwork
        integer,     intent(in)    :: desca(9), descu(9), descvt(9)
        integer,     intent(out)   :: info
        complex(ep), intent(inout) :: A(*)
        real(ep),    intent(out)   :: s(*), rwork(*)
        complex(ep), intent(out)   :: U(*), VT(*), work(*)
        integer :: na, nu, nvt, ns, lwt
        ${target_real}$,    allocatable :: st(:), rwork_t(:)
        ${target_complex}$, allocatable :: At(:), Ut(:), VTt(:), work_t(:)
        na = nloc(desca); nu = nloc(descu); nvt = nloc(descvt)
        ns = min(m, n)
        if (lwork == -1) then
            allocate(At(1), Ut(1), VTt(1), st(1), work_t(1), rwork_t(1))
            call ${C}$gesvd(jobu, jobvt, m, n, At, ia, ja, desca, st, &
                             Ut, iu, ju, descu, VTt, ivt, jvt, descvt, &
                             work_t, -1, rwork_t, info)
            work(1) = t2q_c(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), Ut(nu), VTt(nvt), st(ns), work_t(lwt), &
                     rwork_t(max(1, 1 + 4 * max(m, n))))
            At = q2t_c(A(1:na))
            call ${C}$gesvd(jobu, jobvt, m, n, At, ia, ja, desca, st, &
                             Ut, iu, ju, descu, VTt, ivt, jvt, descvt, &
                             work_t, lwt, rwork_t, info)
            s(1:ns) = t2q_r(st)
            U(1:nu) = t2q_c(Ut)
            VT(1:nvt) = t2q_c(VTt)
        end if
    end subroutine

    function target_pdlange(norm, m, n, A, ia, ja, desca, work) result(r)
        character, intent(in) :: norm
        integer,   intent(in) :: m, n, ia, ja
        integer,   intent(in) :: desca(9)
        real(ep),  intent(in) :: A(*)
        real(ep)              :: work(*)
        real(ep) :: r
        integer :: na, nw
        ${target_real}$, allocatable :: At(:), work_t(:)
        ${target_real}$ :: r_t
        na = nloc(desca)
        nw = max(m, n, 1)
        allocate(At(na), work_t(nw))
        At = q2t_r(A(1:na))
        r_t = ${R}$lange(norm, m, n, At, ia, ja, desca, work_t)
        r = t2q_r(r_t)
    end function

    function target_pdlansy(norm, uplo, n, A, ia, ja, desca, work) result(r)
        character, intent(in) :: norm, uplo
        integer,   intent(in) :: n, ia, ja
        integer,   intent(in) :: desca(9)
        real(ep),  intent(in) :: A(*)
        real(ep)              :: work(*)
        real(ep) :: r
        integer :: na, nw
        ${target_real}$, allocatable :: At(:), work_t(:)
        ${target_real}$ :: r_t
        na = nloc(desca); nw = max(8 * n, 1024)
        allocate(At(na), work_t(nw))
        At = q2t_r(A(1:na))
        r_t = ${R}$lansy(norm, uplo, n, At, ia, ja, desca, work_t)
        r = t2q_r(r_t)
    end function

