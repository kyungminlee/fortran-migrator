            Bt = q2t_r(B(1:ldb * nrhs))
            call ${R}$dbtrs(trans, n, bwl, bwu, nrhs, At, ja, desca, &
                             Bt, ib, descb, aft, laf, work_t, lwt, info)
            B(1:ldb * nrhs) = t2q_r(Bt)
        end if
    end subroutine

