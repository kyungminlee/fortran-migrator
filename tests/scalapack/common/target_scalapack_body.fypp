            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$gerqf(m, n, A, ia, ja, desca, tau, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: m, n, ia, ja, lwork
