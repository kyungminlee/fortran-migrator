    subroutine target_pdgetri(n, A, ia, ja, desca, ipiv, work, lwork, &
                              iwork, liwork, info)
        integer,  intent(in)    :: n, ia, ja, lwork, liwork
        integer,  intent(in)    :: desca(9), ipiv(*)
        integer,  intent(out)   :: info
        integer,  intent(out)   :: iwork(*)
        real(ep), intent(inout) :: A(*)
        real(ep), intent(out)   :: work(*)
        integer :: na, lwt
        ${target_real}$, allocatable :: At(:), work_t(:)
        na = nloc(desca)
        if (lwork == -1) then
            allocate(At(max(1,na)), work_t(1))
            call ${R}$getri(n, At, ia, ja, desca, ipiv, work_t, -1, &
                             iwork, liwork, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), work_t(lwt))
            At = q2t_r(A(1:na))
            call ${R}$getri(n, At, ia, ja, desca, ipiv, work_t, lwt, &
                             iwork, liwork, info)
