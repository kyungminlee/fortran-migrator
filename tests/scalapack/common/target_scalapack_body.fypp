#! Per-framework ScaLAPACK test wrapper, parameterized by target.
#!
#! Each per-target shim sets:
#!   target          'kind10' | 'kind16' | 'multifloats'
#!   target_name     human-readable label string
#!   target_eps      Fortran expression giving the target's epsilon as REAL(KIND=ep)
#!   target_real     Fortran type-spec for the target's real type
#!   target_complex  Fortran type-spec for the target's complex type
#!   prefix_real     migrated entry-point prefix for the D family (e.g. 'pq')
#!   prefix_complex  migrated entry-point prefix for the Z family (e.g. 'px')

#:set R = prefix_real
#:set C = prefix_complex

#:def IMPORT_R()
#:if target == 'multifloats'
            import :: real64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

#:def IMPORT_C()
#:if target == 'multifloats'
            import :: cmplx64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

#:def IMPORT_RC()
#:if target == 'multifloats'
            import :: real64x2, cmplx64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

module target_scalapack
    use prec_kinds,  only: ep
    use target_conv, only: q2t_r, t2q_r, q2t_c, t2q_c
    use pblas_grid,  only: numroc_local
#:if target == 'multifloats'
    use multifloats, only: real64x2, cmplx64x2
#:endif
    implicit none
    private

    public :: target_name, target_eps
    public :: target_pdgesv, target_pdgetrf, target_pdgetrs
    public :: target_pdpotrf, target_pdpotrs
    public :: target_pdgeqrf, target_pdgeqr2, target_pdorgqr, target_pdormqr
    public :: target_pdgelqf, target_pdorglq, target_pdormlq
    public :: target_pdgeqlf, target_pdorgql, target_pdormql
    public :: target_pdgerqf, target_pdorgrq, target_pdormrq
    public :: target_pdgehrd, target_pdormhr
    public :: target_pdgels
    public :: target_pdposv, target_pdpotri, target_pdgetri
    public :: target_pdgebrd
    public :: target_pdsyev, target_pdsyevd
    public :: target_pdgesvd
    public :: target_pdlange
    public :: target_pdlacpy, target_pdlaset
    public :: target_pzgesv, target_pzgeqrf, target_pzheev
    public :: target_pzgeqr2, target_pzungqr, target_pzunmqr
    public :: target_pzheevd
    public :: target_pzgelqf, target_pzunglq, target_pzunmlq
    public :: target_pzgeqlf, target_pzungql, target_pzunmql
    public :: target_pzgerqf, target_pzungrq, target_pzunmrq
    public :: target_pzgehrd, target_pzunmhr
    public :: target_pzgels
    public :: target_pzgebrd
    public :: target_pzposv, target_pzpotrf, target_pzpotri
    public :: target_pzgetrf, target_pzgetri

    character(len=*), parameter :: target_name = "${target_name}$"
    real(ep),         parameter :: target_eps  = ${target_eps}$

    interface
        subroutine blacs_gridinfo(icontxt, nprow, npcol, myrow, mycol)
            integer, intent(in)  :: icontxt
            integer, intent(out) :: nprow, npcol, myrow, mycol
        end subroutine
    end interface

    interface
        subroutine ${R}$gesv(n, nrhs, A, ia, ja, desca, ipiv, &
                             B, ib, jb, descb, info)
$:IMPORT_R()
            integer, intent(in)    :: n, nrhs, ia, ja, ib, jb
            integer, intent(in)    :: desca(9), descb(9)
            integer, intent(out)   :: ipiv(*), info
            ${target_real}$, intent(inout) :: A(*), B(*)
        end subroutine

        subroutine ${R}$getrf(m, n, A, ia, ja, desca, ipiv, info)
$:IMPORT_R()
            integer, intent(in)    :: m, n, ia, ja
            integer, intent(in)    :: desca(9)
            integer, intent(out)   :: ipiv(*), info
            ${target_real}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${R}$getrs(trans, n, nrhs, A, ia, ja, desca, ipiv, &
                              B, ib, jb, descb, info)
$:IMPORT_R()
            character, intent(in)    :: trans
            integer,   intent(in)    :: n, nrhs, ia, ja, ib, jb
            integer,   intent(in)    :: desca(9), descb(9), ipiv(*)
            integer,   intent(out)   :: info
            ${target_real}$, intent(in)    :: A(*)
            ${target_real}$, intent(inout) :: B(*)
        end subroutine

        subroutine ${R}$potrf(uplo, n, A, ia, ja, desca, info)
$:IMPORT_R()
            character, intent(in)    :: uplo
            integer,   intent(in)    :: n, ia, ja
            integer,   intent(in)    :: desca(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${R}$potrs(uplo, n, nrhs, A, ia, ja, desca, &
                              B, ib, jb, descb, info)
$:IMPORT_R()
            character, intent(in)    :: uplo
            integer,   intent(in)    :: n, nrhs, ia, ja, ib, jb
            integer,   intent(in)    :: desca(9), descb(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(in)    :: A(*)
            ${target_real}$, intent(inout) :: B(*)
        end subroutine

        subroutine ${R}$geqrf(m, n, A, ia, ja, desca, tau, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: m, n, ia, ja, lwork
            integer, intent(in)    :: desca(9)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(out)   :: tau(*), work(*)
        end subroutine

        subroutine ${R}$geqr2(m, n, A, ia, ja, desca, tau, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: m, n, ia, ja, lwork
            integer, intent(in)    :: desca(9)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(out)   :: tau(*), work(*)
        end subroutine

        subroutine ${R}$orgqr(m, n, k, A, ia, ja, desca, tau, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: m, n, k, ia, ja, lwork
            integer, intent(in)    :: desca(9)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(in)    :: tau(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$ormqr(side, trans, m, n, k, A, ia, ja, desca, tau, &
                              C, ic, jc, descc, work, lwork, info)
$:IMPORT_R()
            character, intent(in)    :: side, trans
            integer,   intent(in)    :: m, n, k, ia, ja, ic, jc, lwork
            integer,   intent(in)    :: desca(9), descc(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(in)    :: A(*), tau(*)
            ${target_real}$, intent(inout) :: C(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$gelqf(m, n, A, ia, ja, desca, tau, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: m, n, ia, ja, lwork
            integer, intent(in)    :: desca(9)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(out)   :: tau(*), work(*)
        end subroutine

        subroutine ${R}$orglq(m, n, k, A, ia, ja, desca, tau, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: m, n, k, ia, ja, lwork
            integer, intent(in)    :: desca(9)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(in)    :: tau(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$ormlq(side, trans, m, n, k, A, ia, ja, desca, tau, &
                              C, ic, jc, descc, work, lwork, info)
$:IMPORT_R()
            character, intent(in)    :: side, trans
            integer,   intent(in)    :: m, n, k, ia, ja, ic, jc, lwork
            integer,   intent(in)    :: desca(9), descc(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(in)    :: A(*), tau(*)
            ${target_real}$, intent(inout) :: C(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$geqlf(m, n, A, ia, ja, desca, tau, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: m, n, ia, ja, lwork
            integer, intent(in)    :: desca(9)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(out)   :: tau(*), work(*)
        end subroutine

        subroutine ${R}$orgql(m, n, k, A, ia, ja, desca, tau, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: m, n, k, ia, ja, lwork
            integer, intent(in)    :: desca(9)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(in)    :: tau(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$ormql(side, trans, m, n, k, A, ia, ja, desca, tau, &
                              C, ic, jc, descc, work, lwork, info)
$:IMPORT_R()
            character, intent(in)    :: side, trans
            integer,   intent(in)    :: m, n, k, ia, ja, ic, jc, lwork
