    end interface

contains

    function loccols(desc) result(lc)
        integer, intent(in) :: desc(9)
        integer :: lc, nprow, npcol, myrow, mycol
        call blacs_gridinfo(desc(2), nprow, npcol, myrow, mycol)
        lc = numroc_local(desc(4), desc(6), mycol, desc(8), npcol)
    end function

    function locrows(desc) result(lr)
        integer, intent(in) :: desc(9)
        integer :: lr, nprow, npcol, myrow, mycol
        call blacs_gridinfo(desc(2), nprow, npcol, myrow, mycol)
        lr = numroc_local(desc(3), desc(5), myrow, desc(7), nprow)
    end function

    function nloc(desc) result(n)
        integer, intent(in) :: desc(9)
        integer :: n
        n = desc(9) * max(1, loccols(desc))
    end function

    subroutine target_pdgesv(n, nrhs, A, ia, ja, desca, ipiv, &
                             B, ib, jb, descb, info)
        integer,  intent(in)    :: n, nrhs, ia, ja, ib, jb
        integer,  intent(in)    :: desca(9), descb(9)
        integer,  intent(out)   :: ipiv(*), info
        real(ep), intent(inout) :: A(*), B(*)
        integer :: na, nb
        ${target_real}$, allocatable :: At(:), Bt(:)
        na = nloc(desca); nb = nloc(descb)
        allocate(At(na), Bt(nb))
        At = q2t_r(A(1:na)); Bt = q2t_r(B(1:nb))
        call ${R}$gesv(n, nrhs, At, ia, ja, desca, ipiv, &
                        Bt, ib, jb, descb, info)
        A(1:na) = t2q_r(At); B(1:nb) = t2q_r(Bt)
    end subroutine

    subroutine target_pdgetrf(m, n, A, ia, ja, desca, ipiv, info)
        integer,  intent(in)    :: m, n, ia, ja
        integer,  intent(in)    :: desca(9)
        integer,  intent(out)   :: ipiv(*), info
        real(ep), intent(inout) :: A(*)
        integer :: na
        ${target_real}$, allocatable :: At(:)
        na = nloc(desca)
        allocate(At(na))
        At = q2t_r(A(1:na))
        call ${R}$getrf(m, n, At, ia, ja, desca, ipiv, info)
        A(1:na) = t2q_r(At)
    end subroutine

    subroutine target_pdgetrs(trans, n, nrhs, A, ia, ja, desca, ipiv, &
                              B, ib, jb, descb, info)
        character, intent(in)    :: trans
        integer,   intent(in)    :: n, nrhs, ia, ja, ib, jb
        integer,   intent(in)    :: desca(9), descb(9), ipiv(*)
        integer,   intent(out)   :: info
        real(ep),  intent(in)    :: A(*)
        real(ep),  intent(inout) :: B(*)
        integer :: na, nb
        ${target_real}$, allocatable :: At(:), Bt(:)
        na = nloc(desca); nb = nloc(descb)
        allocate(At(na), Bt(nb))
        At = q2t_r(A(1:na)); Bt = q2t_r(B(1:nb))
        call ${R}$getrs(trans, n, nrhs, At, ia, ja, desca, ipiv, &
                         Bt, ib, jb, descb, info)
        B(1:nb) = t2q_r(Bt)
    end subroutine

    subroutine target_pdpotrf(uplo, n, A, ia, ja, desca, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, ia, ja
        integer,   intent(in)    :: desca(9)
        integer,   intent(out)   :: info
        real(ep),  intent(inout) :: A(*)
        integer :: na
        ${target_real}$, allocatable :: At(:)
        na = nloc(desca)
        allocate(At(na))
        At = q2t_r(A(1:na))
        call ${R}$potrf(uplo, n, At, ia, ja, desca, info)
        A(1:na) = t2q_r(At)
    end subroutine

    subroutine target_pdpotrs(uplo, n, nrhs, A, ia, ja, desca, &
                              B, ib, jb, descb, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, nrhs, ia, ja, ib, jb
        integer,   intent(in)    :: desca(9), descb(9)
        integer,   intent(out)   :: info
        real(ep),  intent(in)    :: A(*)
        real(ep),  intent(inout) :: B(*)
        integer :: na, nb
        ${target_real}$, allocatable :: At(:), Bt(:)
        na = nloc(desca); nb = nloc(descb)
        allocate(At(na), Bt(nb))
        At = q2t_r(A(1:na)); Bt = q2t_r(B(1:nb))
        call ${R}$potrs(uplo, n, nrhs, At, ia, ja, desca, &
                         Bt, ib, jb, descb, info)
        B(1:nb) = t2q_r(Bt)
    end subroutine

    subroutine target_pdgeqrf(m, n, A, ia, ja, desca, tau, work, lwork, info)
        integer,  intent(in)    :: m, n, ia, ja, lwork
        integer,  intent(in)    :: desca(9)
        integer,  intent(out)   :: info
        real(ep), intent(inout) :: A(*)
        real(ep), intent(out)   :: tau(*), work(*)
        integer :: na, ntau, lwt
        ${target_real}$, allocatable :: At(:), tau_t(:), work_t(:)
        na = nloc(desca)
        ntau = max(1, loccols(desca))
        if (lwork == -1) then
            allocate(At(max(1,na)), tau_t(ntau), work_t(1))
            call ${R}$geqrf(m, n, At, ia, ja, desca, tau_t, work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), tau_t(ntau), work_t(lwt))
            At = q2t_r(A(1:na))
            call ${R}$geqrf(m, n, At, ia, ja, desca, tau_t, work_t, lwt, info)
            A(1:na) = t2q_r(At)
            tau(1:ntau) = t2q_r(tau_t)
        end if
    end subroutine

    subroutine target_pdptsv(n, nrhs, d, e, ja, desca, &
                             B, ib, descb, work, lwork, info)
        ! Positive-definite tridiagonal solver. D is the diagonal, E
        ! is the off-diagonal (sub-diagonal — both halves are equal
        ! in symmetric tridiagonal).
        integer,  intent(in)    :: n, nrhs, ja, ib, lwork
        integer,  intent(in)    :: desca(*), descb(*)
        integer,  intent(out)   :: info
        real(ep), intent(inout) :: d(*), e(*), B(*)
        real(ep), intent(out)   :: work(*)
        integer :: nv, nb, lwt, ldb
        ${target_real}$, allocatable :: dt(:), et(:), Bt(:), work_t(:)
        nb = desca(4)
        nv = nb
        ldb = descb(6)
        lwt = max(1, lwork)
        allocate(dt(nv), et(nv), Bt(ldb * nrhs), work_t(lwt))
        dt = q2t_r(d(1:nv)); et = q2t_r(e(1:nv))
        Bt = q2t_r(B(1:ldb * nrhs))
        call ${R}$ptsv(n, nrhs, dt, et, ja, desca, &
                        Bt, ib, descb, work_t, lwt, info)
        d(1:nv) = t2q_r(dt); e(1:nv) = t2q_r(et)
        B(1:ldb * nrhs) = t2q_r(Bt)
    end subroutine

    subroutine target_pddtsv(n, nrhs, dl, d, du, ja, desca, &
                             B, ib, descb, work, lwork, info)
        ! Tridiagonal-solve wrapper. dl/d/du are local slices of the
        ! three diagonals; sizes are NB per process (descriptor field
        ! 4). B is a 2D-cyclic-by-rows array of NRHS columns. WORK is
        ! pre-sized by the caller.
        integer,  intent(in)    :: n, nrhs, ja, ib, lwork
        integer,  intent(in)    :: desca(*), descb(*)
        integer,  intent(out)   :: info
        real(ep), intent(inout) :: dl(*), d(*), du(*), B(*)
        real(ep), intent(out)   :: work(*)
        integer :: nv, nb, lwt, ldb, locm_b
        ${target_real}$, allocatable :: dlt(:), dt(:), dut(:), Bt(:), work_t(:)
        nb = desca(4)
        nv = nb
        ldb = descb(6)
        locm_b = nb
        lwt = max(1, lwork)
        allocate(dlt(nv), dt(nv), dut(nv), Bt(ldb * nrhs), work_t(lwt))
        dlt = q2t_r(dl(1:nv)); dt = q2t_r(d(1:nv)); dut = q2t_r(du(1:nv))
        Bt = q2t_r(B(1:ldb * nrhs))
        call ${R}$dtsv(n, nrhs, dlt, dt, dut, ja, desca, &
                        Bt, ib, descb, work_t, lwt, info)
        dl(1:nv) = t2q_r(dlt); d(1:nv) = t2q_r(dt); du(1:nv) = t2q_r(dut)
        B(1:ldb * nrhs) = t2q_r(Bt)
    end subroutine

    subroutine target_pzdtsv(n, nrhs, dl, d, du, ja, desca, &
                             B, ib, descb, work, lwork, info)
        ! Complex tridiagonal-solve. See target_pddtsv for layout.
        integer,     intent(in)    :: n, nrhs, ja, ib, lwork
        integer,     intent(in)    :: desca(*), descb(*)
        integer,     intent(out)   :: info
        complex(ep), intent(inout) :: dl(*), d(*), du(*), B(*)
        complex(ep), intent(out)   :: work(*)
        integer :: nv, nb, lwt, ldb
        ${target_complex}$, allocatable :: dlt(:), dt(:), dut(:), Bt(:), work_t(:)
        nb = desca(4)
        nv = nb
        ldb = descb(6)
        lwt = max(1, lwork)
        allocate(dlt(nv), dt(nv), dut(nv), Bt(ldb * nrhs), work_t(lwt))
        dlt = q2t_c(dl(1:nv)); dt = q2t_c(d(1:nv)); dut = q2t_c(du(1:nv))
        Bt = q2t_c(B(1:ldb * nrhs))
        call ${C}$dtsv(n, nrhs, dlt, dt, dut, ja, desca, &
                        Bt, ib, descb, work_t, lwt, info)
        dl(1:nv) = t2q_c(dlt); d(1:nv) = t2q_c(dt); du(1:nv) = t2q_c(dut)
        B(1:ldb * nrhs) = t2q_c(Bt)
    end subroutine

    subroutine target_pddttrf(n, dl, d, du, ja, desca, &
                              af, laf, work, lwork, info)
        integer,  intent(in)    :: n, ja, laf, lwork
        integer,  intent(in)    :: desca(*)
        integer,  intent(out)   :: info
        real(ep), intent(inout) :: dl(*), d(*), du(*)
        real(ep), intent(out)   :: af(*), work(*)
        integer :: nv, nb, lwt
        ${target_real}$, allocatable :: dlt(:), dt(:), dut(:), aft(:), work_t(:)
        nb = desca(4); nv = nb
        if (lwork == -1) then
            allocate(dlt(nv), dt(nv), dut(nv), aft(max(1, laf)), work_t(1))
            call ${R}$dttrf(n, dlt, dt, dut, ja, desca, &
                             aft, laf, work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(dlt(nv), dt(nv), dut(nv), aft(max(1, laf)), work_t(lwt))
            dlt = q2t_r(dl(1:nv)); dt = q2t_r(d(1:nv)); dut = q2t_r(du(1:nv))
            call ${R}$dttrf(n, dlt, dt, dut, ja, desca, &
                             aft, laf, work_t, lwt, info)
            dl(1:nv) = t2q_r(dlt); d(1:nv) = t2q_r(dt); du(1:nv) = t2q_r(dut)
            af(1:laf) = t2q_r(aft)
        end if
    end subroutine

    subroutine target_pzdttrf(n, dl, d, du, ja, desca, &
                              af, laf, work, lwork, info)
        integer,     intent(in)    :: n, ja, laf, lwork
        integer,     intent(in)    :: desca(*)
        integer,     intent(out)   :: info
        complex(ep), intent(inout) :: dl(*), d(*), du(*)
        complex(ep), intent(out)   :: af(*), work(*)
        integer :: nv, nb, lwt
        ${target_complex}$, allocatable :: dlt(:), dt(:), dut(:), aft(:), work_t(:)
        nb = desca(4); nv = nb
        if (lwork == -1) then
            allocate(dlt(nv), dt(nv), dut(nv), aft(max(1, laf)), work_t(1))
            call ${C}$dttrf(n, dlt, dt, dut, ja, desca, &
                             aft, laf, work_t, -1, info)
            work(1) = t2q_c(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(dlt(nv), dt(nv), dut(nv), aft(max(1, laf)), work_t(lwt))
            dlt = q2t_c(dl(1:nv)); dt = q2t_c(d(1:nv)); dut = q2t_c(du(1:nv))
            call ${C}$dttrf(n, dlt, dt, dut, ja, desca, &
                             aft, laf, work_t, lwt, info)
            dl(1:nv) = t2q_c(dlt); d(1:nv) = t2q_c(dt); du(1:nv) = t2q_c(dut)
            af(1:laf) = t2q_c(aft)
        end if
    end subroutine

