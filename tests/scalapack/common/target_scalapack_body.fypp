        else
            lwt = max(1, lwork)
            allocate(At(na), tau_t(ntau), work_t(lwt))
            At = q2t_c(A(1:na))
            call ${C}$gehrd(n, ilo, ihi, At, ia, ja, desca, tau_t, &
                             work_t, lwt, info)
            A(1:na) = t2q_c(At)
            tau(1:ntau) = t2q_c(tau_t)
        end if
    end subroutine

