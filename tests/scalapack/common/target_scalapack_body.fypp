    function target_pzlantr(norm, uplo, diag, m, n, A, ia, ja, desca, work) result(r)
        character,   intent(in) :: norm, uplo, diag
        integer,     intent(in) :: m, n, ia, ja
        integer,     intent(in) :: desca(9)
        complex(ep), intent(in) :: A(*)
        real(ep)                :: work(*)
        real(ep) :: r
        integer :: na, nw
        ${target_complex}$, allocatable :: At(:)
        ${target_real}$,    allocatable :: work_t(:)
        ${target_real}$ :: r_t
        na = nloc(desca); nw = max(8 * max(m, n), 1024)
        allocate(At(na), work_t(nw))
        At = q2t_c(A(1:na))
        r_t = ${C}$lantr(norm, uplo, diag, m, n, At, ia, ja, desca, work_t)
        r = t2q_r(r_t)
    end function

