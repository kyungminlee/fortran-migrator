#! Per-framework ScaLAPACK test wrapper, parameterized by target.
#!
#! Each per-target shim sets:
#!   target          'kind10' | 'kind16' | 'multifloats'
#!   target_name     human-readable label string
#!   target_eps      Fortran expression giving the target's epsilon as REAL(KIND=ep)
#!   target_real     Fortran type-spec for the target's real type
#!   target_complex  Fortran type-spec for the target's complex type
#!   prefix_real     migrated entry-point prefix for the D family (e.g. 'pq')
#!   prefix_complex  migrated entry-point prefix for the Z family (e.g. 'px')

#:set R = prefix_real
#:set C = prefix_complex

#:def IMPORT_R()
#:if target == 'multifloats'
            import :: real64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

#:def IMPORT_C()
#:if target == 'multifloats'
            import :: cmplx64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

#:def IMPORT_RC()
#:if target == 'multifloats'
            import :: real64x2, cmplx64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

module target_scalapack
    use prec_kinds,  only: ep
    use target_conv, only: q2t_r, t2q_r, q2t_c, t2q_c
    use pblas_grid,  only: numroc_local
#:if target == 'multifloats'
    use multifloats, only: real64x2, cmplx64x2
#:endif
    implicit none
    private

    public :: target_name, target_eps
    public :: target_pdgesv, target_pdgetrf, target_pdgetrs
    public :: target_pdpotrf, target_pdpotrs
    public :: target_pddtsv, target_pdptsv, target_pzdtsv, target_pzptsv
    public :: target_pddttrf, target_pddttrs, target_pzdttrf, target_pzdttrs
    public :: target_pdpttrf, target_pdpttrs, target_pzpttrf, target_pzpttrs
    public :: target_pddbsv, target_pzdbsv
    public :: target_pddbtrf, target_pddbtrs, target_pzdbtrf, target_pzdbtrs
    public :: target_pdgbsv, target_pzgbsv
    public :: target_pdgbtrf, target_pdgbtrs, target_pzgbtrf, target_pzgbtrs
    public :: target_pdpbsv, target_pzpbsv
    public :: target_pdpbtrf, target_pdpbtrs, target_pzpbtrf, target_pzpbtrs
    public :: target_pdgecon, target_pdgeequ, target_pdpocon
    public :: target_pdstein
    public :: target_pdgeqrf, target_pdgeqr2, target_pdorgqr, target_pdormqr
    public :: target_pdgelqf, target_pdorglq, target_pdormlq
    public :: target_pdgeqlf, target_pdorgql, target_pdormql
    public :: target_pdgerqf, target_pdorgrq, target_pdormrq
    public :: target_pdgeql2, target_pdgelq2, target_pdgerq2
    public :: target_pdgehrd, target_pdormhr, target_pdgehd2
    public :: target_pdsytrd, target_pdsygst, target_pdormtr
    public :: target_pdgels
    public :: target_pdposv, target_pdpotri, target_pdgetri, target_pdtrtri
    public :: target_pdgebrd
    public :: target_pdsyev, target_pdsyevd
    public :: target_pdgesvd, target_pzgesvd
    public :: target_pdlange, target_pdlansy, target_pdlanhs, target_pdlantr
    public :: target_pzlange, target_pzlanhe, target_pzlanhs, target_pzlantr
    public :: target_pdlacpy, target_pdlaset
    public :: target_pzgesv, target_pzgeqrf, target_pzheev
    public :: target_pzgeqr2, target_pzungqr, target_pzunmqr
    public :: target_pzheevd
    public :: target_pzgelqf, target_pzunglq, target_pzunmlq
    public :: target_pzgeqlf, target_pzungql, target_pzunmql
    public :: target_pzgerqf, target_pzungrq, target_pzunmrq
    public :: target_pzgeql2, target_pzgelq2, target_pzgerq2
    public :: target_pzgehrd, target_pzunmhr, target_pzgehd2
    public :: target_pzhetrd
    public :: target_pzgels
    public :: target_pzgebrd
    public :: target_pzposv, target_pzpotrf, target_pzpotri
    public :: target_pzgetrf, target_pzgetri, target_pztrtri

    character(len=*), parameter :: target_name = "${target_name}$"
    real(ep),         parameter :: target_eps  = ${target_eps}$

    interface
        subroutine blacs_gridinfo(icontxt, nprow, npcol, myrow, mycol)
            integer, intent(in)  :: icontxt
            integer, intent(out) :: nprow, npcol, myrow, mycol
        end subroutine
    end interface

    interface
        subroutine ${R}$gesv(n, nrhs, A, ia, ja, desca, ipiv, &
                             B, ib, jb, descb, info)
$:IMPORT_R()
            integer, intent(in)    :: n, nrhs, ia, ja, ib, jb
            integer, intent(in)    :: desca(9), descb(9)
            integer, intent(out)   :: ipiv(*), info
            ${target_real}$, intent(inout) :: A(*), B(*)
        end subroutine

        subroutine ${R}$getrf(m, n, A, ia, ja, desca, ipiv, info)
$:IMPORT_R()
            integer, intent(in)    :: m, n, ia, ja
            integer, intent(in)    :: desca(9)
            integer, intent(out)   :: ipiv(*), info
            ${target_real}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${R}$getrs(trans, n, nrhs, A, ia, ja, desca, ipiv, &
                              B, ib, jb, descb, info)
$:IMPORT_R()
            character, intent(in)    :: trans
            integer,   intent(in)    :: n, nrhs, ia, ja, ib, jb
            integer,   intent(in)    :: desca(9), descb(9), ipiv(*)
            integer,   intent(out)   :: info
            ${target_real}$, intent(in)    :: A(*)
            ${target_real}$, intent(inout) :: B(*)
        end subroutine

        subroutine ${R}$potrf(uplo, n, A, ia, ja, desca, info)
$:IMPORT_R()
            character, intent(in)    :: uplo
            integer,   intent(in)    :: n, ia, ja
            integer,   intent(in)    :: desca(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${R}$potrs(uplo, n, nrhs, A, ia, ja, desca, &
                              B, ib, jb, descb, info)
$:IMPORT_R()
            character, intent(in)    :: uplo
            integer,   intent(in)    :: n, nrhs, ia, ja, ib, jb
            integer,   intent(in)    :: desca(9), descb(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(in)    :: A(*)
            ${target_real}$, intent(inout) :: B(*)
        end subroutine

        ! 1D-distributed tridiagonal solver. DESCA / DESCB use the
        ! 1D descriptor format (DTYPE=501); the BLACS context inside
        ! must be a 1xNPROCS or NPROCSx1 grid. DL/D/DU are aligned
        ! diagonal vectors, length DESCA(NB_=4) per process.
        subroutine ${R}$dtsv(n, nrhs, dl, d, du, ja, desca, &
                             B, ib, descb, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: n, nrhs, ja, ib, lwork
            integer, intent(in)    :: desca(*), descb(*)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: dl(*), d(*), du(*), B(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${C}$dtsv(n, nrhs, dl, d, du, ja, desca, &
                             B, ib, descb, work, lwork, info)
$:IMPORT_C()
            integer, intent(in)    :: n, nrhs, ja, ib, lwork
            integer, intent(in)    :: desca(*), descb(*)
            integer, intent(out)   :: info
            ${target_complex}$, intent(inout) :: dl(*), d(*), du(*), B(*)
            ${target_complex}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$dttrf(n, dl, d, du, ja, desca, &
                              af, laf, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: n, ja, laf, lwork
            integer, intent(in)    :: desca(*)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: dl(*), d(*), du(*)
            ${target_real}$, intent(out)   :: af(*), work(*)
        end subroutine

        subroutine ${C}$dttrf(n, dl, d, du, ja, desca, &
                              af, laf, work, lwork, info)
$:IMPORT_C()
            integer, intent(in)    :: n, ja, laf, lwork
            integer, intent(in)    :: desca(*)
            integer, intent(out)   :: info
            ${target_complex}$, intent(inout) :: dl(*), d(*), du(*)
            ${target_complex}$, intent(out)   :: af(*), work(*)
        end subroutine

        subroutine ${R}$dttrs(trans, n, nrhs, dl, d, du, ja, desca, &
                              B, ib, descb, af, laf, work, lwork, info)
$:IMPORT_R()
            character, intent(in)  :: trans
            integer, intent(in)    :: n, nrhs, ja, ib, laf, lwork
            integer, intent(in)    :: desca(*), descb(*)
            integer, intent(out)   :: info
            ${target_real}$, intent(in)    :: dl(*), d(*), du(*), af(*)
            ${target_real}$, intent(inout) :: B(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${C}$dttrs(trans, n, nrhs, dl, d, du, ja, desca, &
                              B, ib, descb, af, laf, work, lwork, info)
$:IMPORT_C()
            character, intent(in)  :: trans
            integer, intent(in)    :: n, nrhs, ja, ib, laf, lwork
            integer, intent(in)    :: desca(*), descb(*)
            integer, intent(out)   :: info
            ${target_complex}$, intent(in)    :: dl(*), d(*), du(*), af(*)
            ${target_complex}$, intent(inout) :: B(*)
            ${target_complex}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$ptsv(n, nrhs, d, e, ja, desca, &
                             B, ib, descb, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: n, nrhs, ja, ib, lwork
            integer, intent(in)    :: desca(*), descb(*)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: d(*), e(*), B(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${C}$ptsv(uplo, n, nrhs, d, e, ja, desca, &
                             B, ib, descb, work, lwork, info)
$:IMPORT_RC()
            character, intent(in) :: uplo
            integer, intent(in)    :: n, nrhs, ja, ib, lwork
            integer, intent(in)    :: desca(*), descb(*)
            integer, intent(out)   :: info
            ${target_real}$,    intent(inout) :: d(*)
            ${target_complex}$, intent(inout) :: e(*), B(*)
            ${target_complex}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$pttrf(n, d, e, ja, desca, &
                              af, laf, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: n, ja, laf, lwork
            integer, intent(in)    :: desca(*)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: d(*), e(*)
            ${target_real}$, intent(out)   :: af(*), work(*)
        end subroutine

        subroutine ${C}$pttrf(n, d, e, ja, desca, &
                              af, laf, work, lwork, info)
$:IMPORT_RC()
            integer, intent(in)    :: n, ja, laf, lwork
            integer, intent(in)    :: desca(*)
            integer, intent(out)   :: info
            ${target_real}$,    intent(inout) :: d(*)
            ${target_complex}$, intent(inout) :: e(*)
            ${target_complex}$, intent(out)   :: af(*), work(*)
        end subroutine

        subroutine ${R}$pttrs(n, nrhs, d, e, ja, desca, &
                              B, ib, descb, af, laf, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: n, nrhs, ja, ib, laf, lwork
            integer, intent(in)    :: desca(*), descb(*)
            integer, intent(out)   :: info
            ${target_real}$, intent(in)    :: d(*), e(*), af(*)
            ${target_real}$, intent(inout) :: B(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${C}$pttrs(uplo, n, nrhs, d, e, ja, desca, &
                              B, ib, descb, af, laf, work, lwork, info)
$:IMPORT_RC()
            character, intent(in) :: uplo
            integer, intent(in)    :: n, nrhs, ja, ib, laf, lwork
            integer, intent(in)    :: desca(*), descb(*)
            integer, intent(out)   :: info
            ${target_real}$,    intent(in)    :: d(*)
            ${target_complex}$, intent(in)    :: e(*), af(*)
            ${target_complex}$, intent(inout) :: B(*)
            ${target_complex}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$dbsv(n, bwl, bwu, nrhs, A, ja, desca, &
                             B, ib, descb, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: n, bwl, bwu, nrhs, ja, ib, lwork
            integer, intent(in)    :: desca(*), descb(*)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*), B(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${C}$dbsv(n, bwl, bwu, nrhs, A, ja, desca, &
                             B, ib, descb, work, lwork, info)
$:IMPORT_C()
            integer, intent(in)    :: n, bwl, bwu, nrhs, ja, ib, lwork
            integer, intent(in)    :: desca(*), descb(*)
            integer, intent(out)   :: info
            ${target_complex}$, intent(inout) :: A(*), B(*)
            ${target_complex}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$dbtrf(n, bwl, bwu, A, ja, desca, &
                              af, laf, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: n, bwl, bwu, ja, laf, lwork
            integer, intent(in)    :: desca(*)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(out)   :: af(*), work(*)
        end subroutine

        subroutine ${C}$dbtrf(n, bwl, bwu, A, ja, desca, &
                              af, laf, work, lwork, info)
$:IMPORT_C()
            integer, intent(in)    :: n, bwl, bwu, ja, laf, lwork
            integer, intent(in)    :: desca(*)
            integer, intent(out)   :: info
            ${target_complex}$, intent(inout) :: A(*)
            ${target_complex}$, intent(out)   :: af(*), work(*)
        end subroutine

        subroutine ${R}$dbtrs(trans, n, bwl, bwu, nrhs, A, ja, desca, &
                              B, ib, descb, af, laf, work, lwork, info)
$:IMPORT_R()
            character, intent(in)  :: trans
            integer, intent(in)    :: n, bwl, bwu, nrhs, ja, ib, laf, lwork
            integer, intent(in)    :: desca(*), descb(*)
            integer, intent(out)   :: info
            ${target_real}$, intent(in)    :: A(*), af(*)
            ${target_real}$, intent(inout) :: B(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${C}$dbtrs(trans, n, bwl, bwu, nrhs, A, ja, desca, &
                              B, ib, descb, af, laf, work, lwork, info)
$:IMPORT_C()
            character, intent(in)  :: trans
            integer, intent(in)    :: n, bwl, bwu, nrhs, ja, ib, laf, lwork
            integer, intent(in)    :: desca(*), descb(*)
            integer, intent(out)   :: info
            ${target_complex}$, intent(in)    :: A(*), af(*)
            ${target_complex}$, intent(inout) :: B(*)
