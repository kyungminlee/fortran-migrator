    subroutine target_pddbtrs(trans, n, bwl, bwu, nrhs, A, ja, desca, &
                              B, ib, descb, af, laf, work, lwork, info)
        character, intent(in)    :: trans
        integer,   intent(in)    :: n, bwl, bwu, nrhs, ja, ib, laf, lwork
        integer,   intent(in)    :: desca(*), descb(*)
        integer,   intent(out)   :: info
        real(ep),  intent(in)    :: A(*), af(*)
        real(ep),  intent(inout) :: B(*)
