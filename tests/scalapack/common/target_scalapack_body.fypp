$:IMPORT_R()
            character, intent(in)    :: side, trans
            integer,   intent(in)    :: m, n, k, ia, ja, ic, jc, lwork
            integer,   intent(in)    :: desca(9), descc(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(in)    :: A(*), tau(*)
            ${target_real}$, intent(inout) :: C(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$gehrd(n, ilo, ihi, A, ia, ja, desca, tau, &
                              work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: n, ilo, ihi, ia, ja, lwork
            integer, intent(in)    :: desca(9)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(out)   :: tau(*), work(*)
        end subroutine

        subroutine ${R}$ormhr(side, trans, m, n, ilo, ihi, A, ia, ja, desca, &
                              tau, C, ic, jc, descc, work, lwork, info)
$:IMPORT_R()
            character, intent(in)    :: side, trans
            integer,   intent(in)    :: m, n, ilo, ihi, ia, ja, ic, jc, lwork
            integer,   intent(in)    :: desca(9), descc(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(in)    :: A(*), tau(*)
            ${target_real}$, intent(inout) :: C(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$gels(trans, m, n, nrhs, A, ia, ja, desca, &
                             B, ib, jb, descb, work, lwork, info)
$:IMPORT_R()
            character, intent(in)    :: trans
            integer,   intent(in)    :: m, n, nrhs, ia, ja, ib, jb, lwork
            integer,   intent(in)    :: desca(9), descb(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*), B(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$posv(uplo, n, nrhs, A, ia, ja, desca, &
                             B, ib, jb, descb, info)
$:IMPORT_R()
            character, intent(in)    :: uplo
            integer,   intent(in)    :: n, nrhs, ia, ja, ib, jb
            integer,   intent(in)    :: desca(9), descb(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*), B(*)
        end subroutine

        subroutine ${R}$potri(uplo, n, A, ia, ja, desca, info)
$:IMPORT_R()
            character, intent(in)    :: uplo
            integer,   intent(in)    :: n, ia, ja
            integer,   intent(in)    :: desca(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${R}$getri(n, A, ia, ja, desca, ipiv, work, lwork, &
                              iwork, liwork, info)
$:IMPORT_R()
            integer, intent(in)    :: n, ia, ja, lwork, liwork
            integer, intent(in)    :: desca(9), ipiv(*)
            integer, intent(out)   :: info
            integer, intent(out)   :: iwork(*)
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(out)   :: work(*)
        end subroutine

        subroutine ${R}$gebrd(m, n, A, ia, ja, desca, d, e, tauq, taup, &
                              work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: m, n, ia, ja, lwork
            integer, intent(in)    :: desca(9)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(out)   :: d(*), e(*), tauq(*), taup(*), work(*)
        end subroutine

        subroutine ${R}$syev(jobz, uplo, n, A, ia, ja, desca, w, &
                             Z, iz, jz, descz, work, lwork, info)
$:IMPORT_R()
            character, intent(in)    :: jobz, uplo
            integer,   intent(in)    :: n, ia, ja, iz, jz, lwork
            integer,   intent(in)    :: desca(9), descz(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(out)   :: w(*), Z(*), work(*)
        end subroutine

        subroutine ${R}$syevd(jobz, uplo, n, A, ia, ja, desca, w, &
                              Z, iz, jz, descz, work, lwork, &
                              iwork, liwork, info)
$:IMPORT_R()
            character, intent(in)    :: jobz, uplo
            integer,   intent(in)    :: n, ia, ja, iz, jz, lwork, liwork
            integer,   intent(in)    :: desca(9), descz(9)
            integer,   intent(out)   :: iwork(*), info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(out)   :: w(*), Z(*), work(*)
        end subroutine

        subroutine ${R}$gesvd(jobu, jobvt, m, n, A, ia, ja, desca, s, &
                              U, iu, ju, descu, VT, ivt, jvt, descvt, &
                              work, lwork, info)
$:IMPORT_R()
            character, intent(in)    :: jobu, jobvt
            integer,   intent(in)    :: m, n, ia, ja, iu, ju, ivt, jvt, lwork
            integer,   intent(in)    :: desca(9), descu(9), descvt(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(out)   :: s(*), U(*), VT(*), work(*)
        end subroutine

        function ${R}$lange(norm, m, n, A, ia, ja, desca, work) result(r)
$:IMPORT_R()
            character, intent(in) :: norm
            integer,   intent(in) :: m, n, ia, ja
            integer,   intent(in) :: desca(9)
            ${target_real}$, intent(in) :: A(*)
            ${target_real}$             :: work(*)
            ${target_real}$ :: r
        end function

        subroutine ${R}$lacpy(uplo, m, n, A, ia, ja, desca, B, ib, jb, descb)
$:IMPORT_R()
            character, intent(in)  :: uplo
            integer,   intent(in)  :: m, n, ia, ja, ib, jb
            integer,   intent(in)  :: desca(9), descb(9)
            ${target_real}$, intent(in)  :: A(*)
            ${target_real}$, intent(out) :: B(*)
        end subroutine

        subroutine ${R}$laset(uplo, m, n, alpha, beta, A, ia, ja, desca)
$:IMPORT_R()
            character, intent(in)    :: uplo
            integer,   intent(in)    :: m, n, ia, ja
            integer,   intent(in)    :: desca(9)
            ${target_real}$, intent(in)    :: alpha, beta
            ${target_real}$, intent(inout) :: A(*)
        end subroutine

