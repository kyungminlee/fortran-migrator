        At = q2t_c(A(1:na)); Bt = q2t_c(B(1:ldb * nrhs))
        call ${C}$gbsv(n, bwl, bwu, nrhs, At, ja, desca, ipiv, &
                        Bt, ib, descb, work_t, lwt, info)
        A(1:na) = t2q_c(At); B(1:ldb * nrhs) = t2q_c(Bt)
