    subroutine target_pzptsv(uplo, n, nrhs, d, e, ja, desca, &
                             B, ib, descb, work, lwork, info)
        ! Complex Hermitian PD tridiagonal solve. D real, E complex.
        character,   intent(in)    :: uplo
        integer,     intent(in)    :: n, nrhs, ja, ib, lwork
        integer,     intent(in)    :: desca(*), descb(*)
        integer,     intent(out)   :: info
        real(ep),    intent(inout) :: d(*)
        complex(ep), intent(inout) :: e(*), B(*)
        complex(ep), intent(out)   :: work(*)
        integer :: nv, nb, lwt, ldb
        ${target_real}$,    allocatable :: dt(:)
        ${target_complex}$, allocatable :: et(:), Bt(:), work_t(:)
        nb = desca(4); nv = nb; ldb = descb(6)
        lwt = max(1, lwork)
        allocate(dt(nv), et(nv), Bt(ldb * nrhs), work_t(lwt))
        dt = q2t_r(d(1:nv)); et = q2t_c(e(1:nv))
        Bt = q2t_c(B(1:ldb * nrhs))
        call ${C}$ptsv(uplo, n, nrhs, dt, et, ja, desca, &
                        Bt, ib, descb, work_t, lwt, info)
        d(1:nv) = t2q_r(dt); e(1:nv) = t2q_c(et)
        B(1:ldb * nrhs) = t2q_c(Bt)
    end subroutine

    subroutine target_pdpttrf(n, d, e, ja, desca, &
                              af, laf, work, lwork, info)
        integer,  intent(in)    :: n, ja, laf, lwork
