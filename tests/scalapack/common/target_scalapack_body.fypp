            call ${C}$gels(trans, m, n, nrhs, At, ia, ja, desca, &
                            Bt, ib, jb, descb, work_t, lwt, info)
            A(1:na) = t2q_c(At); B(1:nb) = t2q_c(Bt)
        end if
