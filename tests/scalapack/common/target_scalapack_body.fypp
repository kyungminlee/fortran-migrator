    subroutine target_pdgecon(norm, n, A, ia, ja, desca, anorm, rcond, &
                              work, lwork, iwork, liwork, info)
        character, intent(in)    :: norm
        integer,   intent(in)    :: n, ia, ja, lwork, liwork
        integer,   intent(in)    :: desca(9)
        real(ep),  intent(in)    :: A(*), anorm
        real(ep),  intent(out)   :: rcond
        real(ep),  intent(out)   :: work(*)
        integer,   intent(out)   :: iwork(*), info
        integer :: na, lwt
        ${target_real}$, allocatable :: At(:), work_t(:)
        ${target_real}$ :: anorm_t, rcond_t
        na = nloc(desca)
        if (lwork == -1) then
            allocate(At(max(1,na)), work_t(1))
            anorm_t = q2t_r(anorm)
            call ${R}$gecon(norm, n, At, ia, ja, desca, anorm_t, rcond_t, &
                             work_t, -1, iwork, liwork, info)
            work(1) = t2q_r(work_t(1))
            rcond = t2q_r(rcond_t)
        else
            lwt = max(1, lwork)
            allocate(At(na), work_t(lwt))
            At = q2t_r(A(1:na))
            anorm_t = q2t_r(anorm)
            call ${R}$gecon(norm, n, At, ia, ja, desca, anorm_t, rcond_t, &
                             work_t, lwt, iwork, liwork, info)
            rcond = t2q_r(rcond_t)
        end if
    end subroutine

    subroutine target_pdgeequ(m, n, A, ia, ja, desca, R, C, &
                              rowcnd, colcnd, amax, info)
        integer,   intent(in)    :: m, n, ia, ja
        integer,   intent(in)    :: desca(9)
        real(ep),  intent(in)    :: A(*)
        real(ep),  intent(out)   :: R(*), C(*), rowcnd, colcnd, amax
        integer,   intent(out)   :: info
        integer :: na, nr, nc
        ${target_real}$, allocatable :: At(:), Rt(:), Ct(:)
        ${target_real}$ :: rowcnd_t, colcnd_t, amax_t
        na = nloc(desca)
        nr = max(1, locrows(desca))
        nc = max(1, loccols(desca))
        allocate(At(na), Rt(nr), Ct(nc))
        At = q2t_r(A(1:na))
        call ${R}$geequ(m, n, At, ia, ja, desca, Rt, Ct, &
                         rowcnd_t, colcnd_t, amax_t, info)
        R(1:nr) = t2q_r(Rt); C(1:nc) = t2q_r(Ct)
        rowcnd = t2q_r(rowcnd_t); colcnd = t2q_r(colcnd_t)
        amax = t2q_r(amax_t)
    end subroutine

    subroutine target_pdpocon(uplo, n, A, ia, ja, desca, anorm, rcond, &
                              work, lwork, iwork, liwork, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, ia, ja, lwork, liwork
        integer,   intent(in)    :: desca(9)
        real(ep),  intent(in)    :: A(*), anorm
        real(ep),  intent(out)   :: rcond
        real(ep),  intent(out)   :: work(*)
        integer,   intent(out)   :: iwork(*), info
        integer :: na, lwt
        ${target_real}$, allocatable :: At(:), work_t(:)
        ${target_real}$ :: anorm_t, rcond_t
        na = nloc(desca)
        if (lwork == -1) then
            allocate(At(max(1,na)), work_t(1))
            anorm_t = q2t_r(anorm)
            call ${R}$pocon(uplo, n, At, ia, ja, desca, anorm_t, rcond_t, &
                             work_t, -1, iwork, liwork, info)
            work(1) = t2q_r(work_t(1))
            rcond = t2q_r(rcond_t)
        else
            lwt = max(1, lwork)
            allocate(At(na), work_t(lwt))
            At = q2t_r(A(1:na))
            anorm_t = q2t_r(anorm)
            call ${R}$pocon(uplo, n, At, ia, ja, desca, anorm_t, rcond_t, &
                             work_t, lwt, iwork, liwork, info)
            rcond = t2q_r(rcond_t)
        end if
    end subroutine

    subroutine target_pdstein(n, d, e, m, w, iblock, isplit, orfac, &
                               Z, iz, jz, descZ, work, lwork, iwork, liwork, &
                               ifail, iclustr, gap, info)
        ! ICLUSTR length 2*P; GAP length P (P = NPROW*NPCOL); IFAIL length N.
        integer,   intent(in)    :: n, m, iz, jz, lwork, liwork
        integer,   intent(in)    :: descZ(9), iblock(*), isplit(*)
        real(ep),  intent(in)    :: d(*), e(*), w(*), orfac
        real(ep),  intent(out)   :: Z(*), work(*), gap(*)
        integer,   intent(out)   :: iwork(*), ifail(*), iclustr(*)
        integer,   intent(out)   :: info
        integer :: nz, lwt, np
        ${target_real}$, allocatable :: dt(:), et(:), wt(:), Zt(:), work_t(:), gap_t(:)
        ${target_real}$ :: orfac_t
        nz = nloc(descZ)
        block
            integer :: nprow, npcol, myrow, mycol
            call blacs_gridinfo(descZ(2), nprow, npcol, myrow, mycol)
            np = max(1, nprow * npcol)
        end block
        if (lwork == -1) then
            allocate(dt(max(1,n)), et(max(1,n)), wt(max(1,m)), &
                     Zt(max(1,nz)), work_t(1), gap_t(np))
            orfac_t = q2t_r(orfac)
            call ${R}$stein(n, dt, et, m, wt, iblock, isplit, orfac_t, &
                             Zt, iz, jz, descZ, work_t, -1, iwork, liwork, &
                             ifail, iclustr, gap_t, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(dt(n), et(n), wt(m), Zt(max(1,nz)), work_t(lwt), &
                     gap_t(np))
            dt = q2t_r(d(1:n)); et = q2t_r(e(1:n))
            wt = q2t_r(w(1:m))
            orfac_t = q2t_r(orfac)
            call ${R}$stein(n, dt, et, m, wt, iblock, isplit, orfac_t, &
                             Zt, iz, jz, descZ, work_t, lwt, iwork, liwork, &
                             ifail, iclustr, gap_t, info)
            Z(1:nz) = t2q_r(Zt)
            gap(1:np) = t2q_r(gap_t)
        end if
    end subroutine

    subroutine target_pdgeqr2(m, n, A, ia, ja, desca, tau, work, lwork, info)
        integer,  intent(in)    :: m, n, ia, ja, lwork
        integer,  intent(in)    :: desca(9)
        integer,  intent(out)   :: info
        real(ep), intent(inout) :: A(*)
        real(ep), intent(out)   :: tau(*), work(*)
        integer :: na, ntau, lwt
        ${target_real}$, allocatable :: At(:), tau_t(:), work_t(:)
        na = nloc(desca)
        ntau = max(1, loccols(desca))
        if (lwork == -1) then
            allocate(At(max(1,na)), tau_t(ntau), work_t(1))
            call ${R}$geqr2(m, n, At, ia, ja, desca, tau_t, work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), tau_t(ntau), work_t(lwt))
            At = q2t_r(A(1:na))
            call ${R}$geqr2(m, n, At, ia, ja, desca, tau_t, work_t, lwt, info)
            A(1:na) = t2q_r(At)
            tau(1:ntau) = t2q_r(tau_t)
        end if
    end subroutine

    subroutine target_pdorgqr(m, n, k, A, ia, ja, desca, tau, work, lwork, info)
        integer,  intent(in)    :: m, n, k, ia, ja, lwork
        integer,  intent(in)    :: desca(9)
        integer,  intent(out)   :: info
        real(ep), intent(inout) :: A(*)
        real(ep), intent(in)    :: tau(*)
        real(ep), intent(out)   :: work(*)
        integer :: na, ntau, lwt
        ${target_real}$, allocatable :: At(:), tau_t(:), work_t(:)
