                             B, ib, descb, work, lwork, info)
        integer,     intent(in)    :: n, bwl, bwu, nrhs, ja, ib, lwork
        integer,     intent(in)    :: desca(*), descb(*)
        integer,     intent(out)   :: ipiv(*)
