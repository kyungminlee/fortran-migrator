#! Per-framework ScaLAPACK test wrapper, parameterized by target.
#!
#! Each per-target shim sets:
#!   target          'kind10' | 'kind16' | 'multifloats'
#!   target_name     human-readable label string
#!   target_eps      Fortran expression giving the target's epsilon as REAL(KIND=ep)
#!   target_real     Fortran type-spec for the target's real type
#!   target_complex  Fortran type-spec for the target's complex type
#!   prefix_real     migrated entry-point prefix for the D family (e.g. 'pq')
#!   prefix_complex  migrated entry-point prefix for the Z family (e.g. 'px')

#:set R = prefix_real
#:set C = prefix_complex

#:def IMPORT_R()
#:if target == 'multifloats'
            import :: real64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

#:def IMPORT_C()
#:if target == 'multifloats'
            import :: cmplx64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

#:def IMPORT_RC()
#:if target == 'multifloats'
            import :: real64x2, cmplx64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

module target_scalapack
    use prec_kinds,  only: ep
    use target_conv, only: q2t_r, t2q_r, q2t_c, t2q_c
    use pblas_grid,  only: numroc_local
#:if target == 'multifloats'
    use multifloats, only: real64x2, cmplx64x2
#:endif
    implicit none
    private

    public :: target_name, target_eps
    public :: target_pdgesv, target_pdgetrf, target_pdgetrs
    public :: target_pdpotrf, target_pdpotrs
    public :: target_pdgeqrf
    public :: target_pdsyev
    public :: target_pdgesvd
    public :: target_pdlange
    public :: target_pdlacpy, target_pdlaset
    public :: target_pzgesv, target_pzgeqrf, target_pzheev

    character(len=*), parameter :: target_name = "${target_name}$"
    real(ep),         parameter :: target_eps  = ${target_eps}$

    interface
        subroutine blacs_gridinfo(icontxt, nprow, npcol, myrow, mycol)
            integer, intent(in)  :: icontxt
            integer, intent(out) :: nprow, npcol, myrow, mycol
        end subroutine
    end interface

    interface
        subroutine ${R}$gesv(n, nrhs, A, ia, ja, desca, ipiv, &
                             B, ib, jb, descb, info)
$:IMPORT_R()
            integer, intent(in)    :: n, nrhs, ia, ja, ib, jb
            integer, intent(in)    :: desca(9), descb(9)
            integer, intent(out)   :: ipiv(*), info
            ${target_real}$, intent(inout) :: A(*), B(*)
        end subroutine

        subroutine ${R}$getrf(m, n, A, ia, ja, desca, ipiv, info)
$:IMPORT_R()
            integer, intent(in)    :: m, n, ia, ja
            integer, intent(in)    :: desca(9)
            integer, intent(out)   :: ipiv(*), info
            ${target_real}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${R}$getrs(trans, n, nrhs, A, ia, ja, desca, ipiv, &
                              B, ib, jb, descb, info)
$:IMPORT_R()
            character, intent(in)    :: trans
            integer,   intent(in)    :: n, nrhs, ia, ja, ib, jb
            integer,   intent(in)    :: desca(9), descb(9), ipiv(*)
            integer,   intent(out)   :: info
            ${target_real}$, intent(in)    :: A(*)
            ${target_real}$, intent(inout) :: B(*)
        end subroutine

        subroutine ${R}$potrf(uplo, n, A, ia, ja, desca, info)
$:IMPORT_R()
            character, intent(in)    :: uplo
            integer,   intent(in)    :: n, ia, ja
            integer,   intent(in)    :: desca(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${R}$potrs(uplo, n, nrhs, A, ia, ja, desca, &
                              B, ib, jb, descb, info)
$:IMPORT_R()
            character, intent(in)    :: uplo
            integer,   intent(in)    :: n, nrhs, ia, ja, ib, jb
            integer,   intent(in)    :: desca(9), descb(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(in)    :: A(*)
            ${target_real}$, intent(inout) :: B(*)
        end subroutine

        subroutine ${R}$geqrf(m, n, A, ia, ja, desca, tau, work, lwork, info)
$:IMPORT_R()
            integer, intent(in)    :: m, n, ia, ja, lwork
            integer, intent(in)    :: desca(9)
            integer, intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(out)   :: tau(*), work(*)
        end subroutine

        subroutine ${R}$syev(jobz, uplo, n, A, ia, ja, desca, w, &
                             Z, iz, jz, descz, work, lwork, info)
$:IMPORT_R()
            character, intent(in)    :: jobz, uplo
            integer,   intent(in)    :: n, ia, ja, iz, jz, lwork
            integer,   intent(in)    :: desca(9), descz(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(out)   :: w(*), Z(*), work(*)
        end subroutine

        subroutine ${R}$gesvd(jobu, jobvt, m, n, A, ia, ja, desca, s, &
                              U, iu, ju, descu, VT, ivt, jvt, descvt, &
                              work, lwork, info)
$:IMPORT_R()
            character, intent(in)    :: jobu, jobvt
            integer,   intent(in)    :: m, n, ia, ja, iu, ju, ivt, jvt, lwork
            integer,   intent(in)    :: desca(9), descu(9), descvt(9)
            integer,   intent(out)   :: info
            ${target_real}$, intent(inout) :: A(*)
            ${target_real}$, intent(out)   :: s(*), U(*), VT(*), work(*)
        end subroutine

        function ${R}$lange(norm, m, n, A, ia, ja, desca, work) result(r)
$:IMPORT_R()
            character, intent(in) :: norm
            integer,   intent(in) :: m, n, ia, ja
            integer,   intent(in) :: desca(9)
            ${target_real}$, intent(in) :: A(*)
            ${target_real}$             :: work(*)
            ${target_real}$ :: r
        end function

        subroutine ${R}$lacpy(uplo, m, n, A, ia, ja, desca, B, ib, jb, descb)
$:IMPORT_R()
            character, intent(in)  :: uplo
            integer,   intent(in)  :: m, n, ia, ja, ib, jb
            integer,   intent(in)  :: desca(9), descb(9)
            ${target_real}$, intent(in)  :: A(*)
            ${target_real}$, intent(out) :: B(*)
        end subroutine

        subroutine ${R}$laset(uplo, m, n, alpha, beta, A, ia, ja, desca)
$:IMPORT_R()
            character, intent(in)    :: uplo
            integer,   intent(in)    :: m, n, ia, ja
            integer,   intent(in)    :: desca(9)
            ${target_real}$, intent(in)    :: alpha, beta
            ${target_real}$, intent(inout) :: A(*)
        end subroutine

        subroutine ${C}$gesv(n, nrhs, A, ia, ja, desca, ipiv, &
                             B, ib, jb, descb, info)
$:IMPORT_C()
            integer, intent(in)    :: n, nrhs, ia, ja, ib, jb
            integer, intent(in)    :: desca(9), descb(9)
            integer, intent(out)   :: ipiv(*), info
            ${target_complex}$, intent(inout) :: A(*), B(*)
        end subroutine

        subroutine ${C}$geqrf(m, n, A, ia, ja, desca, tau, work, lwork, info)
$:IMPORT_C()
            integer, intent(in)    :: m, n, ia, ja, lwork
            integer, intent(in)    :: desca(9)
            integer, intent(out)   :: info
            ${target_complex}$, intent(inout) :: A(*)
            ${target_complex}$, intent(out)   :: tau(*), work(*)
        end subroutine

        subroutine ${C}$heev(jobz, uplo, n, A, ia, ja, desca, w, &
                             Z, iz, jz, descz, work, lwork, rwork, lrwork, info)
$:IMPORT_RC()
            character, intent(in)    :: jobz, uplo
            integer,   intent(in)    :: n, ia, ja, iz, jz, lwork, lrwork
            integer,   intent(in)    :: desca(9), descz(9)
            integer,   intent(out)   :: info
            ${target_complex}$, intent(inout) :: A(*)
            ${target_real}$,    intent(out)   :: w(*), rwork(*)
            ${target_complex}$, intent(out)   :: Z(*), work(*)
        end subroutine
    end interface

contains

    function loccols(desc) result(lc)
        integer, intent(in) :: desc(9)
        integer :: lc, nprow, npcol, myrow, mycol
        call blacs_gridinfo(desc(2), nprow, npcol, myrow, mycol)
        lc = numroc_local(desc(4), desc(6), mycol, desc(8), npcol)
    end function

    function nloc(desc) result(n)
        integer, intent(in) :: desc(9)
        integer :: n
        n = desc(9) * max(1, loccols(desc))
    end function

    subroutine target_pdgesv(n, nrhs, A, ia, ja, desca, ipiv, &
                             B, ib, jb, descb, info)
        integer,  intent(in)    :: n, nrhs, ia, ja, ib, jb
        integer,  intent(in)    :: desca(9), descb(9)
        integer,  intent(out)   :: ipiv(*), info
        real(ep), intent(inout) :: A(*), B(*)
        integer :: na, nb
        ${target_real}$, allocatable :: At(:), Bt(:)
        na = nloc(desca); nb = nloc(descb)
        allocate(At(na), Bt(nb))
        At = q2t_r(A(1:na)); Bt = q2t_r(B(1:nb))
        call ${R}$gesv(n, nrhs, At, ia, ja, desca, ipiv, &
                        Bt, ib, jb, descb, info)
        A(1:na) = t2q_r(At); B(1:nb) = t2q_r(Bt)
    end subroutine

    subroutine target_pdgetrf(m, n, A, ia, ja, desca, ipiv, info)
        integer,  intent(in)    :: m, n, ia, ja
        integer,  intent(in)    :: desca(9)
        integer,  intent(out)   :: ipiv(*), info
        real(ep), intent(inout) :: A(*)
        integer :: na
        ${target_real}$, allocatable :: At(:)
        na = nloc(desca)
        allocate(At(na))
        At = q2t_r(A(1:na))
        call ${R}$getrf(m, n, At, ia, ja, desca, ipiv, info)
        A(1:na) = t2q_r(At)
    end subroutine

    subroutine target_pdgetrs(trans, n, nrhs, A, ia, ja, desca, ipiv, &
                              B, ib, jb, descb, info)
        character, intent(in)    :: trans
        integer,   intent(in)    :: n, nrhs, ia, ja, ib, jb
        integer,   intent(in)    :: desca(9), descb(9), ipiv(*)
        integer,   intent(out)   :: info
        real(ep),  intent(in)    :: A(*)
        real(ep),  intent(inout) :: B(*)
        integer :: na, nb
        ${target_real}$, allocatable :: At(:), Bt(:)
        na = nloc(desca); nb = nloc(descb)
        allocate(At(na), Bt(nb))
        At = q2t_r(A(1:na)); Bt = q2t_r(B(1:nb))
        call ${R}$getrs(trans, n, nrhs, At, ia, ja, desca, ipiv, &
                         Bt, ib, jb, descb, info)
        B(1:nb) = t2q_r(Bt)
    end subroutine

    subroutine target_pdpotrf(uplo, n, A, ia, ja, desca, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, ia, ja
        integer,   intent(in)    :: desca(9)
        integer,   intent(out)   :: info
        real(ep),  intent(inout) :: A(*)
        integer :: na
        ${target_real}$, allocatable :: At(:)
        na = nloc(desca)
        allocate(At(na))
        At = q2t_r(A(1:na))
        call ${R}$potrf(uplo, n, At, ia, ja, desca, info)
        A(1:na) = t2q_r(At)
    end subroutine

    subroutine target_pdpotrs(uplo, n, nrhs, A, ia, ja, desca, &
                              B, ib, jb, descb, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, nrhs, ia, ja, ib, jb
        integer,   intent(in)    :: desca(9), descb(9)
        integer,   intent(out)   :: info
        real(ep),  intent(in)    :: A(*)
        real(ep),  intent(inout) :: B(*)
        integer :: na, nb
        ${target_real}$, allocatable :: At(:), Bt(:)
        na = nloc(desca); nb = nloc(descb)
        allocate(At(na), Bt(nb))
        At = q2t_r(A(1:na)); Bt = q2t_r(B(1:nb))
        call ${R}$potrs(uplo, n, nrhs, At, ia, ja, desca, &
                         Bt, ib, jb, descb, info)
        B(1:nb) = t2q_r(Bt)
    end subroutine

    subroutine target_pdgeqrf(m, n, A, ia, ja, desca, tau, work, lwork, info)
        integer,  intent(in)    :: m, n, ia, ja, lwork
        integer,  intent(in)    :: desca(9)
        integer,  intent(out)   :: info
        real(ep), intent(inout) :: A(*)
        real(ep), intent(out)   :: tau(*), work(*)
        integer :: na, ntau, lwt
        ${target_real}$, allocatable :: At(:), tau_t(:), work_t(:)
        na = nloc(desca)
        ntau = max(1, loccols(desca))
        if (lwork == -1) then
            allocate(At(max(1,na)), tau_t(ntau), work_t(1))
            call ${R}$geqrf(m, n, At, ia, ja, desca, tau_t, work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), tau_t(ntau), work_t(lwt))
            At = q2t_r(A(1:na))
            call ${R}$geqrf(m, n, At, ia, ja, desca, tau_t, work_t, lwt, info)
            A(1:na) = t2q_r(At)
            tau(1:ntau) = t2q_r(tau_t)
        end if
    end subroutine

    subroutine target_pdsyev(jobz, uplo, n, A, ia, ja, desca, w, &
                             Z, iz, jz, descz, work, lwork, info)
        character, intent(in)    :: jobz, uplo
        integer,   intent(in)    :: n, ia, ja, iz, jz, lwork
        integer,   intent(in)    :: desca(9), descz(9)
        integer,   intent(out)   :: info
        real(ep),  intent(inout) :: A(*)
        real(ep),  intent(out)   :: w(*), Z(*), work(*)
        integer :: na, nz, lwt
        ${target_real}$, allocatable :: At(:), Zt(:), wt(:), work_t(:)
        na = nloc(desca); nz = nloc(descz)
        if (lwork == -1) then
            allocate(At(1), Zt(1), wt(1), work_t(1))
            call ${R}$syev(jobz, uplo, n, At, ia, ja, desca, wt, &
                            Zt, iz, jz, descz, work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), Zt(nz), wt(n), work_t(lwt))
            At = q2t_r(A(1:na))
            call ${R}$syev(jobz, uplo, n, At, ia, ja, desca, wt, &
                            Zt, iz, jz, descz, work_t, lwt, info)
            w(1:n) = t2q_r(wt)
            Z(1:nz) = t2q_r(Zt)
        end if
    end subroutine

    subroutine target_pdgesvd(jobu, jobvt, m, n, A, ia, ja, desca, s, &
                              U, iu, ju, descu, VT, ivt, jvt, descvt, &
                              work, lwork, info)
        character, intent(in)    :: jobu, jobvt
        integer,   intent(in)    :: m, n, ia, ja, iu, ju, ivt, jvt, lwork
        integer,   intent(in)    :: desca(9), descu(9), descvt(9)
        integer,   intent(out)   :: info
        real(ep),  intent(inout) :: A(*)
        real(ep),  intent(out)   :: s(*), U(*), VT(*), work(*)
        integer :: na, nu, nvt, ns, lwt
        ${target_real}$, allocatable :: At(:), Ut(:), VTt(:), st(:), work_t(:)
        na = nloc(desca); nu = nloc(descu); nvt = nloc(descvt)
        ns = min(m, n)
        if (lwork == -1) then
            allocate(At(1), Ut(1), VTt(1), st(1), work_t(1))
            call ${R}$gesvd(jobu, jobvt, m, n, At, ia, ja, desca, st, &
                             Ut, iu, ju, descu, VTt, ivt, jvt, descvt, &
                             work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), Ut(nu), VTt(nvt), st(ns), work_t(lwt))
            At = q2t_r(A(1:na))
            call ${R}$gesvd(jobu, jobvt, m, n, At, ia, ja, desca, st, &
                             Ut, iu, ju, descu, VTt, ivt, jvt, descvt, &
                             work_t, lwt, info)
            s(1:ns) = t2q_r(st)
            U(1:nu) = t2q_r(Ut)
            VT(1:nvt) = t2q_r(VTt)
        end if
    end subroutine

    function target_pdlange(norm, m, n, A, ia, ja, desca, work) result(r)
        character, intent(in) :: norm
        integer,   intent(in) :: m, n, ia, ja
        integer,   intent(in) :: desca(9)
        real(ep),  intent(in) :: A(*)
        real(ep)              :: work(*)
        real(ep) :: r
        integer :: na, nw
        ${target_real}$, allocatable :: At(:), work_t(:)
        ${target_real}$ :: r_t
        na = nloc(desca)
        nw = max(m, n, 1)
        allocate(At(na), work_t(nw))
        At = q2t_r(A(1:na))
        r_t = ${R}$lange(norm, m, n, At, ia, ja, desca, work_t)
        r = t2q_r(r_t)
    end function

    subroutine target_pdlacpy(uplo, m, n, A, ia, ja, desca, B, ib, jb, descb)
        character, intent(in)  :: uplo
        integer,   intent(in)  :: m, n, ia, ja, ib, jb
        integer,   intent(in)  :: desca(9), descb(9)
        real(ep),  intent(in)  :: A(*)
        real(ep),  intent(out) :: B(*)
        integer :: na, nb
        ${target_real}$, allocatable :: At(:), Bt(:)
        na = nloc(desca); nb = nloc(descb)
        allocate(At(na), Bt(nb))
        At = q2t_r(A(1:na))
        call ${R}$lacpy(uplo, m, n, At, ia, ja, desca, Bt, ib, jb, descb)
        B(1:nb) = t2q_r(Bt)
    end subroutine

    subroutine target_pdlaset(uplo, m, n, alpha, beta, A, ia, ja, desca)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: m, n, ia, ja
        integer,   intent(in)    :: desca(9)
        real(ep),  intent(in)    :: alpha, beta
        real(ep),  intent(inout) :: A(*)
        integer :: na
        ${target_real}$, allocatable :: At(:)
        na = nloc(desca)
        allocate(At(na))
        At = q2t_r(A(1:na))
        call ${R}$laset(uplo, m, n, q2t_r(alpha), q2t_r(beta), &
                         At, ia, ja, desca)
        A(1:na) = t2q_r(At)
    end subroutine

    subroutine target_pzgesv(n, nrhs, A, ia, ja, desca, ipiv, &
                             B, ib, jb, descb, info)
        integer,     intent(in)    :: n, nrhs, ia, ja, ib, jb
        integer,     intent(in)    :: desca(9), descb(9)
        integer,     intent(out)   :: ipiv(*), info
        complex(ep), intent(inout) :: A(*), B(*)
        integer :: na, nb
        ${target_complex}$, allocatable :: At(:), Bt(:)
        na = nloc(desca); nb = nloc(descb)
        allocate(At(na), Bt(nb))
        At = q2t_c(A(1:na)); Bt = q2t_c(B(1:nb))
        call ${C}$gesv(n, nrhs, At, ia, ja, desca, ipiv, &
                        Bt, ib, jb, descb, info)
        A(1:na) = t2q_c(At); B(1:nb) = t2q_c(Bt)
    end subroutine

    subroutine target_pzgeqrf(m, n, A, ia, ja, desca, tau, work, lwork, info)
        integer,     intent(in)    :: m, n, ia, ja, lwork
        integer,     intent(in)    :: desca(9)
        integer,     intent(out)   :: info
        complex(ep), intent(inout) :: A(*)
        complex(ep), intent(out)   :: tau(*), work(*)
        integer :: na, ntau, lwt
        ${target_complex}$, allocatable :: At(:), tau_t(:), work_t(:)
        na = nloc(desca); ntau = max(1, loccols(desca))
        if (lwork == -1) then
            allocate(At(max(1,na)), tau_t(ntau), work_t(1))
            call ${C}$geqrf(m, n, At, ia, ja, desca, tau_t, work_t, -1, info)
            work(1) = t2q_c(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), tau_t(ntau), work_t(lwt))
            At = q2t_c(A(1:na))
            call ${C}$geqrf(m, n, At, ia, ja, desca, tau_t, work_t, lwt, info)
            A(1:na) = t2q_c(At)
            tau(1:ntau) = t2q_c(tau_t)
        end if
    end subroutine

    subroutine target_pzheev(jobz, uplo, n, A, ia, ja, desca, w, &
                             Z, iz, jz, descz, work, lwork, rwork, lrwork, info)
        character,   intent(in)    :: jobz, uplo
        integer,     intent(in)    :: n, ia, ja, iz, jz, lwork, lrwork
        integer,     intent(in)    :: desca(9), descz(9)
        integer,     intent(out)   :: info
        complex(ep), intent(inout) :: A(*)
        real(ep),    intent(out)   :: w(*), rwork(*)
        complex(ep), intent(out)   :: Z(*), work(*)
        integer :: na, nz, lwt, lrwt
        ${target_complex}$, allocatable :: At(:), Zt(:), work_t(:)
        ${target_real}$,    allocatable :: wt(:), rwork_t(:)
        na = nloc(desca); nz = nloc(descz)
        if (lwork == -1) then
            allocate(At(1), Zt(1), wt(1), work_t(1), rwork_t(1))
            call ${C}$heev(jobz, uplo, n, At, ia, ja, desca, wt, &
                            Zt, iz, jz, descz, work_t, -1, rwork_t, -1, info)
            work(1) = t2q_c(work_t(1))
            rwork(1) = t2q_r(rwork_t(1))
        else
            lwt = max(1, lwork); lrwt = max(1, lrwork)
            allocate(At(na), Zt(nz), wt(n), work_t(lwt), rwork_t(lrwt))
            At = q2t_c(A(1:na))
            call ${C}$heev(jobz, uplo, n, At, ia, ja, desca, wt, &
                            Zt, iz, jz, descz, work_t, lwt, rwork_t, lrwt, info)
            w(1:n) = t2q_r(wt)
            Z(1:nz) = t2q_c(Zt)
        end if
    end subroutine

end module target_scalapack
