    subroutine target_pdgbsv(n, bwl, bwu, nrhs, A, ja, desca, ipiv, &
                             B, ib, descb, work, lwork, info)
        ! General banded LU solve (with pivoting). Local A is sized
        ! LLD_A * NB where LLD_A >= 2*bwl+2*bwu+1.
        integer,  intent(in)    :: n, bwl, bwu, nrhs, ja, ib, lwork
        integer,  intent(in)    :: desca(*), descb(*)
        integer,  intent(out)   :: ipiv(*)
        integer,  intent(out)   :: info
        real(ep), intent(inout) :: A(*), B(*)
        real(ep), intent(out)   :: work(*)
        integer :: nb, lda, na, ldb, lwt
        ${target_real}$, allocatable :: At(:), Bt(:), work_t(:)
        nb = desca(4); lda = desca(6); na = lda * nb; ldb = descb(6)
        lwt = max(1, lwork)
        allocate(At(na), Bt(ldb * nrhs), work_t(lwt))
        At = q2t_r(A(1:na)); Bt = q2t_r(B(1:ldb * nrhs))
        call ${R}$gbsv(n, bwl, bwu, nrhs, At, ja, desca, ipiv, &
                        Bt, ib, descb, work_t, lwt, info)
        A(1:na) = t2q_r(At); B(1:ldb * nrhs) = t2q_r(Bt)
    end subroutine

