        if (lwork == -1) then
            allocate(At(max(1,na)), tau_t(ntau), work_t(1))
            call ${R}$gerq2(m, n, At, ia, ja, desca, tau_t, work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), tau_t(ntau), work_t(lwt))
            At = q2t_r(A(1:na))
            call ${R}$gerq2(m, n, At, ia, ja, desca, tau_t, work_t, lwt, info)
            A(1:na) = t2q_r(At)
            tau(1:ntau) = t2q_r(tau_t)
        end if
    end subroutine

    subroutine target_pdgehd2(n, ilo, ihi, A, ia, ja, desca, tau, &
                              work, lwork, info)
        integer,  intent(in)    :: n, ilo, ihi, ia, ja, lwork
        integer,  intent(in)    :: desca(9)
        integer,  intent(out)   :: info
        real(ep), intent(inout) :: A(*)
        real(ep), intent(out)   :: tau(*), work(*)
        integer :: na, ntau, lwt
        ${target_real}$, allocatable :: At(:), tau_t(:), work_t(:)
        na = nloc(desca); ntau = max(1, loccols(desca))
        if (lwork == -1) then
            allocate(At(max(1,na)), tau_t(ntau), work_t(1))
            call ${R}$gehd2(n, ilo, ihi, At, ia, ja, desca, tau_t, &
                             work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), tau_t(ntau), work_t(lwt))
            At = q2t_r(A(1:na))
            call ${R}$gehd2(n, ilo, ihi, At, ia, ja, desca, tau_t, &
                             work_t, lwt, info)
            A(1:na) = t2q_r(At)
            tau(1:ntau) = t2q_r(tau_t)
        end if
    end subroutine

    subroutine target_pdormhr(side, trans, m, n, ilo, ihi, A, ia, ja, desca, &
                              tau, C, ic, jc, descc, work, lwork, info)
        character, intent(in)    :: side, trans
        integer,   intent(in)    :: m, n, ilo, ihi, ia, ja, ic, jc, lwork
        integer,   intent(in)    :: desca(9), descc(9)
        integer,   intent(out)   :: info
        real(ep),  intent(in)    :: A(*), tau(*)
        real(ep),  intent(inout) :: C(*)
        real(ep),  intent(out)   :: work(*)
        integer :: na, nc, ntau, lwt
        ${target_real}$, allocatable :: At(:), Ct(:), tau_t(:), work_t(:)
        na = nloc(desca); nc = nloc(descc); ntau = max(1, loccols(desca))
        if (lwork == -1) then
            allocate(At(max(1,na)), Ct(max(1,nc)), tau_t(ntau), work_t(1))
            call ${R}$ormhr(side, trans, m, n, ilo, ihi, At, ia, ja, desca, &
                             tau_t, Ct, ic, jc, descc, work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), Ct(nc), tau_t(ntau), work_t(lwt))
            At = q2t_r(A(1:na)); Ct = q2t_r(C(1:nc))
            tau_t(1:ntau) = q2t_r(tau(1:ntau))
            call ${R}$ormhr(side, trans, m, n, ilo, ihi, At, ia, ja, desca, &
                             tau_t, Ct, ic, jc, descc, work_t, lwt, info)
            C(1:nc) = t2q_r(Ct)
        end if
    end subroutine

    subroutine target_pdgels(trans, m, n, nrhs, A, ia, ja, desca, &
                             B, ib, jb, descb, work, lwork, info)
        character, intent(in)    :: trans
        integer,   intent(in)    :: m, n, nrhs, ia, ja, ib, jb, lwork
        integer,   intent(in)    :: desca(9), descb(9)
        integer,   intent(out)   :: info
        real(ep),  intent(inout) :: A(*), B(*)
        real(ep),  intent(out)   :: work(*)
        integer :: na, nb, lwt
        ${target_real}$, allocatable :: At(:), Bt(:), work_t(:)
        na = nloc(desca); nb = nloc(descb)
        if (lwork == -1) then
            allocate(At(max(1,na)), Bt(max(1,nb)), work_t(1))
            call ${R}$gels(trans, m, n, nrhs, At, ia, ja, desca, &
                            Bt, ib, jb, descb, work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), Bt(nb), work_t(lwt))
            At = q2t_r(A(1:na)); Bt = q2t_r(B(1:nb))
            call ${R}$gels(trans, m, n, nrhs, At, ia, ja, desca, &
                            Bt, ib, jb, descb, work_t, lwt, info)
            A(1:na) = t2q_r(At); B(1:nb) = t2q_r(Bt)
        end if
    end subroutine

    subroutine target_pdposv(uplo, n, nrhs, A, ia, ja, desca, &
                             B, ib, jb, descb, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, nrhs, ia, ja, ib, jb
        integer,   intent(in)    :: desca(9), descb(9)
        integer,   intent(out)   :: info
        real(ep),  intent(inout) :: A(*), B(*)
        integer :: na, nb
        ${target_real}$, allocatable :: At(:), Bt(:)
        na = nloc(desca); nb = nloc(descb)
        allocate(At(na), Bt(nb))
        At = q2t_r(A(1:na)); Bt = q2t_r(B(1:nb))
        call ${R}$posv(uplo, n, nrhs, At, ia, ja, desca, &
                        Bt, ib, jb, descb, info)
        A(1:na) = t2q_r(At); B(1:nb) = t2q_r(Bt)
    end subroutine

    subroutine target_pdpotri(uplo, n, A, ia, ja, desca, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, ia, ja
        integer,   intent(in)    :: desca(9)
        integer,   intent(out)   :: info
        real(ep),  intent(inout) :: A(*)
        integer :: na
        ${target_real}$, allocatable :: At(:)
        na = nloc(desca)
        allocate(At(na))
        At = q2t_r(A(1:na))
        call ${R}$potri(uplo, n, At, ia, ja, desca, info)
        A(1:na) = t2q_r(At)
    end subroutine

    subroutine target_pdtrtri(uplo, diag, n, A, ia, ja, desca, info)
        character, intent(in)    :: uplo, diag
        integer,   intent(in)    :: n, ia, ja
