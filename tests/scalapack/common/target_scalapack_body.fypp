    subroutine target_pzunmhr(side, trans, m, n, ilo, ihi, A, ia, ja, desca, &
                              tau, C, ic, jc, descc, work, lwork, info)
        character,   intent(in)    :: side, trans
        integer,     intent(in)    :: m, n, ilo, ihi, ia, ja, ic, jc, lwork
        integer,     intent(in)    :: desca(9), descc(9)
        integer,     intent(out)   :: info
        complex(ep), intent(in)    :: A(*), tau(*)
        complex(ep), intent(inout) :: C(*)
        complex(ep), intent(out)   :: work(*)
        integer :: na, nc, ntau, lwt
        ${target_complex}$, allocatable :: At(:), Ct(:), tau_t(:), work_t(:)
        na = nloc(desca); nc = nloc(descc); ntau = max(1, loccols(desca))
        if (lwork == -1) then
            allocate(At(max(1,na)), Ct(max(1,nc)), tau_t(ntau), work_t(1))
            call ${C}$unmhr(side, trans, m, n, ilo, ihi, At, ia, ja, desca, &
                             tau_t, Ct, ic, jc, descc, work_t, -1, info)
            work(1) = t2q_c(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), Ct(nc), tau_t(ntau), work_t(lwt))
            At = q2t_c(A(1:na)); Ct = q2t_c(C(1:nc))
            tau_t(1:ntau) = q2t_c(tau(1:ntau))
            call ${C}$unmhr(side, trans, m, n, ilo, ihi, At, ia, ja, desca, &
                             tau_t, Ct, ic, jc, descc, work_t, lwt, info)
            C(1:nc) = t2q_c(Ct)
        end if
    end subroutine

    subroutine target_pzgels(trans, m, n, nrhs, A, ia, ja, desca, &
                             B, ib, jb, descb, work, lwork, info)
