        end if
    end subroutine

    subroutine target_pdgebrd(m, n, A, ia, ja, desca, d, e, tauq, taup, &
                              work, lwork, info)
        integer,  intent(in)    :: m, n, ia, ja, lwork
        integer,  intent(in)    :: desca(9)
        integer,  intent(out)   :: info
        real(ep), intent(inout) :: A(*)
        real(ep), intent(out)   :: d(*), e(*), tauq(*), taup(*), work(*)
        integer :: na, nd, ne, ntauq, ntaup, lwt
        ${target_real}$, allocatable :: At(:), dt(:), et(:), tq(:), tp(:), work_t(:)
        na = nloc(desca)
        if (m >= n) then
            nd = max(1, loccols(desca))
            ne = max(1, locrows(desca))
            ntauq = max(1, loccols(desca))
            ntaup = max(1, locrows(desca))
        else
            nd = max(1, locrows(desca))
            ne = max(1, loccols(desca))
            ntauq = max(1, loccols(desca))
            ntaup = max(1, locrows(desca))
        end if
        if (lwork == -1) then
            allocate(At(max(1,na)), dt(nd), et(ne), tq(ntauq), tp(ntaup), work_t(1))
            call ${R}$gebrd(m, n, At, ia, ja, desca, dt, et, tq, tp, &
                             work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), dt(nd), et(ne), tq(ntauq), tp(ntaup), work_t(lwt))
            At = q2t_r(A(1:na))
            call ${R}$gebrd(m, n, At, ia, ja, desca, dt, et, tq, tp, &
                             work_t, lwt, info)
            A(1:na) = t2q_r(At)
            d(1:nd) = t2q_r(dt); e(1:ne) = t2q_r(et)
            tauq(1:ntauq) = t2q_r(tq); taup(1:ntaup) = t2q_r(tp)
        end if
    end subroutine

    subroutine target_pdsyev(jobz, uplo, n, A, ia, ja, desca, w, &
                             Z, iz, jz, descz, work, lwork, info)
        character, intent(in)    :: jobz, uplo
        integer,   intent(in)    :: n, ia, ja, iz, jz, lwork
        integer,   intent(in)    :: desca(9), descz(9)
