        ldb = descb(6)
        if (lwork == -1) then
            allocate(At(max(1,na)), aft(max(1, laf)), Bt(1), work_t(1))
            call ${R}$dbtrs(trans, n, bwl, bwu, nrhs, At, ja, desca, &
                             Bt, ib, descb, aft, laf, work_t, -1, info)
            work(1) = t2q_r(work_t(1))
        else
            lwt = max(1, lwork)
            allocate(At(na), aft(max(1, laf)), Bt(ldb * nrhs), work_t(lwt))
