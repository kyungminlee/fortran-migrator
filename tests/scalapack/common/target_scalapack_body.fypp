    function target_pzlanhs(norm, n, A, ia, ja, desca, work) result(r)
        character,   intent(in) :: norm
        integer,     intent(in) :: n, ia, ja
        integer,     intent(in) :: desca(9)
        complex(ep), intent(in) :: A(*)
        real(ep)                :: work(*)
        real(ep) :: r
        integer :: na, nw
        ${target_complex}$, allocatable :: At(:)
        ${target_real}$,    allocatable :: work_t(:)
        ${target_real}$ :: r_t
        na = nloc(desca); nw = max(4 * n, 1024)
        allocate(At(na), work_t(nw))
        At = q2t_c(A(1:na))
