    subroutine target_dormrq(side, trans, m, n, k, A, lda, tau, C, ldc, info)
        character, intent(in)    :: side, trans
        integer,   intent(in)    :: m, n, k, lda, ldc
        real(ep),  intent(in)    :: A(lda,*), tau(*)
        real(ep),  intent(inout) :: C(ldc,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), taut(:), Ct(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, ncolA
        if (side == 'L' .or. side == 'l') then
            ncolA = m
        else
            ncolA = n
        end if
        allocate(At(lda, ncolA), taut(k), Ct(ldc, n))
        At = q2t_r(A(1:lda, 1:ncolA))
        taut = q2t_r(tau(1:k))
        Ct = q2t_r(C(1:ldc, 1:n))
        call ${R}$ormrq(side, trans, m, n, k, At, lda, taut, Ct, ldc, &
                        wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$ormrq(side, trans, m, n, k, At, lda, taut, Ct, ldc, &
                        work, lwork, info)
        C(1:ldc, 1:n) = t2q_r(Ct)
    end subroutine

