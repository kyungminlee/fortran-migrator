        real(ep),  intent(in) :: AB(ldab,*)
        real(ep) :: r
        ${target_real}$, allocatable :: ABt(:,:), workt(:)
        allocate(ABt(ldab,n), workt(max(1,n)))
        ABt = q2t_r(AB(1:ldab,1:n))
        r = t2q_r(${R}$langb(norm, n, kl, ku, ABt, ldab, workt))
    end function

