        taut = q2t_r(tau(1:k))
        call ${R}$orglq(m, n, k, At, lda, taut, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$orglq(m, n, k, At, lda, taut, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
