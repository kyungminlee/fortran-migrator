    ! ── Phase 15 wrappers ────────────────────────────────────────────
    subroutine target_dgerfs(trans, n, nrhs, A, lda, AF, ldaf, ipiv, B, ldb, &
                             X, ldx, ferr, berr, info)
        character, intent(in)    :: trans
        integer,   intent(in)    :: n, nrhs, lda, ldaf, ldb, ldx
        real(ep),  intent(in)    :: A(lda,*), AF(ldaf,*), B(ldb,*)
        integer,   intent(in)    :: ipiv(*)
        real(ep),  intent(inout) :: X(ldx,*)
        real(ep),  intent(out)   :: ferr(*), berr(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), AFt(:,:), Bt(:,:), Xt(:,:), &
                                         work(:), ferrt(:), berrt(:)
        integer, allocatable :: iwork(:)
        allocate(At(lda, n), AFt(ldaf, n), Bt(ldb, nrhs), Xt(ldx, nrhs), &
                 work(3*n), iwork(n), ferrt(nrhs), berrt(nrhs))
        At = q2t_r(A(1:lda, 1:n)); AFt = q2t_r(AF(1:ldaf, 1:n))
        Bt = q2t_r(B(1:ldb, 1:nrhs)); Xt = q2t_r(X(1:ldx, 1:nrhs))
        call ${R}$gerfs(trans, n, nrhs, At, lda, AFt, ldaf, ipiv, Bt, ldb, &
                        Xt, ldx, ferrt, berrt, work, iwork, info)
        X(1:ldx, 1:nrhs) = t2q_r(Xt)
        ferr(1:nrhs) = t2q_r(ferrt)
        berr(1:nrhs) = t2q_r(berrt)
    end subroutine

