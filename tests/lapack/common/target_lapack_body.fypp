        ${target_real}$, allocatable :: At(:,:), Dt(:), Et(:), tauqt(:), taupt(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, mn, nE
        mn = min(m, n); nE = max(1, mn - 1)
        allocate(At(lda, n), Dt(mn), Et(nE), tauqt(mn), taupt(mn))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$gebrd(m, n, At, lda, Dt, Et, tauqt, taupt, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$gebrd(m, n, At, lda, Dt, Et, tauqt, taupt, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
        D(1:mn) = t2q_r(Dt); E(1:nE) = t2q_r(Et)
        tauq(1:mn) = t2q_r(tauqt); taup(1:mn) = t2q_r(taupt)
    end subroutine

