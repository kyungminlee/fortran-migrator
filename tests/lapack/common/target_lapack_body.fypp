    subroutine target_dlapll(n, X, incx, Y, incy, ssmin)
        integer,  intent(in)    :: n, incx, incy
        real(ep), intent(inout) :: X(*), Y(*)
        real(ep), intent(out)   :: ssmin
        integer :: lx, ly
        ${target_real}$, allocatable :: Xt(:), Yt(:)
        ${target_real}$ :: st
        lx = max(1, 1 + (n-1) * abs(incx))
        ly = max(1, 1 + (n-1) * abs(incy))
        allocate(Xt(lx), Yt(ly))
        Xt = q2t_r(X(1:lx)); Yt = q2t_r(Y(1:ly))
        call ${R}$lapll(n, Xt, incx, Yt, incy, st)
        X(1:lx) = t2q_r(Xt); Y(1:ly) = t2q_r(Yt)
        ssmin = t2q_r(st)
    end subroutine

    subroutine target_zlapll(n, X, incx, Y, incy, ssmin)
        integer,     intent(in)    :: n, incx, incy
        complex(ep), intent(inout) :: X(*), Y(*)
        real(ep),    intent(out)   :: ssmin
        integer :: lx, ly
        ${target_complex}$, allocatable :: Xt(:), Yt(:)
        ${target_real}$ :: st
        lx = max(1, 1 + (n-1) * abs(incx))
        ly = max(1, 1 + (n-1) * abs(incy))
        allocate(Xt(lx), Yt(ly))
        Xt = q2t_c(X(1:lx)); Yt = q2t_c(Y(1:ly))
        call ${C}$lapll(n, Xt, incx, Yt, incy, st)
        X(1:lx) = t2q_c(Xt); Y(1:ly) = t2q_c(Yt)
        ssmin = t2q_r(st)
    end subroutine

    subroutine target_dlacn2(n, V, X, isgn, est, kase, isave)
        integer,  intent(in)    :: n
        real(ep), intent(out)   :: V(*)
        real(ep), intent(inout) :: X(*), est
        integer,  intent(out)   :: isgn(*)
        integer,  intent(inout) :: kase, isave(3)
        ${target_real}$, allocatable :: Vt(:), Xt(:)
        ${target_real}$ :: estt
        allocate(Vt(n), Xt(n))
        Xt = q2t_r(X(1:n))
        estt = q2t_r(est)
        call ${R}$lacn2(n, Vt, Xt, isgn, estt, kase, isave)
        V(1:n) = t2q_r(Vt); X(1:n) = t2q_r(Xt)
        est = t2q_r(estt)
    end subroutine

    subroutine target_zlacn2(n, V, X, est, kase, isave)
        integer,     intent(in)    :: n
        complex(ep), intent(out)   :: V(*)
        complex(ep), intent(inout) :: X(*)
        real(ep),    intent(inout) :: est
        integer,     intent(inout) :: kase, isave(3)
        ${target_complex}$, allocatable :: Vt(:), Xt(:)
        ${target_real}$ :: estt
        allocate(Vt(n), Xt(n))
        Xt = q2t_c(X(1:n))
        estt = q2t_r(est)
        call ${C}$lacn2(n, Vt, Xt, estt, kase, isave)
        V(1:n) = t2q_c(Vt); X(1:n) = t2q_c(Xt)
        est = t2q_r(estt)
    end subroutine

    subroutine target_dlartg(f, g, c, s, r)
        real(ep), intent(in)  :: f, g
        real(ep), intent(out) :: c, s, r
        ${target_real}$ :: ct, st, rt
        call ${R}$lartg(q2t_r(f), q2t_r(g), ct, st, rt)
        c = t2q_r(ct); s = t2q_r(st); r = t2q_r(rt)
    end subroutine

    subroutine target_zlartg(f, g, c, s, r)
        complex(ep), intent(in)  :: f, g
        real(ep),    intent(out) :: c
        complex(ep), intent(out) :: s, r
        ${target_real}$    :: ct
        ${target_complex}$ :: st, rt
        call ${C}$lartg(q2t_c(f), q2t_c(g), ct, st, rt)
        c = t2q_r(ct); s = t2q_c(st); r = t2q_c(rt)
    end subroutine

    subroutine target_dlartgp(f, g, c, s, r)
        real(ep), intent(in)  :: f, g
        real(ep), intent(out) :: c, s, r
        ${target_real}$ :: ct, st, rt
        call ${R}$lartgp(q2t_r(f), q2t_r(g), ct, st, rt)
        c = t2q_r(ct); s = t2q_r(st); r = t2q_r(rt)
    end subroutine

    subroutine target_dlartgs(x, y, sigma, c, s)
        real(ep), intent(in)  :: x, y, sigma
        real(ep), intent(out) :: c, s
        ${target_real}$ :: ct, st
        call ${R}$lartgs(q2t_r(x), q2t_r(y), q2t_r(sigma), ct, st)
        c = t2q_r(ct); s = t2q_r(st)
    end subroutine

    ! ── Phase L20 — Small public scalar utilities ────────────────────
    function target_dlapy2(x, y) result(r)
        real(ep), intent(in) :: x, y
        real(ep) :: r
        r = t2q_r(${R}$lapy2(q2t_r(x), q2t_r(y)))
    end function

    function target_dlapy3(x, y, z) result(r)
        real(ep), intent(in) :: x, y, z
        real(ep) :: r
        r = t2q_r(${R}$lapy3(q2t_r(x), q2t_r(y), q2t_r(z)))
    end function

    subroutine target_dladiv(a, b, c, d, p, q)
        real(ep), intent(in)  :: a, b, c, d
        real(ep), intent(out) :: p, q
        ${target_real}$ :: pt, qt
        call ${R}$ladiv(q2t_r(a), q2t_r(b), q2t_r(c), q2t_r(d), pt, qt)
        p = t2q_r(pt); q = t2q_r(qt)
    end subroutine

    function target_zladiv(x, y) result(r)
        complex(ep), intent(in) :: x, y
        complex(ep) :: r
        r = t2q_c(${C}$ladiv(q2t_c(x), q2t_c(y)))
    end function

    subroutine target_dlamrg(n1, n2, A, dtrd1, dtrd2, index)
        integer,  intent(in)  :: n1, n2, dtrd1, dtrd2
        real(ep), intent(in)  :: A(*)
        integer,  intent(out) :: index(*)
        ${target_real}$, allocatable :: At(:)
        allocate(At(n1+n2))
        At = q2t_r(A(1:n1+n2))
        call ${R}$lamrg(n1, n2, At, dtrd1, dtrd2, index)
    end subroutine

    subroutine target_dlarnv(idist, iseed, n, X)
        integer,  intent(in)    :: idist, n
        integer,  intent(inout) :: iseed(4)
        real(ep), intent(out)   :: X(*)
        ${target_real}$, allocatable :: Xt(:)
        allocate(Xt(n))
        call ${R}$larnv(idist, iseed, n, Xt)
        X(1:n) = t2q_r(Xt)
    end subroutine

    subroutine target_zlarnv(idist, iseed, n, X)
        integer,     intent(in)    :: idist, n
        integer,     intent(inout) :: iseed(4)
        complex(ep), intent(out)   :: X(*)
        ${target_complex}$, allocatable :: Xt(:)
        allocate(Xt(n))
        call ${C}$larnv(idist, iseed, n, Xt)
        X(1:n) = t2q_c(Xt)
    end subroutine

    ! ── Phase L21 — Generalized sym/Hermitian glue ───────────────────
    subroutine target_dsbgst(vect, uplo, n, ka, kb, AB, ldab, BB, ldbb, &
                             X, ldx, info)
        character, intent(in)    :: vect, uplo
        integer,   intent(in)    :: n, ka, kb, ldab, ldbb, ldx
        real(ep),  intent(inout) :: AB(ldab,*)
        real(ep),  intent(in)    :: BB(ldbb,*)
        real(ep),  intent(out)   :: X(ldx,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: ABt(:,:), BBt(:,:), Xt(:,:), work(:)
        allocate(ABt(ldab,n), BBt(ldbb,n), Xt(ldx,n), work(2*n))
        ABt = q2t_r(AB(1:ldab,1:n)); BBt = q2t_r(BB(1:ldbb,1:n))
        call ${R}$sbgst(vect, uplo, n, ka, kb, ABt, ldab, BBt, ldbb, &
                        Xt, ldx, work, info)
        AB(1:ldab,1:n) = t2q_r(ABt)
        if (vect /= 'N') X(1:ldx,1:n) = t2q_r(Xt)
    end subroutine

    subroutine target_zhbgst(vect, uplo, n, ka, kb, AB, ldab, BB, ldbb, &
                             X, ldx, info)
        character,   intent(in)    :: vect, uplo
        integer,     intent(in)    :: n, ka, kb, ldab, ldbb, ldx
        complex(ep), intent(inout) :: AB(ldab,*)
        complex(ep), intent(in)    :: BB(ldbb,*)
        complex(ep), intent(out)   :: X(ldx,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: ABt(:,:), BBt(:,:), Xt(:,:), work(:)
        ${target_real}$,    allocatable :: rwork(:)
        allocate(ABt(ldab,n), BBt(ldbb,n), Xt(ldx,n), work(n), rwork(n))
        ABt = q2t_c(AB(1:ldab,1:n)); BBt = q2t_c(BB(1:ldbb,1:n))
        call ${C}$hbgst(vect, uplo, n, ka, kb, ABt, ldab, BBt, ldbb, &
                        Xt, ldx, work, rwork, info)
        AB(1:ldab,1:n) = t2q_c(ABt)
        if (vect /= 'N') X(1:ldx,1:n) = t2q_c(Xt)
    end subroutine

    subroutine target_dspgst(itype, uplo, n, AP, BP, info)
        integer,   intent(in)    :: itype, n
        character, intent(in)    :: uplo
        real(ep),  intent(inout) :: AP(*)
        real(ep),  intent(in)    :: BP(*)
        integer,   intent(out)   :: info
        integer :: nap
        ${target_real}$, allocatable :: APt(:), BPt(:)
        nap = n*(n+1)/2
        allocate(APt(max(1,nap)), BPt(max(1,nap)))
        APt = q2t_r(AP(1:nap)); BPt = q2t_r(BP(1:nap))
        call ${R}$spgst(itype, uplo, n, APt, BPt, info)
        AP(1:nap) = t2q_r(APt)
    end subroutine

    subroutine target_zhpgst(itype, uplo, n, AP, BP, info)
        integer,     intent(in)    :: itype, n
