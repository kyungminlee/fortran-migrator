    ! ── Phase 10 wrappers ────────────────────────────────────────────
#:def CPACK_FACTOR(name, ref)
    subroutine target_${name}$(uplo, n, AP, ipiv, info)
        character,   intent(in)    :: uplo
        integer,     intent(in)    :: n
        complex(ep), intent(inout) :: AP(*)
        integer,     intent(out)   :: ipiv(*), info
        ${target_complex}$, allocatable :: APt(:)
        integer :: np
        np = n*(n+1)/2
        allocate(APt(np))
        APt = q2t_c(AP(1:np))
        call ${ref}$(uplo, n, APt, ipiv, info)
        AP(1:np) = t2q_c(APt)
    end subroutine
#:enddef

#:def CPACK_SOLVE(name, ref)
    subroutine target_${name}$(uplo, n, nrhs, AP, ipiv, B, ldb, info)
        character,   intent(in)    :: uplo
        integer,     intent(in)    :: n, nrhs, ldb
        complex(ep), intent(in)    :: AP(*)
        integer,     intent(in)    :: ipiv(*)
        complex(ep), intent(inout) :: B(ldb,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: APt(:), Bt(:,:)
        integer :: np
        np = n*(n+1)/2
        allocate(APt(np), Bt(ldb, nrhs))
        APt = q2t_c(AP(1:np)); Bt = q2t_c(B(1:ldb, 1:nrhs))
        call ${ref}$(uplo, n, nrhs, APt, ipiv, Bt, ldb, info)
        B(1:ldb, 1:nrhs) = t2q_c(Bt)
    end subroutine
#:enddef

#:def CPACK_DRIVER(name, ref)
    subroutine target_${name}$(uplo, n, nrhs, AP, ipiv, B, ldb, info)
        character,   intent(in)    :: uplo
        integer,     intent(in)    :: n, nrhs, ldb
        complex(ep), intent(inout) :: AP(*), B(ldb,*)
        integer,     intent(out)   :: ipiv(*), info
        ${target_complex}$, allocatable :: APt(:), Bt(:,:)
        integer :: np
        np = n*(n+1)/2
        allocate(APt(np), Bt(ldb, nrhs))
        APt = q2t_c(AP(1:np)); Bt = q2t_c(B(1:ldb, 1:nrhs))
        call ${ref}$(uplo, n, nrhs, APt, ipiv, Bt, ldb, info)
        AP(1:np) = t2q_c(APt)
        B(1:ldb, 1:nrhs) = t2q_c(Bt)
    end subroutine
#:enddef

#:def CPACK_INV(name, ref)
    subroutine target_${name}$(uplo, n, AP, ipiv, info)
        character,   intent(in)    :: uplo
        integer,     intent(in)    :: n
        complex(ep), intent(inout) :: AP(*)
        integer,     intent(in)    :: ipiv(*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: APt(:), work(:)
        integer :: np
        np = n*(n+1)/2
        allocate(APt(np), work(n))
        APt = q2t_c(AP(1:np))
        call ${ref}$(uplo, n, APt, ipiv, work, info)
        AP(1:np) = t2q_c(APt)
    end subroutine
#:enddef

$:CPACK_FACTOR('zhptrf', C + 'hptrf')
$:CPACK_SOLVE('zhptrs', C + 'hptrs')
$:CPACK_DRIVER('zhpsv', C + 'hpsv')
$:CPACK_INV('zhptri', C + 'hptri')

$:CPACK_FACTOR('zsptrf', C + 'sptrf')
$:CPACK_SOLVE('zsptrs', C + 'sptrs')
$:CPACK_DRIVER('zspsv', C + 'spsv')
$:CPACK_INV('zsptri', C + 'sptri')

    subroutine target_zpptrf(uplo, n, AP, info)
        character,   intent(in)    :: uplo
        integer,     intent(in)    :: n
        complex(ep), intent(inout) :: AP(*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: APt(:)
        integer :: np
        np = n*(n+1)/2
