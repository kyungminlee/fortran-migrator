        integer,     intent(out)   :: info
        ${target_real}$,    allocatable :: dt(:)
        ${target_complex}$, allocatable :: et(:)
        allocate(dt(n), et(n-1))
        dt = q2t_r(d(1:n)); et = q2t_c(e(1:n-1))
        call ${C}$pttrf(n, dt, et, info)
        d(1:n)   = t2q_r(dt)
        e(1:n-1) = t2q_c(et)
    end subroutine

