        allocate(ABt(ldab, n), BBt(ldbb, n), Wt(n), Zt(ldz, n), work(3*n))
        ABt = q2t_r(AB(1:ldab, 1:n)); BBt = q2t_r(BB(1:ldbb, 1:n))
        call ${R}$sbgv(jobz, uplo, n, ka, kb, ABt, ldab, BBt, ldbb, Wt, Zt, ldz, work, info)
        AB(1:ldab, 1:n) = t2q_r(ABt); BB(1:ldbb, 1:n) = t2q_r(BBt)
        W(1:n) = t2q_r(Wt)
        if (jobz == 'V' .or. jobz == 'v') Z(1:ldz, 1:n) = t2q_r(Zt)
    end subroutine

