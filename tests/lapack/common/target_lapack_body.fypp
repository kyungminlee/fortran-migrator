    subroutine target_dsbev(jobz, uplo, n, kd, AB, ldab, w, z, ldz, info)
        character, intent(in)    :: jobz, uplo
        integer,   intent(in)    :: n, kd, ldab, ldz
        real(ep),  intent(inout) :: AB(ldab,*)
        real(ep),  intent(out)   :: w(*), z(ldz,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: ABt(:,:), wt(:), zt(:,:), work(:)
        integer :: lw
        lw = max(1, 3*n - 2)
        allocate(ABt(ldab, n), wt(n), zt(ldz, n), work(lw))
        ABt = q2t_r(AB(1:ldab, 1:n))
        call ${R}$sbev(jobz, uplo, n, kd, ABt, ldab, wt, zt, ldz, work, info)
        AB(1:ldab, 1:n) = t2q_r(ABt)
        w(1:n) = t2q_r(wt)
        if (jobz /= 'N' .and. jobz /= 'n') z(1:ldz, 1:n) = t2q_r(zt)
    end subroutine

