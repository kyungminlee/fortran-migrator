    ! ── Phase 24 wrappers ────────────────────────────────────────────
    subroutine target_dspgv(itype, jobz, uplo, n, AP, BP, W, Z, ldz, info)
        character, intent(in)    :: jobz, uplo
        integer,   intent(in)    :: itype, n, ldz
        real(ep),  intent(inout) :: AP(*), BP(*)
        real(ep),  intent(out)   :: W(*), Z(ldz,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: APt(:), BPt(:), Wt(:), Zt(:,:), work(:)
        integer :: np
        np = n*(n+1)/2
        allocate(APt(np), BPt(np), Wt(n), Zt(ldz, n), work(3*n))
        APt = q2t_r(AP(1:np)); BPt = q2t_r(BP(1:np))
        call ${R}$spgv(itype, jobz, uplo, n, APt, BPt, Wt, Zt, ldz, work, info)
        AP(1:np) = t2q_r(APt); BP(1:np) = t2q_r(BPt)
        W(1:n) = t2q_r(Wt)
        if (jobz == 'V' .or. jobz == 'v') Z(1:ldz, 1:n) = t2q_r(Zt)
    end subroutine

    subroutine target_zhpgv(itype, jobz, uplo, n, AP, BP, W, Z, ldz, info)
        character,   intent(in)    :: jobz, uplo
        integer,     intent(in)    :: itype, n, ldz
        complex(ep), intent(inout) :: AP(*), BP(*)
        real(ep),    intent(out)   :: W(*)
        complex(ep), intent(out)   :: Z(ldz,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: APt(:), BPt(:), Zt(:,:), work(:)
        ${target_real}$,    allocatable :: Wt(:), rwork(:)
        integer :: np
        np = n*(n+1)/2
        allocate(APt(np), BPt(np), Wt(n), Zt(ldz, n), work(max(1, 2*n-1)), rwork(max(1, 3*n-2)))
        APt = q2t_c(AP(1:np)); BPt = q2t_c(BP(1:np))
        call ${C}$hpgv(itype, jobz, uplo, n, APt, BPt, Wt, Zt, ldz, work, rwork, info)
        AP(1:np) = t2q_c(APt); BP(1:np) = t2q_c(BPt)
        W(1:n) = t2q_r(Wt)
        if (jobz == 'V' .or. jobz == 'v') Z(1:ldz, 1:n) = t2q_c(Zt)
    end subroutine

    subroutine target_dsbgv(jobz, uplo, n, ka, kb, AB, ldab, BB, ldbb, W, Z, ldz, info)
        character, intent(in)    :: jobz, uplo
