        allocate(ABt(ldab, n), Bt(ldb, nrhs))
        ABt = q2t_c(AB(1:ldab, 1:n)); Bt = q2t_c(B(1:ldb, 1:nrhs))
        call ${C}$pbsv(uplo, n, kd, nrhs, ABt, ldab, Bt, ldb, info)
        AB(1:ldab, 1:n) = t2q_c(ABt)
        B(1:ldb, 1:nrhs) = t2q_c(Bt)
    end subroutine

    subroutine target_zgttrf(n, dl, d, du, du2, ipiv, info)
        integer,     intent(in)    :: n
        complex(ep), intent(inout) :: dl(*), d(*), du(*)
        complex(ep), intent(out)   :: du2(*)
        integer,     intent(out)   :: ipiv(*), info
        ${target_complex}$, allocatable :: dlt(:), dt(:), dut(:), du2t(:)
        allocate(dlt(n-1), dt(n), dut(n-1), du2t(n-2))
        dlt = q2t_c(dl(1:n-1)); dt = q2t_c(d(1:n)); dut = q2t_c(du(1:n-1))
        call ${C}$gttrf(n, dlt, dt, dut, du2t, ipiv, info)
        dl(1:n-1) = t2q_c(dlt); d(1:n) = t2q_c(dt); du(1:n-1) = t2q_c(dut)
        du2(1:n-2) = t2q_c(du2t)
    end subroutine

    subroutine target_zgttrs(trans, n, nrhs, dl, d, du, du2, ipiv, B, ldb, info)
        character,   intent(in)    :: trans
        integer,     intent(in)    :: n, nrhs, ldb
        complex(ep), intent(in)    :: dl(*), d(*), du(*), du2(*)
        integer,     intent(in)    :: ipiv(*)
        complex(ep), intent(inout) :: B(ldb,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: dlt(:), dt(:), dut(:), du2t(:), Bt(:,:)
        allocate(dlt(n-1), dt(n), dut(n-1), du2t(n-2), Bt(ldb, nrhs))
        dlt = q2t_c(dl(1:n-1)); dt = q2t_c(d(1:n)); dut = q2t_c(du(1:n-1))
        du2t = q2t_c(du2(1:n-2)); Bt = q2t_c(B(1:ldb, 1:nrhs))
        call ${C}$gttrs(trans, n, nrhs, dlt, dt, dut, du2t, ipiv, Bt, ldb, info)
        B(1:ldb, 1:nrhs) = t2q_c(Bt)
    end subroutine

    subroutine target_zgtsv(n, nrhs, dl, d, du, B, ldb, info)
        integer,     intent(in)    :: n, nrhs, ldb
        complex(ep), intent(inout) :: dl(*), d(*), du(*), B(ldb,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: dlt(:), dt(:), dut(:), Bt(:,:)
        allocate(dlt(n-1), dt(n), dut(n-1), Bt(ldb, nrhs))
        dlt = q2t_c(dl(1:n-1)); dt = q2t_c(d(1:n)); dut = q2t_c(du(1:n-1))
        Bt = q2t_c(B(1:ldb, 1:nrhs))
        call ${C}$gtsv(n, nrhs, dlt, dt, dut, Bt, ldb, info)
        dl(1:n-1) = t2q_c(dlt); d(1:n) = t2q_c(dt); du(1:n-1) = t2q_c(dut)
        B(1:ldb, 1:nrhs) = t2q_c(Bt)
    end subroutine

