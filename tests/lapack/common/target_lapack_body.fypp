    ! ── Phase 2 wrappers ─────────────────────────────────────────────
    subroutine target_dposv(uplo, n, nrhs, A, lda, B, ldb, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, nrhs, lda, ldb
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:)
        allocate(At(lda, n), Bt(ldb, nrhs))
        At = q2t_r(A(1:lda, 1:n))
        Bt = q2t_r(B(1:ldb, 1:nrhs))
        call ${R}$posv(uplo, n, nrhs, At, lda, Bt, ldb, info)
        A(1:lda, 1:n)    = t2q_r(At)
        B(1:ldb, 1:nrhs) = t2q_r(Bt)
    end subroutine

    subroutine target_dsysv(uplo, n, nrhs, A, lda, ipiv, B, ldb, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, nrhs, lda, ldb
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*)
        integer,   intent(out)   :: ipiv(*), info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), Bt(ldb, nrhs))
        At = q2t_r(A(1:lda, 1:n))
        Bt = q2t_r(B(1:ldb, 1:nrhs))
        call ${R}$sysv(uplo, n, nrhs, At, lda, ipiv, Bt, ldb, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$sysv(uplo, n, nrhs, At, lda, ipiv, Bt, ldb, work, lwork, info)
        A(1:lda, 1:n)    = t2q_r(At)
        B(1:ldb, 1:nrhs) = t2q_r(Bt)
    end subroutine

    subroutine target_dsytrf(uplo, n, A, lda, ipiv, info)
        character, intent(in)    :: uplo
