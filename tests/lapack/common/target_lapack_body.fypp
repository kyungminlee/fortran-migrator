    subroutine target_dgghrd(compq, compz, n, ilo, ihi, A, lda, B, ldb, &
                             Q, ldq, Z, ldz, info)
        character, intent(in)    :: compq, compz
        integer,   intent(in)    :: n, ilo, ihi, lda, ldb, ldq, ldz
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*), Q(ldq,*), Z(ldz,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), Qt(:,:), Zt(:,:)
        integer :: nq, nz
        nq = merge(n, 1, compq == 'V' .or. compq == 'v' .or. compq == 'I' .or. compq == 'i')
        nz = merge(n, 1, compz == 'V' .or. compz == 'v' .or. compz == 'I' .or. compz == 'i')
        allocate(At(lda, n), Bt(ldb, n), Qt(ldq, nq), Zt(ldz, nz))
        At = q2t_r(A(1:lda, 1:n)); Bt = q2t_r(B(1:ldb, 1:n))
        if (compq == 'V' .or. compq == 'v') Qt = q2t_r(Q(1:ldq, 1:nq))
        if (compz == 'V' .or. compz == 'v') Zt = q2t_r(Z(1:ldz, 1:nz))
        call ${R}$gghrd(compq, compz, n, ilo, ihi, At, lda, Bt, ldb, &
                       Qt, ldq, Zt, ldz, info)
        A(1:lda, 1:n) = t2q_r(At); B(1:ldb, 1:n) = t2q_r(Bt)
        if (compq /= 'N' .and. compq /= 'n') Q(1:ldq, 1:nq) = t2q_r(Qt)
        if (compz /= 'N' .and. compz /= 'n') Z(1:ldz, 1:nz) = t2q_r(Zt)
    end subroutine

    subroutine target_zgghrd(compq, compz, n, ilo, ihi, A, lda, B, ldb, &
                             Q, ldq, Z, ldz, info)
        character,   intent(in)    :: compq, compz
        integer,     intent(in)    :: n, ilo, ihi, lda, ldb, ldq, ldz
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*), Q(ldq,*), Z(ldz,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), Qt(:,:), Zt(:,:)
        integer :: nq, nz
        nq = merge(n, 1, compq == 'V' .or. compq == 'v' .or. compq == 'I' .or. compq == 'i')
        nz = merge(n, 1, compz == 'V' .or. compz == 'v' .or. compz == 'I' .or. compz == 'i')
        allocate(At(lda, n), Bt(ldb, n), Qt(ldq, nq), Zt(ldz, nz))
        At = q2t_c(A(1:lda, 1:n)); Bt = q2t_c(B(1:ldb, 1:n))
        if (compq == 'V' .or. compq == 'v') Qt = q2t_c(Q(1:ldq, 1:nq))
        if (compz == 'V' .or. compz == 'v') Zt = q2t_c(Z(1:ldz, 1:nz))
        call ${C}$gghrd(compq, compz, n, ilo, ihi, At, lda, Bt, ldb, &
                       Qt, ldq, Zt, ldz, info)
        A(1:lda, 1:n) = t2q_c(At); B(1:ldb, 1:n) = t2q_c(Bt)
        if (compq /= 'N' .and. compq /= 'n') Q(1:ldq, 1:nq) = t2q_c(Qt)
        if (compz /= 'N' .and. compz /= 'n') Z(1:ldz, 1:nz) = t2q_c(Zt)
    end subroutine

    ! ── Phase 30 wrappers ────────────────────────────────────────────
    subroutine target_dggqrf(n, m, p, A, lda, taua, B, ldb, taub, info)
        integer,  intent(in)    :: n, m, p, lda, ldb
        real(ep), intent(inout) :: A(lda,*), B(ldb,*)
        real(ep), intent(out)   :: taua(*), taub(*)
        integer,  intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), tauat(:), taubt(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, m), Bt(ldb, p), tauat(min(n,m)), taubt(min(n,p)))
        At = q2t_r(A(1:lda, 1:m)); Bt = q2t_r(B(1:ldb, 1:p))
        call ${R}$ggqrf(n, m, p, At, lda, tauat, Bt, ldb, taubt, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$ggqrf(n, m, p, At, lda, tauat, Bt, ldb, taubt, work, lwork, info)
        A(1:lda, 1:m) = t2q_r(At); B(1:ldb, 1:p) = t2q_r(Bt)
        taua(1:min(n,m)) = t2q_r(tauat); taub(1:min(n,p)) = t2q_r(taubt)
    end subroutine

