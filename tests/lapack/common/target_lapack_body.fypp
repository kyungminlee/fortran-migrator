    subroutine target_dgemqrt(side, trans, m, n, k, nb, V, ldv, T, ldt, &
                              C, ldc, info)
        character, intent(in)    :: side, trans
        integer,   intent(in)    :: m, n, k, nb, ldv, ldt, ldc
        real(ep),  intent(in)    :: V(ldv,*), T(ldt,*)
        real(ep),  intent(inout) :: C(ldc,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: Vt(:,:), Tt(:,:), Ct(:,:), work(:)
        integer :: nq, lwork
        nq = merge(m, n, side == 'L' .or. side == 'l')
        lwork = merge(n, m, side == 'L' .or. side == 'l') * nb
        allocate(Vt(ldv, k), Tt(ldt, k), Ct(ldc, n), work(max(1, lwork)))
        Vt = q2t_r(V(1:ldv, 1:k)); Tt = q2t_r(T(1:ldt, 1:k))
        Ct = q2t_r(C(1:ldc, 1:n))
        call ${R}$gemqrt(side, trans, m, n, k, nb, Vt, ldv, Tt, ldt, Ct, ldc, work, info)
        C(1:ldc, 1:n) = t2q_r(Ct)
    end subroutine

