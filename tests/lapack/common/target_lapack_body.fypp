        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), AFt(:,:), Bt(:,:), Xt(:,:), work(:)
        ${target_real}$,    allocatable :: rwork(:), ferrt(:), berrt(:)
        allocate(At(lda, n), AFt(ldaf, n), Bt(ldb, nrhs), Xt(ldx, nrhs), &
                 work(2*n), rwork(n), ferrt(nrhs), berrt(nrhs))
        At = q2t_c(A(1:lda, 1:n)); AFt = q2t_c(AF(1:ldaf, 1:n))
        Bt = q2t_c(B(1:ldb, 1:nrhs)); Xt = q2t_c(X(1:ldx, 1:nrhs))
        call ${C}$syrfs(uplo, n, nrhs, At, lda, AFt, ldaf, ipiv, Bt, ldb, &
                        Xt, ldx, ferrt, berrt, work, rwork, info)
        X(1:ldx, 1:nrhs) = t2q_c(Xt)
        ferr(1:nrhs) = t2q_r(ferrt); berr(1:nrhs) = t2q_r(berrt)
    end subroutine

