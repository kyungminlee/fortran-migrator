    end subroutine

    ! ── Phase 8 wrappers ─────────────────────────────────────────────
    subroutine target_dgeqlf(m, n, A, lda, tau, info)
        integer,  intent(in)    :: m, n, lda
        real(ep), intent(inout) :: A(lda,*)
        real(ep), intent(out)   :: tau(*)
        integer,  intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), taut(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, kmn
        kmn = min(m, n)
        allocate(At(lda, n), taut(kmn))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$geqlf(m, n, At, lda, taut, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$geqlf(m, n, At, lda, taut, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
        tau(1:kmn)    = t2q_r(taut)
    end subroutine

    subroutine target_dorgql(m, n, k, A, lda, tau, info)
        integer,  intent(in)    :: m, n, k, lda
        real(ep), intent(inout) :: A(lda,*)
        real(ep), intent(in)    :: tau(*)
        integer,  intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), taut(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), taut(k))
        At = q2t_r(A(1:lda, 1:n))
        taut = q2t_r(tau(1:k))
        call ${R}$orgql(m, n, k, At, lda, taut, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$orgql(m, n, k, At, lda, taut, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
    end subroutine

    subroutine target_dormql(side, trans, m, n, k, A, lda, tau, C, ldc, info)
        character, intent(in)    :: side, trans
        integer,   intent(in)    :: m, n, k, lda, ldc
        real(ep),  intent(in)    :: A(lda,*), tau(*)
        real(ep),  intent(inout) :: C(ldc,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), taut(:), Ct(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, ncolA
        ncolA = k
        allocate(At(lda, ncolA), taut(k), Ct(ldc, n))
        At = q2t_r(A(1:lda, 1:ncolA))
        taut = q2t_r(tau(1:k))
        Ct = q2t_r(C(1:ldc, 1:n))
        call ${R}$ormql(side, trans, m, n, k, At, lda, taut, Ct, ldc, &
                        wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$ormql(side, trans, m, n, k, At, lda, taut, Ct, ldc, &
                        work, lwork, info)
        C(1:ldc, 1:n) = t2q_r(Ct)
    end subroutine

