        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: dlt(:), dt(:), dut(:), Bt(:,:)
        allocate(dlt(n-1), dt(n), dut(n-1), Bt(ldb, nrhs))
        dlt = q2t_c(dl(1:n-1)); dt = q2t_c(d(1:n)); dut = q2t_c(du(1:n-1))
        Bt = q2t_c(B(1:ldb, 1:nrhs))
        call ${C}$gtsv(n, nrhs, dlt, dt, dut, Bt, ldb, info)
        dl(1:n-1) = t2q_c(dlt); d(1:n) = t2q_c(dt); du(1:n-1) = t2q_c(dut)
        B(1:ldb, 1:nrhs) = t2q_c(Bt)
    end subroutine

