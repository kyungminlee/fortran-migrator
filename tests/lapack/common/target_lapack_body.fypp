    subroutine target_dtgsna(job, howmny, select, n, A, lda, B, ldb, vl, ldvl, &
                             vr, ldvr, s, dif, mm, m, info)
        character, intent(in)    :: job, howmny
        integer,   intent(in)    :: n, lda, ldb, ldvl, ldvr, mm
        logical,   intent(in)    :: select(*)
        real(ep),  intent(in)    :: A(lda,*), B(ldb,*), vl(ldvl,*), vr(ldvr,*)
        real(ep),  intent(out)   :: s(*), dif(*)
        integer,   intent(out)   :: m, info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), vlt(:,:), vrt(:,:)
        ${target_real}$, allocatable :: st(:), dift(:), work(:)
        integer, allocatable :: iwork(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda,n), Bt(ldb,n), vlt(ldvl,mm), vrt(ldvr,mm))
        allocate(st(mm), dift(mm), iwork(n+6))
        At = q2t_r(A(1:lda,1:n)); Bt = q2t_r(B(1:ldb,1:n))
        vlt = q2t_r(vl(1:ldvl,1:mm)); vrt = q2t_r(vr(1:ldvr,1:mm))
        call ${R}$tgsna(job, howmny, select, n, At, lda, Bt, ldb, vlt, ldvl, &
                        vrt, ldvr, st, dift, mm, m, wopt, -1, iwork, info)
        lwork = max(1, int(t2q_r(wopt(1)))); allocate(work(lwork))
        call ${R}$tgsna(job, howmny, select, n, At, lda, Bt, ldb, vlt, ldvl, &
                        vrt, ldvr, st, dift, mm, m, work, lwork, iwork, info)
        s(1:mm) = t2q_r(st); dif(1:mm) = t2q_r(dift)
    end subroutine

