    subroutine target_dpbrfs(uplo, n, kd, nrhs, AB, ldab, AFB, ldafb, B, ldb, &
                             X, ldx, ferr, berr, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, kd, nrhs, ldab, ldafb, ldb, ldx
        real(ep),  intent(in)    :: AB(ldab,*), AFB(ldafb,*), B(ldb,*)
        real(ep),  intent(inout) :: X(ldx,*)
        real(ep),  intent(out)   :: ferr(*), berr(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: ABt(:,:), AFBt(:,:), Bt(:,:), Xt(:,:), &
                                         work(:), ferrt(:), berrt(:)
        integer, allocatable :: iwork(:)
        allocate(ABt(ldab, n), AFBt(ldafb, n), Bt(ldb, nrhs), Xt(ldx, nrhs), &
                 work(3*n), iwork(n), ferrt(nrhs), berrt(nrhs))
        ABt = q2t_r(AB(1:ldab, 1:n)); AFBt = q2t_r(AFB(1:ldafb, 1:n))
