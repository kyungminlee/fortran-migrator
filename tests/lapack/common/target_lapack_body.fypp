    subroutine target_zgemlq(side, trans, m, n, k, A, lda, T, tsize, C, ldc, info)
        character,   intent(in)    :: side, trans
        integer,     intent(in)    :: m, n, k, lda, tsize, ldc
        complex(ep), intent(in)    :: A(lda,*), T(*)
        complex(ep), intent(inout) :: C(ldc,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Tt(:), Ct(:,:), work(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork, nq
        nq = merge(m, n, side == 'L' .or. side == 'l')
        allocate(At(lda, nq), Tt(tsize), Ct(ldc, n))
        At = q2t_c(A(1:lda, 1:nq)); Tt = q2t_c(T(1:tsize))
        Ct = q2t_c(C(1:ldc, 1:n))
        call ${C}$gemlq(side, trans, m, n, k, At, lda, Tt, tsize, Ct, ldc, wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$gemlq(side, trans, m, n, k, At, lda, Tt, tsize, Ct, ldc, work, lwork, info)
        C(1:ldc, 1:n) = t2q_c(Ct)
    end subroutine

    subroutine target_zggev(jobvl, jobvr, n, A, lda, B, ldb, alpha, beta, &
                            VL, ldvl, VR, ldvr, info)
        character,   intent(in)    :: jobvl, jobvr
        integer,     intent(in)    :: n, lda, ldb, ldvl, ldvr
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*)
        complex(ep), intent(out)   :: alpha(*), beta(*)
        complex(ep), intent(out)   :: VL(ldvl,*), VR(ldvr,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), VLt(:,:), VRt(:,:), &
                                           alt(:), bet(:), work(:)
        ${target_real}$,    allocatable :: rwork(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork, nVL, nVR
        nVL = merge(n, 1, jobvl == 'V' .or. jobvl == 'v')
        nVR = merge(n, 1, jobvr == 'V' .or. jobvr == 'v')
        allocate(At(lda, n), Bt(ldb, n), VLt(ldvl, nVL), VRt(ldvr, nVR), &
                 alt(n), bet(n), rwork(8*n))
        At = q2t_c(A(1:lda, 1:n)); Bt = q2t_c(B(1:ldb, 1:n))
        call ${C}$ggev(jobvl, jobvr, n, At, lda, Bt, ldb, alt, bet, &
                      VLt, ldvl, VRt, ldvr, wopt, -1, rwork, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$ggev(jobvl, jobvr, n, At, lda, Bt, ldb, alt, bet, &
                      VLt, ldvl, VRt, ldvr, work, lwork, rwork, info)
        A(1:lda, 1:n) = t2q_c(At); B(1:ldb, 1:n) = t2q_c(Bt)
        alpha(1:n) = t2q_c(alt); beta(1:n) = t2q_c(bet)
        if (jobvl == 'V' .or. jobvl == 'v') VL(1:ldvl, 1:nVL) = t2q_c(VLt)
        if (jobvr == 'V' .or. jobvr == 'v') VR(1:ldvr, 1:nVR) = t2q_c(VRt)
    end subroutine

    subroutine target_dbdsdc(uplo, compq, n, D, E, U, ldu, VT, ldvt, Q, IQ, info)
        character, intent(in)    :: uplo, compq
        integer,   intent(in)    :: n, ldu, ldvt
        real(ep),  intent(inout) :: D(*), E(*)
        real(ep),  intent(out)   :: U(ldu,*), VT(ldvt,*), Q(*)
        integer,   intent(out)   :: IQ(*), info
        ${target_real}$, allocatable :: Dt(:), Et(:), Ut(:,:), VTt(:,:), Qt(:), work(:)
        integer, allocatable :: iwork(:)
        integer :: nU, nVT, lwork, lQ
        nU  = merge(n, 1, compq == 'I' .or. compq == 'i' .or. compq == 'P' .or. compq == 'p')
        nVT = nU
        if (compq == 'N' .or. compq == 'n') then
            lwork = 4*n; lQ = 1
        else if (compq == 'P' .or. compq == 'p') then
            lwork = 6*n; lQ = max(1, n*(11 + 2*int(log(real(n,ep))/log(2.0_ep))) )
        else
            lwork = 3*n*n + 4*n; lQ = 1
        end if
        allocate(Dt(n), Et(max(1, n - 1)), Ut(ldu, nU), VTt(ldvt, nVT), &
                 Qt(lQ), work(lwork), iwork(8*n))
        Dt = q2t_r(D(1:n)); Et = q2t_r(E(1:max(1, n - 1)))
        call ${R}$bdsdc(uplo, compq, n, Dt, Et, Ut, ldu, VTt, ldvt, Qt, IQ, &
                       work, iwork, info)
        D(1:n) = t2q_r(Dt); E(1:max(1, n - 1)) = t2q_r(Et)
        if (compq /= 'N' .and. compq /= 'n') then
            U(1:ldu, 1:nU)   = t2q_r(Ut)
            VT(1:ldvt, 1:nVT) = t2q_r(VTt)
        end if
    end subroutine

    ! ── Phase 37 wrappers ────────────────────────────────────────────
    subroutine target_dgetsls(trans, m, n, nrhs, A, lda, B, ldb, info)
        character, intent(in)    :: trans
        integer,   intent(in)    :: m, n, nrhs, lda, ldb
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), Bt(ldb, nrhs))
        At = q2t_r(A(1:lda, 1:n)); Bt = q2t_r(B(1:ldb, 1:nrhs))
        call ${R}$getsls(trans, m, n, nrhs, At, lda, Bt, ldb, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$getsls(trans, m, n, nrhs, At, lda, Bt, ldb, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At); B(1:ldb, 1:nrhs) = t2q_r(Bt)
    end subroutine

    subroutine target_zgetsls(trans, m, n, nrhs, A, lda, B, ldb, info)
        character,   intent(in)    :: trans
        integer,     intent(in)    :: m, n, nrhs, lda, ldb
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), work(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), Bt(ldb, nrhs))
        At = q2t_c(A(1:lda, 1:n)); Bt = q2t_c(B(1:ldb, 1:nrhs))
        call ${C}$getsls(trans, m, n, nrhs, At, lda, Bt, ldb, wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$getsls(trans, m, n, nrhs, At, lda, Bt, ldb, work, lwork, info)
        A(1:lda, 1:n) = t2q_c(At); B(1:ldb, 1:nrhs) = t2q_c(Bt)
    end subroutine

    ! ── Phase 38 wrappers ────────────────────────────────────────────
    subroutine target_dgesvx(fact, trans, n, nrhs, A, lda, AF, ldaf, ipiv, equed, &
                             R, C, B, ldb, X, ldx, rcond, ferr, berr, info)
        character, intent(in)    :: fact, trans
        character, intent(inout) :: equed
        integer,   intent(in)    :: n, nrhs, lda, ldaf, ldb, ldx
        real(ep),  intent(inout) :: A(lda,*), AF(ldaf,*), B(ldb,*), R(*), C(*)
        integer,   intent(inout) :: ipiv(*)
        real(ep),  intent(out)   :: X(ldx,*), rcond, ferr(*), berr(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), AFt(:,:), Bt(:,:), Xt(:,:), &
                                        Rt(:), Ct(:), ferrt(:), berrt(:), work(:)
        ${target_real}$ :: rcondt
        integer, allocatable :: iwork(:)
        allocate(At(lda, n), AFt(ldaf, n), Bt(ldb, nrhs), Xt(ldx, nrhs), &
                 Rt(n), Ct(n), ferrt(nrhs), berrt(nrhs), work(4*n), iwork(n))
        At = q2t_r(A(1:lda, 1:n)); AFt = q2t_r(AF(1:ldaf, 1:n))
        Bt = q2t_r(B(1:ldb, 1:nrhs))
        Rt = q2t_r(R(1:n)); Ct = q2t_r(C(1:n))
        call ${R}$gesvx(fact, trans, n, nrhs, At, lda, AFt, ldaf, ipiv, equed, &
                       Rt, Ct, Bt, ldb, Xt, ldx, rcondt, ferrt, berrt, work, iwork, info)
        A(1:lda, 1:n) = t2q_r(At); AF(1:ldaf, 1:n) = t2q_r(AFt)
        B(1:ldb, 1:nrhs) = t2q_r(Bt); X(1:ldx, 1:nrhs) = t2q_r(Xt)
        R(1:n) = t2q_r(Rt); C(1:n) = t2q_r(Ct)
        rcond = t2q_r(rcondt)
        ferr(1:nrhs) = t2q_r(ferrt); berr(1:nrhs) = t2q_r(berrt)
    end subroutine

    subroutine target_zgesvx(fact, trans, n, nrhs, A, lda, AF, ldaf, ipiv, equed, &
                             R, C, B, ldb, X, ldx, rcond, ferr, berr, info)
        character,   intent(in)    :: fact, trans
        character,   intent(inout) :: equed
        integer,     intent(in)    :: n, nrhs, lda, ldaf, ldb, ldx
        complex(ep), intent(inout) :: A(lda,*), AF(ldaf,*), B(ldb,*)
        real(ep),    intent(inout) :: R(*), C(*)
        integer,     intent(inout) :: ipiv(*)
        complex(ep), intent(out)   :: X(ldx,*)
        real(ep),    intent(out)   :: rcond, ferr(*), berr(*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), AFt(:,:), Bt(:,:), Xt(:,:), work(:)
        ${target_real}$,    allocatable :: Rt(:), Ct(:), ferrt(:), berrt(:), rwork(:)
        ${target_real}$ :: rcondt
        allocate(At(lda, n), AFt(ldaf, n), Bt(ldb, nrhs), Xt(ldx, nrhs), &
                 Rt(n), Ct(n), ferrt(nrhs), berrt(nrhs), work(2*n), rwork(2*n))
        At = q2t_c(A(1:lda, 1:n)); AFt = q2t_c(AF(1:ldaf, 1:n))
        Bt = q2t_c(B(1:ldb, 1:nrhs))
        Rt = q2t_r(R(1:n)); Ct = q2t_r(C(1:n))
        call ${C}$gesvx(fact, trans, n, nrhs, At, lda, AFt, ldaf, ipiv, equed, &
                       Rt, Ct, Bt, ldb, Xt, ldx, rcondt, ferrt, berrt, work, rwork, info)
        A(1:lda, 1:n) = t2q_c(At); AF(1:ldaf, 1:n) = t2q_c(AFt)
        B(1:ldb, 1:nrhs) = t2q_c(Bt); X(1:ldx, 1:nrhs) = t2q_c(Xt)
        R(1:n) = t2q_r(Rt); C(1:n) = t2q_r(Ct)
        rcond = t2q_r(rcondt)
        ferr(1:nrhs) = t2q_r(ferrt); berr(1:nrhs) = t2q_r(berrt)
    end subroutine

