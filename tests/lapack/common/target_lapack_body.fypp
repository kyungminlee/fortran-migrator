    subroutine target_dtgevc(side, howmny, select, n, S, lds, P, ldp, &
                             vl, ldvl, vr, ldvr, mm, m, info)
        character, intent(in)    :: side, howmny
        integer,   intent(in)    :: n, lds, ldp, ldvl, ldvr, mm
        logical,   intent(in)    :: select(*)
        real(ep),  intent(in)    :: S(lds,*), P(ldp,*)
        real(ep),  intent(inout) :: vl(ldvl,*), vr(ldvr,*)
        integer,   intent(out)   :: m, info
        ${target_real}$, allocatable :: St(:,:), Pt(:,:), vlt(:,:), vrt(:,:), work(:)
        allocate(St(lds,n), Pt(ldp,n), vlt(ldvl,mm), vrt(ldvr,mm))
        allocate(work(6*n))
        St = q2t_r(S(1:lds,1:n)); Pt = q2t_r(P(1:ldp,1:n))
        vlt = q2t_r(vl(1:ldvl,1:mm)); vrt = q2t_r(vr(1:ldvr,1:mm))
        call ${R}$tgevc(side, howmny, select, n, St, lds, Pt, ldp, &
                        vlt, ldvl, vrt, ldvr, mm, m, work, info)
        vl(1:ldvl,1:mm) = t2q_r(vlt); vr(1:ldvr,1:mm) = t2q_r(vrt)
    end subroutine

