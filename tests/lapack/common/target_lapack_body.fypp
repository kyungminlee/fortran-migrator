    subroutine target_dsyevd(jobz, uplo, n, A, lda, w, info)
        character, intent(in)    :: jobz, uplo
        integer,   intent(in)    :: n, lda
        real(ep),  intent(inout) :: A(lda,*)
        real(ep),  intent(out)   :: w(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), wt(:), work(:)
        integer,         allocatable :: iwork(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, liwork, iwopt(1)
        allocate(At(lda, n), wt(n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$syevd(jobz, uplo, n, At, lda, wt, wopt, -1, iwopt, -1, info)
        lwork  = max(1, int(t2q_r(wopt(1))))
        liwork = max(1, iwopt(1))
        allocate(work(lwork), iwork(liwork))
        call ${R}$syevd(jobz, uplo, n, At, lda, wt, work, lwork, iwork, liwork, info)
        A(1:lda, 1:n) = t2q_r(At)
        w(1:n)        = t2q_r(wt)
    end subroutine

    subroutine target_dgeev(jobvl, jobvr, n, A, lda, wr, wi, &
                            vl, ldvl, vr, ldvr, info)
        character, intent(in)    :: jobvl, jobvr
        integer,   intent(in)    :: n, lda, ldvl, ldvr
        real(ep),  intent(inout) :: A(lda,*)
        real(ep),  intent(out)   :: wr(*), wi(*), vl(ldvl,*), vr(ldvr,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), wrt(:), wit(:), vlt(:,:), vrt(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), wrt(n), wit(n), vlt(ldvl, n), vrt(ldvr, n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$geev(jobvl, jobvr, n, At, lda, wrt, wit, vlt, ldvl, vrt, ldvr, &
                       wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$geev(jobvl, jobvr, n, At, lda, wrt, wit, vlt, ldvl, vrt, ldvr, &
                       work, lwork, info)
        A(1:lda, 1:n)    = t2q_r(At)
        wr(1:n)          = t2q_r(wrt)
        wi(1:n)          = t2q_r(wit)
        if (jobvl /= 'N' .and. jobvl /= 'n') vl(1:ldvl, 1:n) = t2q_r(vlt)
        if (jobvr /= 'N' .and. jobvr /= 'n') vr(1:ldvr, 1:n) = t2q_r(vrt)
    end subroutine

    subroutine target_dgesdd(jobz, m, n, A, lda, s, U, ldu, VT, ldvt, info)
        character, intent(in)    :: jobz
        integer,   intent(in)    :: m, n, lda, ldu, ldvt
        real(ep),  intent(inout) :: A(lda,*)
        real(ep),  intent(out)   :: s(*), U(ldu,*), VT(ldvt,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Ut(:,:), VTt(:,:), st(:), work(:)
        integer,         allocatable :: iwork(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, kmn
        kmn = min(m, n)
        allocate(At(lda, n), Ut(ldu, m), VTt(ldvt, n), st(kmn), iwork(8*kmn))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$gesdd(jobz, m, n, At, lda, st, Ut, ldu, VTt, ldvt, &
                        wopt, -1, iwork, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$gesdd(jobz, m, n, At, lda, st, Ut, ldu, VTt, ldvt, &
                        work, lwork, iwork, info)
        A(1:lda, 1:n)    = t2q_r(At)
        s(1:kmn)         = t2q_r(st)
        U(1:ldu, 1:m)    = t2q_r(Ut)
        VT(1:ldvt, 1:n)  = t2q_r(VTt)
    end subroutine

    subroutine target_dpotri(uplo, n, A, lda, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, lda
        real(ep),  intent(inout) :: A(lda,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:)
        allocate(At(lda, n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$potri(uplo, n, At, lda, info)
        A(1:lda, 1:n) = t2q_r(At)
    end subroutine

    subroutine target_dgetri(n, A, lda, ipiv, info)
        integer,  intent(in)    :: n, lda
        real(ep), intent(inout) :: A(lda,*)
        integer,  intent(in)    :: ipiv(*)
        integer,  intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$getri(n, At, lda, ipiv, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$getri(n, At, lda, ipiv, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
    end subroutine

    ! ── Phase 3 wrappers ─────────────────────────────────────────────
    subroutine target_dtrtri(uplo, diag, n, A, lda, info)
        character, intent(in)    :: uplo, diag
        integer,   intent(in)    :: n, lda
        real(ep),  intent(inout) :: A(lda,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:)
        allocate(At(lda, n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$trtri(uplo, diag, n, At, lda, info)
        A(1:lda, 1:n) = t2q_r(At)
    end subroutine

    subroutine target_dtrtrs(uplo, trans, diag, n, nrhs, A, lda, B, ldb, info)
        character, intent(in)    :: uplo, trans, diag
        integer,   intent(in)    :: n, nrhs, lda, ldb
        real(ep),  intent(in)    :: A(lda,*)
        real(ep),  intent(inout) :: B(ldb,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:)
        allocate(At(lda, n), Bt(ldb, nrhs))
        At = q2t_r(A(1:lda, 1:n))
        Bt = q2t_r(B(1:ldb, 1:nrhs))
        call ${R}$trtrs(uplo, trans, diag, n, nrhs, At, lda, Bt, ldb, info)
        B(1:ldb, 1:nrhs) = t2q_r(Bt)
    end subroutine

    subroutine target_ztrtri(uplo, diag, n, A, lda, info)
        character,   intent(in)    :: uplo, diag
        integer,     intent(in)    :: n, lda
        complex(ep), intent(inout) :: A(lda,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:)
        allocate(At(lda, n))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$trtri(uplo, diag, n, At, lda, info)
        A(1:lda, 1:n) = t2q_c(At)
    end subroutine

    subroutine target_ztrtrs(uplo, trans, diag, n, nrhs, A, lda, B, ldb, info)
        character,   intent(in)    :: uplo, trans, diag
        integer,     intent(in)    :: n, nrhs, lda, ldb
        complex(ep), intent(in)    :: A(lda,*)
        complex(ep), intent(inout) :: B(ldb,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:)
        allocate(At(lda, n), Bt(ldb, nrhs))
        At = q2t_c(A(1:lda, 1:n))
        Bt = q2t_c(B(1:ldb, 1:nrhs))
        call ${C}$trtrs(uplo, trans, diag, n, nrhs, At, lda, Bt, ldb, info)
        B(1:ldb, 1:nrhs) = t2q_c(Bt)
    end subroutine

    subroutine target_zposv(uplo, n, nrhs, A, lda, B, ldb, info)
        character,   intent(in)    :: uplo
        integer,     intent(in)    :: n, nrhs, lda, ldb
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:)
        allocate(At(lda, n), Bt(ldb, nrhs))
        At = q2t_c(A(1:lda, 1:n))
        Bt = q2t_c(B(1:ldb, 1:nrhs))
        call ${C}$posv(uplo, n, nrhs, At, lda, Bt, ldb, info)
        A(1:lda, 1:n)    = t2q_c(At)
        B(1:ldb, 1:nrhs) = t2q_c(Bt)
    end subroutine

    subroutine target_zhesv(uplo, n, nrhs, A, lda, ipiv, B, ldb, info)
        character,   intent(in)    :: uplo
        integer,     intent(in)    :: n, nrhs, lda, ldb
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*)
        integer,     intent(out)   :: ipiv(*), info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), work(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), Bt(ldb, nrhs))
        At = q2t_c(A(1:lda, 1:n))
        Bt = q2t_c(B(1:ldb, 1:nrhs))
        call ${C}$hesv(uplo, n, nrhs, At, lda, ipiv, Bt, ldb, wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$hesv(uplo, n, nrhs, At, lda, ipiv, Bt, ldb, work, lwork, info)
        A(1:lda, 1:n)    = t2q_c(At)
        B(1:ldb, 1:nrhs) = t2q_c(Bt)
    end subroutine

    subroutine target_zheevd(jobz, uplo, n, A, lda, w, info)
        character,   intent(in)    :: jobz, uplo
        integer,     intent(in)    :: n, lda
        complex(ep), intent(inout) :: A(lda,*)
        real(ep),    intent(out)   :: w(*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), work(:)
        ${target_real}$,    allocatable :: wt(:), rwork(:)
        integer,            allocatable :: iwork(:)
        ${target_complex}$ :: wopt(1)
        ${target_real}$    :: rwopt(1)
        integer :: lwork, lrwork, liwork, iwopt(1)
        allocate(At(lda, n), wt(n))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$heevd(jobz, uplo, n, At, lda, wt, wopt, -1, &
                        rwopt, -1, iwopt, -1, info)
        lwork  = max(1, int(real(t2q_c(wopt(1)), ep)))
        lrwork = max(1, int(t2q_r(rwopt(1))))
        liwork = max(1, iwopt(1))
        allocate(work(lwork), rwork(lrwork), iwork(liwork))
        call ${C}$heevd(jobz, uplo, n, At, lda, wt, work, lwork, &
                        rwork, lrwork, iwork, liwork, info)
        A(1:lda, 1:n) = t2q_c(At)
        w(1:n)        = t2q_r(wt)
    end subroutine

    subroutine target_zgeev(jobvl, jobvr, n, A, lda, w, vl, ldvl, vr, ldvr, info)
        character,   intent(in)    :: jobvl, jobvr
        integer,     intent(in)    :: n, lda, ldvl, ldvr
        complex(ep), intent(inout) :: A(lda,*)
        complex(ep), intent(out)   :: w(*), vl(ldvl,*), vr(ldvr,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), wt(:), vlt(:,:), vrt(:,:), work(:)
        ${target_real}$,    allocatable :: rwork(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), wt(n), vlt(ldvl, n), vrt(ldvr, n), rwork(max(1, 2*n)))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$geev(jobvl, jobvr, n, At, lda, wt, vlt, ldvl, vrt, ldvr, &
                       wopt, -1, rwork, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$geev(jobvl, jobvr, n, At, lda, wt, vlt, ldvl, vrt, ldvr, &
                       work, lwork, rwork, info)
        A(1:lda, 1:n) = t2q_c(At)
        w(1:n)        = t2q_c(wt)
        if (jobvl /= 'N' .and. jobvl /= 'n') vl(1:ldvl, 1:n) = t2q_c(vlt)
        if (jobvr /= 'N' .and. jobvr /= 'n') vr(1:ldvr, 1:n) = t2q_c(vrt)
    end subroutine

    subroutine target_zgesdd(jobz, m, n, A, lda, s, U, ldu, VT, ldvt, info)
        character,   intent(in)    :: jobz
        integer,     intent(in)    :: m, n, lda, ldu, ldvt
        complex(ep), intent(inout) :: A(lda,*)
        real(ep),    intent(out)   :: s(*)
        complex(ep), intent(out)   :: U(ldu,*), VT(ldvt,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Ut(:,:), VTt(:,:), work(:)
        ${target_real}$,    allocatable :: st(:), rwork(:)
        integer,            allocatable :: iwork(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork, kmn, lrwork
        kmn = min(m, n)
        ! Per LAPACK doc: jobz='A' needs lrwork >= 5*min*min + 7*min.
        lrwork = max(1, 5 * kmn * kmn + 7 * kmn)
        allocate(At(lda, n), Ut(ldu, m), VTt(ldvt, n), st(kmn), &
                 rwork(lrwork), iwork(8*kmn))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$gesdd(jobz, m, n, At, lda, st, Ut, ldu, VTt, ldvt, &
                        wopt, -1, rwork, iwork, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$gesdd(jobz, m, n, At, lda, st, Ut, ldu, VTt, ldvt, &
                        work, lwork, rwork, iwork, info)
        A(1:lda, 1:n)    = t2q_c(At)
        s(1:kmn)         = t2q_r(st)
        U(1:ldu, 1:m)    = t2q_c(Ut)
        VT(1:ldvt, 1:n)  = t2q_c(VTt)
    end subroutine

    subroutine target_zgels(trans, m, n, nrhs, A, lda, B, ldb, info)
        character,   intent(in)    :: trans
        integer,     intent(in)    :: m, n, nrhs, lda, ldb
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), work(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), Bt(ldb, nrhs))
        At = q2t_c(A(1:lda, 1:n))
        Bt = q2t_c(B(1:ldb, 1:nrhs))
        call ${C}$gels(trans, m, n, nrhs, At, lda, Bt, ldb, wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$gels(trans, m, n, nrhs, At, lda, Bt, ldb, work, lwork, info)
        A(1:lda, 1:n)    = t2q_c(At)
        B(1:ldb, 1:nrhs) = t2q_c(Bt)
    end subroutine

    ! ── Phase 4 wrappers ─────────────────────────────────────────────
    subroutine target_dsyevr(jobz, range, uplo, n, A, lda, vl, vu, il, iu, &
                             abstol, m, w, z, ldz, isuppz, info)
        character, intent(in)    :: jobz, range, uplo
        integer,   intent(in)    :: n, lda, il, iu, ldz
        real(ep),  intent(in)    :: vl, vu, abstol
        real(ep),  intent(inout) :: A(lda,*)
        integer,   intent(out)   :: m, isuppz(*), info
        real(ep),  intent(out)   :: w(*), z(ldz,*)
        ${target_real}$, allocatable :: At(:,:), wt(:), zt(:,:), work(:)
        integer,         allocatable :: iwork(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, liwork, iwopt(1)
        allocate(At(lda, n), wt(n), zt(ldz, n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$syevr(jobz, range, uplo, n, At, lda, q2t_r(vl), q2t_r(vu), &
                        il, iu, q2t_r(abstol), m, wt, zt, ldz, isuppz, &
                        wopt, -1, iwopt, -1, info)
        lwork  = max(1, int(t2q_r(wopt(1))))
        liwork = max(1, iwopt(1))
        allocate(work(lwork), iwork(liwork))
        call ${R}$syevr(jobz, range, uplo, n, At, lda, q2t_r(vl), q2t_r(vu), &
                        il, iu, q2t_r(abstol), m, wt, zt, ldz, isuppz, &
                        work, lwork, iwork, liwork, info)
        A(1:lda, 1:n) = t2q_r(At)
        w(1:n)        = t2q_r(wt)
        if (jobz /= 'N' .and. jobz /= 'n') z(1:ldz, 1:n) = t2q_r(zt)
    end subroutine

    subroutine target_zheevr(jobz, range, uplo, n, A, lda, vl, vu, il, iu, &
                             abstol, m, w, z, ldz, isuppz, info)
        character,   intent(in)    :: jobz, range, uplo
        integer,     intent(in)    :: n, lda, il, iu, ldz
        real(ep),    intent(in)    :: vl, vu, abstol
        complex(ep), intent(inout) :: A(lda,*)
        integer,     intent(out)   :: m, isuppz(*), info
        real(ep),    intent(out)   :: w(*)
        complex(ep), intent(out)   :: z(ldz,*)
        ${target_complex}$, allocatable :: At(:,:), zt(:,:), work(:)
        ${target_real}$,    allocatable :: wt(:), rwork(:)
        integer,            allocatable :: iwork(:)
        ${target_complex}$ :: wopt(1)
        ${target_real}$    :: rwopt(1)
        integer :: lwork, lrwork, liwork, iwopt(1)
        allocate(At(lda, n), zt(ldz, n), wt(n))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$heevr(jobz, range, uplo, n, At, lda, q2t_r(vl), q2t_r(vu), &
                        il, iu, q2t_r(abstol), m, wt, zt, ldz, isuppz, &
                        wopt, -1, rwopt, -1, iwopt, -1, info)
        lwork  = max(1, int(real(t2q_c(wopt(1)), ep)))
        lrwork = max(1, int(t2q_r(rwopt(1))))
        liwork = max(1, iwopt(1))
        allocate(work(lwork), rwork(lrwork), iwork(liwork))
        call ${C}$heevr(jobz, range, uplo, n, At, lda, q2t_r(vl), q2t_r(vu), &
                        il, iu, q2t_r(abstol), m, wt, zt, ldz, isuppz, &
                        work, lwork, rwork, lrwork, iwork, liwork, info)
        A(1:lda, 1:n) = t2q_c(At)
        w(1:n)        = t2q_r(wt)
        if (jobz /= 'N' .and. jobz /= 'n') z(1:ldz, 1:n) = t2q_c(zt)
    end subroutine

    subroutine target_dsygv(itype, jobz, uplo, n, A, lda, B, ldb, w, info)
        character, intent(in)    :: jobz, uplo
        integer,   intent(in)    :: itype, n, lda, ldb
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*)
        real(ep),  intent(out)   :: w(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), wt(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), Bt(ldb, n), wt(n))
        At = q2t_r(A(1:lda, 1:n))
        Bt = q2t_r(B(1:ldb, 1:n))
        call ${R}$sygv(itype, jobz, uplo, n, At, lda, Bt, ldb, wt, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$sygv(itype, jobz, uplo, n, At, lda, Bt, ldb, wt, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
        B(1:ldb, 1:n) = t2q_r(Bt)
        w(1:n)        = t2q_r(wt)
    end subroutine

    subroutine target_zhegv(itype, jobz, uplo, n, A, lda, B, ldb, w, info)
        character,   intent(in)    :: jobz, uplo
        integer,     intent(in)    :: itype, n, lda, ldb
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*)
        real(ep),    intent(out)   :: w(*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), work(:)
        ${target_real}$,    allocatable :: wt(:), rwork(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), Bt(ldb, n), wt(n), rwork(max(1, 3*n - 2)))
        At = q2t_c(A(1:lda, 1:n))
        Bt = q2t_c(B(1:ldb, 1:n))
        call ${C}$hegv(itype, jobz, uplo, n, At, lda, Bt, ldb, wt, &
                       wopt, -1, rwork, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$hegv(itype, jobz, uplo, n, At, lda, Bt, ldb, wt, &
                       work, lwork, rwork, info)
        A(1:lda, 1:n) = t2q_c(At)
        B(1:ldb, 1:n) = t2q_c(Bt)
        w(1:n)        = t2q_r(wt)
    end subroutine

    subroutine target_dgehrd(n, ilo, ihi, A, lda, tau, info)
        integer,  intent(in)    :: n, ilo, ihi, lda
        real(ep), intent(inout) :: A(lda,*)
        real(ep), intent(out)   :: tau(*)
        integer,  intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), taut(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), taut(max(1, n-1)))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$gehrd(n, ilo, ihi, At, lda, taut, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$gehrd(n, ilo, ihi, At, lda, taut, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
        tau(1:max(1, n-1)) = t2q_r(taut)
    end subroutine

    subroutine target_dorghr(n, ilo, ihi, A, lda, tau, info)
        integer,  intent(in)    :: n, ilo, ihi, lda
        real(ep), intent(inout) :: A(lda,*)
        real(ep), intent(in)    :: tau(*)
        integer,  intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), taut(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, ntau
        ntau = max(1, n - 1)
        allocate(At(lda, n), taut(ntau))
        At = q2t_r(A(1:lda, 1:n))
        taut = q2t_r(tau(1:ntau))
        call ${R}$orghr(n, ilo, ihi, At, lda, taut, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$orghr(n, ilo, ihi, At, lda, taut, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
    end subroutine

