    subroutine target_dtgexc(wantq, wantz, n, A, lda, B, ldb, Q, ldq, Z, ldz, &
                             ifst, ilst, info)
        logical,   intent(in)    :: wantq, wantz
        integer,   intent(in)    :: n, lda, ldb, ldq, ldz
        integer,   intent(inout) :: ifst, ilst
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*), Q(ldq,*), Z(ldz,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), Qt(:,:), Zt(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda,n), Bt(ldb,n), Qt(ldq,n), Zt(ldz,n))
        At = q2t_r(A(1:lda,1:n)); Bt = q2t_r(B(1:ldb,1:n))
        Qt = q2t_r(Q(1:ldq,1:n)); Zt = q2t_r(Z(1:ldz,1:n))
        call ${R}$tgexc(wantq, wantz, n, At, lda, Bt, ldb, Qt, ldq, Zt, ldz, &
                        ifst, ilst, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1)))); allocate(work(lwork))
        call ${R}$tgexc(wantq, wantz, n, At, lda, Bt, ldb, Qt, ldq, Zt, ldz, &
                        ifst, ilst, work, lwork, info)
        A(1:lda,1:n) = t2q_r(At); B(1:ldb,1:n) = t2q_r(Bt)
        Q(1:ldq,1:n) = t2q_r(Qt); Z(1:ldz,1:n) = t2q_r(Zt)
    end subroutine

