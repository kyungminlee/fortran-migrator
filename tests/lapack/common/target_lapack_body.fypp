    subroutine target_dsbgvd(jobz, uplo, n, ka, kb, AB, ldab, BB, ldbb, W, Z, ldz, info)
        character, intent(in)    :: jobz, uplo
        integer,   intent(in)    :: n, ka, kb, ldab, ldbb, ldz
        real(ep),  intent(inout) :: AB(ldab,*), BB(ldbb,*)
        real(ep),  intent(out)   :: W(*), Z(ldz,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: ABt(:,:), BBt(:,:), Wt(:), Zt(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer, allocatable :: iwork(:)
        integer :: lwork, liwork, iwopt(1)
        allocate(ABt(ldab, n), BBt(ldbb, n), Wt(n), Zt(ldz, n))
        ABt = q2t_r(AB(1:ldab, 1:n)); BBt = q2t_r(BB(1:ldbb, 1:n))
        call ${R}$sbgvd(jobz, uplo, n, ka, kb, ABt, ldab, BBt, ldbb, Wt, Zt, ldz, &
                       wopt, -1, iwopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1)))); liwork = max(1, iwopt(1))
        allocate(work(lwork), iwork(liwork))
        call ${R}$sbgvd(jobz, uplo, n, ka, kb, ABt, ldab, BBt, ldbb, Wt, Zt, ldz, &
                       work, lwork, iwork, liwork, info)
        AB(1:ldab, 1:n) = t2q_r(ABt); BB(1:ldbb, 1:n) = t2q_r(BBt)
        W(1:n) = t2q_r(Wt)
        if (jobz == 'V' .or. jobz == 'v') Z(1:ldz, 1:n) = t2q_r(Zt)
    end subroutine

    subroutine target_zhbgvd(jobz, uplo, n, ka, kb, AB, ldab, BB, ldbb, W, Z, ldz, info)
        character,   intent(in)    :: jobz, uplo
        integer,     intent(in)    :: n, ka, kb, ldab, ldbb, ldz
        complex(ep), intent(inout) :: AB(ldab,*), BB(ldbb,*)
        real(ep),    intent(out)   :: W(*)
        complex(ep), intent(out)   :: Z(ldz,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: ABt(:,:), BBt(:,:), Zt(:,:), work(:)
        ${target_complex}$ :: wopt(1)
        ${target_real}$,    allocatable :: Wt(:), rwork(:)
        ${target_real}$ :: rwopt(1)
        integer, allocatable :: iwork(:)
        integer :: lwork, lrwork, liwork, iwopt(1)
        allocate(ABt(ldab, n), BBt(ldbb, n), Wt(n), Zt(ldz, n))
        ABt = q2t_c(AB(1:ldab, 1:n)); BBt = q2t_c(BB(1:ldbb, 1:n))
        call ${C}$hbgvd(jobz, uplo, n, ka, kb, ABt, ldab, BBt, ldbb, Wt, Zt, ldz, &
                       wopt, -1, rwopt, -1, iwopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        lrwork = max(1, int(t2q_r(rwopt(1)))); liwork = max(1, iwopt(1))
        allocate(work(lwork), rwork(lrwork), iwork(liwork))
        call ${C}$hbgvd(jobz, uplo, n, ka, kb, ABt, ldab, BBt, ldbb, Wt, Zt, ldz, &
                       work, lwork, rwork, lrwork, iwork, liwork, info)
        AB(1:ldab, 1:n) = t2q_c(ABt); BB(1:ldbb, 1:n) = t2q_c(BBt)
        W(1:n) = t2q_r(Wt)
        if (jobz == 'V' .or. jobz == 'v') Z(1:ldz, 1:n) = t2q_c(Zt)
    end subroutine

    ! ── Phase 26 wrappers ────────────────────────────────────────────
    subroutine target_dsterf(n, D, E, info)
        integer,  intent(in)    :: n
        real(ep), intent(inout) :: D(*), E(*)
        integer,  intent(out)   :: info
        ${target_real}$, allocatable :: Dt(:), Et(:)
        allocate(Dt(n), Et(max(1, n - 1)))
        Dt = q2t_r(D(1:n)); Et = q2t_r(E(1:max(1, n - 1)))
        call ${R}$sterf(n, Dt, Et, info)
        D(1:n) = t2q_r(Dt); E(1:max(1, n - 1)) = t2q_r(Et)
    end subroutine

    subroutine target_dsteqr(compz, n, D, E, Z, ldz, info)
        character, intent(in)    :: compz
        integer,   intent(in)    :: n, ldz
        real(ep),  intent(inout) :: D(*), E(*), Z(ldz,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: Dt(:), Et(:), Zt(:,:), work(:)
        integer :: nz, lwork
        nz = merge(n, 1, compz == 'V' .or. compz == 'v' .or. compz == 'I' .or. compz == 'i')
        lwork = merge(max(1, 2*n - 2), 1, compz == 'V' .or. compz == 'v' &
                                          .or. compz == 'I' .or. compz == 'i')
        allocate(Dt(n), Et(max(1, n - 1)), Zt(ldz, nz), work(lwork))
        Dt = q2t_r(D(1:n)); Et = q2t_r(E(1:max(1, n - 1)))
        if (compz == 'V' .or. compz == 'v') Zt = q2t_r(Z(1:ldz, 1:nz))
        call ${R}$steqr(compz, n, Dt, Et, Zt, ldz, work, info)
        D(1:n) = t2q_r(Dt); E(1:max(1, n - 1)) = t2q_r(Et)
        if (compz /= 'N' .and. compz /= 'n') Z(1:ldz, 1:nz) = t2q_r(Zt)
    end subroutine

