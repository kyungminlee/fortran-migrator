        call ${C}$ggqrf(n, m, p, At, lda, tauat, Bt, ldb, taubt, wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$ggqrf(n, m, p, At, lda, tauat, Bt, ldb, taubt, work, lwork, info)
        A(1:lda, 1:m) = t2q_c(At); B(1:ldb, 1:p) = t2q_c(Bt)
        taua(1:min(n,m)) = t2q_c(tauat); taub(1:min(n,p)) = t2q_c(taubt)
    end subroutine

