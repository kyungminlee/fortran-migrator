        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:)
        ${target_real}$,    allocatable :: lst(:), rst(:), work(:)
        allocate(At(lda, n), Bt(ldb, n), lst(n), rst(n), work(6*n))
