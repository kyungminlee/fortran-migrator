        ${target_complex}$, allocatable :: Zt(:,:)
        integer :: nz, lwork
        nz = merge(n, 1, compz == 'V' .or. compz == 'v' .or. compz == 'I' .or. compz == 'i')
        lwork = merge(max(1, 2*n - 2), 1, compz == 'V' .or. compz == 'v' &
                                          .or. compz == 'I' .or. compz == 'i')
        allocate(Dt(n), Et(max(1, n - 1)), Zt(ldz, nz), work(lwork))
        Dt = q2t_r(D(1:n)); Et = q2t_r(E(1:max(1, n - 1)))
        if (compz == 'V' .or. compz == 'v') Zt = q2t_c(Z(1:ldz, 1:nz))
        call ${C}$steqr(compz, n, Dt, Et, Zt, ldz, work, info)
        D(1:n) = t2q_r(Dt); E(1:max(1, n - 1)) = t2q_r(Et)
        if (compz /= 'N' .and. compz /= 'n') Z(1:ldz, 1:nz) = t2q_c(Zt)
    end subroutine

    subroutine target_dstedc(compz, n, D, E, Z, ldz, info)
        character, intent(in)    :: compz
        integer,   intent(in)    :: n, ldz
        real(ep),  intent(inout) :: D(*), E(*), Z(ldz,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: Dt(:), Et(:), Zt(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer, allocatable :: iwork(:)
        integer :: nz, lwork, liwork, iwopt(1)
        nz = merge(n, 1, compz == 'V' .or. compz == 'v' .or. compz == 'I' .or. compz == 'i')
        allocate(Dt(n), Et(max(1, n - 1)), Zt(ldz, nz))
        Dt = q2t_r(D(1:n)); Et = q2t_r(E(1:max(1, n - 1)))
        if (compz == 'V' .or. compz == 'v') Zt = q2t_r(Z(1:ldz, 1:nz))
        call ${R}$stedc(compz, n, Dt, Et, Zt, ldz, wopt, -1, iwopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1)))); liwork = max(1, iwopt(1))
        allocate(work(lwork), iwork(liwork))
        call ${R}$stedc(compz, n, Dt, Et, Zt, ldz, work, lwork, iwork, liwork, info)
        D(1:n) = t2q_r(Dt); E(1:max(1, n - 1)) = t2q_r(Et)
        if (compz /= 'N' .and. compz /= 'n') Z(1:ldz, 1:nz) = t2q_r(Zt)
    end subroutine

    subroutine target_zstedc(compz, n, D, E, Z, ldz, info)
        character,   intent(in)    :: compz
        integer,     intent(in)    :: n, ldz
        real(ep),    intent(inout) :: D(*), E(*)
        complex(ep), intent(inout) :: Z(ldz,*)
        integer,     intent(out)   :: info
        ${target_real}$,    allocatable :: Dt(:), Et(:), rwork(:)
        ${target_complex}$, allocatable :: Zt(:,:), work(:)
        ${target_complex}$ :: wopt(1)
        ${target_real}$ :: rwopt(1)
        integer, allocatable :: iwork(:)
        integer :: nz, lwork, lrwork, liwork, iwopt(1)
        nz = merge(n, 1, compz == 'V' .or. compz == 'v' .or. compz == 'I' .or. compz == 'i')
        allocate(Dt(n), Et(max(1, n - 1)), Zt(ldz, nz))
        Dt = q2t_r(D(1:n)); Et = q2t_r(E(1:max(1, n - 1)))
        if (compz == 'V' .or. compz == 'v') Zt = q2t_c(Z(1:ldz, 1:nz))
        call ${C}$stedc(compz, n, Dt, Et, Zt, ldz, wopt, -1, rwopt, -1, iwopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        lrwork = max(1, int(t2q_r(rwopt(1)))); liwork = max(1, iwopt(1))
        allocate(work(lwork), rwork(lrwork), iwork(liwork))
        call ${C}$stedc(compz, n, Dt, Et, Zt, ldz, work, lwork, rwork, lrwork, &
                       iwork, liwork, info)
        D(1:n) = t2q_r(Dt); E(1:max(1, n - 1)) = t2q_r(Et)
        if (compz /= 'N' .and. compz /= 'n') Z(1:ldz, 1:nz) = t2q_c(Zt)
    end subroutine

    subroutine target_dstebz(range, order, n, vl, vu, il, iu, abstol, D, E, &
                             m, nsplit, W, iblock, isplit, info)
        character, intent(in)  :: range, order
        integer,   intent(in)  :: n, il, iu
        real(ep),  intent(in)  :: vl, vu, abstol, D(*), E(*)
        integer,   intent(out) :: m, nsplit
        real(ep),  intent(out) :: W(*)
        integer,   intent(out) :: iblock(*), isplit(*), info
        ${target_real}$, allocatable :: Dt(:), Et(:), Wt(:), work(:)
        integer, allocatable :: iworkt(:)
        allocate(Dt(n), Et(max(1, n - 1)), Wt(n), work(4*n), iworkt(3*n))
        Dt = q2t_r(D(1:n)); Et = q2t_r(E(1:max(1, n - 1)))
        call ${R}$stebz(range, order, n, q2t_r(vl), q2t_r(vu), il, iu, &
                       q2t_r(abstol), Dt, Et, m, nsplit, Wt, iblock, isplit, &
                       work, iworkt, info)
        W(1:n) = t2q_r(Wt)
    end subroutine

    ! ── Phase 27 wrappers ────────────────────────────────────────────
    subroutine target_dbdsqr(uplo, n, ncvt, nru, ncc, D, E, VT, ldvt, U, ldu, &
                             C, ldc, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, ncvt, nru, ncc, ldvt, ldu, ldc
        real(ep),  intent(inout) :: D(*), E(*), VT(ldvt,*), U(ldu,*), C(ldc,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: Dt(:), Et(:), VTt(:,:), Ut(:,:), Ct(:,:), work(:)
        integer :: nVT, nU, nC
        nVT = max(1, ncvt); nU = max(1, nru); nC = max(1, ncc)
        allocate(Dt(n), Et(max(1, n - 1)), VTt(ldvt, nVT), Ut(ldu, n), &
                 Ct(ldc, nC), work(4*n))
        Dt = q2t_r(D(1:n)); Et = q2t_r(E(1:max(1, n - 1)))
        if (ncvt > 0) VTt = q2t_r(VT(1:ldvt, 1:nVT))
        if (nru  > 0) Ut  = q2t_r(U(1:ldu, 1:n))
        if (ncc  > 0) Ct  = q2t_r(C(1:ldc, 1:nC))
        call ${R}$bdsqr(uplo, n, ncvt, nru, ncc, Dt, Et, VTt, ldvt, Ut, ldu, &
                       Ct, ldc, work, info)
        D(1:n) = t2q_r(Dt); E(1:max(1, n - 1)) = t2q_r(Et)
        if (ncvt > 0) VT(1:ldvt, 1:nVT) = t2q_r(VTt)
        if (nru  > 0) U(1:ldu, 1:n)     = t2q_r(Ut)
        if (ncc  > 0) C(1:ldc, 1:nC)    = t2q_r(Ct)
    end subroutine

    subroutine target_zbdsqr(uplo, n, ncvt, nru, ncc, D, E, VT, ldvt, U, ldu, &
                             C, ldc, info)
        character,   intent(in)    :: uplo
        integer,     intent(in)    :: n, ncvt, nru, ncc, ldvt, ldu, ldc
        real(ep),    intent(inout) :: D(*), E(*)
        complex(ep), intent(inout) :: VT(ldvt,*), U(ldu,*), C(ldc,*)
        integer,     intent(out)   :: info
        ${target_real}$,    allocatable :: Dt(:), Et(:), rwork(:)
        ${target_complex}$, allocatable :: VTt(:,:), Ut(:,:), Ct(:,:)
        integer :: nVT, nU, nC
        nVT = max(1, ncvt); nU = max(1, nru); nC = max(1, ncc)
        allocate(Dt(n), Et(max(1, n - 1)), VTt(ldvt, nVT), Ut(ldu, n), &
                 Ct(ldc, nC), rwork(4*n))
        Dt = q2t_r(D(1:n)); Et = q2t_r(E(1:max(1, n - 1)))
        if (ncvt > 0) VTt = q2t_c(VT(1:ldvt, 1:nVT))
        if (nru  > 0) Ut  = q2t_c(U(1:ldu, 1:n))
        if (ncc  > 0) Ct  = q2t_c(C(1:ldc, 1:nC))
        call ${C}$bdsqr(uplo, n, ncvt, nru, ncc, Dt, Et, VTt, ldvt, Ut, ldu, &
                       Ct, ldc, rwork, info)
        D(1:n) = t2q_r(Dt); E(1:max(1, n - 1)) = t2q_r(Et)
        if (ncvt > 0) VT(1:ldvt, 1:nVT) = t2q_c(VTt)
        if (nru  > 0) U(1:ldu, 1:n)     = t2q_c(Ut)
        if (ncc  > 0) C(1:ldc, 1:nC)    = t2q_c(Ct)
    end subroutine

    ! ── Phase 28 wrappers ────────────────────────────────────────────
    subroutine target_ddisna(job, m, n, D, sep, info)
        character, intent(in)  :: job
        integer,   intent(in)  :: m, n
        real(ep),  intent(in)  :: D(*)
        real(ep),  intent(out) :: sep(*)
        integer,   intent(out) :: info
        ${target_real}$, allocatable :: Dt(:), sept(:)
        integer :: nlen
        nlen = min(m, n)
        allocate(Dt(nlen), sept(nlen))
        Dt = q2t_r(D(1:nlen))
        call ${R}$disna(job, m, n, Dt, sept, info)
        sep(1:nlen) = t2q_r(sept)
    end subroutine

