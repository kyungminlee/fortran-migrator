    subroutine target_dsfrk(transr, uplo, trans, n, k, alpha, A, lda, beta, C)
        character, intent(in)    :: transr, uplo, trans
        integer,   intent(in)    :: n, k, lda
        real(ep),  intent(in)    :: alpha, beta, A(lda,*)
        real(ep),  intent(inout) :: C(0:*)
        integer :: nt, ar
        ${target_real}$, allocatable :: At(:,:), Ct(:)
        nt = n*(n+1)/2
        ar = merge(n, k, trans == 'N' .or. trans == 'n')
        allocate(At(lda, max(1, merge(k, n, trans == 'N' .or. trans == 'n'))), Ct(0:nt-1))
        At = q2t_r(A(1:lda, 1:size(At, 2)))
        Ct = q2t_r(C(0:nt-1))
        call ${R}$sfrk(transr, uplo, trans, n, k, q2t_r(alpha), At, lda, q2t_r(beta), Ct)
        C(0:nt-1) = t2q_r(Ct)
    end subroutine

