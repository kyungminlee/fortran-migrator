    subroutine target_dgtcon(norm, n, dl, d, du, du2, ipiv, anorm, rcond, info)
        character, intent(in)  :: norm
        integer,   intent(in)  :: n
        real(ep),  intent(in)  :: dl(*), d(*), du(*), du2(*), anorm
        integer,   intent(in)  :: ipiv(*)
        real(ep),  intent(out) :: rcond
        integer,   intent(out) :: info
        ${target_real}$, allocatable :: dlt(:), dt(:), dut(:), du2t(:), work(:)
        ${target_real}$ :: rct
        integer, allocatable :: iwork(:)
        allocate(dlt(n-1), dt(n), dut(n-1), du2t(n-2), work(2*n), iwork(n))
        dlt = q2t_r(dl(1:n-1)); dt = q2t_r(d(1:n)); dut = q2t_r(du(1:n-1))
        du2t = q2t_r(du2(1:n-2))
        call ${R}$gtcon(norm, n, dlt, dt, dut, du2t, ipiv, q2t_r(anorm), rct, &
                        work, iwork, info)
        rcond = t2q_r(rct)
