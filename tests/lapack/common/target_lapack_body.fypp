        call ${C}$getrf(m, n, At, lda, ipiv, info)
        A(1:lda, 1:n) = t2q_c(At)
    end subroutine

    subroutine target_zgetrs(trans, n, nrhs, A, lda, ipiv, B, ldb, info)
        character,   intent(in)    :: trans
        integer,     intent(in)    :: n, nrhs, lda, ldb
        complex(ep), intent(in)    :: A(lda,*)
        integer,     intent(in)    :: ipiv(*)
        complex(ep), intent(inout) :: B(ldb,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:)
        allocate(At(lda, n), Bt(ldb, nrhs))
        At = q2t_c(A(1:lda, 1:n))
        Bt = q2t_c(B(1:ldb, 1:nrhs))
        call ${C}$getrs(trans, n, nrhs, At, lda, ipiv, Bt, ldb, info)
        B(1:ldb, 1:nrhs) = t2q_c(Bt)
