    ! ── Phase 9 wrappers ─────────────────────────────────────────────
    subroutine target_dsptrf(uplo, n, AP, ipiv, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n
        real(ep),  intent(inout) :: AP(*)
        integer,   intent(out)   :: ipiv(*), info
        ${target_real}$, allocatable :: APt(:)
        integer :: np
        np = n*(n+1)/2
        allocate(APt(np))
        APt = q2t_r(AP(1:np))
        call ${R}$sptrf(uplo, n, APt, ipiv, info)
        AP(1:np) = t2q_r(APt)
    end subroutine

    subroutine target_dsptrs(uplo, n, nrhs, AP, ipiv, B, ldb, info)
        character, intent(in)    :: uplo
