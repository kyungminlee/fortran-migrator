        ct = q2t_c(c(1:m)); dt = q2t_c(d(1:p))
        call ${C}$gglse(m, n, p, At, lda, Bt, ldb, ct, dt, xt, wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        call ${C}$gglse(m, n, p, At, lda, Bt, ldb, ct, dt, xt, work, lwork, info)
