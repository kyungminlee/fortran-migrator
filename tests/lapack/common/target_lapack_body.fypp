    subroutine target_dgecon(norm, n, A, lda, anorm, rcond, info)
        character, intent(in)  :: norm
        integer,   intent(in)  :: n, lda
        real(ep),  intent(in)  :: A(lda,*), anorm
        real(ep),  intent(out) :: rcond
        integer,   intent(out) :: info
        ${target_real}$, allocatable :: At(:,:), work(:)
        ${target_real}$ :: rct
        integer, allocatable :: iwork(:)
        allocate(At(lda, n), work(4*n), iwork(n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$gecon(norm, n, At, lda, q2t_r(anorm), rct, work, iwork, info)
        rcond = t2q_r(rct)
    end subroutine

    subroutine target_zgecon(norm, n, A, lda, anorm, rcond, info)
        character,   intent(in)  :: norm
        integer,     intent(in)  :: n, lda
