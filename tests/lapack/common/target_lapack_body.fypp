    end subroutine

    subroutine target_dsbevx(jobz, range, uplo, n, kd, AB, ldab, Q, ldq, &
                             vl, vu, il, iu, abstol, m, w, z, ldz, ifail, info)
        character, intent(in)    :: jobz, range, uplo
        integer,   intent(in)    :: n, kd, ldab, ldq, il, iu, ldz
        real(ep),  intent(in)    :: vl, vu, abstol
        real(ep),  intent(inout) :: AB(ldab,*)
        real(ep),  intent(out)   :: Q(ldq,*), w(*), z(ldz,*)
        integer,   intent(out)   :: m, ifail(*), info
        ${target_real}$, allocatable :: ABt(:,:), Qt(:,:), wt(:), zt(:,:), work(:)
        integer,         allocatable :: iwork(:)
        allocate(ABt(ldab, n), Qt(ldq, n), wt(n), zt(ldz, n), &
                 work(max(1, 7*n)), iwork(5*n))
        ABt = q2t_r(AB(1:ldab, 1:n))
        call ${R}$sbevx(jobz, range, uplo, n, kd, ABt, ldab, Qt, ldq, &
                        q2t_r(vl), q2t_r(vu), il, iu, q2t_r(abstol), &
                        m, wt, zt, ldz, work, iwork, ifail, info)
        AB(1:ldab, 1:n) = t2q_r(ABt)
        if (jobz /= 'N' .and. jobz /= 'n') Q(1:ldq, 1:n) = t2q_r(Qt)
        w(1:n) = t2q_r(wt)
        if (jobz /= 'N' .and. jobz /= 'n') z(1:ldz, 1:n) = t2q_r(zt)
    end subroutine

    subroutine target_zhbev(jobz, uplo, n, kd, AB, ldab, w, z, ldz, info)
        character,   intent(in)    :: jobz, uplo
        integer,     intent(in)    :: n, kd, ldab, ldz
        complex(ep), intent(inout) :: AB(ldab,*)
        real(ep),    intent(out)   :: w(*)
        complex(ep), intent(out)   :: z(ldz,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: ABt(:,:), zt(:,:), work(:)
        ${target_real}$,    allocatable :: wt(:), rwork(:)
        integer :: lrw
        lrw = max(1, 3*n - 2)
        allocate(ABt(ldab, n), zt(ldz, n), wt(n), &
                 work(max(1, n)), rwork(lrw))
        ABt = q2t_c(AB(1:ldab, 1:n))
        call ${C}$hbev(jobz, uplo, n, kd, ABt, ldab, wt, zt, ldz, &
                       work, rwork, info)
        AB(1:ldab, 1:n) = t2q_c(ABt)
        w(1:n) = t2q_r(wt)
        if (jobz /= 'N' .and. jobz /= 'n') z(1:ldz, 1:n) = t2q_c(zt)
    end subroutine

    subroutine target_zhbevd(jobz, uplo, n, kd, AB, ldab, w, z, ldz, info)
        character,   intent(in)    :: jobz, uplo
        integer,     intent(in)    :: n, kd, ldab, ldz
        complex(ep), intent(inout) :: AB(ldab,*)
        real(ep),    intent(out)   :: w(*)
        complex(ep), intent(out)   :: z(ldz,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: ABt(:,:), zt(:,:), work(:)
        ${target_real}$,    allocatable :: wt(:), rwork(:)
        integer,            allocatable :: iwork(:)
        ${target_complex}$ :: wopt(1)
        ${target_real}$    :: rwopt(1)
        integer :: lwork, lrwork, liwork, iwopt(1)
        allocate(ABt(ldab, n), zt(ldz, n), wt(n))
        ABt = q2t_c(AB(1:ldab, 1:n))
        call ${C}$hbevd(jobz, uplo, n, kd, ABt, ldab, wt, zt, ldz, &
                        wopt, -1, rwopt, -1, iwopt, -1, info)
        lwork  = max(1, int(real(t2q_c(wopt(1)), ep)))
        lrwork = max(1, int(t2q_r(rwopt(1))))
        liwork = max(1, iwopt(1))
        allocate(work(lwork), rwork(lrwork), iwork(liwork))
        call ${C}$hbevd(jobz, uplo, n, kd, ABt, ldab, wt, zt, ldz, &
                        work, lwork, rwork, lrwork, iwork, liwork, info)
        AB(1:ldab, 1:n) = t2q_c(ABt)
        w(1:n) = t2q_r(wt)
        if (jobz /= 'N' .and. jobz /= 'n') z(1:ldz, 1:n) = t2q_c(zt)
    end subroutine

    subroutine target_zhbevx(jobz, range, uplo, n, kd, AB, ldab, Q, ldq, &
                             vl, vu, il, iu, abstol, m, w, z, ldz, ifail, info)
        character,   intent(in)    :: jobz, range, uplo
        integer,     intent(in)    :: n, kd, ldab, ldq, il, iu, ldz
        real(ep),    intent(in)    :: vl, vu, abstol
        complex(ep), intent(inout) :: AB(ldab,*)
        complex(ep), intent(out)   :: Q(ldq,*), z(ldz,*)
        real(ep),    intent(out)   :: w(*)
        integer,     intent(out)   :: m, ifail(*), info
        ${target_complex}$, allocatable :: ABt(:,:), Qt(:,:), zt(:,:), work(:)
        ${target_real}$,    allocatable :: wt(:), rwork(:)
        integer,            allocatable :: iwork(:)
        allocate(ABt(ldab, n), Qt(ldq, n), zt(ldz, n), wt(n), &
                 work(max(1, n)), rwork(max(1, 7*n)), iwork(5*n))
        ABt = q2t_c(AB(1:ldab, 1:n))
        call ${C}$hbevx(jobz, range, uplo, n, kd, ABt, ldab, Qt, ldq, &
                        q2t_r(vl), q2t_r(vu), il, iu, q2t_r(abstol), &
                        m, wt, zt, ldz, work, rwork, iwork, ifail, info)
        AB(1:ldab, 1:n) = t2q_c(ABt)
        if (jobz /= 'N' .and. jobz /= 'n') Q(1:ldq, 1:n) = t2q_c(Qt)
        w(1:n) = t2q_r(wt)
        if (jobz /= 'N' .and. jobz /= 'n') z(1:ldz, 1:n) = t2q_c(zt)
    end subroutine

    subroutine target_dspev(jobz, uplo, n, AP, w, z, ldz, info)
        character, intent(in)    :: jobz, uplo
        integer,   intent(in)    :: n, ldz
        real(ep),  intent(inout) :: AP(*)
        real(ep),  intent(out)   :: w(*), z(ldz,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: APt(:), wt(:), zt(:,:), work(:)
        integer :: np
        np = n*(n+1)/2
        allocate(APt(np), wt(n), zt(ldz, n), work(max(1, 3*n)))
        APt = q2t_r(AP(1:np))
        call ${R}$spev(jobz, uplo, n, APt, wt, zt, ldz, work, info)
        AP(1:np) = t2q_r(APt)
        w(1:n)   = t2q_r(wt)
        if (jobz /= 'N' .and. jobz /= 'n') z(1:ldz, 1:n) = t2q_r(zt)
    end subroutine

    subroutine target_dspevd(jobz, uplo, n, AP, w, z, ldz, info)
        character, intent(in)    :: jobz, uplo
        integer,   intent(in)    :: n, ldz
        real(ep),  intent(inout) :: AP(*)
        real(ep),  intent(out)   :: w(*), z(ldz,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: APt(:), wt(:), zt(:,:), work(:)
        integer,         allocatable :: iwork(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, liwork, iwopt(1), np
        np = n*(n+1)/2
        allocate(APt(np), wt(n), zt(ldz, n))
        APt = q2t_r(AP(1:np))
        call ${R}$spevd(jobz, uplo, n, APt, wt, zt, ldz, &
                        wopt, -1, iwopt, -1, info)
        lwork  = max(1, int(t2q_r(wopt(1))))
        liwork = max(1, iwopt(1))
        allocate(work(lwork), iwork(liwork))
        call ${R}$spevd(jobz, uplo, n, APt, wt, zt, ldz, &
                        work, lwork, iwork, liwork, info)
        AP(1:np) = t2q_r(APt)
        w(1:n)   = t2q_r(wt)
        if (jobz /= 'N' .and. jobz /= 'n') z(1:ldz, 1:n) = t2q_r(zt)
    end subroutine

    subroutine target_dspevx(jobz, range, uplo, n, AP, vl, vu, il, iu, &
                             abstol, m, w, z, ldz, ifail, info)
        character, intent(in)    :: jobz, range, uplo
        integer,   intent(in)    :: n, il, iu, ldz
        real(ep),  intent(in)    :: vl, vu, abstol
        real(ep),  intent(inout) :: AP(*)
        integer,   intent(out)   :: m, ifail(*), info
        real(ep),  intent(out)   :: w(*), z(ldz,*)
        ${target_real}$, allocatable :: APt(:), wt(:), zt(:,:), work(:)
        integer,         allocatable :: iwork(:)
        integer :: np
        np = n*(n+1)/2
        allocate(APt(np), wt(n), zt(ldz, n), work(max(1, 8*n)), iwork(5*n))
        APt = q2t_r(AP(1:np))
        call ${R}$spevx(jobz, range, uplo, n, APt, q2t_r(vl), q2t_r(vu), &
                        il, iu, q2t_r(abstol), m, wt, zt, ldz, &
                        work, iwork, ifail, info)
        AP(1:np) = t2q_r(APt)
        w(1:n)   = t2q_r(wt)
        if (jobz /= 'N' .and. jobz /= 'n') z(1:ldz, 1:n) = t2q_r(zt)
    end subroutine

    subroutine target_zhpev(jobz, uplo, n, AP, w, z, ldz, info)
        character,   intent(in)    :: jobz, uplo
        integer,     intent(in)    :: n, ldz
        complex(ep), intent(inout) :: AP(*)
        real(ep),    intent(out)   :: w(*)
        complex(ep), intent(out)   :: z(ldz,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: APt(:), zt(:,:), work(:)
        ${target_real}$,    allocatable :: wt(:), rwork(:)
        integer :: np
        np = n*(n+1)/2
        allocate(APt(np), zt(ldz, n), wt(n), &
                 work(max(1, 2*n - 1)), rwork(max(1, 3*n - 2)))
        APt = q2t_c(AP(1:np))
        call ${C}$hpev(jobz, uplo, n, APt, wt, zt, ldz, work, rwork, info)
        AP(1:np) = t2q_c(APt)
        w(1:n)   = t2q_r(wt)
        if (jobz /= 'N' .and. jobz /= 'n') z(1:ldz, 1:n) = t2q_c(zt)
    end subroutine

