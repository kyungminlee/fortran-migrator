    subroutine target_ztbcon(norm, uplo, diag, n, kd, AB, ldab, rcond, info)
        character,   intent(in)  :: norm, uplo, diag
        integer,     intent(in)  :: n, kd, ldab
        complex(ep), intent(in)  :: AB(ldab,*)
        real(ep),    intent(out) :: rcond
        integer,     intent(out) :: info
        ${target_complex}$, allocatable :: ABt(:,:), work(:)
        ${target_real}$,    allocatable :: rwork(:)
        ${target_real}$ :: rct
        allocate(ABt(ldab, n), work(2*n), rwork(n))
        ABt = q2t_c(AB(1:ldab, 1:n))
        call ${C}$tbcon(norm, uplo, diag, n, kd, ABt, ldab, rct, work, rwork, info)
        rcond = t2q_r(rct)
    end subroutine

