    subroutine target_zgelsy(m, n, nrhs, A, lda, B, ldb, jpvt, rcond, rank, info)
        integer,     intent(in)    :: m, n, nrhs, lda, ldb
        real(ep),    intent(in)    :: rcond
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*)
        integer,     intent(inout) :: jpvt(*)
        integer,     intent(out)   :: rank, info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), work(:)
        ${target_real}$,    allocatable :: rwork(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda,n), Bt(ldb,nrhs), rwork(2*n))
        At = q2t_c(A(1:lda,1:n)); Bt = q2t_c(B(1:ldb,1:nrhs))
        call ${C}$gelsy(m, n, nrhs, At, lda, Bt, ldb, jpvt, q2t_r(rcond), rank, &
                        wopt, -1, rwork, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        call ${C}$gelsy(m, n, nrhs, At, lda, Bt, ldb, jpvt, q2t_r(rcond), rank, &
                        work, lwork, rwork, info)
        A(1:lda,1:n) = t2q_c(At); B(1:ldb,1:nrhs) = t2q_c(Bt)
    end subroutine

    subroutine target_dgelst(trans, m, n, nrhs, A, lda, B, ldb, info)
        character, intent(in)    :: trans
        integer,   intent(in)    :: m, n, nrhs, lda, ldb
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda,n), Bt(ldb,nrhs))
        At = q2t_r(A(1:lda,1:n)); Bt = q2t_r(B(1:ldb,1:nrhs))
        call ${R}$gelst(trans, m, n, nrhs, At, lda, Bt, ldb, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1)))); allocate(work(lwork))
        call ${R}$gelst(trans, m, n, nrhs, At, lda, Bt, ldb, work, lwork, info)
        A(1:lda,1:n) = t2q_r(At); B(1:ldb,1:nrhs) = t2q_r(Bt)
    end subroutine

    subroutine target_zgelst(trans, m, n, nrhs, A, lda, B, ldb, info)
        character,   intent(in)    :: trans
        integer,     intent(in)    :: m, n, nrhs, lda, ldb
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), work(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda,n), Bt(ldb,nrhs))
        At = q2t_c(A(1:lda,1:n)); Bt = q2t_c(B(1:ldb,1:nrhs))
        call ${C}$gelst(trans, m, n, nrhs, At, lda, Bt, ldb, wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        call ${C}$gelst(trans, m, n, nrhs, At, lda, Bt, ldb, work, lwork, info)
        A(1:lda,1:n) = t2q_c(At); B(1:ldb,1:nrhs) = t2q_c(Bt)
    end subroutine

    subroutine target_dgejsv(joba, jobu, jobv, jobr, jobt, jobp, m, n, A, lda, &
                             sva, U, ldu, V, ldv, info)
        character, intent(in)    :: joba, jobu, jobv, jobr, jobt, jobp
        integer,   intent(in)    :: m, n, lda, ldu, ldv
        real(ep),  intent(inout) :: A(lda,*)
        real(ep),  intent(out)   :: sva(*), U(ldu,*), V(ldv,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), svat(:), Ut(:,:), Vt(:,:), work(:)
        integer,         allocatable :: iwork(:)
        integer :: lwork, ucols, vcols
        ! DGEJSV does not provide a workspace query; size pessimistically.
        lwork = max(1, 7*n + 4*n*n + 6 + 2*max(m,n))
        ucols = merge(m, n, jobu == 'F')
        vcols = n
        allocate(At(lda,n), svat(n), Ut(ldu,max(1,ucols)), Vt(ldv,max(1,vcols)))
        allocate(work(lwork), iwork(max(1, m+3*n)))
        At = q2t_r(A(1:lda,1:n))
        call ${R}$gejsv(joba, jobu, jobv, jobr, jobt, jobp, m, n, At, lda, &
                        svat, Ut, ldu, Vt, ldv, work, lwork, iwork, info)
        A(1:lda,1:n) = t2q_r(At); sva(1:n) = t2q_r(svat)
        if (jobu /= 'N') U(1:ldu,1:ucols) = t2q_r(Ut)
        if (jobv /= 'N') V(1:ldv,1:vcols) = t2q_r(Vt)
    end subroutine

    subroutine target_zgejsv(joba, jobu, jobv, jobr, jobt, jobp, m, n, A, lda, &
                             sva, U, ldu, V, ldv, info)
        character,   intent(in)    :: joba, jobu, jobv, jobr, jobt, jobp
        integer,     intent(in)    :: m, n, lda, ldu, ldv
        complex(ep), intent(inout) :: A(lda,*)
        real(ep),    intent(out)   :: sva(*)
        complex(ep), intent(out)   :: U(ldu,*), V(ldv,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Ut(:,:), Vt(:,:), cwork(:)
        ${target_real}$,    allocatable :: svat(:), rwork(:)
        integer,            allocatable :: iwork(:)
        integer :: lwork, lrwork, ucols, vcols
        lwork  = max(2, 5*n + 2*n*n)
        lrwork = max(7, n + 2*m)
        ucols = merge(m, n, jobu == 'F')
        vcols = n
        allocate(At(lda,n), svat(n), Ut(ldu,max(1,ucols)), Vt(ldv,max(1,vcols)))
        allocate(cwork(lwork), rwork(lrwork), iwork(max(1, m+3*n)))
        At = q2t_c(A(1:lda,1:n))
        call ${C}$gejsv(joba, jobu, jobv, jobr, jobt, jobp, m, n, At, lda, &
                        svat, Ut, ldu, Vt, ldv, cwork, lwork, rwork, lrwork, &
                        iwork, info)
        A(1:lda,1:n) = t2q_c(At); sva(1:n) = t2q_r(svat)
        if (jobu /= 'N') U(1:ldu,1:ucols) = t2q_c(Ut)
        if (jobv /= 'N') V(1:ldv,1:vcols) = t2q_c(Vt)
    end subroutine

    subroutine target_dgesvj(joba, jobu, jobv, m, n, A, lda, sva, mv, V, ldv, &
                             ctol, info)
        character, intent(in)    :: joba, jobu, jobv
        integer,   intent(in)    :: m, n, lda, mv, ldv
        real(ep),  intent(in)    :: ctol
        real(ep),  intent(inout) :: A(lda,*), V(ldv,*)
        real(ep),  intent(out)   :: sva(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Vt(:,:), svat(:), work(:)
        integer :: lwork
        lwork = max(6, m + n)
        allocate(At(lda,n), Vt(ldv,n), svat(n), work(lwork))
        At = q2t_r(A(1:lda,1:n)); Vt = q2t_r(V(1:ldv,1:n))
        ! DGESVJ uses work(1) as input "ctol" hint (0 → routine's default).
        work(1) = q2t_r(ctol)
        call ${R}$gesvj(joba, jobu, jobv, m, n, At, lda, svat, mv, Vt, ldv, &
                        work, lwork, info)
        A(1:lda,1:n) = t2q_r(At); V(1:ldv,1:n) = t2q_r(Vt)
        sva(1:n) = t2q_r(svat)
    end subroutine

    subroutine target_zgesvj(joba, jobu, jobv, m, n, A, lda, sva, mv, V, ldv, &
                             ctol, info)
        character,   intent(in)    :: joba, jobu, jobv
        integer,     intent(in)    :: m, n, lda, mv, ldv
        real(ep),    intent(in)    :: ctol
        complex(ep), intent(inout) :: A(lda,*), V(ldv,*)
        real(ep),    intent(out)   :: sva(*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Vt(:,:), cwork(:)
        ${target_real}$,    allocatable :: svat(:), rwork(:)
        integer :: lwork, lrwork
        lwork  = max(6, m + n)
        lrwork = max(6, n)
        allocate(At(lda,n), Vt(ldv,n), svat(n), cwork(lwork), rwork(lrwork))
        At = q2t_c(A(1:lda,1:n)); Vt = q2t_c(V(1:ldv,1:n))
        rwork(1) = q2t_r(ctol)
        call ${C}$gesvj(joba, jobu, jobv, m, n, At, lda, svat, mv, Vt, ldv, &
                        cwork, lwork, rwork, lrwork, info)
        A(1:lda,1:n) = t2q_c(At); V(1:ldv,1:n) = t2q_c(Vt)
        sva(1:n) = t2q_r(svat)
    end subroutine

