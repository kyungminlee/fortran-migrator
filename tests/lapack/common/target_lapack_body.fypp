    subroutine target_dtgsja(jobu, jobv, jobq, m, p, n, k, l, A, lda, B, ldb, &
                             tola, tolb, alpha, beta, U, ldu, V, ldv, Q, ldq, &
                             ncycle, info)
        character, intent(in)    :: jobu, jobv, jobq
        integer,   intent(in)    :: m, p, n, k, l, lda, ldb, ldu, ldv, ldq
        real(ep),  intent(in)    :: tola, tolb
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*), U(ldu,*), V(ldv,*), Q(ldq,*)
        real(ep),  intent(out)   :: alpha(*), beta(*)
        integer,   intent(out)   :: ncycle, info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), Ut(:,:), Vt(:,:), Qt(:,:)
        ${target_real}$, allocatable :: alphat(:), betat(:), work(:)
        allocate(At(lda,n), Bt(ldb,n), Ut(ldu,m), Vt(ldv,p), Qt(ldq,n))
        allocate(alphat(n), betat(n), work(2*n))
        At = q2t_r(A(1:lda,1:n)); Bt = q2t_r(B(1:ldb,1:n))
        Ut = q2t_r(U(1:ldu,1:m)); Vt = q2t_r(V(1:ldv,1:p))
        Qt = q2t_r(Q(1:ldq,1:n))
        call ${R}$tgsja(jobu, jobv, jobq, m, p, n, k, l, At, lda, Bt, ldb, &
                        q2t_r(tola), q2t_r(tolb), alphat, betat, Ut, ldu, Vt, ldv, &
                        Qt, ldq, work, ncycle, info)
        A(1:lda,1:n) = t2q_r(At); B(1:ldb,1:n) = t2q_r(Bt)
        U(1:ldu,1:m) = t2q_r(Ut); V(1:ldv,1:p) = t2q_r(Vt); Q(1:ldq,1:n) = t2q_r(Qt)
        alpha(1:n) = t2q_r(alphat); beta(1:n) = t2q_r(betat)
    end subroutine

    subroutine target_ztgsja(jobu, jobv, jobq, m, p, n, k, l, A, lda, B, ldb, &
                             tola, tolb, alpha, beta, U, ldu, V, ldv, Q, ldq, &
                             ncycle, info)
        character,   intent(in)    :: jobu, jobv, jobq
        integer,     intent(in)    :: m, p, n, k, l, lda, ldb, ldu, ldv, ldq
        real(ep),    intent(in)    :: tola, tolb
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*), U(ldu,*), V(ldv,*), Q(ldq,*)
        real(ep),    intent(out)   :: alpha(*), beta(*)
        integer,     intent(out)   :: ncycle, info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), Ut(:,:), Vt(:,:), Qt(:,:), work(:)
        ${target_real}$,    allocatable :: alphat(:), betat(:)
        allocate(At(lda,n), Bt(ldb,n), Ut(ldu,m), Vt(ldv,p), Qt(ldq,n))
        allocate(alphat(n), betat(n), work(2*n))
        At = q2t_c(A(1:lda,1:n)); Bt = q2t_c(B(1:ldb,1:n))
        Ut = q2t_c(U(1:ldu,1:m)); Vt = q2t_c(V(1:ldv,1:p))
        Qt = q2t_c(Q(1:ldq,1:n))
        call ${C}$tgsja(jobu, jobv, jobq, m, p, n, k, l, At, lda, Bt, ldb, &
                        q2t_r(tola), q2t_r(tolb), alphat, betat, Ut, ldu, Vt, ldv, &
                        Qt, ldq, work, ncycle, info)
        A(1:lda,1:n) = t2q_c(At); B(1:ldb,1:n) = t2q_c(Bt)
        U(1:ldu,1:m) = t2q_c(Ut); V(1:ldv,1:p) = t2q_c(Vt); Q(1:ldq,1:n) = t2q_c(Qt)
        alpha(1:n) = t2q_r(alphat); beta(1:n) = t2q_r(betat)
    end subroutine

    subroutine target_dtgsyl(trans, ijob, m, n, A, lda, B, ldb, C, ldc, &
                             D, ldd, E, lde, F, ldf, scale, dif, info)
        character, intent(in)    :: trans
        integer,   intent(in)    :: ijob, m, n, lda, ldb, ldc, ldd, lde, ldf
        real(ep),  intent(in)    :: A(lda,*), B(ldb,*), D(ldd,*), E(lde,*)
        real(ep),  intent(inout) :: C(ldc,*), F(ldf,*)
        real(ep),  intent(out)   :: scale, dif
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), Ct(:,:), Dt(:,:), Et(:,:), Ft(:,:), work(:)
        integer, allocatable :: iwork(:)
        ${target_real}$ :: wopt(1), scalet, dift
        integer :: lwork
        allocate(At(lda,m), Bt(ldb,n), Ct(ldc,n), Dt(ldd,m), Et(lde,n), Ft(ldf,n))
        allocate(iwork(m+n+6))
        At = q2t_r(A(1:lda,1:m)); Bt = q2t_r(B(1:ldb,1:n))
        Ct = q2t_r(C(1:ldc,1:n)); Dt = q2t_r(D(1:ldd,1:m))
        Et = q2t_r(E(1:lde,1:n)); Ft = q2t_r(F(1:ldf,1:n))
        call ${R}$tgsyl(trans, ijob, m, n, At, lda, Bt, ldb, Ct, ldc, &
                        Dt, ldd, Et, lde, Ft, ldf, scalet, dift, wopt, -1, iwork, info)
        lwork = max(1, int(t2q_r(wopt(1)))); allocate(work(lwork))
        call ${R}$tgsyl(trans, ijob, m, n, At, lda, Bt, ldb, Ct, ldc, &
                        Dt, ldd, Et, lde, Ft, ldf, scalet, dift, work, lwork, iwork, info)
        C(1:ldc,1:n) = t2q_r(Ct); F(1:ldf,1:n) = t2q_r(Ft)
        scale = t2q_r(scalet); dif = t2q_r(dift)
    end subroutine

    subroutine target_ztgsyl(trans, ijob, m, n, A, lda, B, ldb, C, ldc, &
                             D, ldd, E, lde, F, ldf, scale, dif, info)
        character,   intent(in)    :: trans
        integer,     intent(in)    :: ijob, m, n, lda, ldb, ldc, ldd, lde, ldf
        complex(ep), intent(in)    :: A(lda,*), B(ldb,*), D(ldd,*), E(lde,*)
        complex(ep), intent(inout) :: C(ldc,*), F(ldf,*)
        real(ep),    intent(out)   :: scale, dif
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), Ct(:,:), Dt(:,:), Et(:,:), Ft(:,:), work(:)
        integer, allocatable :: iwork(:)
        ${target_complex}$ :: wopt(1)
        ${target_real}$ :: scalet, dift
        integer :: lwork
        allocate(At(lda,m), Bt(ldb,n), Ct(ldc,n), Dt(ldd,m), Et(lde,n), Ft(ldf,n))
        allocate(iwork(m+n+2))
        At = q2t_c(A(1:lda,1:m)); Bt = q2t_c(B(1:ldb,1:n))
        Ct = q2t_c(C(1:ldc,1:n)); Dt = q2t_c(D(1:ldd,1:m))
        Et = q2t_c(E(1:lde,1:n)); Ft = q2t_c(F(1:ldf,1:n))
        call ${C}$tgsyl(trans, ijob, m, n, At, lda, Bt, ldb, Ct, ldc, &
                        Dt, ldd, Et, lde, Ft, ldf, scalet, dift, wopt, -1, iwork, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        call ${C}$tgsyl(trans, ijob, m, n, At, lda, Bt, ldb, Ct, ldc, &
                        Dt, ldd, Et, lde, Ft, ldf, scalet, dift, work, lwork, iwork, info)
        C(1:ldc,1:n) = t2q_c(Ct); F(1:ldf,1:n) = t2q_c(Ft)
        scale = t2q_r(scalet); dif = t2q_r(dift)
    end subroutine

    subroutine target_dggglm(n, m, p, A, lda, B, ldb, d, x, y, info)
        integer,   intent(in)    :: n, m, p, lda, ldb
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*), d(*)
        real(ep),  intent(out)   :: x(*), y(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), dt(:), xt(:), yt(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda,m), Bt(ldb,p), dt(n), xt(m), yt(p))
        At = q2t_r(A(1:lda,1:m)); Bt = q2t_r(B(1:ldb,1:p)); dt = q2t_r(d(1:n))
        call ${R}$ggglm(n, m, p, At, lda, Bt, ldb, dt, xt, yt, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1)))); allocate(work(lwork))
        call ${R}$ggglm(n, m, p, At, lda, Bt, ldb, dt, xt, yt, work, lwork, info)
        A(1:lda,1:m) = t2q_r(At); B(1:ldb,1:p) = t2q_r(Bt); d(1:n) = t2q_r(dt)
        x(1:m) = t2q_r(xt); y(1:p) = t2q_r(yt)
    end subroutine

    subroutine target_zggglm(n, m, p, A, lda, B, ldb, d, x, y, info)
        integer,     intent(in)    :: n, m, p, lda, ldb
