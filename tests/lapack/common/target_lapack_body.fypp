        tsz = max(tsize, int(t2q_r(tquery(1))))
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(Tt(tsz), work(lwork))
        call ${R}$gelq(m, n, At, lda, Tt, tsz, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At); T(1:tsize) = t2q_r(Tt(1:tsize))
    end subroutine

    subroutine target_zgelq(m, n, A, lda, T, tsize, info)
        integer,     intent(in)    :: m, n, lda, tsize
        complex(ep), intent(inout) :: A(lda,*)
        complex(ep), intent(out)   :: T(*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Tt(:), work(:)
        ${target_complex}$ :: tquery(5), wopt(1)
        integer :: tsz, lwork
        allocate(At(lda, n))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$gelq(m, n, At, lda, tquery, -1, wopt, -1, info)
        tsz = max(tsize, int(real(t2q_c(tquery(1)), ep)))
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(Tt(tsz), work(lwork))
        call ${C}$gelq(m, n, At, lda, Tt, tsz, work, lwork, info)
        A(1:lda, 1:n) = t2q_c(At); T(1:tsize) = t2q_c(Tt(1:tsize))
    end subroutine

    subroutine target_dgemqr(side, trans, m, n, k, A, lda, T, tsize, C, ldc, info)
        character, intent(in)    :: side, trans
        integer,   intent(in)    :: m, n, k, lda, tsize, ldc
        real(ep),  intent(in)    :: A(lda,*), T(*)
        real(ep),  intent(inout) :: C(ldc,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Tt(:), Ct(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, nq
        nq = merge(m, n, side == 'L' .or. side == 'l')
        allocate(At(lda, k), Tt(tsize), Ct(ldc, n))
        At = q2t_r(A(1:lda, 1:k)); Tt = q2t_r(T(1:tsize))
        Ct = q2t_r(C(1:ldc, 1:n))
        call ${R}$gemqr(side, trans, m, n, k, At, lda, Tt, tsize, Ct, ldc, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$gemqr(side, trans, m, n, k, At, lda, Tt, tsize, Ct, ldc, work, lwork, info)
        C(1:ldc, 1:n) = t2q_r(Ct)
    end subroutine

