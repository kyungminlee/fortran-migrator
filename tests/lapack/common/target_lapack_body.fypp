    ! ── Phase 9 wrappers ─────────────────────────────────────────────
    subroutine target_dsptrf(uplo, n, AP, ipiv, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n
        real(ep),  intent(inout) :: AP(*)
        integer,   intent(out)   :: ipiv(*), info
        ${target_real}$, allocatable :: APt(:)
        integer :: np
        np = n*(n+1)/2
        allocate(APt(np))
        APt = q2t_r(AP(1:np))
        call ${R}$sptrf(uplo, n, APt, ipiv, info)
        AP(1:np) = t2q_r(APt)
    end subroutine

    subroutine target_dsptrs(uplo, n, nrhs, AP, ipiv, B, ldb, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, nrhs, ldb
        real(ep),  intent(in)    :: AP(*)
        integer,   intent(in)    :: ipiv(*)
        real(ep),  intent(inout) :: B(ldb,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: APt(:), Bt(:,:)
        integer :: np
        np = n*(n+1)/2
        allocate(APt(np), Bt(ldb, nrhs))
        APt = q2t_r(AP(1:np)); Bt = q2t_r(B(1:ldb, 1:nrhs))
        call ${R}$sptrs(uplo, n, nrhs, APt, ipiv, Bt, ldb, info)
        B(1:ldb, 1:nrhs) = t2q_r(Bt)
    end subroutine

