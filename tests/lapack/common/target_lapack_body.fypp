    ! ── Phase 29 wrappers ────────────────────────────────────────────
    subroutine target_dggbal(job, n, A, lda, B, ldb, ilo, ihi, lscale, rscale, info)
        character, intent(in)    :: job
        integer,   intent(in)    :: n, lda, ldb
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*)
        integer,   intent(out)   :: ilo, ihi
        real(ep),  intent(out)   :: lscale(*), rscale(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), lst(:), rst(:), work(:)
        allocate(At(lda, n), Bt(ldb, n), lst(n), rst(n), work(6*n))
        At = q2t_r(A(1:lda, 1:n)); Bt = q2t_r(B(1:ldb, 1:n))
        call ${R}$ggbal(job, n, At, lda, Bt, ldb, ilo, ihi, lst, rst, work, info)
        A(1:lda, 1:n) = t2q_r(At); B(1:ldb, 1:n) = t2q_r(Bt)
        lscale(1:n) = t2q_r(lst); rscale(1:n) = t2q_r(rst)
    end subroutine

