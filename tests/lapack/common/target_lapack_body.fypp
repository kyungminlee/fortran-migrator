        dt = q2t_r(d(1:n)); et = q2t_c(e(1:n-1)); Bt = q2t_c(B(1:ldb, 1:nrhs))
        call ${C}$pttrs(uplo, n, nrhs, dt, et, Bt, ldb, info)
        B(1:ldb, 1:nrhs) = t2q_c(Bt)
