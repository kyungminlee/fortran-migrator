    subroutine target_dggevx(balanc, jobvl, jobvr, sense, n, A, lda, B, ldb, &
                             alphar, alphai, beta, vl, ldvl, vr, ldvr, &
                             ilo, ihi, lscale, rscale, abnrm, bbnrm, &
                             rconde, rcondv, info)
        character, intent(in)    :: balanc, jobvl, jobvr, sense
        integer,   intent(in)    :: n, lda, ldb, ldvl, ldvr
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*)
        integer,   intent(out)   :: ilo, ihi, info
        real(ep),  intent(out)   :: alphar(*), alphai(*), beta(*)
        real(ep),  intent(out)   :: vl(ldvl,*), vr(ldvr,*)
        real(ep),  intent(out)   :: lscale(*), rscale(*), abnrm, bbnrm
        real(ep),  intent(out)   :: rconde(*), rcondv(*)
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), art(:), ait(:), bet(:)
        ${target_real}$, allocatable :: vlt(:,:), vrt(:,:), lscalet(:), rscalet(:)
        ${target_real}$, allocatable :: rcondet(:), rcondvt(:), work(:)
        integer, allocatable :: iwork(:)
        logical, allocatable :: bwork(:)
        ${target_real}$ :: wopt(1), abnrmt, bbnrmt
        integer :: lwork
        allocate(At(lda,n), Bt(ldb,n), art(n), ait(n), bet(n))
        allocate(vlt(ldvl,n), vrt(ldvr,n), lscalet(n), rscalet(n))
        allocate(rcondet(n), rcondvt(n), iwork(n+6), bwork(n))
        At = q2t_r(A(1:lda,1:n)); Bt = q2t_r(B(1:ldb,1:n))
        call ${R}$ggevx(balanc, jobvl, jobvr, sense, n, At, lda, Bt, ldb, &
                        art, ait, bet, vlt, ldvl, vrt, ldvr, ilo, ihi, &
                        lscalet, rscalet, abnrmt, bbnrmt, rcondet, rcondvt, &
                        wopt, -1, iwork, bwork, info)
        lwork = max(1, int(t2q_r(wopt(1)))); allocate(work(lwork))
        call ${R}$ggevx(balanc, jobvl, jobvr, sense, n, At, lda, Bt, ldb, &
                        art, ait, bet, vlt, ldvl, vrt, ldvr, ilo, ihi, &
                        lscalet, rscalet, abnrmt, bbnrmt, rcondet, rcondvt, &
                        work, lwork, iwork, bwork, info)
        A(1:lda,1:n) = t2q_r(At); B(1:ldb,1:n) = t2q_r(Bt)
        alphar(1:n) = t2q_r(art); alphai(1:n) = t2q_r(ait); beta(1:n) = t2q_r(bet)
        if (jobvl /= 'N' .and. jobvl /= 'n') vl(1:ldvl,1:n) = t2q_r(vlt)
        if (jobvr /= 'N' .and. jobvr /= 'n') vr(1:ldvr,1:n) = t2q_r(vrt)
        lscale(1:n) = t2q_r(lscalet); rscale(1:n) = t2q_r(rscalet)
        abnrm = t2q_r(abnrmt); bbnrm = t2q_r(bbnrmt)
        rconde(1:n) = t2q_r(rcondet); rcondv(1:n) = t2q_r(rcondvt)
    end subroutine

    subroutine target_zggevx(balanc, jobvl, jobvr, sense, n, A, lda, B, ldb, &
                             alpha, beta, vl, ldvl, vr, ldvr, &
                             ilo, ihi, lscale, rscale, abnrm, bbnrm, &
                             rconde, rcondv, info)
        character,   intent(in)    :: balanc, jobvl, jobvr, sense
        integer,     intent(in)    :: n, lda, ldb, ldvl, ldvr
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*)
        integer,     intent(out)   :: ilo, ihi, info
        complex(ep), intent(out)   :: alpha(*), beta(*)
        complex(ep), intent(out)   :: vl(ldvl,*), vr(ldvr,*)
        real(ep),    intent(out)   :: lscale(*), rscale(*), abnrm, bbnrm
        real(ep),    intent(out)   :: rconde(*), rcondv(*)
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), at_(:), bet(:)
        ${target_complex}$, allocatable :: vlt(:,:), vrt(:,:), work(:)
        ${target_real}$,    allocatable :: lscalet(:), rscalet(:)
        ${target_real}$,    allocatable :: rcondet(:), rcondvt(:), rwork(:)
        integer, allocatable :: iwork(:)
        logical, allocatable :: bwork(:)
        ${target_complex}$ :: wopt(1)
        ${target_real}$ :: abnrmt, bbnrmt
        integer :: lwork
        allocate(At(lda,n), Bt(ldb,n), at_(n), bet(n))
        allocate(vlt(ldvl,n), vrt(ldvr,n), lscalet(n), rscalet(n))
        allocate(rcondet(n), rcondvt(n), rwork(6*n), iwork(n+2), bwork(n))
        At = q2t_c(A(1:lda,1:n)); Bt = q2t_c(B(1:ldb,1:n))
        call ${C}$ggevx(balanc, jobvl, jobvr, sense, n, At, lda, Bt, ldb, &
                        at_, bet, vlt, ldvl, vrt, ldvr, ilo, ihi, &
                        lscalet, rscalet, abnrmt, bbnrmt, rcondet, rcondvt, &
                        wopt, -1, rwork, iwork, bwork, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        call ${C}$ggevx(balanc, jobvl, jobvr, sense, n, At, lda, Bt, ldb, &
                        at_, bet, vlt, ldvl, vrt, ldvr, ilo, ihi, &
                        lscalet, rscalet, abnrmt, bbnrmt, rcondet, rcondvt, &
                        work, lwork, rwork, iwork, bwork, info)
        A(1:lda,1:n) = t2q_c(At); B(1:ldb,1:n) = t2q_c(Bt)
        alpha(1:n) = t2q_c(at_); beta(1:n) = t2q_c(bet)
        if (jobvl /= 'N' .and. jobvl /= 'n') vl(1:ldvl,1:n) = t2q_c(vlt)
        if (jobvr /= 'N' .and. jobvr /= 'n') vr(1:ldvr,1:n) = t2q_c(vrt)
        lscale(1:n) = t2q_r(lscalet); rscale(1:n) = t2q_r(rscalet)
        abnrm = t2q_r(abnrmt); bbnrm = t2q_r(bbnrmt)
        rconde(1:n) = t2q_r(rcondet); rcondv(1:n) = t2q_r(rcondvt)
    end subroutine

    subroutine target_dhgeqz(job, compq, compz, n, ilo, ihi, H, ldh, T, ldt, &
                             alphar, alphai, beta, Q, ldq, Z, ldz, info)
        character, intent(in)    :: job, compq, compz
        integer,   intent(in)    :: n, ilo, ihi, ldh, ldt, ldq, ldz
        real(ep),  intent(inout) :: H(ldh,*), T(ldt,*), Q(ldq,*), Z(ldz,*)
        real(ep),  intent(out)   :: alphar(*), alphai(*), beta(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: Ht(:,:), Tt(:,:), Qt(:,:), Zt(:,:)
        ${target_real}$, allocatable :: art(:), ait(:), bet(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(Ht(ldh,n), Tt(ldt,n), Qt(ldq,n), Zt(ldz,n))
        allocate(art(n), ait(n), bet(n))
        Ht = q2t_r(H(1:ldh,1:n)); Tt = q2t_r(T(1:ldt,1:n))
        Qt = q2t_r(Q(1:ldq,1:n)); Zt = q2t_r(Z(1:ldz,1:n))
        call ${R}$hgeqz(job, compq, compz, n, ilo, ihi, Ht, ldh, Tt, ldt, &
                        art, ait, bet, Qt, ldq, Zt, ldz, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1)))); allocate(work(lwork))
        call ${R}$hgeqz(job, compq, compz, n, ilo, ihi, Ht, ldh, Tt, ldt, &
                        art, ait, bet, Qt, ldq, Zt, ldz, work, lwork, info)
        H(1:ldh,1:n) = t2q_r(Ht); T(1:ldt,1:n) = t2q_r(Tt)
        Q(1:ldq,1:n) = t2q_r(Qt); Z(1:ldz,1:n) = t2q_r(Zt)
        alphar(1:n) = t2q_r(art); alphai(1:n) = t2q_r(ait); beta(1:n) = t2q_r(bet)
    end subroutine

    subroutine target_zhgeqz(job, compq, compz, n, ilo, ihi, H, ldh, T, ldt, &
