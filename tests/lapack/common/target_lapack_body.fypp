        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, kd, nrhs, ldab, ldb
        real(ep),  intent(inout) :: AB(ldab,*), B(ldb,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: ABt(:,:), Bt(:,:)
        allocate(ABt(ldab, n), Bt(ldb, nrhs))
        ABt = q2t_r(AB(1:ldab, 1:n))
        Bt  = q2t_r(B(1:ldb, 1:nrhs))
        call ${R}$pbsv(uplo, n, kd, nrhs, ABt, ldab, Bt, ldb, info)
        AB(1:ldab, 1:n)  = t2q_r(ABt)
        B(1:ldb, 1:nrhs) = t2q_r(Bt)
    end subroutine

    subroutine target_dgttrf(n, dl, d, du, du2, ipiv, info)
        integer,  intent(in)    :: n
        real(ep), intent(inout) :: dl(*), d(*), du(*)
        real(ep), intent(out)   :: du2(*)
        integer,  intent(out)   :: ipiv(*), info
        ${target_real}$, allocatable :: dlt(:), dt(:), dut(:), du2t(:)
        allocate(dlt(n-1), dt(n), dut(n-1), du2t(n-2))
        dlt = q2t_r(dl(1:n-1)); dt = q2t_r(d(1:n)); dut = q2t_r(du(1:n-1))
        call ${R}$gttrf(n, dlt, dt, dut, du2t, ipiv, info)
        dl(1:n-1) = t2q_r(dlt); d(1:n) = t2q_r(dt); du(1:n-1) = t2q_r(dut)
        du2(1:n-2) = t2q_r(du2t)
    end subroutine

    subroutine target_dgttrs(trans, n, nrhs, dl, d, du, du2, ipiv, B, ldb, info)
        character, intent(in)    :: trans
        integer,   intent(in)    :: n, nrhs, ldb
        real(ep),  intent(in)    :: dl(*), d(*), du(*), du2(*)
        integer,   intent(in)    :: ipiv(*)
        real(ep),  intent(inout) :: B(ldb,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: dlt(:), dt(:), dut(:), du2t(:), Bt(:,:)
        allocate(dlt(n-1), dt(n), dut(n-1), du2t(n-2), Bt(ldb, nrhs))
        dlt = q2t_r(dl(1:n-1)); dt = q2t_r(d(1:n)); dut = q2t_r(du(1:n-1))
        du2t = q2t_r(du2(1:n-2)); Bt = q2t_r(B(1:ldb, 1:nrhs))
        call ${R}$gttrs(trans, n, nrhs, dlt, dt, dut, du2t, ipiv, Bt, ldb, info)
        B(1:ldb, 1:nrhs) = t2q_r(Bt)
    end subroutine

    subroutine target_dpttrf(n, d, e, info)
        integer,  intent(in)    :: n
        real(ep), intent(inout) :: d(*), e(*)
        integer,  intent(out)   :: info
        ${target_real}$, allocatable :: dt(:), et(:)
        allocate(dt(n), et(n-1))
        dt = q2t_r(d(1:n)); et = q2t_r(e(1:n-1))
        call ${R}$pttrf(n, dt, et, info)
        d(1:n)   = t2q_r(dt)
        e(1:n-1) = t2q_r(et)
    end subroutine

    subroutine target_dpttrs(n, nrhs, d, e, B, ldb, info)
        integer,  intent(in)    :: n, nrhs, ldb
        real(ep), intent(in)    :: d(*), e(*)
        real(ep), intent(inout) :: B(ldb,*)
        integer,  intent(out)   :: info
        ${target_real}$, allocatable :: dt(:), et(:), Bt(:,:)
        allocate(dt(n), et(n-1), Bt(ldb, nrhs))
        dt = q2t_r(d(1:n)); et = q2t_r(e(1:n-1)); Bt = q2t_r(B(1:ldb, 1:nrhs))
        call ${R}$pttrs(n, nrhs, dt, et, Bt, ldb, info)
        B(1:ldb, 1:nrhs) = t2q_r(Bt)
    end subroutine

    ! ── Phase 7 wrappers ─────────────────────────────────────────────
    subroutine target_dsyevx(jobz, range, uplo, n, A, lda, vl, vu, il, iu, &
                             abstol, m, w, z, ldz, ifail, info)
        character, intent(in)    :: jobz, range, uplo
        integer,   intent(in)    :: n, lda, il, iu, ldz
        real(ep),  intent(in)    :: vl, vu, abstol
        real(ep),  intent(inout) :: A(lda,*)
        integer,   intent(out)   :: m, ifail(*), info
        real(ep),  intent(out)   :: w(*), z(ldz,*)
        ${target_real}$, allocatable :: At(:,:), wt(:), zt(:,:), work(:)
        integer,         allocatable :: iwork(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), wt(n), zt(ldz, n), iwork(5*n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$syevx(jobz, range, uplo, n, At, lda, q2t_r(vl), q2t_r(vu), &
                        il, iu, q2t_r(abstol), m, wt, zt, ldz, &
                        wopt, -1, iwork, ifail, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$syevx(jobz, range, uplo, n, At, lda, q2t_r(vl), q2t_r(vu), &
