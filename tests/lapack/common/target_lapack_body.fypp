        allocate(At(lda, n), Bt(ldb, n), Wt(n))
        At = q2t_c(A(1:lda, 1:n)); Bt = q2t_c(B(1:ldb, 1:n))
        call ${C}$hegvd(itype, jobz, uplo, n, At, lda, Bt, ldb, Wt, wopt, -1, &
                       rwopt, -1, iwopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        lrwork = max(1, int(t2q_r(rwopt(1)))); liwork = max(1, iwopt(1))
        allocate(work(lwork), rwork(lrwork), iwork(liwork))
        call ${C}$hegvd(itype, jobz, uplo, n, At, lda, Bt, ldb, Wt, work, lwork, &
                       rwork, lrwork, iwork, liwork, info)
        A(1:lda, 1:n) = t2q_c(At); B(1:ldb, 1:n) = t2q_c(Bt)
        W(1:n) = t2q_r(Wt)
    end subroutine

