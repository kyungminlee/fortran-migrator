        allocate(APt(max(1,nap)), BPt(max(1,nap)))
        APt = q2t_c(AP(1:nap)); BPt = q2t_c(BP(1:nap))
        call ${C}$hpgst(itype, uplo, n, APt, BPt, info)
        AP(1:nap) = t2q_c(APt)
    end subroutine

