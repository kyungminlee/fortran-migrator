        real(ep) :: r
        ${target_complex}$, allocatable :: At(:,:)
        ${target_real}$,    allocatable :: work(:)
        allocate(At(lda, n), work(max(1, m)))
        At = q2t_c(A(1:lda, 1:n))
        r = t2q_r(${C}$lange(norm, m, n, At, lda, work))
    end function

