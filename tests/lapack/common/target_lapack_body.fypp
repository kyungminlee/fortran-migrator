    ! ── Phase 31 wrappers ────────────────────────────────────────────
    subroutine target_dtrsyl(trana, tranb, isgn, m, n, A, lda, B, ldb, C, ldc, &
                             scale, info)
        character, intent(in)    :: trana, tranb
        integer,   intent(in)    :: isgn, m, n, lda, ldb, ldc
        real(ep),  intent(in)    :: A(lda,*), B(ldb,*)
        real(ep),  intent(inout) :: C(ldc,*)
        real(ep),  intent(out)   :: scale
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), Ct(:,:)
        ${target_real}$ :: scalet
        allocate(At(lda, m), Bt(ldb, n), Ct(ldc, n))
        At = q2t_r(A(1:lda, 1:m)); Bt = q2t_r(B(1:ldb, 1:n))
        Ct = q2t_r(C(1:ldc, 1:n))
        call ${R}$trsyl(trana, tranb, isgn, m, n, At, lda, Bt, ldb, Ct, ldc, scalet, info)
        C(1:ldc, 1:n) = t2q_r(Ct); scale = t2q_r(scalet)
    end subroutine

    subroutine target_ztrsyl(trana, tranb, isgn, m, n, A, lda, B, ldb, C, ldc, &
                             scale, info)
        character,   intent(in)    :: trana, tranb
