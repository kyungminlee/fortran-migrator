        ${target_real}$ :: wopt(1)
        integer :: lwork, kmn
        kmn = min(m, n)
        allocate(At(lda, n), taut(kmn))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$geqp3(m, n, At, lda, jpvt, taut, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$geqp3(m, n, At, lda, jpvt, taut, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
        tau(1:kmn)    = t2q_r(taut)
    end subroutine

    subroutine target_zgeqp3(m, n, A, lda, jpvt, tau, info)
        integer,     intent(in)    :: m, n, lda
        complex(ep), intent(inout) :: A(lda,*)
        integer,     intent(inout) :: jpvt(*)
        complex(ep), intent(out)   :: tau(*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), taut(:), work(:)
        ${target_real}$,    allocatable :: rwork(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork, kmn
        kmn = min(m, n)
        allocate(At(lda, n), taut(kmn), rwork(max(1, 2*n)))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$geqp3(m, n, At, lda, jpvt, taut, wopt, -1, rwork, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$geqp3(m, n, At, lda, jpvt, taut, work, lwork, rwork, info)
        A(1:lda, 1:n) = t2q_c(At)
        tau(1:kmn)    = t2q_c(taut)
    end subroutine

    subroutine target_dormqr(side, trans, m, n, k, A, lda, tau, C, ldc, info)
        character, intent(in)    :: side, trans
        integer,   intent(in)    :: m, n, k, lda, ldc
        real(ep),  intent(in)    :: A(lda,*), tau(*)
        real(ep),  intent(inout) :: C(ldc,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), taut(:), Ct(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, ar
        ar = merge(m, n, side == 'L' .or. side == 'l')
        allocate(At(lda, k), taut(k), Ct(ldc, n))
        At = q2t_r(A(1:lda, 1:k))
        taut = q2t_r(tau(1:k))
        Ct = q2t_r(C(1:ldc, 1:n))
        call ${R}$ormqr(side, trans, m, n, k, At, lda, taut, Ct, ldc, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$ormqr(side, trans, m, n, k, At, lda, taut, Ct, ldc, work, lwork, info)
        C(1:ldc, 1:n) = t2q_r(Ct)
    end subroutine

    subroutine target_zunmqr(side, trans, m, n, k, A, lda, tau, C, ldc, info)
        character,   intent(in)    :: side, trans
        integer,     intent(in)    :: m, n, k, lda, ldc
        complex(ep), intent(in)    :: A(lda,*), tau(*)
        complex(ep), intent(inout) :: C(ldc,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), taut(:), Ct(:,:), work(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, k), taut(k), Ct(ldc, n))
        At = q2t_c(A(1:lda, 1:k))
        taut = q2t_c(tau(1:k))
        Ct = q2t_c(C(1:ldc, 1:n))
        call ${C}$unmqr(side, trans, m, n, k, At, lda, taut, Ct, ldc, wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$unmqr(side, trans, m, n, k, At, lda, taut, Ct, ldc, work, lwork, info)
        C(1:ldc, 1:n) = t2q_c(Ct)
    end subroutine

