    subroutine target_dgeqrt(m, n, nb, A, lda, T, ldt, info)
        integer,  intent(in)    :: m, n, nb, lda, ldt
        real(ep), intent(inout) :: A(lda,*)
        real(ep), intent(out)   :: T(ldt,*)
        integer,  intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Tt(:,:), work(:)
        allocate(At(lda, n), Tt(ldt, min(m, n)), work(nb*n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$geqrt(m, n, nb, At, lda, Tt, ldt, work, info)
        A(1:lda, 1:n) = t2q_r(At); T(1:ldt, 1:min(m,n)) = t2q_r(Tt)
    end subroutine

