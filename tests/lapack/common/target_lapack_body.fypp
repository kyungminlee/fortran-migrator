    subroutine target_dlapmr(forwrd, m, n, X, ldx, K)
        logical,  intent(in)    :: forwrd
        integer,  intent(in)    :: m, n, ldx
        real(ep), intent(inout) :: X(ldx,*)
        integer,  intent(inout) :: K(*)
        ${target_real}$, allocatable :: Xt(:,:)
        allocate(Xt(ldx,n))
        Xt = q2t_r(X(1:ldx,1:n))
        call ${R}$lapmr(forwrd, m, n, Xt, ldx, K)
        X(1:ldx,1:n) = t2q_r(Xt)
    end subroutine

