        call ${R}$pftrs(transr, uplo, n, nrhs, At, Bt, ldb, info)
        B(1:ldb, 1:nrhs) = t2q_r(Bt)
    end subroutine

    subroutine target_zpftrs(transr, uplo, n, nrhs, A, B, ldb, info)
        character,   intent(in)    :: transr, uplo
