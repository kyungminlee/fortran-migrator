    subroutine target_dgeqp3rk(m, n, nrhs, kmax, abstol, reltol, A, lda, &
                               K, maxc2nrmk, relmaxc2nrmk, jpiv, tau, info)
        integer,  intent(in)    :: m, n, nrhs, kmax, lda
        real(ep), intent(in)    :: abstol, reltol
        real(ep), intent(inout) :: A(lda,*)
        integer,  intent(out)   :: K, jpiv(*), info
        real(ep), intent(out)   :: maxc2nrmk, relmaxc2nrmk, tau(*)
        ${target_real}$, allocatable :: At(:,:), taut(:), work(:)
        ${target_real}$ :: wopt(1), m2k, rm2k
        integer, allocatable :: iwork(:)
        integer :: lwork, ncols
        ncols = n + nrhs
        allocate(At(lda, ncols), taut(min(m, n)), iwork(n))
        At = q2t_r(A(1:lda, 1:ncols))
        call ${R}$geqp3rk(m, n, nrhs, kmax, q2t_r(abstol), q2t_r(reltol), At, lda, &
                          K, m2k, rm2k, jpiv, taut, wopt, -1, iwork, info)
        lwork = max(1, int(real(t2q_r(wopt(1)), ep))); allocate(work(lwork))
        call ${R}$geqp3rk(m, n, nrhs, kmax, q2t_r(abstol), q2t_r(reltol), At, lda, &
                          K, m2k, rm2k, jpiv, taut, work, lwork, iwork, info)
        A(1:lda, 1:ncols) = t2q_r(At)
        tau(1:min(m,n)) = t2q_r(taut)
        maxc2nrmk = t2q_r(m2k); relmaxc2nrmk = t2q_r(rm2k)
    end subroutine

    subroutine target_zgeqp3rk(m, n, nrhs, kmax, abstol, reltol, A, lda, &
                               K, maxc2nrmk, relmaxc2nrmk, jpiv, tau, info)
        integer,     intent(in)    :: m, n, nrhs, kmax, lda
        real(ep),    intent(in)    :: abstol, reltol
        complex(ep), intent(inout) :: A(lda,*)
        integer,     intent(out)   :: K, jpiv(*), info
        real(ep),    intent(out)   :: maxc2nrmk, relmaxc2nrmk
        complex(ep), intent(out)   :: tau(*)
        ${target_complex}$, allocatable :: At(:,:), taut(:), work(:)
        ${target_complex}$ :: wopt(1)
        ${target_real}$, allocatable :: rwork(:)
        ${target_real}$ :: m2k, rm2k
        integer, allocatable :: iwork(:)
        integer :: lwork, ncols
        ncols = n + nrhs
        allocate(At(lda, ncols), taut(min(m, n)), iwork(n), rwork(2*n))
        At = q2t_c(A(1:lda, 1:ncols))
        call ${C}$geqp3rk(m, n, nrhs, kmax, q2t_r(abstol), q2t_r(reltol), At, lda, &
                          K, m2k, rm2k, jpiv, taut, wopt, -1, rwork, iwork, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        call ${C}$geqp3rk(m, n, nrhs, kmax, q2t_r(abstol), q2t_r(reltol), At, lda, &
                          K, m2k, rm2k, jpiv, taut, work, lwork, rwork, iwork, info)
        A(1:lda, 1:ncols) = t2q_c(At)
        tau(1:min(m,n)) = t2q_c(taut)
        maxc2nrmk = t2q_r(m2k); relmaxc2nrmk = t2q_r(rm2k)
    end subroutine

    ! ----- P16 MRRR / inverse-iteration tridiagonal eigensolvers -----

    subroutine target_dstegr(jobz, range, n, D, E, vl, vu, il, iu, abstol, &
                             m, W, Z, ldz, isuppz, info)
        character, intent(in)    :: jobz, range
        integer,   intent(in)    :: n, il, iu, ldz
        real(ep),  intent(in)    :: vl, vu, abstol
        real(ep),  intent(inout) :: D(*), E(*)
        integer,   intent(out)   :: m, isuppz(*), info
        real(ep),  intent(out)   :: W(*), Z(ldz,*)
        ${target_real}$, allocatable :: Dt(:), Et(:), Wt(:), Zt(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer, allocatable :: iwork(:)
        integer :: lwork, liwork, iopt(1)
        allocate(Dt(n), Et(max(1, n)), Wt(n), Zt(ldz, n))
        Dt = q2t_r(D(1:n)); Et = q2t_r(E(1:max(1,n)))
        call ${R}$stegr(jobz, range, n, Dt, Et, q2t_r(vl), q2t_r(vu), il, iu, q2t_r(abstol), &
                        m, Wt, Zt, ldz, isuppz, wopt, -1, iopt, -1, info)
        lwork = max(1, int(real(t2q_r(wopt(1)), ep))); liwork = max(1, iopt(1))
        allocate(work(lwork), iwork(liwork))
        call ${R}$stegr(jobz, range, n, Dt, Et, q2t_r(vl), q2t_r(vu), il, iu, q2t_r(abstol), &
                        m, Wt, Zt, ldz, isuppz, work, lwork, iwork, liwork, info)
        D(1:n) = t2q_r(Dt); if (n > 0) E(1:max(1,n)) = t2q_r(Et)
        if (m > 0) W(1:m) = t2q_r(Wt(1:m))
        if (jobz /= 'N' .and. jobz /= 'n' .and. m > 0) Z(1:ldz, 1:m) = t2q_r(Zt(1:ldz, 1:m))
    end subroutine

    subroutine target_zstegr(jobz, range, n, D, E, vl, vu, il, iu, abstol, &
                             m, W, Z, ldz, isuppz, info)
        character,   intent(in)    :: jobz, range
        integer,     intent(in)    :: n, il, iu, ldz
        real(ep),    intent(in)    :: vl, vu, abstol
        real(ep),    intent(inout) :: D(*), E(*)
        integer,     intent(out)   :: m, isuppz(*), info
        real(ep),    intent(out)   :: W(*)
        complex(ep), intent(out)   :: Z(ldz,*)
        ${target_real}$, allocatable :: Dt(:), Et(:), Wt(:), work(:)
        ${target_complex}$, allocatable :: Zt(:,:)
        ${target_real}$ :: wopt(1)
        integer, allocatable :: iwork(:)
        integer :: lwork, liwork, iopt(1)
        allocate(Dt(n), Et(max(1, n)), Wt(n), Zt(ldz, n))
        Dt = q2t_r(D(1:n)); Et = q2t_r(E(1:max(1,n)))
        call ${C}$stegr(jobz, range, n, Dt, Et, q2t_r(vl), q2t_r(vu), il, iu, q2t_r(abstol), &
                        m, Wt, Zt, ldz, isuppz, wopt, -1, iopt, -1, info)
        lwork = max(1, int(real(t2q_r(wopt(1)), ep))); liwork = max(1, iopt(1))
        allocate(work(lwork), iwork(liwork))
        call ${C}$stegr(jobz, range, n, Dt, Et, q2t_r(vl), q2t_r(vu), il, iu, q2t_r(abstol), &
                        m, Wt, Zt, ldz, isuppz, work, lwork, iwork, liwork, info)
        D(1:n) = t2q_r(Dt); if (n > 0) E(1:max(1,n)) = t2q_r(Et)
        if (m > 0) W(1:m) = t2q_r(Wt(1:m))
        if (jobz /= 'N' .and. jobz /= 'n' .and. m > 0) Z(1:ldz, 1:m) = t2q_c(Zt(1:ldz, 1:m))
    end subroutine

    subroutine target_dstemr(jobz, range, n, D, E, vl, vu, il, iu, &
                             m, W, Z, ldz, nzc, isuppz, tryrac, info)
        character, intent(in)    :: jobz, range
        integer,   intent(in)    :: n, il, iu, ldz, nzc
        logical,   intent(inout) :: tryrac
        real(ep),  intent(in)    :: vl, vu
        real(ep),  intent(inout) :: D(*), E(*)
        integer,   intent(out)   :: m, isuppz(*), info
        real(ep),  intent(out)   :: W(*), Z(ldz,*)
        ${target_real}$, allocatable :: Dt(:), Et(:), Wt(:), Zt(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer, allocatable :: iwork(:)
        integer :: lwork, liwork, iopt(1)
        allocate(Dt(n), Et(max(1, n)), Wt(n), Zt(ldz, max(1, nzc)))
        Dt = q2t_r(D(1:n)); Et = q2t_r(E(1:max(1,n)))
        call ${R}$stemr(jobz, range, n, Dt, Et, q2t_r(vl), q2t_r(vu), il, iu, &
                        m, Wt, Zt, ldz, nzc, isuppz, tryrac, wopt, -1, iopt, -1, info)
        lwork = max(1, int(real(t2q_r(wopt(1)), ep))); liwork = max(1, iopt(1))
        allocate(work(lwork), iwork(liwork))
        call ${R}$stemr(jobz, range, n, Dt, Et, q2t_r(vl), q2t_r(vu), il, iu, &
                        m, Wt, Zt, ldz, nzc, isuppz, tryrac, work, lwork, iwork, liwork, info)
        D(1:n) = t2q_r(Dt); if (n > 0) E(1:max(1,n)) = t2q_r(Et)
        if (m > 0) W(1:m) = t2q_r(Wt(1:m))
        if (jobz /= 'N' .and. jobz /= 'n' .and. m > 0) Z(1:ldz, 1:m) = t2q_r(Zt(1:ldz, 1:m))
    end subroutine

    subroutine target_zstemr(jobz, range, n, D, E, vl, vu, il, iu, &
                             m, W, Z, ldz, nzc, isuppz, tryrac, info)
        character,   intent(in)    :: jobz, range
        integer,     intent(in)    :: n, il, iu, ldz, nzc
        logical,     intent(inout) :: tryrac
        real(ep),    intent(in)    :: vl, vu
        real(ep),    intent(inout) :: D(*), E(*)
        integer,     intent(out)   :: m, isuppz(*), info
        real(ep),    intent(out)   :: W(*)
        complex(ep), intent(out)   :: Z(ldz,*)
        ${target_real}$, allocatable :: Dt(:), Et(:), Wt(:), work(:)
        ${target_complex}$, allocatable :: Zt(:,:)
        ${target_real}$ :: wopt(1)
        integer, allocatable :: iwork(:)
        integer :: lwork, liwork, iopt(1)
        allocate(Dt(n), Et(max(1, n)), Wt(n), Zt(ldz, max(1, nzc)))
        Dt = q2t_r(D(1:n)); Et = q2t_r(E(1:max(1,n)))
        call ${C}$stemr(jobz, range, n, Dt, Et, q2t_r(vl), q2t_r(vu), il, iu, &
                        m, Wt, Zt, ldz, nzc, isuppz, tryrac, wopt, -1, iopt, -1, info)
        lwork = max(1, int(real(t2q_r(wopt(1)), ep))); liwork = max(1, iopt(1))
        allocate(work(lwork), iwork(liwork))
        call ${C}$stemr(jobz, range, n, Dt, Et, q2t_r(vl), q2t_r(vu), il, iu, &
                        m, Wt, Zt, ldz, nzc, isuppz, tryrac, work, lwork, iwork, liwork, info)
        D(1:n) = t2q_r(Dt); if (n > 0) E(1:max(1,n)) = t2q_r(Et)
        if (m > 0) W(1:m) = t2q_r(Wt(1:m))
        if (jobz /= 'N' .and. jobz /= 'n' .and. m > 0) Z(1:ldz, 1:m) = t2q_c(Zt(1:ldz, 1:m))
    end subroutine

    subroutine target_dstein(n, D, E, m, W, iblock, isplit, Z, ldz, ifail, info)
        integer,  intent(in)    :: n, m, ldz
        real(ep), intent(in)    :: D(*), E(*), W(*)
        integer,  intent(in)    :: iblock(*), isplit(*)
        real(ep), intent(out)   :: Z(ldz,*)
        integer,  intent(out)   :: ifail(*), info
        ${target_real}$, allocatable :: Dt(:), Et(:), Wt(:), Zt(:,:), work(:)
        integer, allocatable :: iwork(:)
        allocate(Dt(n), Et(max(1, n-1)), Wt(m), Zt(ldz, m), work(5*n), iwork(n))
        Dt = q2t_r(D(1:n)); if (n > 1) Et = q2t_r(E(1:n-1)); Wt = q2t_r(W(1:m))
        call ${R}$stein(n, Dt, Et, m, Wt, iblock, isplit, Zt, ldz, work, iwork, ifail, info)
        Z(1:ldz, 1:m) = t2q_r(Zt)
    end subroutine

    subroutine target_zstein(n, D, E, m, W, iblock, isplit, Z, ldz, ifail, info)
        integer,     intent(in)    :: n, m, ldz
        real(ep),    intent(in)    :: D(*), E(*), W(*)
        integer,     intent(in)    :: iblock(*), isplit(*)
        complex(ep), intent(out)   :: Z(ldz,*)
        integer,     intent(out)   :: ifail(*), info
        ${target_real}$, allocatable :: Dt(:), Et(:), Wt(:), work(:)
        ${target_complex}$, allocatable :: Zt(:,:)
        integer, allocatable :: iwork(:)
        allocate(Dt(n), Et(max(1, n-1)), Wt(m), Zt(ldz, m), work(5*n), iwork(n))
        Dt = q2t_r(D(1:n)); if (n > 1) Et = q2t_r(E(1:n-1)); Wt = q2t_r(W(1:m))
        call ${C}$stein(n, Dt, Et, m, Wt, iblock, isplit, Zt, ldz, work, iwork, ifail, info)
        Z(1:ldz, 1:m) = t2q_c(Zt)
    end subroutine

    ! ----- P6/P7 modern SVD + banded bidiag reduction -----

    subroutine target_dgesvdq(joba, jobp, jobr, jobu, jobv, m, n, A, lda, &
                              S, U, ldu, V, ldv, numrank, info)
        character, intent(in)    :: joba, jobp, jobr, jobu, jobv
        integer,   intent(in)    :: m, n, lda, ldu, ldv
        real(ep),  intent(inout) :: A(lda,*)
        real(ep),  intent(out)   :: S(*), U(ldu,*), V(ldv,*)
        integer,   intent(out)   :: numrank, info
        ${target_real}$, allocatable :: At(:,:), St(:), Ut(:,:), Vt(:,:), work(:), rwork(:)
        ${target_real}$ :: wopt(1), ropt(1)
        integer, allocatable :: iwork(:)
        integer :: lwork, lrwork, liwork
        liwork = max(m + n, 1)
        allocate(At(lda, n), St(min(m, n)), Ut(ldu, n), Vt(ldv, n), iwork(liwork))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$gesvdq(joba, jobp, jobr, jobu, jobv, m, n, At, lda, &
                         St, Ut, ldu, Vt, ldv, numrank, iwork, -1, &
                         wopt, -1, ropt, -1, info)
        lwork  = max(1, int(real(t2q_r(wopt(1)), ep)))
        lrwork = max(1, int(t2q_r(ropt(1))))
        liwork = max(liwork, iwork(1))
        deallocate(iwork); allocate(iwork(liwork), work(lwork), rwork(lrwork))
        call ${R}$gesvdq(joba, jobp, jobr, jobu, jobv, m, n, At, lda, &
                         St, Ut, ldu, Vt, ldv, numrank, iwork, liwork, &
                         work, lwork, rwork, lrwork, info)
        A(1:lda, 1:n) = t2q_r(At); S(1:min(m,n)) = t2q_r(St)
        U(1:ldu, 1:n) = t2q_r(Ut); V(1:ldv, 1:n) = t2q_r(Vt)
    end subroutine

    subroutine target_zgesvdq(joba, jobp, jobr, jobu, jobv, m, n, A, lda, &
                              S, U, ldu, V, ldv, numrank, info)
        character,   intent(in)    :: joba, jobp, jobr, jobu, jobv
        integer,     intent(in)    :: m, n, lda, ldu, ldv
        complex(ep), intent(inout) :: A(lda,*)
        real(ep),    intent(out)   :: S(*)
        complex(ep), intent(out)   :: U(ldu,*), V(ldv,*)
        integer,     intent(out)   :: numrank, info
        ${target_complex}$, allocatable :: At(:,:), Ut(:,:), Vt(:,:), cwork(:)
        ${target_real}$,    allocatable :: St(:), rwork(:)
        ${target_complex}$ :: wopt(1)
        ${target_real}$ :: ropt(1)
        integer, allocatable :: iwork(:)
        integer :: lcwork, lrwork, liwork
        liwork = max(m + n, 1)
        allocate(At(lda, n), St(min(m, n)), Ut(ldu, n), Vt(ldv, n), iwork(liwork))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$gesvdq(joba, jobp, jobr, jobu, jobv, m, n, At, lda, &
                         St, Ut, ldu, Vt, ldv, numrank, iwork, -1, &
                         wopt, -1, ropt, -1, info)
        lcwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        lrwork = max(1, int(t2q_r(ropt(1))))
        liwork = max(liwork, iwork(1))
        deallocate(iwork); allocate(iwork(liwork), cwork(lcwork), rwork(lrwork))
        call ${C}$gesvdq(joba, jobp, jobr, jobu, jobv, m, n, At, lda, &
                         St, Ut, ldu, Vt, ldv, numrank, iwork, liwork, &
                         cwork, lcwork, rwork, lrwork, info)
        A(1:lda, 1:n) = t2q_c(At); S(1:min(m,n)) = t2q_r(St)
        U(1:ldu, 1:n) = t2q_c(Ut); V(1:ldv, 1:n) = t2q_c(Vt)
    end subroutine

    subroutine target_dgesvdx(jobu, jobvt, range, m, n, A, lda, vl, vu, il, iu, &
                              ns, S, U, ldu, Vt, ldvt, info)
        character, intent(in)    :: jobu, jobvt, range
        integer,   intent(in)    :: m, n, il, iu, lda, ldu, ldvt
        real(ep),  intent(in)    :: vl, vu
        real(ep),  intent(inout) :: A(lda,*)
        integer,   intent(out)   :: ns, info
        real(ep),  intent(out)   :: S(*), U(ldu,*), Vt(ldvt,*)
        ${target_real}$, allocatable :: At(:,:), St(:), Ut(:,:), Vtt(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer, allocatable :: iwork(:)
        integer :: lwork
        allocate(At(lda, n), St(min(m, n)), Ut(ldu, min(m, n)), Vtt(ldvt, n), iwork(12*min(m, n)))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$gesvdx(jobu, jobvt, range, m, n, At, lda, q2t_r(vl), q2t_r(vu), &
                         il, iu, ns, St, Ut, ldu, Vtt, ldvt, wopt, -1, iwork, info)
        lwork = max(1, int(real(t2q_r(wopt(1)), ep))); allocate(work(lwork))
        call ${R}$gesvdx(jobu, jobvt, range, m, n, At, lda, q2t_r(vl), q2t_r(vu), &
                         il, iu, ns, St, Ut, ldu, Vtt, ldvt, work, lwork, iwork, info)
        A(1:lda, 1:n) = t2q_r(At); S(1:ns) = t2q_r(St(1:ns))
        if (jobu /= 'N' .and. jobu /= 'n' .and. ns > 0) U(1:ldu, 1:ns) = t2q_r(Ut(1:ldu, 1:ns))
        if (jobvt /= 'N' .and. jobvt /= 'n' .and. ns > 0) Vt(1:ldvt, 1:n) = t2q_r(Vtt)
    end subroutine

    subroutine target_zgesvdx(jobu, jobvt, range, m, n, A, lda, vl, vu, il, iu, &
                              ns, S, U, ldu, Vt, ldvt, info)
        character,   intent(in)    :: jobu, jobvt, range
        integer,     intent(in)    :: m, n, il, iu, lda, ldu, ldvt
        real(ep),    intent(in)    :: vl, vu
        complex(ep), intent(inout) :: A(lda,*)
        integer,     intent(out)   :: ns, info
        real(ep),    intent(out)   :: S(*)
        complex(ep), intent(out)   :: U(ldu,*), Vt(ldvt,*)
        ${target_complex}$, allocatable :: At(:,:), Ut(:,:), Vtt(:,:), work(:)
        ${target_real}$,    allocatable :: St(:), rwork(:)
        ${target_complex}$ :: wopt(1)
        integer, allocatable :: iwork(:)
        integer :: lwork
        allocate(At(lda, n), St(min(m, n)), Ut(ldu, min(m, n)), Vtt(ldvt, n), &
                 rwork(min(m, n)*(min(m, n)*2+15*min(m, n))), iwork(12*min(m, n)))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$gesvdx(jobu, jobvt, range, m, n, At, lda, q2t_r(vl), q2t_r(vu), &
                         il, iu, ns, St, Ut, ldu, Vtt, ldvt, wopt, -1, rwork, iwork, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        call ${C}$gesvdx(jobu, jobvt, range, m, n, At, lda, q2t_r(vl), q2t_r(vu), &
                         il, iu, ns, St, Ut, ldu, Vtt, ldvt, work, lwork, rwork, iwork, info)
        A(1:lda, 1:n) = t2q_c(At); S(1:ns) = t2q_r(St(1:ns))
        if (jobu /= 'N' .and. jobu /= 'n' .and. ns > 0) U(1:ldu, 1:ns) = t2q_c(Ut(1:ldu, 1:ns))
        if (jobvt /= 'N' .and. jobvt /= 'n' .and. ns > 0) Vt(1:ldvt, 1:n) = t2q_c(Vtt)
    end subroutine

    subroutine target_dgbbrd(vect, m, n, ncc, kl, ku, AB, ldab, D, E, &
                             Q, ldq, Pt, ldpt, C, ldc, info)
        character, intent(in)    :: vect
        integer,   intent(in)    :: m, n, ncc, kl, ku, ldab, ldq, ldpt, ldc
        real(ep),  intent(inout) :: AB(ldab,*), C(ldc,*)
        real(ep),  intent(out)   :: D(*), E(*), Q(ldq,*), Pt(ldpt,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: ABt(:,:), Dt(:), Et(:), Qt(:,:), Ptt(:,:), Ct(:,:), work(:)
        allocate(ABt(ldab, n), Dt(min(m, n)), Et(max(1, min(m, n)-1)), &
                 Qt(ldq, m), Ptt(ldpt, n), Ct(ldc, ncc), work(2*max(m, n)))
        ABt = q2t_r(AB(1:ldab, 1:n))
        if (ncc > 0) Ct = q2t_r(C(1:ldc, 1:ncc))
        call ${R}$gbbrd(vect, m, n, ncc, kl, ku, ABt, ldab, Dt, Et, &
                        Qt, ldq, Ptt, ldpt, Ct, ldc, work, info)
        AB(1:ldab, 1:n) = t2q_r(ABt)
        D(1:min(m,n)) = t2q_r(Dt); if (min(m,n) > 1) E(1:min(m,n)-1) = t2q_r(Et)
        if (vect == 'Q' .or. vect == 'B') Q(1:ldq, 1:m) = t2q_r(Qt)
        if (vect == 'P' .or. vect == 'B') Pt(1:ldpt, 1:n) = t2q_r(Ptt)
        if (ncc > 0) C(1:ldc, 1:ncc) = t2q_r(Ct)
    end subroutine

    subroutine target_zgbbrd(vect, m, n, ncc, kl, ku, AB, ldab, D, E, &
                             Q, ldq, Pt, ldpt, C, ldc, info)
        character,   intent(in)    :: vect
        integer,     intent(in)    :: m, n, ncc, kl, ku, ldab, ldq, ldpt, ldc
        complex(ep), intent(inout) :: AB(ldab,*), C(ldc,*)
        real(ep),    intent(out)   :: D(*), E(*)
        complex(ep), intent(out)   :: Q(ldq,*), Pt(ldpt,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: ABt(:,:), Qt(:,:), Ptt(:,:), Ct(:,:), work(:)
        ${target_real}$,    allocatable :: Dt(:), Et(:), rwork(:)
        allocate(ABt(ldab, n), Dt(min(m, n)), Et(max(1, min(m, n)-1)), &
                 Qt(ldq, m), Ptt(ldpt, n), Ct(ldc, ncc), &
                 work(max(m, n)), rwork(max(m, n)))
        ABt = q2t_c(AB(1:ldab, 1:n))
        if (ncc > 0) Ct = q2t_c(C(1:ldc, 1:ncc))
        call ${C}$gbbrd(vect, m, n, ncc, kl, ku, ABt, ldab, Dt, Et, &
                        Qt, ldq, Ptt, ldpt, Ct, ldc, work, rwork, info)
        AB(1:ldab, 1:n) = t2q_c(ABt)
        D(1:min(m,n)) = t2q_r(Dt); if (min(m,n) > 1) E(1:min(m,n)-1) = t2q_r(Et)
        if (vect == 'Q' .or. vect == 'B') Q(1:ldq, 1:m) = t2q_c(Qt)
        if (vect == 'P' .or. vect == 'B') Pt(1:ldpt, 1:n) = t2q_c(Ptt)
        if (ncc > 0) C(1:ldc, 1:ncc) = t2q_c(Ct)
    end subroutine

    ! ----- P15 CS decomposition + bdsvdx -----

    subroutine target_dbdsvdx(uplo, jobz, range, n, D, E, vl, vu, il, iu, &
                              ns, S, Z, ldz, info)
        character, intent(in)  :: uplo, jobz, range
        integer,   intent(in)  :: n, il, iu, ldz
        real(ep),  intent(in)  :: D(*), E(*), vl, vu
        integer,   intent(out) :: ns, info
        real(ep),  intent(out) :: S(*), Z(ldz,*)
        ${target_real}$, allocatable :: Dt(:), Et(:), St(:), Zt(:,:), work(:)
        integer, allocatable :: iwork(:)
        integer :: lw
        allocate(Dt(n), Et(max(1, n-1)), St(2*n), Zt(ldz, 2*n+1), work(14*n), iwork(12*n))
        Dt = q2t_r(D(1:n)); if (n > 1) Et = q2t_r(E(1:n-1))
        lw = 14*n
        call ${R}$bdsvdx(uplo, jobz, range, n, Dt, Et, q2t_r(vl), q2t_r(vu), &
                         il, iu, ns, St, Zt, ldz, work, iwork, info)
        S(1:ns) = t2q_r(St(1:ns))
        if (jobz /= 'N' .and. jobz /= 'n' .and. ns > 0) Z(1:ldz, 1:2*ns) = t2q_r(Zt(1:ldz, 1:2*ns))
    end subroutine

    subroutine target_dbbcsd(jobu1, jobu2, jobv1t, jobv2t, trans, m, p, q, &
                             theta, phi, U1, ldu1, U2, ldu2, V1t, ldv1t, V2t, ldv2t, &
                             B11d, B11e, B12d, B12e, B21d, B21e, B22d, B22e, info)
        character, intent(in)    :: jobu1, jobu2, jobv1t, jobv2t, trans
        integer,   intent(in)    :: m, p, q, ldu1, ldu2, ldv1t, ldv2t
        real(ep),  intent(inout) :: theta(*), phi(*)
        real(ep),  intent(inout) :: U1(ldu1,*), U2(ldu2,*), V1t(ldv1t,*), V2t(ldv2t,*)
        real(ep),  intent(out)   :: B11d(*), B11e(*), B12d(*), B12e(*)
        real(ep),  intent(out)   :: B21d(*), B21e(*), B22d(*), B22e(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: thetat(:), phit(:)
        ${target_real}$, allocatable :: U1t(:,:), U2t(:,:), V1tt(:,:), V2tt(:,:)
        ${target_real}$, allocatable :: B11dt(:), B11et(:), B12dt(:), B12et(:)
        ${target_real}$, allocatable :: B21dt(:), B21et(:), B22dt(:), B22et(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(thetat(q), phit(max(1, q-1)), U1t(ldu1, p), U2t(ldu2, m-p), &
                 V1tt(ldv1t, q), V2tt(ldv2t, m-q), &
                 B11dt(q), B11et(q), B12dt(q), B12et(q), &
                 B21dt(q), B21et(q), B22dt(q), B22et(q))
        thetat = q2t_r(theta(1:q)); if (q > 1) phit = q2t_r(phi(1:q-1))
        U1t = q2t_r(U1(1:ldu1, 1:p)); U2t = q2t_r(U2(1:ldu2, 1:m-p))
        V1tt = q2t_r(V1t(1:ldv1t, 1:q)); V2tt = q2t_r(V2t(1:ldv2t, 1:m-q))
        call ${R}$bbcsd(jobu1, jobu2, jobv1t, jobv2t, trans, m, p, q, &
                        thetat, phit, U1t, ldu1, U2t, ldu2, V1tt, ldv1t, V2tt, ldv2t, &
                        B11dt, B11et, B12dt, B12et, B21dt, B21et, B22dt, B22et, &
                        wopt, -1, info)
        lwork = max(1, int(real(t2q_r(wopt(1)), ep))); allocate(work(lwork))
        call ${R}$bbcsd(jobu1, jobu2, jobv1t, jobv2t, trans, m, p, q, &
                        thetat, phit, U1t, ldu1, U2t, ldu2, V1tt, ldv1t, V2tt, ldv2t, &
                        B11dt, B11et, B12dt, B12et, B21dt, B21et, B22dt, B22et, &
                        work, lwork, info)
        theta(1:q) = t2q_r(thetat); if (q > 1) phi(1:q-1) = t2q_r(phit)
        U1(1:ldu1, 1:p) = t2q_r(U1t); U2(1:ldu2, 1:m-p) = t2q_r(U2t)
        V1t(1:ldv1t, 1:q) = t2q_r(V1tt); V2t(1:ldv2t, 1:m-q) = t2q_r(V2tt)
        B11d(1:q) = t2q_r(B11dt); B11e(1:q) = t2q_r(B11et)
        B12d(1:q) = t2q_r(B12dt); B12e(1:q) = t2q_r(B12et)
        B21d(1:q) = t2q_r(B21dt); B21e(1:q) = t2q_r(B21et)
        B22d(1:q) = t2q_r(B22dt); B22e(1:q) = t2q_r(B22et)
    end subroutine

    subroutine target_zbbcsd(jobu1, jobu2, jobv1t, jobv2t, trans, m, p, q, &
                             theta, phi, U1, ldu1, U2, ldu2, V1t, ldv1t, V2t, ldv2t, &
                             B11d, B11e, B12d, B12e, B21d, B21e, B22d, B22e, info)
        character,   intent(in)    :: jobu1, jobu2, jobv1t, jobv2t, trans
        integer,     intent(in)    :: m, p, q, ldu1, ldu2, ldv1t, ldv2t
        real(ep),    intent(inout) :: theta(*), phi(*)
        complex(ep), intent(inout) :: U1(ldu1,*), U2(ldu2,*), V1t(ldv1t,*), V2t(ldv2t,*)
        real(ep),    intent(out)   :: B11d(*), B11e(*), B12d(*), B12e(*)
        real(ep),    intent(out)   :: B21d(*), B21e(*), B22d(*), B22e(*)
        integer,     intent(out)   :: info
        ${target_real}$, allocatable :: thetat(:), phit(:), rwork(:)
        ${target_complex}$, allocatable :: U1t(:,:), U2t(:,:), V1tt(:,:), V2tt(:,:)
        ${target_real}$, allocatable :: B11dt(:), B11et(:), B12dt(:), B12et(:)
        ${target_real}$, allocatable :: B21dt(:), B21et(:), B22dt(:), B22et(:)
        ${target_real}$ :: ropt(1)
        integer :: lrwork
        allocate(thetat(q), phit(max(1, q-1)), U1t(ldu1, p), U2t(ldu2, m-p), &
                 V1tt(ldv1t, q), V2tt(ldv2t, m-q), &
                 B11dt(q), B11et(q), B12dt(q), B12et(q), &
                 B21dt(q), B21et(q), B22dt(q), B22et(q))
        thetat = q2t_r(theta(1:q)); if (q > 1) phit = q2t_r(phi(1:q-1))
        U1t = q2t_c(U1(1:ldu1, 1:p)); U2t = q2t_c(U2(1:ldu2, 1:m-p))
        V1tt = q2t_c(V1t(1:ldv1t, 1:q)); V2tt = q2t_c(V2t(1:ldv2t, 1:m-q))
        call ${C}$bbcsd(jobu1, jobu2, jobv1t, jobv2t, trans, m, p, q, &
                        thetat, phit, U1t, ldu1, U2t, ldu2, V1tt, ldv1t, V2tt, ldv2t, &
                        B11dt, B11et, B12dt, B12et, B21dt, B21et, B22dt, B22et, &
                        ropt, -1, info)
        lrwork = max(1, int(t2q_r(ropt(1)))); allocate(rwork(lrwork))
        call ${C}$bbcsd(jobu1, jobu2, jobv1t, jobv2t, trans, m, p, q, &
                        thetat, phit, U1t, ldu1, U2t, ldu2, V1tt, ldv1t, V2tt, ldv2t, &
                        B11dt, B11et, B12dt, B12et, B21dt, B21et, B22dt, B22et, &
                        rwork, lrwork, info)
        theta(1:q) = t2q_r(thetat); if (q > 1) phi(1:q-1) = t2q_r(phit)
        U1(1:ldu1, 1:p) = t2q_c(U1t); U2(1:ldu2, 1:m-p) = t2q_c(U2t)
        V1t(1:ldv1t, 1:q) = t2q_c(V1tt); V2t(1:ldv2t, 1:m-q) = t2q_c(V2tt)
        B11d(1:q) = t2q_r(B11dt); B11e(1:q) = t2q_r(B11et)
        B12d(1:q) = t2q_r(B12dt); B12e(1:q) = t2q_r(B12et)
        B21d(1:q) = t2q_r(B21dt); B21e(1:q) = t2q_r(B21et)
        B22d(1:q) = t2q_r(B22dt); B22e(1:q) = t2q_r(B22et)
    end subroutine

    subroutine target_dorbdb(trans, signs, m, p, q, X11, ldx11, X12, ldx12, &
                             X21, ldx21, X22, ldx22, theta, phi, &
                             taup1, taup2, tauq1, tauq2, info)
        character, intent(in)    :: trans, signs
        integer,   intent(in)    :: m, p, q, ldx11, ldx12, ldx21, ldx22
        real(ep),  intent(inout) :: X11(ldx11,*), X12(ldx12,*), X21(ldx21,*), X22(ldx22,*)
        real(ep),  intent(out)   :: theta(*), phi(*), taup1(*), taup2(*), tauq1(*), tauq2(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: X11t(:,:), X12t(:,:), X21t(:,:), X22t(:,:)
        ${target_real}$, allocatable :: thetat(:), phit(:), tp1(:), tp2(:), tq1(:), tq2(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, c11, c12, c21, c22
        if (trans == 'N' .or. trans == 'n') then
            c11 = q;     c12 = m - q; c21 = q;     c22 = m - q
        else
            c11 = p;     c12 = p;     c21 = m - p; c22 = m - p
        end if
        allocate(X11t(ldx11, c11), X12t(ldx12, c12), X21t(ldx21, c21), X22t(ldx22, c22), &
                 thetat(q), phit(max(1, q-1)), tp1(p), tp2(m-p), tq1(q), tq2(m-q))
        X11t = q2t_r(X11(1:ldx11, 1:c11)); X12t = q2t_r(X12(1:ldx12, 1:c12))
        X21t = q2t_r(X21(1:ldx21, 1:c21)); X22t = q2t_r(X22(1:ldx22, 1:c22))
        call ${R}$orbdb(trans, signs, m, p, q, X11t, ldx11, X12t, ldx12, &
                        X21t, ldx21, X22t, ldx22, thetat, phit, tp1, tp2, tq1, tq2, &
                        wopt, -1, info)
        lwork = max(1, int(real(t2q_r(wopt(1)), ep))); allocate(work(lwork))
        call ${R}$orbdb(trans, signs, m, p, q, X11t, ldx11, X12t, ldx12, &
                        X21t, ldx21, X22t, ldx22, thetat, phit, tp1, tp2, tq1, tq2, &
                        work, lwork, info)
        X11(1:ldx11, 1:c11) = t2q_r(X11t); X12(1:ldx12, 1:c12) = t2q_r(X12t)
        X21(1:ldx21, 1:c21) = t2q_r(X21t); X22(1:ldx22, 1:c22) = t2q_r(X22t)
        theta(1:q) = t2q_r(thetat); if (q > 1) phi(1:q-1) = t2q_r(phit)
        taup1(1:p) = t2q_r(tp1); taup2(1:m-p) = t2q_r(tp2)
        tauq1(1:q) = t2q_r(tq1); tauq2(1:m-q) = t2q_r(tq2)
    end subroutine

    subroutine target_zunbdb(trans, signs, m, p, q, X11, ldx11, X12, ldx12, &
                             X21, ldx21, X22, ldx22, theta, phi, &
                             taup1, taup2, tauq1, tauq2, info)
        character,   intent(in)    :: trans, signs
        integer,     intent(in)    :: m, p, q, ldx11, ldx12, ldx21, ldx22
        complex(ep), intent(inout) :: X11(ldx11,*), X12(ldx12,*), X21(ldx21,*), X22(ldx22,*)
        real(ep),    intent(out)   :: theta(*), phi(*)
        complex(ep), intent(out)   :: taup1(*), taup2(*), tauq1(*), tauq2(*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: X11t(:,:), X12t(:,:), X21t(:,:), X22t(:,:)
        ${target_complex}$, allocatable :: tp1(:), tp2(:), tq1(:), tq2(:), work(:)
        ${target_real}$, allocatable :: thetat(:), phit(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork, c11, c12, c21, c22
        if (trans == 'N' .or. trans == 'n') then
            c11 = q;     c12 = m - q; c21 = q;     c22 = m - q
        else
            c11 = p;     c12 = p;     c21 = m - p; c22 = m - p
        end if
        allocate(X11t(ldx11, c11), X12t(ldx12, c12), X21t(ldx21, c21), X22t(ldx22, c22), &
                 thetat(q), phit(max(1, q-1)), tp1(p), tp2(m-p), tq1(q), tq2(m-q))
        X11t = q2t_c(X11(1:ldx11, 1:c11)); X12t = q2t_c(X12(1:ldx12, 1:c12))
        X21t = q2t_c(X21(1:ldx21, 1:c21)); X22t = q2t_c(X22(1:ldx22, 1:c22))
        call ${C}$unbdb(trans, signs, m, p, q, X11t, ldx11, X12t, ldx12, &
                        X21t, ldx21, X22t, ldx22, thetat, phit, tp1, tp2, tq1, tq2, &
                        wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        call ${C}$unbdb(trans, signs, m, p, q, X11t, ldx11, X12t, ldx12, &
                        X21t, ldx21, X22t, ldx22, thetat, phit, tp1, tp2, tq1, tq2, &
                        work, lwork, info)
        X11(1:ldx11, 1:c11) = t2q_c(X11t); X12(1:ldx12, 1:c12) = t2q_c(X12t)
        X21(1:ldx21, 1:c21) = t2q_c(X21t); X22(1:ldx22, 1:c22) = t2q_c(X22t)
        theta(1:q) = t2q_r(thetat); if (q > 1) phi(1:q-1) = t2q_r(phit)
        taup1(1:p) = t2q_c(tp1); taup2(1:m-p) = t2q_c(tp2)
        tauq1(1:q) = t2q_c(tq1); tauq2(1:m-q) = t2q_c(tq2)
    end subroutine

    subroutine target_dorcsd(jobu1, jobu2, jobv1t, jobv2t, trans, signs, &
                             m, p, q, X11, ldx11, X12, ldx12, X21, ldx21, &
                             X22, ldx22, theta, U1, ldu1, U2, ldu2, &
                             V1t, ldv1t, V2t, ldv2t, info)
        character, intent(in)    :: jobu1, jobu2, jobv1t, jobv2t, trans, signs
        integer,   intent(in)    :: m, p, q, ldx11, ldx12, ldx21, ldx22
        integer,   intent(in)    :: ldu1, ldu2, ldv1t, ldv2t
        real(ep),  intent(inout) :: X11(ldx11,*), X12(ldx12,*), X21(ldx21,*), X22(ldx22,*)
        real(ep),  intent(out)   :: theta(*)
        real(ep),  intent(out)   :: U1(ldu1,*), U2(ldu2,*), V1t(ldv1t,*), V2t(ldv2t,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: X11t(:,:), X12t(:,:), X21t(:,:), X22t(:,:)
        ${target_real}$, allocatable :: thetat(:), U1t(:,:), U2t(:,:), V1tt(:,:), V2tt(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer, allocatable :: iwork(:)
        integer :: lwork, c11, c12, c21, c22
        if (trans == 'N' .or. trans == 'n') then
            c11 = q;     c12 = m - q; c21 = q;     c22 = m - q
        else
            c11 = p;     c12 = p;     c21 = m - p; c22 = m - p
        end if
        allocate(X11t(ldx11, c11), X12t(ldx12, c12), X21t(ldx21, c21), X22t(ldx22, c22), &
                 thetat(q), U1t(ldu1, p), U2t(ldu2, m-p), V1tt(ldv1t, q), V2tt(ldv2t, m-q), &
                 iwork(m))
        X11t = q2t_r(X11(1:ldx11, 1:c11)); X12t = q2t_r(X12(1:ldx12, 1:c12))
        X21t = q2t_r(X21(1:ldx21, 1:c21)); X22t = q2t_r(X22(1:ldx22, 1:c22))
        call ${R}$orcsd(jobu1, jobu2, jobv1t, jobv2t, trans, signs, m, p, q, &
                        X11t, ldx11, X12t, ldx12, X21t, ldx21, X22t, ldx22, thetat, &
                        U1t, ldu1, U2t, ldu2, V1tt, ldv1t, V2tt, ldv2t, &
                        wopt, -1, iwork, info)
        lwork = max(1, int(real(t2q_r(wopt(1)), ep))); allocate(work(lwork))
        call ${R}$orcsd(jobu1, jobu2, jobv1t, jobv2t, trans, signs, m, p, q, &
                        X11t, ldx11, X12t, ldx12, X21t, ldx21, X22t, ldx22, thetat, &
                        U1t, ldu1, U2t, ldu2, V1tt, ldv1t, V2tt, ldv2t, &
                        work, lwork, iwork, info)
        theta(1:q) = t2q_r(thetat)
        U1(1:ldu1, 1:p) = t2q_r(U1t); U2(1:ldu2, 1:m-p) = t2q_r(U2t)
        V1t(1:ldv1t, 1:q) = t2q_r(V1tt); V2t(1:ldv2t, 1:m-q) = t2q_r(V2tt)
    end subroutine

    subroutine target_zuncsd(jobu1, jobu2, jobv1t, jobv2t, trans, signs, &
                             m, p, q, X11, ldx11, X12, ldx12, X21, ldx21, &
                             X22, ldx22, theta, U1, ldu1, U2, ldu2, &
                             V1t, ldv1t, V2t, ldv2t, info)
        character,   intent(in)    :: jobu1, jobu2, jobv1t, jobv2t, trans, signs
        integer,     intent(in)    :: m, p, q, ldx11, ldx12, ldx21, ldx22
        integer,     intent(in)    :: ldu1, ldu2, ldv1t, ldv2t
        complex(ep), intent(inout) :: X11(ldx11,*), X12(ldx12,*), X21(ldx21,*), X22(ldx22,*)
        real(ep),    intent(out)   :: theta(*)
        complex(ep), intent(out)   :: U1(ldu1,*), U2(ldu2,*), V1t(ldv1t,*), V2t(ldv2t,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: X11t(:,:), X12t(:,:), X21t(:,:), X22t(:,:)
        ${target_complex}$, allocatable :: U1t(:,:), U2t(:,:), V1tt(:,:), V2tt(:,:), work(:)
        ${target_real}$, allocatable :: thetat(:), rwork(:)
        ${target_complex}$ :: wopt(1)
        ${target_real}$ :: ropt(1)
        integer, allocatable :: iwork(:)
        integer :: lwork, lrwork, c11, c12, c21, c22
        if (trans == 'N' .or. trans == 'n') then
            c11 = q;     c12 = m - q; c21 = q;     c22 = m - q
        else
            c11 = p;     c12 = p;     c21 = m - p; c22 = m - p
        end if
        allocate(X11t(ldx11, c11), X12t(ldx12, c12), X21t(ldx21, c21), X22t(ldx22, c22), &
                 thetat(q), U1t(ldu1, p), U2t(ldu2, m-p), V1tt(ldv1t, q), V2tt(ldv2t, m-q), &
                 iwork(m))
        X11t = q2t_c(X11(1:ldx11, 1:c11)); X12t = q2t_c(X12(1:ldx12, 1:c12))
        X21t = q2t_c(X21(1:ldx21, 1:c21)); X22t = q2t_c(X22(1:ldx22, 1:c22))
        call ${C}$uncsd(jobu1, jobu2, jobv1t, jobv2t, trans, signs, m, p, q, &
                        X11t, ldx11, X12t, ldx12, X21t, ldx21, X22t, ldx22, thetat, &
                        U1t, ldu1, U2t, ldu2, V1tt, ldv1t, V2tt, ldv2t, &
                        wopt, -1, ropt, -1, iwork, info)
        lwork  = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        lrwork = max(1, int(t2q_r(ropt(1))));            allocate(rwork(lrwork))
        call ${C}$uncsd(jobu1, jobu2, jobv1t, jobv2t, trans, signs, m, p, q, &
                        X11t, ldx11, X12t, ldx12, X21t, ldx21, X22t, ldx22, thetat, &
                        U1t, ldu1, U2t, ldu2, V1tt, ldv1t, V2tt, ldv2t, &
                        work, lwork, rwork, lrwork, iwork, info)
        theta(1:q) = t2q_r(thetat)
        U1(1:ldu1, 1:p) = t2q_c(U1t); U2(1:ldu2, 1:m-p) = t2q_c(U2t)
        V1t(1:ldv1t, 1:q) = t2q_c(V1tt); V2t(1:ldv2t, 1:m-q) = t2q_c(V2tt)
    end subroutine

    subroutine target_ztprfb(side, trans, direct, storev, m, n, k, l, &
                             V, ldv, T, ldt, A, lda, B, ldb, ldwork)
        character,   intent(in)    :: side, trans, direct, storev
        integer,     intent(in)    :: m, n, k, l, ldv, ldt, lda, ldb, ldwork
        complex(ep), intent(in)    :: V(ldv,*), T(ldt,*)
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*)
        ${target_complex}$, allocatable :: Vt(:,:), Tt(:,:), At(:,:), Bt(:,:), work(:,:)
        integer :: vcols, acols, wcols
        if (storev == 'C' .or. storev == 'c') then
            vcols = k
        else
            vcols = merge(n, m, side == 'L' .or. side == 'l')
        end if
        acols = merge(n, k, side == 'L' .or. side == 'l')
        wcols = merge(n, k, side == 'L' .or. side == 'l')
        allocate(Vt(ldv, vcols), Tt(ldt, k), At(lda, acols), Bt(ldb, n), work(ldwork, wcols))
        Vt = q2t_c(V(1:ldv, 1:vcols)); Tt = q2t_c(T(1:ldt, 1:k))
        At = q2t_c(A(1:lda, 1:acols)); Bt = q2t_c(B(1:ldb, 1:n))
        call ${C}$tprfb(side, trans, direct, storev, m, n, k, l, &
                        Vt, ldv, Tt, ldt, At, lda, Bt, ldb, work, ldwork)
        A(1:lda, 1:acols) = t2q_c(At); B(1:ldb, 1:n) = t2q_c(Bt)
    end subroutine

    ! ── Bunch–Kaufman _rook wrappers ───────────────────────────────
    subroutine target_dsytrf_rook(uplo, n, A, lda, ipiv, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, lda
        real(ep),  intent(inout) :: A(lda,*)
        integer,   intent(out)   :: ipiv(*), info
        ${target_real}$, allocatable :: At(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$sytrf_rook(uplo, n, At, lda, ipiv, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$sytrf_rook(uplo, n, At, lda, ipiv, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
    end subroutine

    subroutine target_dsytf2_rook(uplo, n, A, lda, ipiv, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, lda
        real(ep),  intent(inout) :: A(lda,*)
        integer,   intent(out)   :: ipiv(*), info
        ${target_real}$, allocatable :: At(:,:)
        allocate(At(lda, n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$sytf2_rook(uplo, n, At, lda, ipiv, info)
        A(1:lda, 1:n) = t2q_r(At)
    end subroutine

    subroutine target_dsytrs_rook(uplo, n, nrhs, A, lda, ipiv, B, ldb, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, nrhs, lda, ldb
        real(ep),  intent(in)    :: A(lda,*)
        integer,   intent(in)    :: ipiv(*)
        real(ep),  intent(inout) :: B(ldb,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:)
        allocate(At(lda, n), Bt(ldb, nrhs))
        At = q2t_r(A(1:lda, 1:n)); Bt = q2t_r(B(1:ldb, 1:nrhs))
        call ${R}$sytrs_rook(uplo, n, nrhs, At, lda, ipiv, Bt, ldb, info)
        B(1:ldb, 1:nrhs) = t2q_r(Bt)
    end subroutine

    subroutine target_dsytri_rook(uplo, n, A, lda, ipiv, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, lda
        real(ep),  intent(inout) :: A(lda,*)
        integer,   intent(in)    :: ipiv(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), work(:)
        allocate(At(lda, n), work(n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$sytri_rook(uplo, n, At, lda, ipiv, work, info)
        A(1:lda, 1:n) = t2q_r(At)
    end subroutine

    subroutine target_dsycon_rook(uplo, n, A, lda, ipiv, anorm, rcond, info)
        character, intent(in)  :: uplo
        integer,   intent(in)  :: n, lda
        real(ep),  intent(in)  :: A(lda,*), anorm
        integer,   intent(in)  :: ipiv(*)
        real(ep),  intent(out) :: rcond
        integer,   intent(out) :: info
        ${target_real}$, allocatable :: At(:,:), work(:)
        ${target_real}$ :: rct
        integer, allocatable :: iwork(:)
        allocate(At(lda, n), work(2*n), iwork(n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$sycon_rook(uplo, n, At, lda, ipiv, q2t_r(anorm), rct, work, iwork, info)
        rcond = t2q_r(rct)
    end subroutine

    subroutine target_dsysv_rook(uplo, n, nrhs, A, lda, ipiv, B, ldb, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, nrhs, lda, ldb
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*)
        integer,   intent(out)   :: ipiv(*), info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), Bt(ldb, nrhs))
        At = q2t_r(A(1:lda, 1:n)); Bt = q2t_r(B(1:ldb, 1:nrhs))
