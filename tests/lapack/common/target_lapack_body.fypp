        integer :: nw
        nw = merge(n, m, side == 'L' .or. side == 'l')
        allocate(At(lda, k), taut(k), Ct(ldc, n), work(nw))
        At = q2t_r(A(1:lda, 1:k)); taut = q2t_r(tau(1:k)); Ct = q2t_r(C(1:ldc, 1:n))
        call ${R}$orm2r(side, trans, m, n, k, At, lda, taut, Ct, ldc, work, info)
        C(1:ldc, 1:n) = t2q_r(Ct)
    end subroutine

    subroutine target_zunm2r(side, trans, m, n, k, A, lda, tau, C, ldc, info)
        character,   intent(in)    :: side, trans
        integer,     intent(in)    :: m, n, k, lda, ldc
        complex(ep), intent(in)    :: A(lda,*), tau(*)
        complex(ep), intent(inout) :: C(ldc,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), taut(:), Ct(:,:), work(:)
        integer :: nw
        nw = merge(n, m, side == 'L' .or. side == 'l')
        allocate(At(lda, k), taut(k), Ct(ldc, n), work(nw))
        At = q2t_c(A(1:lda, 1:k)); taut = q2t_c(tau(1:k)); Ct = q2t_c(C(1:ldc, 1:n))
        call ${C}$unm2r(side, trans, m, n, k, At, lda, taut, Ct, ldc, work, info)
        C(1:ldc, 1:n) = t2q_c(Ct)
    end subroutine

    subroutine target_dormlq(side, trans, m, n, k, A, lda, tau, C, ldc, info)
        character, intent(in)    :: side, trans
        integer,   intent(in)    :: m, n, k, lda, ldc
        real(ep),  intent(in)    :: A(lda,*), tau(*)
        real(ep),  intent(inout) :: C(ldc,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), taut(:), Ct(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, ncols
        ncols = merge(m, n, side == 'L' .or. side == 'l')   ! A is K x ncols
        allocate(At(lda, ncols), taut(k), Ct(ldc, n))
        At = q2t_r(A(1:lda, 1:ncols)); taut = q2t_r(tau(1:k)); Ct = q2t_r(C(1:ldc, 1:n))
        call ${R}$ormlq(side, trans, m, n, k, At, lda, taut, Ct, ldc, wopt, -1, info)
        lwork = max(1, int(real(t2q_r(wopt(1)), ep))); allocate(work(lwork))
        call ${R}$ormlq(side, trans, m, n, k, At, lda, taut, Ct, ldc, work, lwork, info)
        C(1:ldc, 1:n) = t2q_r(Ct)
    end subroutine

    subroutine target_zunmlq(side, trans, m, n, k, A, lda, tau, C, ldc, info)
        character,   intent(in)    :: side, trans
        integer,     intent(in)    :: m, n, k, lda, ldc
        complex(ep), intent(in)    :: A(lda,*), tau(*)
        complex(ep), intent(inout) :: C(ldc,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), taut(:), Ct(:,:), work(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork, ncols
        ncols = merge(m, n, side == 'L' .or. side == 'l')
        allocate(At(lda, ncols), taut(k), Ct(ldc, n))
        At = q2t_c(A(1:lda, 1:ncols)); taut = q2t_c(tau(1:k)); Ct = q2t_c(C(1:ldc, 1:n))
        call ${C}$unmlq(side, trans, m, n, k, At, lda, taut, Ct, ldc, wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        call ${C}$unmlq(side, trans, m, n, k, At, lda, taut, Ct, ldc, work, lwork, info)
        C(1:ldc, 1:n) = t2q_c(Ct)
    end subroutine

    subroutine target_dormhr(side, trans, m, n, ilo, ihi, A, lda, tau, C, ldc, info)
        character, intent(in)    :: side, trans
        integer,   intent(in)    :: m, n, ilo, ihi, lda, ldc
        real(ep),  intent(in)    :: A(lda,*), tau(*)
        real(ep),  intent(inout) :: C(ldc,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), taut(:), Ct(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, nq
        nq = merge(m, n, side == 'L' .or. side == 'l')
        allocate(At(lda, nq), taut(max(1, nq-1)), Ct(ldc, n))
        At = q2t_r(A(1:lda, 1:nq))
        if (nq > 1) taut(1:nq-1) = q2t_r(tau(1:nq-1))
        Ct = q2t_r(C(1:ldc, 1:n))
        call ${R}$ormhr(side, trans, m, n, ilo, ihi, At, lda, taut, Ct, ldc, &
                        wopt, -1, info)
        lwork = max(1, int(real(t2q_r(wopt(1)), ep))); allocate(work(lwork))
        call ${R}$ormhr(side, trans, m, n, ilo, ihi, At, lda, taut, Ct, ldc, &
                        work, lwork, info)
        C(1:ldc, 1:n) = t2q_r(Ct)
    end subroutine

    subroutine target_zunmhr(side, trans, m, n, ilo, ihi, A, lda, tau, C, ldc, info)
        character,   intent(in)    :: side, trans
        integer,     intent(in)    :: m, n, ilo, ihi, lda, ldc
        complex(ep), intent(in)    :: A(lda,*), tau(*)
        complex(ep), intent(inout) :: C(ldc,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), taut(:), Ct(:,:), work(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork, nq
        nq = merge(m, n, side == 'L' .or. side == 'l')
        allocate(At(lda, nq), taut(max(1, nq-1)), Ct(ldc, n))
        At = q2t_c(A(1:lda, 1:nq))
        if (nq > 1) taut(1:nq-1) = q2t_c(tau(1:nq-1))
        Ct = q2t_c(C(1:ldc, 1:n))
        call ${C}$unmhr(side, trans, m, n, ilo, ihi, At, lda, taut, Ct, ldc, &
                        wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        call ${C}$unmhr(side, trans, m, n, ilo, ihi, At, lda, taut, Ct, ldc, &
                        work, lwork, info)
        C(1:ldc, 1:n) = t2q_c(Ct)
    end subroutine

    subroutine target_dtzrzf(m, n, A, lda, tau, info)
        integer,  intent(in)    :: m, n, lda
        real(ep), intent(inout) :: A(lda,*)
        real(ep), intent(out)   :: tau(*)
        integer,  intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), taut(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), taut(m))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$tzrzf(m, n, At, lda, taut, wopt, -1, info)
        lwork = max(1, int(real(t2q_r(wopt(1)), ep))); allocate(work(lwork))
        call ${R}$tzrzf(m, n, At, lda, taut, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
        tau(1:m) = t2q_r(taut)
    end subroutine

    subroutine target_ztzrzf(m, n, A, lda, tau, info)
        integer,     intent(in)    :: m, n, lda
        complex(ep), intent(inout) :: A(lda,*)
        complex(ep), intent(out)   :: tau(*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), taut(:), work(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), taut(m))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$tzrzf(m, n, At, lda, taut, wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        call ${C}$tzrzf(m, n, At, lda, taut, work, lwork, info)
        A(1:lda, 1:n) = t2q_c(At)
        tau(1:m) = t2q_c(taut)
    end subroutine

    subroutine target_dormrz(side, trans, m, n, k, l, A, lda, tau, C, ldc, info)
        character, intent(in)    :: side, trans
        integer,   intent(in)    :: m, n, k, l, lda, ldc
        real(ep),  intent(in)    :: A(lda,*), tau(*)
        real(ep),  intent(inout) :: C(ldc,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), taut(:), Ct(:,:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, ncols
        ncols = merge(m, n, side == 'L' .or. side == 'l')
        allocate(At(lda, ncols), taut(k), Ct(ldc, n))
        At = q2t_r(A(1:lda, 1:ncols)); taut = q2t_r(tau(1:k)); Ct = q2t_r(C(1:ldc, 1:n))
        call ${R}$ormrz(side, trans, m, n, k, l, At, lda, taut, Ct, ldc, wopt, -1, info)
        lwork = max(1, int(real(t2q_r(wopt(1)), ep))); allocate(work(lwork))
        call ${R}$ormrz(side, trans, m, n, k, l, At, lda, taut, Ct, ldc, work, lwork, info)
        C(1:ldc, 1:n) = t2q_r(Ct)
    end subroutine

    subroutine target_zunmrz(side, trans, m, n, k, l, A, lda, tau, C, ldc, info)
        character,   intent(in)    :: side, trans
        integer,     intent(in)    :: m, n, k, l, lda, ldc
        complex(ep), intent(in)    :: A(lda,*), tau(*)
        complex(ep), intent(inout) :: C(ldc,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), taut(:), Ct(:,:), work(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork, ncols
        ncols = merge(m, n, side == 'L' .or. side == 'l')
        allocate(At(lda, ncols), taut(k), Ct(ldc, n))
        At = q2t_c(A(1:lda, 1:ncols)); taut = q2t_c(tau(1:k)); Ct = q2t_c(C(1:ldc, 1:n))
        call ${C}$unmrz(side, trans, m, n, k, l, At, lda, taut, Ct, ldc, wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        call ${C}$unmrz(side, trans, m, n, k, l, At, lda, taut, Ct, ldc, work, lwork, info)
        C(1:ldc, 1:n) = t2q_c(Ct)
    end subroutine

    ! ----- P11 RFP factor / solve / triangular -----

    subroutine target_dpftrf(transr, uplo, n, A, info)
        character, intent(in)    :: transr, uplo
        integer,   intent(in)    :: n
        real(ep),  intent(inout) :: A(0:*)
        integer,   intent(out)   :: info
        integer :: nt
        ${target_real}$, allocatable :: At(:)
        nt = n*(n+1)/2
        allocate(At(0:nt-1))
        At = q2t_r(A(0:nt-1))
        call ${R}$pftrf(transr, uplo, n, At, info)
        A(0:nt-1) = t2q_r(At)
    end subroutine

