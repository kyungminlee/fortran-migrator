        complex(ep), intent(in)    :: A(lda,*)
        complex(ep), intent(inout) :: C(0:*)
        integer :: nt
        ${target_complex}$, allocatable :: At(:,:), Ct(:)
        nt = n*(n+1)/2
        allocate(At(lda, max(1, merge(k, n, trans == 'N' .or. trans == 'n'))), Ct(0:nt-1))
        At = q2t_c(A(1:lda, 1:size(At, 2)))
        Ct = q2t_c(C(0:nt-1))
        call ${C}$hfrk(transr, uplo, trans, n, k, q2t_r(alpha), At, lda, q2t_r(beta), Ct)
        C(0:nt-1) = t2q_c(Ct)
    end subroutine

    subroutine target_dtfsm(transr, side, uplo, trans, diag, m, n, alpha, A, B, ldb)
        character, intent(in)    :: transr, side, uplo, trans, diag
