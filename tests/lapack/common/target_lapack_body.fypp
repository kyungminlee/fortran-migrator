    subroutine target_dsysv_aa_2stage(uplo, n, nrhs, A, lda, TB, ltb, ipiv, ipiv2, B, ldb, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, nrhs, lda, ltb, ldb
        real(ep),  intent(inout) :: A(lda,*), TB(*), B(ldb,*)
        integer,   intent(out)   :: ipiv(*), ipiv2(*), info
        ${target_real}$, allocatable :: At(:,:), TBt(:), Bt(:,:), work(:)
