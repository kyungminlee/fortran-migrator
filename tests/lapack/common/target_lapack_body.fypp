    ! ── Phase L1 — 2-stage symmetric/Hermitian eigensolvers (JOBZ='N') ──
    ! All 2-stage drivers reject JOBZ='V' at parameter check 1; tests
    ! must hard-code 'N'. Workspaces are much larger than the regular
    ! variants — always do the (-1) workspace query first.
    subroutine target_dsyev_2stage(jobz, uplo, n, A, lda, w, info)
        character, intent(in)    :: jobz, uplo
        integer,   intent(in)    :: n, lda
        real(ep),  intent(inout) :: A(lda,*)
        real(ep),  intent(out)   :: w(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), wt(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda, n), wt(n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$syev_2stage(jobz, uplo, n, At, lda, wt, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$syev_2stage(jobz, uplo, n, At, lda, wt, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
        w(1:n)        = t2q_r(wt)
    end subroutine

    subroutine target_zheev_2stage(jobz, uplo, n, A, lda, w, info)
        character,   intent(in)    :: jobz, uplo
        integer,     intent(in)    :: n, lda
        complex(ep), intent(inout) :: A(lda,*)
        real(ep),    intent(out)   :: w(*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), work(:)
        ${target_real}$,    allocatable :: wt(:), rwork(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork, lrwork
        lrwork = max(1, 3*n - 2)
        allocate(At(lda, n), wt(n), rwork(lrwork))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$heev_2stage(jobz, uplo, n, At, lda, wt, wopt, -1, rwork, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$heev_2stage(jobz, uplo, n, At, lda, wt, work, lwork, rwork, info)
        A(1:lda, 1:n) = t2q_c(At)
        w(1:n)        = t2q_r(wt)
    end subroutine

