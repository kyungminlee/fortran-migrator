        integer,     intent(out) :: info
        ${target_complex}$, allocatable :: At(:,:), work(:)
        ${target_real}$,    allocatable :: rwork(:)
        ${target_real}$ :: rct
        allocate(At(lda, n), work(2*n), rwork(2*n))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$gecon(norm, n, At, lda, q2t_r(anorm), rct, work, rwork, info)
        rcond = t2q_r(rct)
    end subroutine

