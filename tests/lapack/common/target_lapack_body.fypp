        np = nq*(nq+1)/2
        ntau = max(1, nq - 1)
        lwork = merge(n, m, side == 'L' .or. side == 'l')
        allocate(APt(np), taut(ntau), Ct(ldc, n), work(max(1, lwork)))
        APt = q2t_c(AP(1:np)); taut = q2t_c(tau(1:ntau))
        Ct = q2t_c(C(1:ldc, 1:n))
        call ${C}$upmtr(side, uplo, trans, m, n, APt, taut, Ct, ldc, work, info)
        C(1:ldc, 1:n) = t2q_c(Ct)
    end subroutine

    ! ── Phase 23 wrappers ────────────────────────────────────────────
    subroutine target_dgebrd(m, n, A, lda, D, E, tauq, taup, info)
        integer,  intent(in)    :: m, n, lda
        real(ep), intent(inout) :: A(lda,*)
        real(ep), intent(out)   :: D(*), E(*), tauq(*), taup(*)
        integer,  intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Dt(:), Et(:), tauqt(:), taupt(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, mn, nE
        mn = min(m, n); nE = max(1, mn - 1)
        allocate(At(lda, n), Dt(mn), Et(nE), tauqt(mn), taupt(mn))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$gebrd(m, n, At, lda, Dt, Et, tauqt, taupt, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$gebrd(m, n, At, lda, Dt, Et, tauqt, taupt, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
        D(1:mn) = t2q_r(Dt); E(1:nE) = t2q_r(Et)
        tauq(1:mn) = t2q_r(tauqt); taup(1:mn) = t2q_r(taupt)
    end subroutine

    subroutine target_zgebrd(m, n, A, lda, D, E, tauq, taup, info)
        integer,     intent(in)    :: m, n, lda
        complex(ep), intent(inout) :: A(lda,*)
        real(ep),    intent(out)   :: D(*), E(*)
        complex(ep), intent(out)   :: tauq(*), taup(*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), tauqt(:), taupt(:), work(:)
        ${target_complex}$ :: wopt(1)
        ${target_real}$,    allocatable :: Dt(:), Et(:)
        integer :: lwork, mn, nE
        mn = min(m, n); nE = max(1, mn - 1)
        allocate(At(lda, n), Dt(mn), Et(nE), tauqt(mn), taupt(mn))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$gebrd(m, n, At, lda, Dt, Et, tauqt, taupt, wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$gebrd(m, n, At, lda, Dt, Et, tauqt, taupt, work, lwork, info)
        A(1:lda, 1:n) = t2q_c(At)
        D(1:mn) = t2q_r(Dt); E(1:nE) = t2q_r(Et)
        tauq(1:mn) = t2q_c(tauqt); taup(1:mn) = t2q_c(taupt)
    end subroutine

    subroutine target_dorgbr(vect, m, n, k, A, lda, tau, info)
        character, intent(in)    :: vect
        integer,   intent(in)    :: m, n, k, lda
        real(ep),  intent(inout) :: A(lda,*)
        real(ep),  intent(in)    :: tau(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), taut(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, ntau
        ntau = merge(min(m, k), min(n, k), vect == 'Q' .or. vect == 'q')
        allocate(At(lda, n), taut(max(1, ntau)))
        At = q2t_r(A(1:lda, 1:n)); taut = q2t_r(tau(1:max(1, ntau)))
