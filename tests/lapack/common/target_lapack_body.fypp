    subroutine target_dggesx(jobvsl, jobvsr, sort, selctg, sense, n, A, lda, &
                             B, ldb, sdim, alphar, alphai, beta, vsl, ldvsl, &
                             vsr, ldvsr, rconde, rcondv, info)
        character, intent(in) :: jobvsl, jobvsr, sort, sense
        interface
            logical function selctg(re, im, b)
                import :: ep
                real(ep), intent(in) :: re, im, b
            end function selctg
        end interface
        integer,   intent(in)    :: n, lda, ldb, ldvsl, ldvsr
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*)
        integer,   intent(out)   :: sdim, info
        real(ep),  intent(out)   :: alphar(*), alphai(*), beta(*)
        real(ep),  intent(out)   :: vsl(ldvsl,*), vsr(ldvsr,*)
        real(ep),  intent(out)   :: rconde(2), rcondv(2)
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), art(:), ait(:), bet(:)
        ${target_real}$, allocatable :: vslt(:,:), vsrt(:,:), work(:)
        integer, allocatable :: iwork(:)
        ${target_real}$ :: wopt(1), rcondet(2), rcondvt(2)
        logical, allocatable :: bwork(:)
        integer :: lwork, liwork, iwopt(1)
        allocate(At(lda,n), Bt(ldb,n), art(n), ait(n), bet(n))
        allocate(vslt(ldvsl,n), vsrt(ldvsr,n), bwork(n))
        At = q2t_r(A(1:lda,1:n)); Bt = q2t_r(B(1:ldb,1:n))
        call ${R}$ggesx(jobvsl, jobvsr, sort, target_selctg_r, sense, n, At, lda, &
                        Bt, ldb, sdim, art, ait, bet, vslt, ldvsl, vsrt, ldvsr, &
                        rcondet, rcondvt, wopt, -1, iwopt, -1, bwork, info)
        lwork = max(1, int(t2q_r(wopt(1)))); liwork = max(1, iwopt(1))
        allocate(work(lwork), iwork(liwork))
        call ${R}$ggesx(jobvsl, jobvsr, sort, target_selctg_r, sense, n, At, lda, &
                        Bt, ldb, sdim, art, ait, bet, vslt, ldvsl, vsrt, ldvsr, &
                        rcondet, rcondvt, work, lwork, iwork, liwork, bwork, info)
        A(1:lda,1:n) = t2q_r(At); B(1:ldb,1:n) = t2q_r(Bt)
        alphar(1:n) = t2q_r(art); alphai(1:n) = t2q_r(ait); beta(1:n) = t2q_r(bet)
        vsl(1:ldvsl,1:n) = t2q_r(vslt); vsr(1:ldvsr,1:n) = t2q_r(vsrt)
        rconde = t2q_r(rcondet); rcondv = t2q_r(rcondvt)
    end subroutine

