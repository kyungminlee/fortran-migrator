        Bt = q2t_r(B(1:ldb, 1:nrhs)); St = q2t_r(S(1:n))
        call ${R}$ppsvx(fact, uplo, n, nrhs, APt, AFPt, equed, St, Bt, ldb, &
                       Xt, ldx, rcondt, ferrt, berrt, work, iwork, info)
        AP(1:np) = t2q_r(APt); AFP(1:np) = t2q_r(AFPt)
        B(1:ldb, 1:nrhs) = t2q_r(Bt); X(1:ldx, 1:nrhs) = t2q_r(Xt)
