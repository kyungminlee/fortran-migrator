        At = q2t_r(A(0:nt-1)); Bt = q2t_r(B(0:ldb-1, 0:n-1))
        call ${R}$tfsm(transr, side, uplo, trans, diag, m, n, q2t_r(alpha), At, Bt, ldb)
        B(0:ldb-1, 0:n-1) = t2q_r(Bt)
