    subroutine target_zunmrq(side, trans, m, n, k, A, lda, tau, C, ldc, info)
        character,   intent(in)    :: side, trans
        integer,     intent(in)    :: m, n, k, lda, ldc
        complex(ep), intent(in)    :: A(lda,*), tau(*)
        complex(ep), intent(inout) :: C(ldc,*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), taut(:), Ct(:,:), work(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork, ncolA
        if (side == 'L' .or. side == 'l') then
            ncolA = m
        else
            ncolA = n
        end if
        allocate(At(lda, ncolA), taut(k), Ct(ldc, n))
        At = q2t_c(A(1:lda, 1:ncolA))
        taut = q2t_c(tau(1:k))
        Ct = q2t_c(C(1:ldc, 1:n))
        call ${C}$unmrq(side, trans, m, n, k, At, lda, taut, Ct, ldc, &
                        wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$unmrq(side, trans, m, n, k, At, lda, taut, Ct, ldc, &
                        work, lwork, info)
        C(1:ldc, 1:n) = t2q_c(Ct)
    end subroutine

    ! ── Phase 9 wrappers ─────────────────────────────────────────────
    subroutine target_dsptrf(uplo, n, AP, ipiv, info)
        character, intent(in)    :: uplo
