        allocate(At(lda, n), taut(max(1,n-1)))
        At = q2t_r(A(1:lda, 1:n)); taut = q2t_r(tau(1:max(1,n-1)))
        call ${R}$orgtr(uplo, n, At, lda, taut, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$orgtr(uplo, n, At, lda, taut, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
    end subroutine

