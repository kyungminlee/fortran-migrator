                        wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$unmrq(side, trans, m, n, k, At, lda, taut, Ct, ldc, &
                        work, lwork, info)
        C(1:ldc, 1:n) = t2q_c(Ct)
