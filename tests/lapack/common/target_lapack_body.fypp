    ! ── Phase 32 wrappers ────────────────────────────────────────────
    subroutine target_dhseqr(job, compz, n, ilo, ihi, H, ldh, WR, WI, Z, ldz, info)
        character, intent(in)    :: job, compz
        integer,   intent(in)    :: n, ilo, ihi, ldh, ldz
        real(ep),  intent(inout) :: H(ldh,*), Z(ldz,*)
        real(ep),  intent(out)   :: WR(*), WI(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: Ht(:,:), Zt(:,:), WRt(:), WIt(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, nz
        nz = merge(n, 1, compz == 'V' .or. compz == 'v' .or. compz == 'I' .or. compz == 'i')
        allocate(Ht(ldh, n), Zt(ldz, nz), WRt(n), WIt(n))
        Ht = q2t_r(H(1:ldh, 1:n))
        if (compz == 'V' .or. compz == 'v') Zt = q2t_r(Z(1:ldz, 1:nz))
        call ${R}$hseqr(job, compz, n, ilo, ihi, Ht, ldh, WRt, WIt, Zt, ldz, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$hseqr(job, compz, n, ilo, ihi, Ht, ldh, WRt, WIt, Zt, ldz, work, lwork, info)
        H(1:ldh, 1:n) = t2q_r(Ht)
        if (compz /= 'N' .and. compz /= 'n') Z(1:ldz, 1:nz) = t2q_r(Zt)
        WR(1:n) = t2q_r(WRt); WI(1:n) = t2q_r(WIt)
    end subroutine

    subroutine target_zhseqr(job, compz, n, ilo, ihi, H, ldh, W, Z, ldz, info)
        character,   intent(in)    :: job, compz
        integer,     intent(in)    :: n, ilo, ihi, ldh, ldz
        complex(ep), intent(inout) :: H(ldh,*), Z(ldz,*)
        complex(ep), intent(out)   :: W(*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: Ht(:,:), Zt(:,:), Wt(:), work(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork, nz
        nz = merge(n, 1, compz == 'V' .or. compz == 'v' .or. compz == 'I' .or. compz == 'i')
        allocate(Ht(ldh, n), Zt(ldz, nz), Wt(n))
        Ht = q2t_c(H(1:ldh, 1:n))
        if (compz == 'V' .or. compz == 'v') Zt = q2t_c(Z(1:ldz, 1:nz))
        call ${C}$hseqr(job, compz, n, ilo, ihi, Ht, ldh, Wt, Zt, ldz, wopt, -1, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        allocate(work(lwork))
        call ${C}$hseqr(job, compz, n, ilo, ihi, Ht, ldh, Wt, Zt, ldz, work, lwork, info)
        H(1:ldh, 1:n) = t2q_c(Ht)
        if (compz /= 'N' .and. compz /= 'n') Z(1:ldz, 1:nz) = t2q_c(Zt)
        W(1:n) = t2q_c(Wt)
    end subroutine

    ! ── Phase 33 wrappers ────────────────────────────────────────────
    subroutine target_dtrevc(side, howmny, sel, n, T, ldt, VL, ldvl, VR, ldvr, &
                             mm, m, info)
        character, intent(in)    :: side, howmny
        integer,   intent(in)    :: n, ldt, ldvl, ldvr, mm
        logical,   intent(inout) :: sel(*)
        real(ep),  intent(in)    :: T(ldt,*)
        real(ep),  intent(inout) :: VL(ldvl,*), VR(ldvr,*)
        integer,   intent(out)   :: m
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: Tt(:,:), VLt(:,:), VRt(:,:), work(:)
        allocate(Tt(ldt, n), VLt(ldvl, mm), VRt(ldvr, mm), work(3*n))
        Tt = q2t_r(T(1:ldt, 1:n))
        if (howmny == 'B' .or. howmny == 'b') then
            VLt = q2t_r(VL(1:ldvl, 1:mm)); VRt = q2t_r(VR(1:ldvr, 1:mm))
        end if
        call ${R}$trevc(side, howmny, sel, n, Tt, ldt, VLt, ldvl, VRt, ldvr, &
                       mm, m, work, info)
        if (side == 'L' .or. side == 'l' .or. side == 'B' .or. side == 'b') &
            VL(1:ldvl, 1:mm) = t2q_r(VLt)
        if (side == 'R' .or. side == 'r' .or. side == 'B' .or. side == 'b') &
            VR(1:ldvr, 1:mm) = t2q_r(VRt)
    end subroutine

    subroutine target_ztrevc(side, howmny, sel, n, T, ldt, VL, ldvl, VR, ldvr, &
                             mm, m, info)
        character,   intent(in)    :: side, howmny
        integer,     intent(in)    :: n, ldt, ldvl, ldvr, mm
        logical,     intent(in)    :: sel(*)
        complex(ep), intent(inout) :: T(ldt,*), VL(ldvl,*), VR(ldvr,*)
        integer,     intent(out)   :: m
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: Tt(:,:), VLt(:,:), VRt(:,:), work(:)
        ${target_real}$,    allocatable :: rwork(:)
        allocate(Tt(ldt, n), VLt(ldvl, mm), VRt(ldvr, mm), work(2*n), rwork(n))
        Tt = q2t_c(T(1:ldt, 1:n))
        if (howmny == 'B' .or. howmny == 'b') then
            VLt = q2t_c(VL(1:ldvl, 1:mm)); VRt = q2t_c(VR(1:ldvr, 1:mm))
        end if
        call ${C}$trevc(side, howmny, sel, n, Tt, ldt, VLt, ldvl, VRt, ldvr, &
                       mm, m, work, rwork, info)
        T(1:ldt, 1:n) = t2q_c(Tt)
        if (side == 'L' .or. side == 'l' .or. side == 'B' .or. side == 'b') &
            VL(1:ldvl, 1:mm) = t2q_c(VLt)
        if (side == 'R' .or. side == 'r' .or. side == 'B' .or. side == 'b') &
            VR(1:ldvr, 1:mm) = t2q_c(VRt)
    end subroutine

    ! ── Phase 34 wrappers ────────────────────────────────────────────
    subroutine target_dggev(jobvl, jobvr, n, A, lda, B, ldb, alphar, alphai, beta, &
                            VL, ldvl, VR, ldvr, info)
        character, intent(in)    :: jobvl, jobvr
        integer,   intent(in)    :: n, lda, ldb, ldvl, ldvr
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*)
        real(ep),  intent(out)   :: alphar(*), alphai(*), beta(*)
        real(ep),  intent(out)   :: VL(ldvl,*), VR(ldvr,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), VLt(:,:), VRt(:,:), &
                                        art(:), ait(:), bet(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, nVL, nVR
        nVL = merge(n, 1, jobvl == 'V' .or. jobvl == 'v')
        nVR = merge(n, 1, jobvr == 'V' .or. jobvr == 'v')
        allocate(At(lda, n), Bt(ldb, n), VLt(ldvl, nVL), VRt(ldvr, nVR), &
                 art(n), ait(n), bet(n))
        At = q2t_r(A(1:lda, 1:n)); Bt = q2t_r(B(1:ldb, 1:n))
        call ${R}$ggev(jobvl, jobvr, n, At, lda, Bt, ldb, art, ait, bet, &
                      VLt, ldvl, VRt, ldvr, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$ggev(jobvl, jobvr, n, At, lda, Bt, ldb, art, ait, bet, &
                      VLt, ldvl, VRt, ldvr, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At); B(1:ldb, 1:n) = t2q_r(Bt)
        alphar(1:n) = t2q_r(art); alphai(1:n) = t2q_r(ait); beta(1:n) = t2q_r(bet)
        if (jobvl == 'V' .or. jobvl == 'v') VL(1:ldvl, 1:nVL) = t2q_r(VLt)
        if (jobvr == 'V' .or. jobvr == 'v') VR(1:ldvr, 1:nVR) = t2q_r(VRt)
    end subroutine

    ! ── Phase 35 wrappers ────────────────────────────────────────────
    subroutine target_dgeqr(m, n, A, lda, T, tsize, info)
        integer,  intent(in)    :: m, n, lda, tsize
        real(ep), intent(inout) :: A(lda,*)
        real(ep), intent(out)   :: T(*)
        integer,  intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Tt(:), work(:)
        ${target_real}$ :: tquery(5), wopt(1)
        integer :: tsz, lwork
        allocate(At(lda, n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$geqr(m, n, At, lda, tquery, -1, wopt, -1, info)
        tsz = max(tsize, int(t2q_r(tquery(1))))
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(Tt(tsz), work(lwork))
        call ${R}$geqr(m, n, At, lda, Tt, tsz, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At); T(1:tsize) = t2q_r(Tt(1:tsize))
    end subroutine

