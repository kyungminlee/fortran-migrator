    subroutine target_dtgsen(ijob, wantq, wantz, select, n, A, lda, B, ldb, &
                             alphar, alphai, beta, Q, ldq, Z, ldz, m, pl, pr, &
                             dif, info)
        integer,   intent(in)    :: ijob, n, lda, ldb, ldq, ldz
        logical,   intent(in)    :: wantq, wantz, select(*)
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*), Q(ldq,*), Z(ldz,*)
        real(ep),  intent(out)   :: alphar(*), alphai(*), beta(*), pl, pr, dif(2)
        integer,   intent(out)   :: m, info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), Qt(:,:), Zt(:,:)
        ${target_real}$, allocatable :: art(:), ait(:), bet(:), work(:)
        ${target_real}$ :: wopt(1), plt, prt, dift(2)
        integer, allocatable :: iwork(:)
        integer :: lwork, liwork, iwopt(1)
        allocate(At(lda,n), Bt(ldb,n), Qt(ldq,n), Zt(ldz,n))
        allocate(art(n), ait(n), bet(n))
        At = q2t_r(A(1:lda,1:n)); Bt = q2t_r(B(1:ldb,1:n))
        Qt = q2t_r(Q(1:ldq,1:n)); Zt = q2t_r(Z(1:ldz,1:n))
        call ${R}$tgsen(ijob, wantq, wantz, select, n, At, lda, Bt, ldb, &
                        art, ait, bet, Qt, ldq, Zt, ldz, m, plt, prt, dift, &
                        wopt, -1, iwopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1)))); liwork = max(1, iwopt(1))
        allocate(work(lwork), iwork(liwork))
        call ${R}$tgsen(ijob, wantq, wantz, select, n, At, lda, Bt, ldb, &
                        art, ait, bet, Qt, ldq, Zt, ldz, m, plt, prt, dift, &
                        work, lwork, iwork, liwork, info)
