    subroutine target_dsysvx(fact, uplo, n, nrhs, A, lda, AF, ldaf, ipiv, B, ldb, &
                             X, ldx, rcond, ferr, berr, info)
        character, intent(in)    :: fact, uplo
        integer,   intent(in)    :: n, nrhs, lda, ldaf, ldb, ldx
        real(ep),  intent(in)    :: A(lda,*), B(ldb,*)
        real(ep),  intent(inout) :: AF(ldaf,*)
        integer,   intent(inout) :: ipiv(*)
        real(ep),  intent(out)   :: X(ldx,*), rcond, ferr(*), berr(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), AFt(:,:), Bt(:,:), Xt(:,:), &
                                        ferrt(:), berrt(:), work(:)
        ${target_real}$ :: rcondt, wopt(1)
        integer, allocatable :: iwork(:)
        integer :: lwork
        allocate(At(lda, n), AFt(ldaf, n), Bt(ldb, nrhs), Xt(ldx, nrhs), &
                 ferrt(nrhs), berrt(nrhs), iwork(n))
        At = q2t_r(A(1:lda, 1:n)); AFt = q2t_r(AF(1:ldaf, 1:n))
        Bt = q2t_r(B(1:ldb, 1:nrhs))
        call ${R}$sysvx(fact, uplo, n, nrhs, At, lda, AFt, ldaf, ipiv, Bt, ldb, &
                       Xt, ldx, rcondt, ferrt, berrt, wopt, -1, iwork, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$sysvx(fact, uplo, n, nrhs, At, lda, AFt, ldaf, ipiv, Bt, ldb, &
                       Xt, ldx, rcondt, ferrt, berrt, work, lwork, iwork, info)
        AF(1:ldaf, 1:n) = t2q_r(AFt)
        X(1:ldx, 1:nrhs) = t2q_r(Xt)
        rcond = t2q_r(rcondt)
        ferr(1:nrhs) = t2q_r(ferrt); berr(1:nrhs) = t2q_r(berrt)
    end subroutine

