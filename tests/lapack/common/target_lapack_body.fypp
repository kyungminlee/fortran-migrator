        ${target_real}$, allocatable :: APt(:), Bt(:,:)
        integer :: np
        np = n*(n+1)/2
        allocate(APt(np), Bt(ldb, nrhs))
        APt = q2t_r(AP(1:np)); Bt = q2t_r(B(1:ldb, 1:nrhs))
        call ${R}$sptrs(uplo, n, nrhs, APt, ipiv, Bt, ldb, info)
        B(1:ldb, 1:nrhs) = t2q_r(Bt)
    end subroutine

