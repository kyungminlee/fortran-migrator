    ! ----- P-misc small utilities and apply/generate Householder -----

    logical function target_disnan(din)
        real(ep), intent(in) :: din
        logical, external :: ${R}$isnan
        target_disnan = ${R}$isnan(q2t_r(din))
    end function

    subroutine target_drscl(n, sa, sx, incx)
        integer,  intent(in)    :: n, incx
        real(ep), intent(in)    :: sa
        real(ep), intent(inout) :: sx(*)
        integer :: nx
        ${target_real}$, allocatable :: sxt(:)
        nx = 1 + (n - 1) * abs(incx)
        allocate(sxt(nx))
        sxt = q2t_r(sx(1:nx))
        call ${R}$rscl(n, q2t_r(sa), sxt, incx)
        sx(1:nx) = t2q_r(sxt)
    end subroutine

    subroutine target_zdrscl(n, sa, sx, incx)
        integer,     intent(in)    :: n, incx
        real(ep),    intent(in)    :: sa
        complex(ep), intent(inout) :: sx(*)
        integer :: nx
        ${target_complex}$, allocatable :: sxt(:)
        nx = 1 + (n - 1) * abs(incx)
        allocate(sxt(nx))
        sxt = q2t_c(sx(1:nx))
        call ${C}$${R}$rscl(n, q2t_r(sa), sxt, incx)
        sx(1:nx) = t2q_c(sxt)
    end subroutine

    subroutine target_zrscl(n, a, x, incx)
        integer,     intent(in)    :: n, incx
        complex(ep), intent(in)    :: a
        complex(ep), intent(inout) :: x(*)
        integer :: nx
        ${target_complex}$, allocatable :: xt(:)
        nx = 1 + (n - 1) * abs(incx)
        allocate(xt(nx))
        xt = q2t_c(x(1:nx))
        call ${C}$rscl(n, q2t_c(a), xt, incx)
        x(1:nx) = t2q_c(xt)
    end subroutine

    subroutine target_zrot(n, cx, incx, cy, incy, c, s)
        integer,     intent(in)    :: n, incx, incy
        real(ep),    intent(in)    :: c
        complex(ep), intent(in)    :: s
        complex(ep), intent(inout) :: cx(*), cy(*)
        integer :: nx, ny
        ${target_complex}$, allocatable :: cxt(:), cyt(:)
        nx = 1 + (n - 1) * abs(incx)
        ny = 1 + (n - 1) * abs(incy)
        allocate(cxt(nx), cyt(ny))
        cxt = q2t_c(cx(1:nx)); cyt = q2t_c(cy(1:ny))
        call ${C}$rot(n, cxt, incx, cyt, incy, q2t_r(c), q2t_c(s))
        cx(1:nx) = t2q_c(cxt); cy(1:ny) = t2q_c(cyt)
    end subroutine

    subroutine target_dorg2l(m, n, k, A, lda, tau, info)
        integer,  intent(in)    :: m, n, k, lda
        real(ep), intent(inout) :: A(lda,*)
        real(ep), intent(in)    :: tau(*)
        integer,  intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), taut(:), work(:)
        allocate(At(lda, n), taut(k), work(n))
        At   = q2t_r(A(1:lda, 1:n))
        taut = q2t_r(tau(1:k))
        call ${R}$org2l(m, n, k, At, lda, taut, work, info)
        A(1:lda, 1:n) = t2q_r(At)
    end subroutine

    subroutine target_zung2l(m, n, k, A, lda, tau, info)
        integer,     intent(in)    :: m, n, k, lda
