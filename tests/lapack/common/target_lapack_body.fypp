                             B, ldb, X, ldx, ferr, berr, info)
        character, intent(in)    :: trans
        integer,   intent(in)    :: n, nrhs, ldb, ldx
        real(ep),  intent(in)    :: dl(*), d(*), du(*), dlf(*), df(*), duf(*), du2(*)
        integer,   intent(in)    :: ipiv(*)
        real(ep),  intent(in)    :: B(ldb,*)
