    subroutine target_dsbgvx(jobz, range, uplo, n, ka, kb, AB, ldab, BB, ldbb, &
                             Q, ldq, vl, vu, il, iu, abstol, m, w, Z, ldz, &
                             ifail, info)
        character, intent(in)    :: jobz, range, uplo
        integer,   intent(in)    :: n, ka, kb, ldab, ldbb, ldq, il, iu, ldz
        real(ep),  intent(in)    :: vl, vu, abstol
        real(ep),  intent(inout) :: AB(ldab,*), BB(ldbb,*)
        real(ep),  intent(out)   :: Q(ldq,*), w(*), Z(ldz,*)
        integer,   intent(out)   :: m, ifail(*), info
        ${target_real}$, allocatable :: ABt(:,:), BBt(:,:), Qt(:,:), wt(:), Zt(:,:), work(:)
        integer, allocatable :: iwork(:)
        allocate(ABt(ldab,n), BBt(ldbb,n), Qt(ldq,n), wt(n), Zt(ldz,n))
        allocate(work(7*n), iwork(5*n))
        ABt = q2t_r(AB(1:ldab,1:n)); BBt = q2t_r(BB(1:ldbb,1:n))
        call ${R}$sbgvx(jobz, range, uplo, n, ka, kb, ABt, ldab, BBt, ldbb, &
                        Qt, ldq, q2t_r(vl), q2t_r(vu), il, iu, q2t_r(abstol), &
                        m, wt, Zt, ldz, work, iwork, ifail, info)
        AB(1:ldab,1:n) = t2q_r(ABt); BB(1:ldbb,1:n) = t2q_r(BBt)
        if (jobz /= 'N') Q(1:ldq,1:n) = t2q_r(Qt)
        w(1:n) = t2q_r(wt)
        if (jobz /= 'N') Z(1:ldz,1:n) = t2q_r(Zt)
    end subroutine

    subroutine target_zhbgvx(jobz, range, uplo, n, ka, kb, AB, ldab, BB, ldbb, &
                             Q, ldq, vl, vu, il, iu, abstol, m, w, Z, ldz, &
                             ifail, info)
        character,   intent(in)    :: jobz, range, uplo
        integer,     intent(in)    :: n, ka, kb, ldab, ldbb, ldq, il, iu, ldz
        real(ep),    intent(in)    :: vl, vu, abstol
        complex(ep), intent(inout) :: AB(ldab,*), BB(ldbb,*)
        complex(ep), intent(out)   :: Q(ldq,*), Z(ldz,*)
        real(ep),    intent(out)   :: w(*)
        integer,     intent(out)   :: m, ifail(*), info
        ${target_complex}$, allocatable :: ABt(:,:), BBt(:,:), Qt(:,:), Zt(:,:), work(:)
        ${target_real}$,    allocatable :: wt(:), rwork(:)
        integer, allocatable :: iwork(:)
        allocate(ABt(ldab,n), BBt(ldbb,n), Qt(ldq,n), wt(n), Zt(ldz,n))
        allocate(work(n), rwork(7*n), iwork(5*n))
        ABt = q2t_c(AB(1:ldab,1:n)); BBt = q2t_c(BB(1:ldbb,1:n))
        call ${C}$hbgvx(jobz, range, uplo, n, ka, kb, ABt, ldab, BBt, ldbb, &
                        Qt, ldq, q2t_r(vl), q2t_r(vu), il, iu, q2t_r(abstol), &
                        m, wt, Zt, ldz, work, rwork, iwork, ifail, info)
        AB(1:ldab,1:n) = t2q_c(ABt); BB(1:ldbb,1:n) = t2q_c(BBt)
        if (jobz /= 'N') Q(1:ldq,1:n) = t2q_c(Qt)
        w(1:n) = t2q_r(wt)
        if (jobz /= 'N') Z(1:ldz,1:n) = t2q_c(Zt)
    end subroutine

    subroutine target_dspgvx(itype, jobz, range, uplo, n, AP, BP, vl, vu, il, iu, &
                             abstol, m, w, Z, ldz, ifail, info)
        integer,   intent(in)    :: itype, n, il, iu, ldz
        character, intent(in)    :: jobz, range, uplo
        real(ep),  intent(in)    :: vl, vu, abstol
        real(ep),  intent(inout) :: AP(*), BP(*)
        real(ep),  intent(out)   :: w(*), Z(ldz,*)
        integer,   intent(out)   :: m, ifail(*), info
        integer :: nap
        ${target_real}$, allocatable :: APt(:), BPt(:), wt(:), Zt(:,:), work(:)
        integer, allocatable :: iwork(:)
        nap = n*(n+1)/2
        allocate(APt(max(1,nap)), BPt(max(1,nap)), wt(n), Zt(ldz,n))
        allocate(work(8*n), iwork(5*n))
        APt = q2t_r(AP(1:nap)); BPt = q2t_r(BP(1:nap))
        call ${R}$spgvx(itype, jobz, range, uplo, n, APt, BPt, q2t_r(vl), q2t_r(vu), &
                        il, iu, q2t_r(abstol), m, wt, Zt, ldz, work, iwork, ifail, info)
        AP(1:nap) = t2q_r(APt); BP(1:nap) = t2q_r(BPt)
        w(1:n) = t2q_r(wt)
        if (jobz /= 'N') Z(1:ldz,1:n) = t2q_r(Zt)
    end subroutine

    subroutine target_zhpgvx(itype, jobz, range, uplo, n, AP, BP, vl, vu, il, iu, &
                             abstol, m, w, Z, ldz, ifail, info)
        integer,     intent(in)    :: itype, n, il, iu, ldz
        character,   intent(in)    :: jobz, range, uplo
        real(ep),    intent(in)    :: vl, vu, abstol
        complex(ep), intent(inout) :: AP(*), BP(*)
        real(ep),    intent(out)   :: w(*)
        complex(ep), intent(out)   :: Z(ldz,*)
        integer,     intent(out)   :: m, ifail(*), info
        integer :: nap
        ${target_complex}$, allocatable :: APt(:), BPt(:), Zt(:,:), work(:)
        ${target_real}$,    allocatable :: wt(:), rwork(:)
        integer, allocatable :: iwork(:)
        nap = n*(n+1)/2
        allocate(APt(max(1,nap)), BPt(max(1,nap)), wt(n), Zt(ldz,n))
        allocate(work(2*n), rwork(7*n), iwork(5*n))
        APt = q2t_c(AP(1:nap)); BPt = q2t_c(BP(1:nap))
        call ${C}$hpgvx(itype, jobz, range, uplo, n, APt, BPt, q2t_r(vl), q2t_r(vu), &
                        il, iu, q2t_r(abstol), m, wt, Zt, ldz, work, rwork, iwork, ifail, info)
        AP(1:nap) = t2q_c(APt); BP(1:nap) = t2q_c(BPt)
        w(1:n) = t2q_r(wt)
        if (jobz /= 'N') Z(1:ldz,1:n) = t2q_c(Zt)
    end subroutine

    subroutine target_dsygvx(itype, jobz, range, uplo, n, A, lda, B, ldb, &
                             vl, vu, il, iu, abstol, m, w, Z, ldz, ifail, info)
        integer,   intent(in)    :: itype, n, lda, ldb, il, iu, ldz
        character, intent(in)    :: jobz, range, uplo
        real(ep),  intent(in)    :: vl, vu, abstol
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*)
        real(ep),  intent(out)   :: w(*), Z(ldz,*)
        integer,   intent(out)   :: m, ifail(*), info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), wt(:), Zt(:,:), work(:)
        integer, allocatable :: iwork(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda,n), Bt(ldb,n), wt(n), Zt(ldz,n), iwork(5*n))
        At = q2t_r(A(1:lda,1:n)); Bt = q2t_r(B(1:ldb,1:n))
        call ${R}$sygvx(itype, jobz, range, uplo, n, At, lda, Bt, ldb, &
                        q2t_r(vl), q2t_r(vu), il, iu, q2t_r(abstol), m, wt, &
                        Zt, ldz, wopt, -1, iwork, ifail, info)
        lwork = max(1, int(t2q_r(wopt(1)))); allocate(work(lwork))
        call ${R}$sygvx(itype, jobz, range, uplo, n, At, lda, Bt, ldb, &
                        q2t_r(vl), q2t_r(vu), il, iu, q2t_r(abstol), m, wt, &
                        Zt, ldz, work, lwork, iwork, ifail, info)
        A(1:lda,1:n) = t2q_r(At); B(1:ldb,1:n) = t2q_r(Bt)
        w(1:n) = t2q_r(wt)
        if (jobz /= 'N') Z(1:ldz,1:n) = t2q_r(Zt)
    end subroutine

    subroutine target_zhegvx(itype, jobz, range, uplo, n, A, lda, B, ldb, &
                             vl, vu, il, iu, abstol, m, w, Z, ldz, ifail, info)
        integer,     intent(in)    :: itype, n, lda, ldb, il, iu, ldz
        character,   intent(in)    :: jobz, range, uplo
        real(ep),    intent(in)    :: vl, vu, abstol
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*)
        real(ep),    intent(out)   :: w(*)
        complex(ep), intent(out)   :: Z(ldz,*)
        integer,     intent(out)   :: m, ifail(*), info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), Zt(:,:), work(:)
        ${target_real}$,    allocatable :: wt(:), rwork(:)
        integer, allocatable :: iwork(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda,n), Bt(ldb,n), wt(n), Zt(ldz,n), rwork(7*n), iwork(5*n))
        At = q2t_c(A(1:lda,1:n)); Bt = q2t_c(B(1:ldb,1:n))
        call ${C}$hegvx(itype, jobz, range, uplo, n, At, lda, Bt, ldb, &
                        q2t_r(vl), q2t_r(vu), il, iu, q2t_r(abstol), m, wt, &
                        Zt, ldz, wopt, -1, rwork, iwork, ifail, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        call ${C}$hegvx(itype, jobz, range, uplo, n, At, lda, Bt, ldb, &
                        q2t_r(vl), q2t_r(vu), il, iu, q2t_r(abstol), m, wt, &
                        Zt, ldz, work, lwork, rwork, iwork, ifail, info)
        A(1:lda,1:n) = t2q_c(At); B(1:ldb,1:n) = t2q_c(Bt)
        w(1:n) = t2q_r(wt)
        if (jobz /= 'N') Z(1:ldz,1:n) = t2q_c(Zt)
    end subroutine

    ! ----- P12 RFP / packed / triangular-full storage conversion -----

    subroutine target_dtfttp(transr, uplo, n, ARF, AP, info)
        character, intent(in)  :: transr, uplo
        integer,   intent(in)  :: n
        real(ep),  intent(in)  :: ARF(0:*)
        real(ep),  intent(out) :: AP(0:*)
        integer,   intent(out) :: info
        integer :: nt
        ${target_real}$, allocatable :: ARFt(:), APt(:)
        nt = n*(n+1)/2
        allocate(ARFt(0:nt-1), APt(0:nt-1))
        ARFt = q2t_r(ARF(0:nt-1))
        call ${R}$tfttp(transr, uplo, n, ARFt, APt, info)
        AP(0:nt-1) = t2q_r(APt)
    end subroutine

    subroutine target_ztfttp(transr, uplo, n, ARF, AP, info)
        character,   intent(in)  :: transr, uplo
        integer,     intent(in)  :: n
        complex(ep), intent(in)  :: ARF(0:*)
        complex(ep), intent(out) :: AP(0:*)
        integer,     intent(out) :: info
        integer :: nt
        ${target_complex}$, allocatable :: ARFt(:), APt(:)
        nt = n*(n+1)/2
        allocate(ARFt(0:nt-1), APt(0:nt-1))
        ARFt = q2t_c(ARF(0:nt-1))
        call ${C}$tfttp(transr, uplo, n, ARFt, APt, info)
        AP(0:nt-1) = t2q_c(APt)
    end subroutine

    subroutine target_dtfttr(transr, uplo, n, ARF, A, lda, info)
        character, intent(in)    :: transr, uplo
        integer,   intent(in)    :: n, lda
        real(ep),  intent(in)    :: ARF(0:*)
        real(ep),  intent(inout) :: A(0:lda-1, 0:*)
        integer,   intent(out)   :: info
        integer :: nt
        ${target_real}$, allocatable :: ARFt(:), At(:,:)
        nt = n*(n+1)/2
        allocate(ARFt(0:nt-1), At(0:lda-1, 0:n-1))
        ARFt = q2t_r(ARF(0:nt-1))
        At = q2t_r(A(0:lda-1, 0:n-1))
        call ${R}$tfttr(transr, uplo, n, ARFt, At, lda, info)
        A(0:lda-1, 0:n-1) = t2q_r(At)
    end subroutine

    subroutine target_ztfttr(transr, uplo, n, ARF, A, lda, info)
        character,   intent(in)    :: transr, uplo
        integer,     intent(in)    :: n, lda
        complex(ep), intent(in)    :: ARF(0:*)
        complex(ep), intent(inout) :: A(0:lda-1, 0:*)
        integer,     intent(out)   :: info
        integer :: nt
        ${target_complex}$, allocatable :: ARFt(:), At(:,:)
        nt = n*(n+1)/2
        allocate(ARFt(0:nt-1), At(0:lda-1, 0:n-1))
        ARFt = q2t_c(ARF(0:nt-1))
        At = q2t_c(A(0:lda-1, 0:n-1))
        call ${C}$tfttr(transr, uplo, n, ARFt, At, lda, info)
        A(0:lda-1, 0:n-1) = t2q_c(At)
    end subroutine

    subroutine target_dtpttf(transr, uplo, n, AP, ARF, info)
        character, intent(in)  :: transr, uplo
        integer,   intent(in)  :: n
        real(ep),  intent(in)  :: AP(0:*)
        real(ep),  intent(out) :: ARF(0:*)
        integer,   intent(out) :: info
        integer :: nt
        ${target_real}$, allocatable :: APt(:), ARFt(:)
        nt = n*(n+1)/2
        allocate(APt(0:nt-1), ARFt(0:nt-1))
        APt = q2t_r(AP(0:nt-1))
        call ${R}$tpttf(transr, uplo, n, APt, ARFt, info)
        ARF(0:nt-1) = t2q_r(ARFt)
    end subroutine

    subroutine target_ztpttf(transr, uplo, n, AP, ARF, info)
        character,   intent(in)  :: transr, uplo
        integer,     intent(in)  :: n
        complex(ep), intent(in)  :: AP(0:*)
        complex(ep), intent(out) :: ARF(0:*)
        integer,     intent(out) :: info
        integer :: nt
        ${target_complex}$, allocatable :: APt(:), ARFt(:)
        nt = n*(n+1)/2
        allocate(APt(0:nt-1), ARFt(0:nt-1))
        APt = q2t_c(AP(0:nt-1))
        call ${C}$tpttf(transr, uplo, n, APt, ARFt, info)
        ARF(0:nt-1) = t2q_c(ARFt)
    end subroutine

    subroutine target_dtpttr(uplo, n, AP, A, lda, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, lda
        real(ep),  intent(in)    :: AP(*)
        real(ep),  intent(inout) :: A(lda,*)
        integer,   intent(out)   :: info
        integer :: nt
        ${target_real}$, allocatable :: APt(:), At(:,:)
        nt = n*(n+1)/2
        allocate(APt(nt), At(lda, n))
        APt = q2t_r(AP(1:nt))
        At  = q2t_r(A(1:lda, 1:n))
        call ${R}$tpttr(uplo, n, APt, At, lda, info)
        A(1:lda, 1:n) = t2q_r(At)
    end subroutine

