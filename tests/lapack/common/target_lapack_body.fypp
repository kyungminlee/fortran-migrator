    subroutine target_zgglse(m, n, p, A, lda, B, ldb, c, d, x, info)
        integer,     intent(in)    :: m, n, p, lda, ldb
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*), c(*), d(*)
        complex(ep), intent(out)   :: x(*)
        integer,     intent(out)   :: info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), ct(:), dt(:), xt(:), work(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda,n), Bt(ldb,n), ct(m), dt(p), xt(n))
