    ! ── Phase 25 wrappers ────────────────────────────────────────────
    subroutine target_dsygvd(itype, jobz, uplo, n, A, lda, B, ldb, W, info)
        character, intent(in)    :: jobz, uplo
        integer,   intent(in)    :: itype, n, lda, ldb
        real(ep),  intent(inout) :: A(lda,*), B(ldb,*)
        real(ep),  intent(out)   :: W(*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), Wt(:), work(:)
        ${target_real}$ :: wopt(1)
        integer, allocatable :: iwork(:)
        integer :: lwork, liwork, iwopt(1)
        allocate(At(lda, n), Bt(ldb, n), Wt(n))
        At = q2t_r(A(1:lda, 1:n)); Bt = q2t_r(B(1:ldb, 1:n))
        call ${R}$sygvd(itype, jobz, uplo, n, At, lda, Bt, ldb, Wt, wopt, -1, iwopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1)))); liwork = max(1, iwopt(1))
        allocate(work(lwork), iwork(liwork))
        call ${R}$sygvd(itype, jobz, uplo, n, At, lda, Bt, ldb, Wt, work, lwork, iwork, liwork, info)
        A(1:lda, 1:n) = t2q_r(At); B(1:ldb, 1:n) = t2q_r(Bt)
        W(1:n) = t2q_r(Wt)
    end subroutine

