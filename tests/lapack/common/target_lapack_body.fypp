    subroutine target_zgtcon(norm, n, dl, d, du, du2, ipiv, anorm, rcond, info)
        character,   intent(in)  :: norm
        integer,     intent(in)  :: n
        complex(ep), intent(in)  :: dl(*), d(*), du(*), du2(*)
        integer,     intent(in)  :: ipiv(*)
        real(ep),    intent(in)  :: anorm
        real(ep),    intent(out) :: rcond
        integer,     intent(out) :: info
        ${target_complex}$, allocatable :: dlt(:), dt(:), dut(:), du2t(:), work(:)
        ${target_real}$ :: rct
        allocate(dlt(n-1), dt(n), dut(n-1), du2t(n-2), work(2*n))
        dlt = q2t_c(dl(1:n-1)); dt = q2t_c(d(1:n)); dut = q2t_c(du(1:n-1))
        du2t = q2t_c(du2(1:n-2))
        call ${C}$gtcon(norm, n, dlt, dt, dut, du2t, ipiv, q2t_r(anorm), rct, &
                        work, info)
        rcond = t2q_r(rct)
    end subroutine

    subroutine target_dsycon(uplo, n, A, lda, ipiv, anorm, rcond, info)
        character, intent(in)  :: uplo
        integer,   intent(in)  :: n, lda
        real(ep),  intent(in)  :: A(lda,*), anorm
        integer,   intent(in)  :: ipiv(*)
        real(ep),  intent(out) :: rcond
        integer,   intent(out) :: info
        ${target_real}$, allocatable :: At(:,:), work(:)
        ${target_real}$ :: rct
        integer, allocatable :: iwork(:)
        allocate(At(lda, n), work(2*n), iwork(n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$sycon(uplo, n, At, lda, ipiv, q2t_r(anorm), rct, work, iwork, info)
        rcond = t2q_r(rct)
    end subroutine

    subroutine target_zhecon(uplo, n, A, lda, ipiv, anorm, rcond, info)
        character,   intent(in)  :: uplo
        integer,     intent(in)  :: n, lda
        complex(ep), intent(in)  :: A(lda,*)
        integer,     intent(in)  :: ipiv(*)
        real(ep),    intent(in)  :: anorm
        real(ep),    intent(out) :: rcond
        integer,     intent(out) :: info
        ${target_complex}$, allocatable :: At(:,:), work(:)
        ${target_real}$ :: rct
        allocate(At(lda, n), work(2*n))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$hecon(uplo, n, At, lda, ipiv, q2t_r(anorm), rct, work, info)
        rcond = t2q_r(rct)
    end subroutine

end module target_lapack
