    end subroutine

    subroutine target_ztgevc(side, howmny, select, n, S, lds, P, ldp, &
                             vl, ldvl, vr, ldvr, mm, m, info)
        character,   intent(in)    :: side, howmny
        integer,     intent(in)    :: n, lds, ldp, ldvl, ldvr, mm
        logical,     intent(in)    :: select(*)
        complex(ep), intent(in)    :: S(lds,*), P(ldp,*)
        complex(ep), intent(inout) :: vl(ldvl,*), vr(ldvr,*)
        integer,     intent(out)   :: m, info
        ${target_complex}$, allocatable :: St(:,:), Pt(:,:), vlt(:,:), vrt(:,:), work(:)
        ${target_real}$,    allocatable :: rwork(:)
        allocate(St(lds,n), Pt(ldp,n), vlt(ldvl,mm), vrt(ldvr,mm))
        allocate(work(2*n), rwork(2*n))
        St = q2t_c(S(1:lds,1:n)); Pt = q2t_c(P(1:ldp,1:n))
        vlt = q2t_c(vl(1:ldvl,1:mm)); vrt = q2t_c(vr(1:ldvr,1:mm))
        call ${C}$tgevc(side, howmny, select, n, St, lds, Pt, ldp, &
                        vlt, ldvl, vrt, ldvr, mm, m, work, rwork, info)
        vl(1:ldvl,1:mm) = t2q_c(vlt); vr(1:ldvr,1:mm) = t2q_c(vrt)
    end subroutine

    ! ── Phase L5 — Modern least-squares + Jacobi SVD ─────────────────
    subroutine target_dgelsd(m, n, nrhs, A, lda, B, ldb, S, rcond, rank, info)
        integer,  intent(in)    :: m, n, nrhs, lda, ldb
        real(ep), intent(in)    :: rcond
        real(ep), intent(inout) :: A(lda,*), B(ldb,*)
        real(ep), intent(out)   :: S(*)
        integer,  intent(out)   :: rank, info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), St(:), work(:)
        integer,         allocatable :: iwork(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork, iwopt(1), liwork
        allocate(At(lda,n), Bt(ldb,nrhs), St(min(m,n)))
        allocate(iwork(1))   ! resized after query
        At = q2t_r(A(1:lda,1:n)); Bt = q2t_r(B(1:ldb,1:nrhs))
        call ${R}$gelsd(m, n, nrhs, At, lda, Bt, ldb, St, q2t_r(rcond), rank, &
                        wopt, -1, iwopt, info)
        lwork = max(1, int(t2q_r(wopt(1)))); liwork = max(1, iwopt(1))
        deallocate(iwork); allocate(work(lwork), iwork(liwork))
        call ${R}$gelsd(m, n, nrhs, At, lda, Bt, ldb, St, q2t_r(rcond), rank, &
                        work, lwork, iwork, info)
        A(1:lda,1:n) = t2q_r(At); B(1:ldb,1:nrhs) = t2q_r(Bt)
        S(1:min(m,n)) = t2q_r(St)
    end subroutine

    subroutine target_zgelsd(m, n, nrhs, A, lda, B, ldb, S, rcond, rank, info)
        integer,     intent(in)    :: m, n, nrhs, lda, ldb
        real(ep),    intent(in)    :: rcond
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*)
        real(ep),    intent(out)   :: S(*)
        integer,     intent(out)   :: rank, info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), work(:)
        ${target_real}$,    allocatable :: St(:), rwork(:)
        integer,            allocatable :: iwork(:)
        ${target_complex}$ :: wopt(1)
        ${target_real}$    :: rwopt(1)
        integer :: lwork, iwopt(1), liwork, lrwork
        allocate(At(lda,n), Bt(ldb,nrhs), St(min(m,n)))
        allocate(iwork(1), rwork(1))
        At = q2t_c(A(1:lda,1:n)); Bt = q2t_c(B(1:ldb,1:nrhs))
        ! ZGELSD's workspace query writes RWORK(1) and IWORK(1) too.
        call ${C}$gelsd(m, n, nrhs, At, lda, Bt, ldb, St, q2t_r(rcond), rank, &
                        wopt, -1, rwopt, iwopt, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep)))
        lrwork = max(1, int(t2q_r(rwopt(1))))
        liwork = max(1, iwopt(1))
        deallocate(iwork, rwork)
        allocate(work(lwork), rwork(lrwork), iwork(liwork))
        call ${C}$gelsd(m, n, nrhs, At, lda, Bt, ldb, St, q2t_r(rcond), rank, &
                        work, lwork, rwork, iwork, info)
        A(1:lda,1:n) = t2q_c(At); B(1:ldb,1:nrhs) = t2q_c(Bt)
        S(1:min(m,n)) = t2q_r(St)
    end subroutine

    subroutine target_dgelss(m, n, nrhs, A, lda, B, ldb, S, rcond, rank, info)
        integer,  intent(in)    :: m, n, nrhs, lda, ldb
        real(ep), intent(in)    :: rcond
        real(ep), intent(inout) :: A(lda,*), B(ldb,*)
        real(ep), intent(out)   :: S(*)
        integer,  intent(out)   :: rank, info
        ${target_real}$, allocatable :: At(:,:), Bt(:,:), St(:), work(:)
        ${target_real}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda,n), Bt(ldb,nrhs), St(min(m,n)))
        At = q2t_r(A(1:lda,1:n)); Bt = q2t_r(B(1:ldb,1:nrhs))
        call ${R}$gelss(m, n, nrhs, At, lda, Bt, ldb, St, q2t_r(rcond), rank, &
                        wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1)))); allocate(work(lwork))
        call ${R}$gelss(m, n, nrhs, At, lda, Bt, ldb, St, q2t_r(rcond), rank, &
                        work, lwork, info)
        A(1:lda,1:n) = t2q_r(At); B(1:ldb,1:nrhs) = t2q_r(Bt)
        S(1:min(m,n)) = t2q_r(St)
    end subroutine

    subroutine target_zgelss(m, n, nrhs, A, lda, B, ldb, S, rcond, rank, info)
        integer,     intent(in)    :: m, n, nrhs, lda, ldb
        real(ep),    intent(in)    :: rcond
        complex(ep), intent(inout) :: A(lda,*), B(ldb,*)
        real(ep),    intent(out)   :: S(*)
        integer,     intent(out)   :: rank, info
        ${target_complex}$, allocatable :: At(:,:), Bt(:,:), work(:)
        ${target_real}$,    allocatable :: St(:), rwork(:)
        ${target_complex}$ :: wopt(1)
        integer :: lwork
        allocate(At(lda,n), Bt(ldb,nrhs), St(min(m,n)), rwork(5*min(m,n)))
        At = q2t_c(A(1:lda,1:n)); Bt = q2t_c(B(1:ldb,1:nrhs))
        call ${C}$gelss(m, n, nrhs, At, lda, Bt, ldb, St, q2t_r(rcond), rank, &
                        wopt, -1, rwork, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); allocate(work(lwork))
        call ${C}$gelss(m, n, nrhs, At, lda, Bt, ldb, St, q2t_r(rcond), rank, &
                        work, lwork, rwork, info)
        A(1:lda,1:n) = t2q_c(At); B(1:ldb,1:nrhs) = t2q_c(Bt)
        S(1:min(m,n)) = t2q_r(St)
    end subroutine

    subroutine target_dgelsy(m, n, nrhs, A, lda, B, ldb, jpvt, rcond, rank, info)
        integer,  intent(in)    :: m, n, nrhs, lda, ldb
