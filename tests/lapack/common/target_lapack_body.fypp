        ${target_real}$, allocatable :: ABt(:,:)
        allocate(ABt(ldab, n))
        ABt = q2t_r(AB(1:ldab, 1:n))
        call ${R}$gbtrf(m, n, kl, ku, ABt, ldab, ipiv, info)
        AB(1:ldab, 1:n) = t2q_r(ABt)
    end subroutine

