                        rcondet, rcondvt, wopt, -1, rwork, iwopt, -1, bwork, info)
        lwork = max(1, int(real(t2q_c(wopt(1)), ep))); liwork = max(1, iwopt(1))
        allocate(work(lwork), iwork(liwork))
