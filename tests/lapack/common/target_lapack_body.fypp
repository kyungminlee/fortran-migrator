        allocate(At(lda, n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$sytrf(uplo, n, At, lda, ipiv, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$sytrf(uplo, n, At, lda, ipiv, work, lwork, info)
        A(1:lda, 1:n) = t2q_r(At)
    end subroutine

