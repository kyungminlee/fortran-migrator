        end if
        allocate(At(lda, ncolA), taut(k), Ct(ldc, n))
        At = q2t_c(A(1:lda, 1:ncolA))
        taut = q2t_c(tau(1:k))
        Ct = q2t_c(C(1:ldc, 1:n))
