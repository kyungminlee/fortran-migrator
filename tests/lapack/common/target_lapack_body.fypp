#! Per-framework LAPACK test wrapper, parameterized by target.
#!
#! Each per-target shim sets:
#!   target          'kind10' | 'kind16' | 'multifloats'
#!   target_name     human-readable label string
#!   target_eps      Fortran expression giving the target's epsilon as REAL(KIND=ep)
#!   target_real     Fortran type-spec for the target's real type
#!   target_complex  Fortran type-spec for the target's complex type
#!   prefix_real     migrated entry-point prefix for the D family
#!   prefix_complex  migrated entry-point prefix for the Z family

#:set R = prefix_real
#:set C = prefix_complex

#:def IMPORT_R()
#:if target == 'multifloats'
            import :: real64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

#:def IMPORT_C()
#:if target == 'multifloats'
            import :: cmplx64x2, real64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

#:def IMPORT_RC()
#:if target == 'multifloats'
            import :: real64x2, cmplx64x2
#:elif target == 'kind16'
            import :: ep
#:endif
#:enddef

module target_lapack
    use prec_kinds, only: ep
    use target_conv, only: q2t_r, t2q_r, q2t_c, t2q_c
#:if target == 'multifloats'
    use multifloats, only: real64x2, cmplx64x2, operator(==)
#:endif
    implicit none
    private

    public :: target_name, target_eps
    public :: target_dgesv, target_dgetrf, target_dgetrs
    public :: target_dpotrf, target_dpotrs
    public :: target_zgesv, target_zgetrf, target_zgetrs
    public :: target_zpotrf, target_zpotrs
    public :: target_dgeqrf, target_dorgqr, target_zgeqrf, target_zungqr
    public :: target_dsyev, target_zheev
    public :: target_dgesvd, target_zgesvd
    public :: target_dlange, target_dlacpy, target_dlaset
    public :: target_zlange, target_zlanhe, target_zlacpy, target_zlaset
    public :: target_dposv, target_dsysv, target_dsytrf, target_dsytrs
    public :: target_dgels, target_dsyevd, target_dgeev, target_dgesdd
    public :: target_dpotri, target_dgetri
    public :: target_dtrtri, target_dtrtrs, target_ztrtri, target_ztrtrs
    public :: target_zposv, target_zhesv, target_zheevd, target_zgeev
    public :: target_zgesdd, target_zgels
    public :: target_dsyevr, target_zheevr, target_dsygv, target_zhegv
    public :: target_dgehrd, target_dorghr
    public :: target_dgelqf, target_dorglq, target_zgelqf, target_zunglq
    public :: target_zgetri, target_zpotri, target_zhetrf, target_zhetrs
    public :: target_zgehrd, target_zunghr
    public :: target_dgeqp3, target_zgeqp3, target_dormqr, target_zunmqr
    public :: target_dgbtrf, target_dgbtrs, target_dgbsv
    public :: target_dpbtrf, target_dpbtrs, target_dpbsv
    public :: target_dgttrf, target_dgttrs, target_dpttrf, target_dpttrs
    public :: target_dsyevx, target_zheevx
    public :: target_dstev,  target_dstevd, target_dstevx, target_dstevr
    public :: target_dsbev,  target_dsbevd, target_dsbevx
    public :: target_zhbev,  target_zhbevd, target_zhbevx
    public :: target_dspev,  target_dspevd, target_dspevx
    public :: target_zhpev,  target_zhpevd, target_zhpevx
    public :: target_dgeqlf, target_dorgql, target_dormql
    public :: target_zgeqlf, target_zungql, target_zunmql
    public :: target_dgerqf, target_dorgrq, target_dormrq
    public :: target_zgerqf, target_zungrq, target_zunmrq
    public :: target_dsptrf, target_dsptrs, target_dspsv, target_dsptri
    public :: target_dpptrf, target_dpptrs, target_dppsv, target_dpptri
    public :: target_zhptrf, target_zhptrs, target_zhpsv, target_zhptri
    public :: target_zsptrf, target_zsptrs, target_zspsv, target_zsptri
    public :: target_zpptrf, target_zpptrs, target_zppsv, target_zpptri
    public :: target_zgbtrf, target_zgbtrs, target_zgbsv
    public :: target_zpbtrf, target_zpbtrs, target_zpbsv
    public :: target_zgttrf, target_zgttrs, target_zgtsv
    public :: target_zpttrf, target_zpttrs, target_zptsv
    public :: target_dtbtrs, target_ztbtrs
    public :: target_dtptrs, target_ztptrs
    public :: target_dtptri, target_ztptri
    public :: target_dgecon, target_zgecon, target_dpocon, target_zpocon
    public :: target_dgbcon, target_zgbcon, target_dgtcon, target_zgtcon
    public :: target_dsycon, target_zhecon
    public :: target_dsytrf_rook, target_dsytf2_rook, target_dsytrs_rook
    public :: target_dsytri_rook, target_dsycon_rook, target_dsysv_rook
    public :: target_zhetrf_rook, target_zhetf2_rook, target_zhetrs_rook
    public :: target_zhetri_rook, target_zhecon_rook, target_zhesv_rook
    public :: target_dsytrf_rk, target_dsytf2_rk, target_dsysv_rk, target_dsytri_3x
    public :: target_zhetrf_rk, target_zhetf2_rk, target_zhesv_rk, target_zhetri_3x
    public :: target_zsytrf_rk, target_zsytf2_rk, target_zsysv_rk, target_zsytri_3x
    public :: target_dsytrf_aa, target_dsytrs_aa, target_dsysv_aa
    public :: target_dsytrf_aa_2stage, target_dsytrs_aa_2stage, target_dsysv_aa_2stage
    public :: target_zhetrf_aa, target_zhetrs_aa, target_zhesv_aa
    public :: target_zhetrf_aa_2stage, target_zhetrs_aa_2stage, target_zhesv_aa_2stage
    public :: target_zsytrf_aa, target_zsytrs_aa, target_zsysv_aa
    public :: target_zsytrf_aa_2stage, target_zsytrs_aa_2stage, target_zsysv_aa_2stage
    public :: target_dpbcon, target_zpbcon, target_dppcon, target_zppcon
    public :: target_dptcon, target_zptcon
    public :: target_dspcon, target_zhpcon, target_zspcon
    public :: target_dtrcon, target_ztrcon, target_dtpcon, target_ztpcon
    public :: target_dtbcon, target_ztbcon
    public :: target_dgerfs, target_zgerfs, target_dporfs, target_zporfs
    public :: target_dgbrfs, target_zgbrfs, target_dpbrfs, target_zpbrfs
    public :: target_dgtrfs, target_zgtrfs, target_dptrfs, target_zptrfs
    public :: target_dsyrfs, target_zsyrfs, target_zherfs
    public :: target_dsprfs, target_zsprfs
    public :: target_dpprfs, target_zpprfs
    public :: target_dtrrfs, target_ztrrfs
    public :: target_dtprfs, target_ztprfs
    public :: target_dtbrfs, target_ztbrfs
    public :: target_dgeequ, target_dgbequ, target_dpoequ, target_dppequ, target_dpbequ
    public :: target_zgeequ, target_zgbequ, target_zpoequ, target_zppequ, target_zpbequ
    public :: target_dgeequb, target_dgbequb, target_dpoequb, target_dsyequb
    public :: target_zgeequb, target_zgbequb, target_zpoequb, target_zsyequb, target_zheequb
    public :: target_dsytrd, target_zhetrd, target_dsptrd, target_zhptrd, target_dsbtrd, target_zhbtrd
    public :: target_dorgtr, target_zungtr, target_dormtr, target_zunmtr
    public :: target_dopgtr, target_zupgtr, target_dopmtr, target_zupmtr
    public :: target_dgebrd, target_zgebrd, target_dorgbr, target_zungbr, target_dormbr, target_zunmbr
    public :: target_dspgv, target_zhpgv, target_dsbgv, target_zhbgv
    public :: target_dsygvd, target_zhegvd, target_dspgvd, target_zhpgvd, target_dsbgvd, target_zhbgvd
    public :: target_dsterf, target_dsteqr, target_zsteqr
    public :: target_dstedc, target_zstedc, target_dstebz
    public :: target_dbdsqr, target_zbdsqr, target_dbdsdc
    public :: target_ddisna, target_dgebal, target_zgebal, target_dgebak, target_zgebak
    public :: target_dggbal, target_zggbal, target_dggbak, target_zggbak
    public :: target_dgghrd, target_zgghrd
    public :: target_dggqrf, target_zggqrf, target_dggrqf, target_zggrqf
    public :: target_dtrsyl, target_ztrsyl
    public :: target_dhseqr, target_zhseqr
    public :: target_dtrevc, target_ztrevc
    public :: target_dggev, target_zggev
    public :: target_dgeqr, target_zgeqr, target_dgelq, target_zgelq
    public :: target_dgemqr, target_zgemqr, target_dgemlq, target_zgemlq
    public :: target_dgeqrt, target_zgeqrt, target_dgelqt, target_zgelqt
    public :: target_dgemqrt, target_zgemqrt, target_dgemlqt, target_zgemlqt
    public :: target_dgetsls, target_zgetsls
    public :: target_dgesvx, target_zgesvx, target_dposvx, target_zposvx
    public :: target_dpbsvx, target_zpbsvx, target_dppsvx, target_zppsvx
    public :: target_dgbsvx, target_zgbsvx, target_dsysvx, target_zsysvx, target_zhesvx
    ! Phase L1 — 2-stage symmetric/Hermitian eigensolvers (JOBZ='N' only).
    public :: target_dsyev_2stage,  target_zheev_2stage
    public :: target_dsyevd_2stage, target_zheevd_2stage
    public :: target_dsyevr_2stage, target_zheevr_2stage
    public :: target_dsyevx_2stage, target_zheevx_2stage
    public :: target_dsbev_2stage,  target_zhbev_2stage
    public :: target_dsbevd_2stage, target_zhbevd_2stage
    public :: target_dsbevx_2stage, target_zhbevx_2stage
    public :: target_dsygv_2stage,  target_zhegv_2stage
    ! Phase L2 — Hessenberg/Schur expert drivers.
    public :: target_dgees,   target_zgees
    public :: target_dgeesx,  target_zgeesx
    public :: target_dgeevx,  target_zgeevx
    public :: target_dhsein,  target_zhsein
    public :: target_dtrevc3, target_ztrevc3
    public :: target_dtrexc,  target_ztrexc
    public :: target_dtrsen,  target_ztrsen
    ! Phase L3 — Generalized non-symmetric expert drivers + QZ.
    public :: target_dgges,   target_zgges
    public :: target_dgges3,  target_zgges3
    public :: target_dggesx,  target_zggesx
    public :: target_dggev3,  target_zggev3
    public :: target_dggevx,  target_zggevx
    public :: target_dhgeqz,  target_zhgeqz
    public :: target_dtgevc,  target_ztgevc
    ! Phase L4 — Generalized post-processing + constrained LS.
    public :: target_dtgexc, target_ztgexc
    public :: target_dtgsen, target_ztgsen
    public :: target_dtgsna, target_ztgsna
    public :: target_dtgsja, target_ztgsja
    public :: target_dtgsyl, target_ztgsyl
    public :: target_dggglm, target_zggglm
    public :: target_dgglse, target_zgglse
    ! Phase L5 — Modern least-squares + Jacobi SVD.
    public :: target_dgelsd, target_zgelsd
    public :: target_dgelss, target_zgelss
    public :: target_dgelsy, target_zgelsy
    public :: target_dgelst, target_zgelst
    public :: target_dgejsv, target_zgejsv
    public :: target_dgesvj, target_zgesvj
    ! Phase L18 — Auxiliary matrix norm utilities.
    public :: target_dlangb, target_zlangb
    public :: target_dlangt, target_zlangt
    public :: target_dlanhs, target_zlanhs
    public :: target_dlansb, target_zlanhb
    public :: target_dlansp, target_zlanhp
    public :: target_dlanst, target_zlanht
    public :: target_dlansy
    public :: target_dlantb, target_zlantb
    public :: target_dlantp, target_zlantp
    public :: target_dlantr, target_zlantr
    ! Phase L19 — Permutation/norm helpers.
    public :: target_dlapmr, target_zlapmr
    public :: target_dlapmt, target_zlapmt
    public :: target_dlapll, target_zlapll
    public :: target_dlacn2, target_zlacn2
    public :: target_dlartg, target_zlartg
    public :: target_dlartgp
    public :: target_dlartgs
    ! Phase L20 — Small public scalar utilities.
    public :: target_dlapy2
    public :: target_dlapy3
    public :: target_dladiv, target_zladiv
    public :: target_dlamrg
    public :: target_dlarnv, target_zlarnv
    ! Phase L21 — Generalized sym/Hermitian glue.
    public :: target_dsbgst, target_zhbgst
    public :: target_dspgst, target_zhpgst
    public :: target_dsygst, target_zhegst
    public :: target_dsbgvx, target_zhbgvx
    public :: target_dspgvx, target_zhpgvx
    public :: target_dsygvx, target_zhegvx
    ! P12 — RFP / packed / triangular-full storage conversion
    public :: target_dtfttp, target_ztfttp
    public :: target_dtfttr, target_ztfttr
    public :: target_dtpttf, target_ztpttf
    public :: target_dtpttr, target_ztpttr
    public :: target_dtrttf, target_ztrttf
    public :: target_dtrttp, target_ztrttp
    ! P-misc — small utilities & unblocked apply/generate Householder
    public :: target_disnan
    public :: target_drscl, target_zdrscl, target_zrscl
    public :: target_zrot
    public :: target_dorg2l, target_zung2l
    public :: target_dorg2r, target_zung2r
    public :: target_dorm2l, target_zunm2l
    public :: target_dorm2r, target_zunm2r
    public :: target_dormlq, target_zunmlq
    public :: target_dormhr, target_zunmhr
    public :: target_dtzrzf, target_ztzrzf
    public :: target_dormrz, target_zunmrz
    ! P11 — RFP factor / solve / triangular ops + pivoted Cholesky + tridiag eig
    public :: target_dpftrf, target_zpftrf
    public :: target_dpftri, target_zpftri
    public :: target_dpftrs, target_zpftrs
    public :: target_dpstrf, target_zpstrf
    public :: target_dpteqr, target_zpteqr
    public :: target_dpbstf, target_zpbstf
    public :: target_dsfrk,  target_zhfrk
    public :: target_dtfsm,  target_ztfsm
    public :: target_dtftri, target_ztftri
    ! P13 — pentagonal QR/LQ
    public :: target_dtpqrt, target_ztpqrt
    public :: target_dtpmqrt, target_ztpmqrt
    public :: target_dtplqt, target_ztplqt
    public :: target_dtpmlqt, target_ztpmlqt
    public :: target_dtprfb, target_ztprfb
    ! P14 — TSQR + Householder reconstruction
    public :: target_dgeqr2p, target_zgeqr2p
    public :: target_dgeqrfp, target_zgeqrfp
    public :: target_dorgtsqr, target_zungtsqr
    public :: target_dorgtsqr_row, target_zungtsqr_row
    public :: target_dorhr_col, target_zunhr_col
    public :: target_dgetsqrhrt, target_zgetsqrhrt
    public :: target_dgeqp3rk, target_zgeqp3rk
    ! P15 — CS decomposition + bdsvdx + bbcsd
    public :: target_dbdsvdx
    public :: target_dbbcsd, target_zbbcsd
    public :: target_dorbdb, target_zunbdb
    public :: target_dorcsd, target_zuncsd
    ! P6/P7 — modern SVD + banded bidiag reduction
    public :: target_dgesvdq, target_zgesvdq
    public :: target_dgesvdx, target_zgesvdx
    public :: target_dgbbrd, target_zgbbrd
    ! P16 — MRRR tridiagonal eigensolvers
    public :: target_dstegr, target_zstegr
    public :: target_dstemr, target_zstemr
    public :: target_dstein, target_zstein

    character(len=*), parameter :: target_name = "${target_name}$"
    real(ep),         parameter :: target_eps  = ${target_eps}$

    interface
        subroutine ${R}$gesv(n, nrhs, A, lda, ipiv, B, ldb, info)
$:IMPORT_R()
            integer, intent(in) :: n, nrhs, lda, ldb
            ${target_real}$, intent(inout) :: A(lda,*), B(ldb,*)
            integer, intent(out) :: ipiv(*), info
        end subroutine

        subroutine ${R}$getrf(m, n, A, lda, ipiv, info)
$:IMPORT_R()
            integer, intent(in) :: m, n, lda
            ${target_real}$, intent(inout) :: A(lda,*)
            integer, intent(out) :: ipiv(*), info
        end subroutine

        subroutine ${R}$getrs(trans, n, nrhs, A, lda, ipiv, B, ldb, info)
$:IMPORT_R()
            character, intent(in) :: trans
            integer,   intent(in) :: n, nrhs, lda, ldb
            ${target_real}$, intent(in)    :: A(lda,*)
            integer,   intent(in)          :: ipiv(*)
            ${target_real}$, intent(inout) :: B(ldb,*)
            integer, intent(out) :: info
        end subroutine

        subroutine ${R}$potrf(uplo, n, A, lda, info)
$:IMPORT_R()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, lda
            ${target_real}$, intent(inout) :: A(lda,*)
            integer, intent(out) :: info
        end subroutine

        subroutine ${R}$potrs(uplo, n, nrhs, A, lda, B, ldb, info)
$:IMPORT_R()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, nrhs, lda, ldb
            ${target_real}$, intent(in)    :: A(lda,*)
            ${target_real}$, intent(inout) :: B(ldb,*)
            integer, intent(out) :: info
        end subroutine

        subroutine ${C}$gesv(n, nrhs, A, lda, ipiv, B, ldb, info)
$:IMPORT_C()
            integer, intent(in) :: n, nrhs, lda, ldb
            ${target_complex}$, intent(inout) :: A(lda,*), B(ldb,*)
            integer, intent(out) :: ipiv(*), info
        end subroutine

        subroutine ${C}$getrf(m, n, A, lda, ipiv, info)
$:IMPORT_C()
            integer, intent(in) :: m, n, lda
            ${target_complex}$, intent(inout) :: A(lda,*)
            integer, intent(out) :: ipiv(*), info
        end subroutine

        subroutine ${C}$getrs(trans, n, nrhs, A, lda, ipiv, B, ldb, info)
$:IMPORT_C()
            character, intent(in) :: trans
            integer,   intent(in) :: n, nrhs, lda, ldb
            ${target_complex}$, intent(in)    :: A(lda,*)
            integer,   intent(in)             :: ipiv(*)
            ${target_complex}$, intent(inout) :: B(ldb,*)
            integer, intent(out) :: info
        end subroutine

        subroutine ${C}$potrf(uplo, n, A, lda, info)
$:IMPORT_C()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, lda
            ${target_complex}$, intent(inout) :: A(lda,*)
            integer, intent(out) :: info
        end subroutine

        subroutine ${C}$potrs(uplo, n, nrhs, A, lda, B, ldb, info)
$:IMPORT_C()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, nrhs, lda, ldb
            ${target_complex}$, intent(in)    :: A(lda,*)
            ${target_complex}$, intent(inout) :: B(ldb,*)
            integer, intent(out) :: info
        end subroutine

        subroutine ${C}$ungqr(m, n, k, A, lda, tau, work, lwork, info)
$:IMPORT_C()
            integer, intent(in) :: m, n, k, lda, lwork
            ${target_complex}$, intent(inout) :: A(lda,*)
            ${target_complex}$, intent(in)    :: tau(*)
            ${target_complex}$, intent(out)   :: work(*)
            integer, intent(out) :: info
        end subroutine

        subroutine ${C}$gesvd(jobu, jobvt, m, n, A, lda, s, U, ldu, VT, ldvt, &
                              work, lwork, rwork, info)
$:IMPORT_RC()
            character, intent(in) :: jobu, jobvt
            integer,   intent(in) :: m, n, lda, ldu, ldvt, lwork
            ${target_complex}$, intent(inout) :: A(lda,*)
            ${target_real}$,    intent(out)   :: s(*), rwork(*)
            ${target_complex}$, intent(out)   :: U(ldu,*), VT(ldvt,*), work(*)
            integer, intent(out) :: info
        end subroutine

        function ${C}$lange(norm, m, n, A, lda, work) result(r)
$:IMPORT_RC()
            character, intent(in) :: norm
            integer,   intent(in) :: m, n, lda
            ${target_complex}$, intent(in) :: A(lda,*)
            ${target_real}$ :: work(*)
            ${target_real}$ :: r
        end function

        function ${C}$lanhe(norm, uplo, n, A, lda, work) result(r)
$:IMPORT_RC()
            character, intent(in) :: norm, uplo
            integer,   intent(in) :: n, lda
            ${target_complex}$, intent(in) :: A(lda,*)
            ${target_real}$ :: work(*)
            ${target_real}$ :: r
        end function

        subroutine ${C}$lacpy(uplo, m, n, A, lda, B, ldb)
$:IMPORT_C()
            character, intent(in) :: uplo
            integer,   intent(in) :: m, n, lda, ldb
            ${target_complex}$, intent(in)  :: A(lda,*)
            ${target_complex}$, intent(out) :: B(ldb,*)
        end subroutine

        subroutine ${C}$laset(uplo, m, n, alpha, beta, A, lda)
$:IMPORT_C()
            character, intent(in) :: uplo
            integer,   intent(in) :: m, n, lda
            ${target_complex}$, intent(in)    :: alpha, beta
            ${target_complex}$, intent(inout) :: A(lda,*)
        end subroutine

        ! ── Phase 2 — real user-facing drivers ───────────────────────
        subroutine ${R}$posv(uplo, n, nrhs, A, lda, B, ldb, info)
$:IMPORT_R()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, nrhs, lda, ldb
            ${target_real}$, intent(inout) :: A(lda,*), B(ldb,*)
            integer, intent(out) :: info
        end subroutine

        subroutine ${R}$sysv(uplo, n, nrhs, A, lda, ipiv, B, ldb, work, lwork, info)
$:IMPORT_R()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, nrhs, lda, ldb, lwork
            ${target_real}$, intent(inout) :: A(lda,*), B(ldb,*)
            integer, intent(out) :: ipiv(*), info
            ${target_real}$, intent(out) :: work(*)
        end subroutine

        subroutine ${R}$sytrf(uplo, n, A, lda, ipiv, work, lwork, info)
$:IMPORT_R()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, lda, lwork
            ${target_real}$, intent(inout) :: A(lda,*)
            integer, intent(out) :: ipiv(*), info
            ${target_real}$, intent(out) :: work(*)
        end subroutine

        subroutine ${R}$sytrs(uplo, n, nrhs, A, lda, ipiv, B, ldb, info)
$:IMPORT_R()
            character, intent(in) :: uplo
            integer,   intent(in) :: n, nrhs, lda, ldb
            ${target_real}$, intent(in)    :: A(lda,*)
            integer,   intent(in)          :: ipiv(*)
            ${target_real}$, intent(inout) :: B(ldb,*)
            integer, intent(out) :: info
        end subroutine

        subroutine ${R}$gels(trans, m, n, nrhs, A, lda, B, ldb, work, lwork, info)
$:IMPORT_R()
            character, intent(in) :: trans
            integer,   intent(in) :: m, n, nrhs, lda, ldb, lwork
            ${target_real}$, intent(inout) :: A(lda,*), B(ldb,*)
            ${target_real}$, intent(out)   :: work(*)
