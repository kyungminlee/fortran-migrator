    ! ── Phase 12 wrappers ────────────────────────────────────────────
    subroutine target_dtbtrs(uplo, trans, diag, n, kd, nrhs, AB, ldab, B, ldb, info)
        character, intent(in)    :: uplo, trans, diag
        integer,   intent(in)    :: n, kd, nrhs, ldab, ldb
        real(ep),  intent(in)    :: AB(ldab,*)
