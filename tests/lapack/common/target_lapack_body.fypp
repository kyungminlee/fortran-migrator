        nq = merge(m, n, side == 'L' .or. side == 'l')
        ncolA = merge(nq, k, vect == 'Q' .or. vect == 'q')
        allocate(At(lda, ncolA), taut(min(nq, k)), Ct(ldc, n))
        At = q2t_r(A(1:lda, 1:ncolA)); taut = q2t_r(tau(1:min(nq, k)))
        Ct = q2t_r(C(1:ldc, 1:n))
        call ${R}$ormbr(vect, side, trans, m, n, k, At, lda, taut, Ct, ldc, wopt, -1, info)
        lwork = max(1, int(t2q_r(wopt(1))))
        allocate(work(lwork))
        call ${R}$ormbr(vect, side, trans, m, n, k, At, lda, taut, Ct, ldc, work, lwork, info)
        C(1:ldc, 1:n) = t2q_r(Ct)
    end subroutine

