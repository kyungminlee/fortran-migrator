                                         duft(:), du2t(:), Bt(:,:), Xt(:,:), &
                                         work(:), ferrt(:), berrt(:)
        integer, allocatable :: iwork(:)
        allocate(dlt(n-1), dt(n), dut(n-1), dlft(n-1), dft(n), duft(n-1), du2t(n-2))
        allocate(Bt(ldb, nrhs), Xt(ldx, nrhs), work(3*n), iwork(n), &
                 ferrt(nrhs), berrt(nrhs))
        dlt = q2t_r(dl(1:n-1)); dt = q2t_r(d(1:n)); dut = q2t_r(du(1:n-1))
        dlft = q2t_r(dlf(1:n-1)); dft = q2t_r(df(1:n)); duft = q2t_r(duf(1:n-1))
        du2t = q2t_r(du2(1:n-2))
        Bt = q2t_r(B(1:ldb, 1:nrhs)); Xt = q2t_r(X(1:ldx, 1:nrhs))
        call ${R}$gtrfs(trans, n, nrhs, dlt, dt, dut, dlft, dft, duft, du2t, ipiv, &
                        Bt, ldb, Xt, ldx, ferrt, berrt, work, iwork, info)
        X(1:ldx, 1:nrhs) = t2q_r(Xt)
        ferr(1:nrhs) = t2q_r(ferrt); berr(1:nrhs) = t2q_r(berrt)
    end subroutine

