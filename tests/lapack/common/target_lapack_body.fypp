    subroutine target_dpstrf(uplo, n, A, lda, piv, rank, tol, info)
        character, intent(in)    :: uplo
        integer,   intent(in)    :: n, lda
        real(ep),  intent(inout) :: A(lda,*)
        integer,   intent(out)   :: piv(*), rank, info
        real(ep),  intent(in)    :: tol
        ${target_real}$, allocatable :: At(:,:), work(:)
        allocate(At(lda, n), work(2*n))
        At = q2t_r(A(1:lda, 1:n))
        call ${R}$pstrf(uplo, n, At, lda, piv, rank, q2t_r(tol), work, info)
        A(1:lda, 1:n) = t2q_r(At)
    end subroutine

    subroutine target_zpstrf(uplo, n, A, lda, piv, rank, tol, info)
        character,   intent(in)    :: uplo
        integer,     intent(in)    :: n, lda
        complex(ep), intent(inout) :: A(lda,*)
        integer,     intent(out)   :: piv(*), rank, info
        real(ep),    intent(in)    :: tol
        ${target_complex}$, allocatable :: At(:,:)
        ${target_real}$,    allocatable :: work(:)
        allocate(At(lda, n), work(2*n))
        At = q2t_c(A(1:lda, 1:n))
        call ${C}$pstrf(uplo, n, At, lda, piv, rank, q2t_r(tol), work, info)
        A(1:lda, 1:n) = t2q_c(At)
    end subroutine

    subroutine target_dpteqr(compz, n, D, E, Z, ldz, info)
        character, intent(in)    :: compz
        integer,   intent(in)    :: n, ldz
        real(ep),  intent(inout) :: D(*), E(*), Z(ldz,*)
        integer,   intent(out)   :: info
        ${target_real}$, allocatable :: Dt(:), Et(:), Zt(:,:), work(:)
        integer :: lw
        allocate(Dt(n), Et(max(1, n-1)), Zt(ldz, n), work(max(1, 4*n)))
        Dt = q2t_r(D(1:n)); if (n > 1) Et = q2t_r(E(1:n-1))
        if (compz /= 'N' .and. compz /= 'n') Zt = q2t_r(Z(1:ldz, 1:n))
        lw = max(1, 4*n)
        call ${R}$pteqr(compz, n, Dt, Et, Zt, ldz, work, info)
        D(1:n) = t2q_r(Dt); if (n > 1) E(1:n-1) = t2q_r(Et)
        if (compz /= 'N' .and. compz /= 'n') Z(1:ldz, 1:n) = t2q_r(Zt)
    end subroutine

    subroutine target_zpteqr(compz, n, D, E, Z, ldz, info)
        character,   intent(in)    :: compz
        integer,     intent(in)    :: n, ldz
        real(ep),    intent(inout) :: D(*), E(*)
        complex(ep), intent(inout) :: Z(ldz,*)
        integer,     intent(out)   :: info
        ${target_real}$,    allocatable :: Dt(:), Et(:), work(:)
        ${target_complex}$, allocatable :: Zt(:,:)
        allocate(Dt(n), Et(max(1, n-1)), Zt(ldz, n), work(max(1, 4*n)))
        Dt = q2t_r(D(1:n)); if (n > 1) Et = q2t_r(E(1:n-1))
        if (compz /= 'N' .and. compz /= 'n') Zt = q2t_c(Z(1:ldz, 1:n))
        call ${C}$pteqr(compz, n, Dt, Et, Zt, ldz, work, info)
        D(1:n) = t2q_r(Dt); if (n > 1) E(1:n-1) = t2q_r(Et)
        if (compz /= 'N' .and. compz /= 'n') Z(1:ldz, 1:n) = t2q_c(Zt)
    end subroutine

