#! Per-target MUMPS wrapper, parameterized by target.
#!
#! Each per-target shim sets:
#!   target            'kind10' | 'kind16' | 'multifloats'  (label)
#!   target_name       human-readable name (== target today)
#!   target_eps        Fortran expression giving the target's epsilon as REAL(KIND=ep)
#!   prefix_real       migrated entry-point name for QMUMPS-equivalent (e.g. 'qmumps')
#!   prefix_complex    migrated entry-point name for XMUMPS-equivalent (e.g. 'xmumps')
#!   real_struc_mod    migrated module providing DMUMPS_STRUC (e.g. 'qmumps_struc_def')
#!   complex_struc_mod migrated module providing ZMUMPS_STRUC (e.g. 'xmumps_struc_def')
#!
#! Re-exports the (D|Z)MUMPS_STRUC types unchanged — the migrator
#! renames the wrapping module but leaves the TYPE name intact (see
#! tests/mumps/TODO.md UNK-1) — so test code uses
#!   USE target_mumps, ONLY: dmumps_struc
#!   TYPE(dmumps_struc) :: id
#!   CALL target_qmumps(id)
#! and stays portable across targets.

module target_mumps
    use prec_kinds, only: ep
    use ${real_struc_mod}$,    only: dmumps_struc
    use ${complex_struc_mod}$, only: zmumps_struc
    implicit none

    character(len=*), parameter :: target_name = '${target_name}$'
    real(ep),         parameter :: target_eps  = ${target_eps}$

    ! Input-validation wrapper return codes (D1 in tests/mumps/TODO.md).
    ! MUMPS 5.8.2 SIGSEGVs on out-of-range IRN/JCN, negative N, mismatched
    ! NNZ instead of returning INFOG(1) < 0; check_*_input lets tests
    ! exercise these cases without crashing the executable. The wrapper
    ! layers ABOVE MUMPS — it does NOT mutate id%INFOG.
    integer, parameter :: MIC_OK            = 0
    integer, parameter :: MIC_BAD_N         = -1
    integer, parameter :: MIC_BAD_NNZ       = -2
    integer, parameter :: MIC_BAD_IRN       = -3
    integer, parameter :: MIC_BAD_JCN       = -4
    integer, parameter :: MIC_SIZE_MISMATCH = -5

    interface
        subroutine ${prefix_real}$(id)
            import :: dmumps_struc
            type(dmumps_struc), intent(inout) :: id
        end subroutine ${prefix_real}$
        subroutine ${prefix_complex}$(id)
            import :: zmumps_struc
            type(zmumps_struc), intent(inout) :: id
        end subroutine ${prefix_complex}$
    end interface

contains

    subroutine target_qmumps(id)
        type(dmumps_struc), intent(inout) :: id
        call ${prefix_real}$(id)
    end subroutine target_qmumps

    subroutine target_xmumps(id)
        type(zmumps_struc), intent(inout) :: id
        call ${prefix_complex}$(id)
    end subroutine target_xmumps

    subroutine check_dmumps_input(id, code)
        type(dmumps_struc), intent(in)  :: id
        integer,            intent(out) :: code
        integer :: i
        integer(8) :: nnz_i
        if (id%N < 1) then
            code = MIC_BAD_N; return
        end if
        nnz_i = id%NNZ
        if (nnz_i < 0) then
            code = MIC_BAD_NNZ; return
        end if
        if (.not. associated(id%IRN) .or. .not. associated(id%JCN) .or. &
            .not. associated(id%A)) then
            code = MIC_SIZE_MISMATCH; return
        end if
        if (size(id%IRN, kind=8) /= nnz_i .or. &
            size(id%JCN, kind=8) /= nnz_i .or. &
            size(id%A,   kind=8) /= nnz_i) then
            code = MIC_SIZE_MISMATCH; return
        end if
        do i = 1, int(nnz_i)
            if (id%IRN(i) < 1 .or. id%IRN(i) > id%N) then
                code = MIC_BAD_IRN; return
            end if
            if (id%JCN(i) < 1 .or. id%JCN(i) > id%N) then
                code = MIC_BAD_JCN; return
            end if
        end do
        code = MIC_OK
    end subroutine check_dmumps_input

    subroutine check_zmumps_input(id, code)
        type(zmumps_struc), intent(in)  :: id
        integer,            intent(out) :: code
        integer :: i
        integer(8) :: nnz_i
        if (id%N < 1) then
            code = MIC_BAD_N; return
        end if
        nnz_i = id%NNZ
        if (nnz_i < 0) then
            code = MIC_BAD_NNZ; return
        end if
        if (.not. associated(id%IRN) .or. .not. associated(id%JCN) .or. &
            .not. associated(id%A)) then
            code = MIC_SIZE_MISMATCH; return
        end if
        if (size(id%IRN, kind=8) /= nnz_i .or. &
            size(id%JCN, kind=8) /= nnz_i .or. &
            size(id%A,   kind=8) /= nnz_i) then
            code = MIC_SIZE_MISMATCH; return
        end if
        do i = 1, int(nnz_i)
            if (id%IRN(i) < 1 .or. id%IRN(i) > id%N) then
                code = MIC_BAD_IRN; return
            end if
            if (id%JCN(i) < 1 .or. id%JCN(i) > id%N) then
                code = MIC_BAD_JCN; return
            end if
        end do
        code = MIC_OK
    end subroutine check_zmumps_input

end module target_mumps
